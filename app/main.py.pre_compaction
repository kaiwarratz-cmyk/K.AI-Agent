def _action_signature(action: Dict[str, Any], message: str = "") -> str:
    kind = str(action.get("kind", "unknown") or "unknown").strip().lower()
    script_type = str(action.get("script_type", "") or "").strip().lower()
    script_path = Path(str(action.get("script_path", "") or "")).name.lower()
    parts: List[str] = [kind]
    if script_type:
        parts.append(script_type)
    if script_path:
        parts.append(script_path)
    for k in ("path", "src", "dst", "target"):
        raw = str(action.get(k, "") or "").strip()
        if not raw:
            continue
        p = str(raw).replace("/", "\\")
        m_drv = re.match(r"^([A-Za-z]:)\\?", p)
        if m_drv:
            parts.append(m_drv.group(1).lower())
        if p.startswith("\\\\"):
            unc_parts = [x for x in p.split("\\") if x]
            if unc_parts:
                parts.append(f"unc:{unc_parts[0].lower()}")
                if len(unc_parts) > 1:
                    parts.append(f"share:{unc_parts[1].lower()}")
        name = Path(raw).name.lower()
        if name:
            parts.append(name)
    terms = [t for t in _query_terms(str(message or "")) if len(t) >= 4]
    if terms:
        parts.extend(terms[:4])
    return "|".join(parts)[:300]

def _load_lesson_by_signature(cfg: Dict[str, Any], signature: str) -> Optional[Dict[str, Any]]:
    sig = str(signature or "").strip().lower()
    if not sig:
        return None
    items = _memory_store(cfg).search_by_kind(kind="lesson", limit=80)  # 220 → 80
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not isinstance(blob, dict):
            continue
        if str(blob.get("signature", "")).strip().lower() == sig:
            return blob
    return None

def _llm_extract_error_lesson(cfg: Dict[str, Any], message: str, action: Dict[str, Any], error_text: str) -> Dict[str, Any]:
    err = str(error_text or "").strip()
    if not err:
        return {"root_cause": "unbekannt", "fix_hint": "Fehlerdetails pruefen", "prevention": "mehr Logging aktivieren"}
    low = err.lower()
    if "modulenotfounderror" in low or "no module named" in low:
        return {
            "root_cause": "fehlende_python_abhaengigkeit",
            "fix_hint": "fehlende Pakete installieren und danach Script erneut ausfuehren",
            "prevention": "vor Ausfuehrung Imports aufloesen und Auto-Dependency-Install verwenden",
        }
    if "permission denied" in low or "zugriff verweigert" in low or "access is denied" in low:
        return {
            "root_cause": "fehlende_rechte",
            "fix_hint": "Rolle/Prozessrechte pruefen oder Zielpfad in Workspace verschieben",
            "prevention": "riskante Pfade vorab gegen Policy und Rechte validieren",
        }
    if "timeout" in low or "timed out" in low:
        return {
            "root_cause": "timeout",
            "fix_hint": "timeout erhoehen oder Aufgabe in kleinere Schritte teilen",
            "prevention": "vorab Komplexitaet pruefen und angemessenen Timeout setzen",
        }
    if "datei nicht gefunden" in low or "file not found" in low:
        return {
            "root_cause": "ungueltiger_pfad",
            "fix_hint": "Pfad/Dateiname korrigieren und Existenz pruefen",
            "prevention": "vor Ausfuehrung Existenzcheck fuer Eingabepfade",
        }
    try:
        router = LLMRouter(cfg)
        schema: Dict[str, Any] = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "root_cause": {"type": "string"},
                "fix_hint": {"type": "string"},
                "prevention": {"type": "string"},
                "confidence": {"type": "number"},
            },
            "required": ["root_cause", "fix_hint", "prevention", "confidence"],
        }
        prompt = (
            "Analysiere den Ausfuehrungsfehler und gib eine kurze, wiederverwendbare Lernregel als JSON aus.\n"
            'Schema: {"root_cause":"...","fix_hint":"...","prevention":"...","confidence":0..1}\n'
            "Regeln:\n"
            "- max 1 Satz pro Feld\n"
            "- technisch konkret, ohne Meta\n"
            f"User-Task: {str(message or '')[:400]}\n"
            f"Action: {json.dumps(action, ensure_ascii=False)[:1200]}\n"
            f"Fehler: {err[:1800]}"
        )
        try:
            obj = router.chat_json(prompt=prompt, schema_name="execution_lesson_v1", schema=schema)
        except Exception:
            raw = router.chat(prompt)
            obj = _extract_json_dict(str(raw.text or ""))
        if not isinstance(obj, dict):
            raise RuntimeError("lesson_json_invalid")
        try:
            conf = float(obj.get("confidence", 0.0) or 0.0)
        except Exception:
            conf = 0.0
        if conf < 0.45:
            raise RuntimeError("lesson_confidence_low")
        return {
            "root_cause": str(obj.get("root_cause", "") or "unbekannt")[:220],
            "fix_hint": str(obj.get("fix_hint", "") or "Fehlerdetails pruefen")[:260],
            "prevention": str(obj.get("prevention", "") or "Mehr Validierung vor Ausfuehrung")[:260],
        }
    except Exception as exc:
        tool_store.log("lesson_extract_error", str(exc))
        return {
            "root_cause": "unbekannt",
            "fix_hint": "Fehlerdetails pruefen und reproduzierbaren Testfall anlegen",
            "prevention": "vor Ausfuehrung mehr Validierung und Logging",
        }

def _record_execution_lesson(
    cfg: Dict[str, Any],
    *,
    message: str,
    action: Dict[str, Any],
    success: bool,
    error_text: str = "",
    reply_text: str = "",
) -> None:
    try:
        # Don't store false failure lessons — if reply/error text contains
        # "tool defekt/gesperrt" claims it's a poisoned LLM hallucination, not a real failure
        import re as _re
        combined_text = (str(error_text) + str(reply_text)).lower()
        if not success and any(_re.search(p, combined_text) for p in _MEMORY_POISON_PATTERNS):
            return
        # Don't store write_file successes as cron lessons — these are plan files, not cron outcomes
        action_kind = str(action.get("kind", "") or "").strip().lower()
        msg_lower = str(message or "").lower()
        if success and action_kind == "write_file" and _has_any(msg_lower, ["cron", "cronjob", "cron_create"]):
            return
        sig = _action_signature(action, message=message)
        if not sig:
            return
        prev = _load_lesson_by_signature(cfg, sig) or {}
        fail_count = int(prev.get("failure_count", 0) or 0)
        ok_count = int(prev.get("success_count", 0) or 0)
        payload: Dict[str, Any] = {
            "field": "execution_lesson",
            "signature": sig,
            "action_kind": str(action.get("kind", "") or ""),
            "script_type": str(action.get("script_type", "") or ""),
            "sample_message": str(message or "")[:260],
            "updated_at": datetime.now().isoformat(),
        }
        if success:
            ok_count += 1
            payload["success_count"] = ok_count
            payload["failure_count"] = fail_count
            if fail_count > 0:
                payload["status"] = "improved_after_failures"
            else:
                payload["status"] = "stable"
            if reply_text:
                payload["last_success"] = str(reply_text or "")[:900]
            _save_workflow_success(cfg, message=message, action=action, reply_text=reply_text)
        else:
            fail_count += 1
            lesson = _llm_extract_error_lesson(cfg, message=message, action=action, error_text=error_text)
            payload.update(lesson)
            payload["failure_count"] = fail_count
            payload["success_count"] = ok_count
            payload["status"] = "needs_fix"
            payload["last_error"] = str(error_text or "")[:1200]
        _memory_store(cfg).upsert_memory("lesson", sig, payload, confidence=0.88 if success else 0.9)
    except Exception as exc:
        tool_store.log("lesson_persist_error", str(exc))

def _lesson_hint_for_action(cfg: Dict[str, Any], action: Dict[str, Any], message: str) -> str:
    sig = _action_signature(action, message=message)
    if not sig:
        return ""
    lesson = _load_lesson_by_signature(cfg, sig)
    if not isinstance(lesson, dict):
        return ""
    if str(lesson.get("status", "")).strip().lower() == "needs_fix":
        root = str(lesson.get("root_cause", "") or "").strip()
        fix = str(lesson.get("fix_hint", "") or "").strip()
        if root or fix:
            return f"Lernhinweis: Letzter aehnlicher Fehler ({root}). Empfohlene Korrektur: {fix}."
    return ""

def _new_trace_id() -> str:
    return uuid.uuid4().hex[:16]

def _job_is_cancelled(trace_id: str) -> bool:
    """Prüft ob ein Job abgebrochen wurde (prüft beide Systeme: _cancelled_jobs und request_queue)."""
    global _cancelled_jobs, _active_jobs_lock, _chat_queue
    with _active_jobs_lock:
        if trace_id in _cancelled_jobs:
            return True
    # Auch request_queue's cancellation system prüfen (falls über INTERRUPT canceliert)
    if _chat_queue:
        try:
            if _chat_queue.is_request_cancelled(trace_id):
                # Synchronisiere mit _cancelled_jobs
                with _active_jobs_lock:
                    _cancelled_jobs.add(trace_id)
                return True
        except Exception:
            pass
    return False

def _job_cancel(trace_id: str) -> bool:
    """Bricht einen Job ab."""
    global _cancelled_jobs, _active_jobs, _active_jobs_lock
    should_stop = False
    with _active_jobs_lock:
        _cancelled_jobs.add(trace_id)
        if trace_id in _active_jobs:
            _active_jobs[trace_id]["status"] = "cancelled"
            _active_jobs.pop(trace_id, None)
            should_stop = True
        else:
            # Auch wenn nicht aktiv (z.B. noch in Queue), 
            # markieren wir es als erfolgreich 'abgebrochen'.
            should_stop = True
    if should_stop:
        # Best effort: stop running scripts if any (outside lock).
        _request_script_stop(reason=f"job_cancel:{trace_id}")
        # Stop-Event für python_exec setzen → unterbricht laufende Python-Scripts sofort
        with contextlib.suppress(Exception):
            from app.tools import python_exec as _py_mod
            _py_mod._stop_event.set()
    return bool(should_stop)

def _job_cancel_all() -> int:
    """Bricht alle aktiven Jobs ab."""
    global _cancelled_jobs, _active_jobs, _active_jobs_lock
    with _active_jobs_lock:
        count = 0
        for trace_id in list(_active_jobs.keys()):
            _cancelled_jobs.add(trace_id)
            _active_jobs[trace_id]["status"] = "cancelling"
            count += 1
    _request_script_stop(reason="job_cancel_all")
    # Stop-Event für python_exec setzen → unterbricht laufende Python-Scripts sofort
    with contextlib.suppress(Exception):
        from app.tools import python_exec as _py_mod
        _py_mod._stop_event.set()
    return count

def _job_get_active() -> List[Dict[str, Any]]:
    """Gibt alle aktiven Jobs zurück."""
    global _active_jobs, _active_jobs_lock
    stale_jobs: List[Tuple[str, float, int, str, str]] = []
    with _active_jobs_lock:
        jobs = []
        now = time.time()
        for trace_id, job in list(_active_jobs.items()):
            started_at = float(job.get("started_at", now) or now)
            runtime = max(0.0, now - started_at)
            max_runtime_sec = int(job.get("max_runtime_sec", 1800) or 1800)
            max_runtime_sec = max(30, min(7200, max_runtime_sec))
            if runtime > float(max_runtime_sec):
                _cancelled_jobs.add(str(trace_id))
                _active_jobs.pop(trace_id, None)
                stale_jobs.append((str(trace_id), float(runtime), int(max_runtime_sec), str(job.get("source", "")), str(job.get("dialog_key", ""))))
                continue
            jobs.append({
                "trace_id": job["trace_id"],
                "message": job["message"],
                "source": job["source"],
                "dialog_key": job["dialog_key"],
                "runtime": round(runtime, 1),
                "status": job["status"]
            })
    if stale_jobs:
        with contextlib.suppress(Exception):
            _request_script_stop(reason="job_timeout_sweep")
        for tid, rt, lim, src, dkey in stale_jobs:
            with contextlib.suppress(Exception):
                tool_store.log("job_timeout_sweep", f"trace={tid} source={src} runtime={int(rt)}s limit={lim}s")
            # Nutzer über Timeout informieren (Telegram)
            if dkey and dkey.startswith("telegram:"):
                with contextlib.suppress(Exception):
                    _send_telegram_reply(
                        _cfg(), dkey,
                        f"⏱️ Job wurde nach {int(rt)}s (Limit: {lim}s) automatisch beendet, da er zu lange lief."
                    )
    return jobs

def _cancelled_reply(note: str = "") -> Optional[Dict[str, Any]]:
    trace_id = _trace_id_ctx.get()
    if trace_id and _job_is_cancelled(trace_id):
        msg = "Job wurde abgebrochen."
        if note:
            msg = f"{msg} ({note})"
        with _active_jobs_lock:
            if trace_id in _active_jobs:
                _active_jobs[trace_id]["status"] = "cancelled"
        return {"ok": False, "reply": msg, "cancelled": True}
    return None

_watchdog_stop_event = threading.Event()

def _watchdog_worker_loop() -> None:
    """Hintergrund-Watchdog: prüft alle 30s ob Jobs ihren max_runtime_sec überschritten haben.
    Unabhängig vom API-Poll – feuert immer zuverlässig."""
    import time as _time
    while not _watchdog_stop_event.wait(30):
        try:
            _job_get_active()  # Enthält die komplette Timeout-Logik + Nutzer-Benachrichtigung
        except Exception:
            pass

def _current_trace_id() -> str:
    return str(_trace_id_ctx.get("") or "").strip()

def _set_script_stream_hook(hook: Optional[Callable[[Dict[str, Any]], None]]) -> contextvars.Token:
    return _script_stream_hook_ctx.set(hook)

