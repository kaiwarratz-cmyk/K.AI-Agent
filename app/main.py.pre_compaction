@app.post("/api/mcp/registry/install")
def api_mcp_registry_install(payload: MCPRegistryInstallRequest) -> Dict[str, Any]:
    from app.mcp_registry import install_from_registry
    import re, os, pathlib, zipfile, shutil
    import httpx
    
    cfg = _cfg()
    source_id = str(payload.source_id or "").strip()
    name = str(payload.name or "").strip()
    if not source_id or not name:
        return {"ok": False, "message": "source_id/name fehlen."}
        
    try:
        res = install_from_registry(cfg, source_id, name)
        if not res.get("ok", False):
            return res
            
        proposal = res.get("proposal", {})
        
        # FALL A: Standard stdio/npx
        if proposal.get("type") == "stdio" and proposal.get("command"):
            action = {
                "name": name,
                "command": proposal.get("command"),
                "args": proposal.get("args", []),
                "env": proposal.get("env", {}),
                "type": "stdio",
            }
            _, msg = _mcp_register_server(cfg, action)
            save_config(cfg)

            # npm-Package vorab global installieren (verhindert npx-Download beim ersten Start)
            _npm_pkg2 = None
            _pkg_args2 = proposal.get("args", [])
            if proposal.get("command") == "npx" and isinstance(_pkg_args2, list) and len(_pkg_args2) >= 2:
                _npm_pkg2 = _pkg_args2[1] if _pkg_args2[0] == "-y" else _pkg_args2[0]
            if _npm_pkg2:
                try:
                    import subprocess as _sp2, shutil as _sh2, sys as _sy2
                    _nc = _sh2.which("npm") or _sh2.which("npm.cmd") or r"C:\Program Files\nodejs\npm.cmd"
                    _cf2 = 0x08000000 if _sy2.platform == "win32" else 0
                    _na = [_nc, "install", "-g", _npm_pkg2]
                    if _sy2.platform == "win32" and str(_nc).lower().endswith((".cmd", ".bat")):
                        _na = ["cmd.exe", "/c"] + _na
                    _sp2.run(_na, capture_output=True, timeout=120, shell=False, creationflags=_cf2)
                except Exception:
                    pass

            # Server sofort proben — liefert er MCP-Tools? Nur Feedback, KEIN Auto-Remove
            try:
                from app.mcp_tools import refresh_mcp_tools, get_cached_mcp_tools
                _, refresh_msg = refresh_mcp_tools(_cfg())
                all_tools = get_cached_mcp_tools()
                import re as _re2
                safe_key = _re2.sub(r"[^a-zA-Z0-9_]", "_", name)
                new_tools = [
                    t.get("function", {}).get("name", "") for t in all_tools
                    if (t.get("mcp_meta", {}) or {}).get("server", "") in (name, safe_key)
                    or safe_key in str(t.get("function", {}).get("name", ""))
                ]
                new_tools = [n for n in new_tools if n]
                if new_tools:
                    return {"ok": True, "message": f"'{name}' installiert. Tools: {', '.join(new_tools[:10])}",
                            "tools": new_tools}
                else:
                    # Kein Tool gefunden — Server bleibt registriert (könnte API-Key brauchen o.ä.)
                    return {"ok": True, "warning": True,
                            "message": f"'{name}' registriert, aber beim Start wurden keine MCP-Tools gefunden. "
                            f"Falls der Server einen API-Key braucht: in config.json unter mcp.servers.{name!r}.env eintragen. ({refresh_msg})"}
            except Exception as _pe:
                return {"ok": True, "message": f"Tool '{name}' registriert (Probe-Fehler: {_pe})"}
            
        # FALL B: GitHub Auto-Download & Configure
        if proposal.get("type") == "github_auto":
            detail_url = proposal.get("url", "")
            downloads_dir = (ROOT_DIR / "data" / "mcp_registry_downloads").resolve()
            downloads_dir.mkdir(parents=True, exist_ok=True)
            
            # 1. Download ZIP
            zip_urls = []
            m = re.search(r"github.com/([^/]+/[^/]+)", detail_url)
            if m:
                owner_repo = m.group(1).rstrip("/")
                # Use api.github.com for more reliable zipball
                zip_urls.append(f"https://api.github.com/repos/{owner_repo}/zipball")
                zip_urls.append(f"https://github.com/{owner_repo}/archive/refs/heads/main.zip")
                zip_urls.append(f"https://github.com/{owner_repo}/archive/refs/heads/master.zip")
            
            saved_zip = None
            last_error = ""
            for url in zip_urls:
                try:
                    # Fix: follow_redirects=True nötig da GitHub HTTP 302 zurückgibt
                    with httpx.Client(timeout=60.0, follow_redirects=True) as client:
                        r = client.get(url)
                        if r.status_code == 200 and len(r.content) > 500: # zipball can be small
                            safe_name = re.sub(r"[^A-Za-z0-9]", "_", name)
                            saved_zip = downloads_dir / f"{safe_name}.zip"
                            saved_zip.write_bytes(r.content)
                            break
                        else:
                            last_error = f"HTTP {r.status_code} für {url} ({len(r.content)} bytes)"
                except Exception as dl_exc:
                    last_error = f"{url}: {dl_exc}"
                    continue
                
            if not saved_zip:
                return {"ok": False, "message": f"Download von GitHub fehlgeschlagen: {last_error}"}
                
            # 2. Extract
            extract_to = downloads_dir / safe_name
            if extract_to.exists(): shutil.rmtree(extract_to, ignore_errors=True)
            with zipfile.ZipFile(saved_zip, 'r') as zip_ref:
                zip_ref.extractall(downloads_dir)
                # Find the root folder in the zip (it's usually the only folder or the largest one)
                possible_folders = [d for d in os.listdir(downloads_dir) if os.path.isdir(downloads_dir / d) and d != safe_name]
                if possible_folders:
                    # Bevorzuge Ordner der mit Repo-Name anfängt
                    repo_name = owner_repo.split('/')[-1]
                    match_folder = next((f for f in possible_folders if repo_name in f), possible_folders[0])
                    os.rename(downloads_dir / match_folder, extract_to)
            
            # 3. Guess Command & Install Deps
            import subprocess as _sp
            venv_path = ROOT_DIR / ".venv"
            python_exe = str((venv_path / "Scripts" / "python.exe").resolve()) if venv_path.exists() else "python"
            pip_exe = str((venv_path / "Scripts" / "pip.exe").resolve()) if venv_path.exists() else "pip"

            note = ""
            # Alle Dateien im gesamten extrahierten Verzeichnis (rekursiv)
            all_files = list(extract_to.rglob("*")) if extract_to.exists() else []
            top_files_names = [f.name for f in extract_to.iterdir() if f.is_file()] if extract_to.exists() else []

            # Priorität: package.json → npm/node
            if "package.json" in top_files_names:
                npm_note = ""
                pkg_data = {}
                try:
                    pkg_data = json.loads((extract_to / "package.json").read_text(encoding="utf-8", errors="replace"))
                except Exception: pass

                try:
                    # Use pnpm if lockfile exists and pnpm is available
                    use_pnpm = (extract_to / "pnpm-lock.yaml").exists() and shutil.which("pnpm")
                    install_cmd = ["pnpm", "install"] if use_pnpm else ["npm", "install", "--prefer-offline"]
                    
                    result = _sp.run(
                        install_cmd,
                        cwd=str(extract_to), shell=True, timeout=300,
                        capture_output=True, text=True, errors="replace"
                    )
                    if result.returncode != 0:
                        npm_note = f" (npm install Warnung)"
                    
                    # Run build if exists
                    if pkg_data.get("scripts", {}).get("build"):
                        _sp.run(["npm", "run", "build"], cwd=str(extract_to), shell=True, timeout=300, check=False)
                except Exception as e:
                    npm_note = f" (npm Fehler: {e})"

                # Einstiegspunkt aus package.json lesen (main oder bin)
                node_exe = shutil.which("node") or "node"
                cmd, args = "npx", ["-y", "." ]
                try:
                    # Versuche 'main' oder ersten 'bin'-Eintrag als Einstiegspunkt
                    entry_rel = pkg_data.get("main") or ""
                    if not entry_rel and isinstance(pkg_data.get("bin"), dict):
                        entry_rel = next(iter(pkg_data["bin"].values()), "")
                    elif not entry_rel and isinstance(pkg_data.get("bin"), str):
                        entry_rel = pkg_data["bin"]

                    if entry_rel:
                        entry_abs = (extract_to / entry_rel).resolve()
                        if entry_abs.exists():
                            cmd = node_exe
                            args = [str(entry_abs)]
                except Exception:
                    pass

                action = {"name": name, "command": cmd, "args": args, "env": {}, "type": "stdio", "cwd": str(extract_to)}
                _mcp_register_server(cfg, action)
                save_config(cfg)
                return {"ok": True, "message": f"MCP-Tool '{name}' registriert{npm_note}.", "cwd": str(extract_to)}



            # Python-Einstiegspunkt: rekursiv suchen nach typischen Namen
            py_entry_candidates = ["server.py", "mcp_server.py", "__main__.py", "main.py", "app.py"]
            found_entry: Optional[pathlib.Path] = None
            for candidate in py_entry_candidates:
                matches = [f for f in all_files if f.name == candidate and f.is_file()]
                if matches:
                    # Bevorzuge flachste (shortest path)
                    found_entry = min(matches, key=lambda p: len(p.parts))
                    break

            # requirements.txt: rekursiv suchen und installieren
            req_files = [f for f in all_files if f.name == "requirements.txt" and f.is_file()]
            if req_files:
                req_file = min(req_files, key=lambda p: len(p.parts))
                try:
                    _sp.run([pip_exe, "install", "-r", str(req_file)], shell=True, timeout=120, check=False)
                except Exception as e:
                    note = f" (pip install Warnung: {e})"

            if found_entry:
                cmd = python_exe
                args = [str(found_entry.resolve())]
                action = {"name": name, "command": cmd, "args": args, "env": {}, "type": "stdio"}
                _mcp_register_server(cfg, action)
                save_config(cfg)
                return {"ok": True, "message": f"Python MCP-Tool '{name}' installiert{note}. Einstiegspunkt: {found_entry.name}"}

            # Kein erkennbarer Einstiegspunkt → klare Fehlermeldung statt silent fail
            return {
                "ok": False,
                "message": (
                    f"GitHub-Tool '{name}' wurde heruntergeladen nach: {str(extract_to)}, "
                    "aber kein lauffähiger Einstiegspunkt gefunden (server.py, main.py, package.json etc.). "
                    "Bitte den MCP-Server manuell über Einstellungen → MCP → Server hinzufügen konfigurieren."
                ),
