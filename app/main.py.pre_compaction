def _mcp_register_server(cfg: Dict[str, Any], action: Dict[str, Any]) -> tuple[str, str]:
    from app.config import save_config
    name = str(action.get("name", "")).strip()
    command = str(action.get("command", "")).strip()
    if not name or not command:
        return "mcp_register_server", "name/command fehlen."
    args = action.get("args", [])
    if not isinstance(args, list):
        args = []
    env = action.get("env", {})
    if not isinstance(env, dict):
        env = {}
    srv_type = str(action.get("type", "stdio")).strip() or "stdio"
    cwd = str(action.get("cwd", "")).strip() or None
    mcp = cfg.setdefault("mcp", {})
    servers = mcp.setdefault("servers", {})
    entry: Dict[str, Any] = {"type": srv_type, "command": command, "args": args, "env": env}
    if cwd:
        entry["cwd"] = cwd
    servers[name] = entry
    save_config(cfg)
    tool_store.log("mcp_register", f"name={name}")
    return "mcp_register_server", f"MCP-Server registriert: {name}"



def _mcp_remove_server(cfg: Dict[str, Any], action: Dict[str, Any]) -> tuple[str, str]:
    from app.config import save_config
    name = str(action.get("name", "")).strip()
    if not name:
        return "mcp_remove_server", "name fehlt."
    servers = cfg.setdefault("mcp", {}).setdefault("servers", {})
    if name not in servers:
        return "mcp_remove_server", f"MCP-Server nicht gefunden: {name}"
    servers.pop(name, None)
    save_config(cfg)
    tool_store.log("mcp_remove", f"name={name}")
    return "mcp_remove_server", f"MCP-Server entfernt: {name}"

def _fix_llm_script_newlines(script: str) -> str:
    """Ersetzt literal \\n (zwei Zeichen) ausserhalb von String-Literalen durch echte Zeilenumbrüche.
    Korrigiert LLM-Fehler bei der JSON-Kodierung von Python-Scripts."""
    out: List[str] = []
    i = 0
    n = len(script)
    in_string: Optional[str] = None  # None oder schließendes Delimiter
    while i < n:
        c = script[i]
        if in_string is not None:
            # Innerhalb eines String-Literals: alles unverändert übernehmen
            if c == "\\" and i + 1 < n:
                out.append(c)
                out.append(script[i + 1])
                i += 2
                continue
            out.append(c)
            if len(in_string) == 3:
                if script[i : i + 3] == in_string:
                    out.append(script[i + 1])
                    out.append(script[i + 2])
                    i += 3
                    in_string = None
                    continue
            else:
                if c == in_string:
                    in_string = None
        elif script[i : i + 3] in ('"""', "'''"):
            in_string = script[i : i + 3]
            out.append(script[i : i + 3])
            i += 3
            continue
        elif c in ('"', "'"):
            in_string = c
            out.append(c)
        elif c == "#":
            # Kommentare bis Zeilenende unverändert
            while i < n and script[i] != "\n":
                out.append(script[i])
                i += 1
            continue
        elif c == "\\" and i + 1 < n and script[i + 1] == "n":
            # Literal \n außerhalb von Strings → echter Zeilenumbruch
            out.append("\n")
            i += 2
            continue
        else:
            out.append(c)
        i += 1
    return "".join(out)

def _ensure_python_script_execution(script: str) -> str:
    """
    Stellt sicher, dass ein Python-Script auch ausgefuehrt wird.
    Wenn nur 'def run(' definiert ist aber kein Aufruf erfolgt, wird ein 
    Main-Block angehaengt.
    """
    s = (script or "").strip()
    if not s: return s
    # Pruefen auf 'run' oder 'main'
    has_async_main = bool(re.search(r"async\s+def\s+main\s*\(", s))
    has_sync_main = bool(re.search(r"def\s+main\s*\(", s))
    has_run = bool(re.search(r"def\s+run\s*\(", s))
    
    if (has_async_main or has_sync_main or has_run) and ("__main__" not in s):
        # Nur anhaengen wenn nicht bereits manuell aufgerufen
        already_called = bool(re.search(r"\n(main|run)\s*\(", s)) or s.endswith("main()") or s.endswith("run()")
        if not already_called:
            s += "\n\nif __name__ == \"__main__\":\n    try:\n"
            if has_async_main:
                s += "        import asyncio\n        asyncio.run(main())\n"
            elif has_sync_main:
                s += "        main()\n"
            else:
                s += "        run()\n"
            s += "    except Exception as e:\n        print(f\"Fehler: {e}\")\n"
    return s
    return s

def _repair_script_if_needed(script: str) -> str:
    """Versucht ein syntaktisch fehlerhaftes Script durch Newline-Normalisierung zu reparieren."""
    # Zuerst Ausfuehrung sicherstellen
    script = _ensure_python_script_execution(script)
    try:
        ast.parse(script)
        return script  # bereits valide
    except SyntaxError:
        pass
    fixed = _fix_llm_script_newlines(script)
    try:
        ast.parse(fixed)
        return fixed  # Reparatur erfolgreich
    except SyntaxError:
        return script  # Reparatur half nicht, Original zurückgeben

def _missing_python_packages(script: str) -> List[str]:
    try:
        tree = ast.parse(script)
    except Exception:
        return []
    imports: set[str] = set()
    for node in ast.walk(tree):
        if isinstance(node, ast.Import):
            for alias in node.names:
                root = (alias.name or "").split(".")[0].strip()
                if root:
                    imports.add(root)
        elif isinstance(node, ast.ImportFrom):
            if node.module:
                root = node.module.split(".")[0].strip()
                if root:
                    imports.add(root)
    stdlib = set(getattr(sys, "stdlib_module_names", set()))
    package_map = {
        "cv2": "opencv-python",
        "pil": "Pillow",
        "sklearn": "scikit-learn",
        "yaml": "PyYAML",
    }
    missing: List[str] = []
    for mod in sorted(imports):
        if mod.lower() in {"__future__"}:
            continue
        if mod in stdlib:
            continue
        if importlib.util.find_spec(mod) is not None:
            continue
        missing.append(package_map.get(mod.lower(), mod))
    # Keep unique order
    seen: set[str] = set()
    out: List[str] = []
    for p in missing:
        if p not in seen:
            seen.add(p)
            out.append(p)
    return out

def _missing_nodejs_packages(script: str) -> List[str]:
    """Detect missing Node.js packages from require() and import statements."""
    imports: set[str] = set()
    
    # Match: require('package') or require("package")
    for m in re.finditer(r"require\s*\(\s*['\"]([^'\"]+)['\"]\s*\)", script):
        pkg = m.group(1).strip()
        if pkg and not pkg.startswith(".") and not pkg.startswith("/"):
            # Extract root package (e.g., 'express/lib' -> 'express')
            root = pkg.split("/")[0]
            imports.add(root)
    
    # Match: import ... from 'package' or import 'package'
    for m in re.finditer(r"import\s+(?:.*?\s+from\s+)?['\"]([^'\"]+)['\"]", script):
        pkg = m.group(1).strip()
        if pkg and not pkg.startswith(".") and not pkg.startswith("/"):
            root = pkg.split("/")[0]
            imports.add(root)
    
    # Node.js built-in modules (no installation needed)
    nodejs_builtins = {
        "assert", "buffer", "child_process", "cluster", "crypto", "dgram",
        "dns", "domain", "events", "fs", "http", "https", "net", "os",
        "path", "punycode", "querystring", "readline", "repl", "stream",
        "string_decoder", "timers", "tls", "tty", "url", "util", "v8",
        "vm", "zlib", "process", "console", "module", "perf_hooks",
        "async_hooks", "worker_threads", "inspector"
    }
    
    missing: List[str] = []
    for pkg in sorted(imports):
        if pkg in nodejs_builtins:
            continue
        # Check if package exists in node_modules (simple heuristic)
        # In real scenario, we'd check if npm/yarn can find it
        missing.append(pkg)
    
    return missing

def _extract_returncode(reply: str) -> Optional[int]:
    m = re.search(r"returncode=([-]?\d+)", reply)
    if not m:
        return None
    try:
        return int(m.group(1))
    except Exception:
        return None

def _infer_missing_packages_from_runtime(reply: str) -> List[str]:
    text = reply or ""
    missing: List[str] = []
    for m in re.finditer(r"ModuleNotFoundError:\s*No module named ['\"]([^'\"]+)['\"]", text, flags=re.IGNORECASE):
        mod = m.group(1).strip()
        if mod:
            missing.append(mod)

    # pyautogui/pyscreeze often hints this when Pillow/pyscreeze is missing/incompatible
    if re.search(r"unable to import pyscreeze", text, flags=re.IGNORECASE):
        missing.extend(["pyscreeze", "Pillow"])
    if re.search(r"depends on\)\s+doesn't support", text, flags=re.IGNORECASE):
        missing.append("Pillow")

    package_map = {
        "cv2": "opencv-python",
        "pil": "Pillow",
        "sklearn": "scikit-learn",
        "yaml": "PyYAML",
    }
    out: List[str] = []
    seen: set[str] = set()
    for name in missing:
        pkg = package_map.get(name.lower(), name)
        if pkg and pkg not in seen:
            seen.add(pkg)
            out.append(pkg)
    return out

def _infer_missing_nodejs_packages_from_runtime(reply: str) -> List[str]:
    """Extract missing Node.js packages from error messages."""
    text = reply or ""
    missing: List[str] = []
    
    # Match: Error: Cannot find module 'package'
    for m in re.finditer(r"Error:\s*Cannot find module ['\"]([^'\"]+)['\"]", text, flags=re.IGNORECASE):
        mod = m.group(1).strip()
        if mod and not mod.startswith(".") and not mod.startswith("/"):
            root = mod.split("/")[0]
            missing.append(root)
    
    # Match: MODULE_NOT_FOUND
    for m in re.finditer(r"MODULE_NOT_FOUND.*?['\"]([^'\"]+)['\"]", text, flags=re.IGNORECASE):
        mod = m.group(1).strip()
        if mod and not mod.startswith(".") and not mod.startswith("/"):
            root = mod.split("/")[0]
            missing.append(root)
    
    # Remove duplicates
    seen: set[str] = set()
    out: List[str] = []
    for pkg in missing:
        if pkg and pkg not in seen:
            seen.add(pkg)
            out.append(pkg)
    return out

def _run_nodejs_script_with_auto_deps(action: Dict[str, Any], max_rounds: int = 4) -> str:
    """Run Node.js script with automatic dependency installation."""
    logs: List[str] = []
    seen_pkg_sets: set[tuple[str, ...]] = set()
    for _ in range(max_rounds):
        _, run_reply = _execute_action(action)
        logs.append(run_reply)
        rc = _extract_returncode(run_reply)
        missing = _infer_missing_nodejs_packages_from_runtime(run_reply)
        if (rc is None or rc == 0) and not missing:
            return "\n\n".join(logs)
        if not missing:
            return "\n\n".join(logs)
        key = tuple(sorted(missing))
        if key in seen_pkg_sets:
            logs.append("Hinweis: Weitere automatische Nachinstallation wurde beendet (wiederholte Abhaengigkeiten).")
            return "\n\n".join(logs)
        seen_pkg_sets.add(key)
        install_action = {"kind": "install_nodejs_packages", "packages": missing}
        _, install_reply = _execute_action(install_action)
        logs.append(install_reply)
    logs.append("Hinweis: Maximale Nachinstallationsrunden erreicht.")
    return "\n\n".join(logs)

def _shell_command_script_with_auto_deps(action: Dict[str, Any], max_rounds: int = 4) -> str:
    logs: List[str] = []
    seen_pkg_sets: set[tuple[str, ...]] = set()
    for i in range(max_rounds):
        _, run_reply = _execute_action(action)
        logs.append(f"--- LAUF {i+1} ---\n{run_reply}")
        rc = _extract_returncode(run_reply)
        missing = _infer_missing_packages_from_runtime(run_reply)
        
        if (rc is None or rc == 0) and not missing:
            return "\n\n".join(logs)
            
        if not missing:
            # Script ist fehlgeschlagen, aber kein fehlendes Paket erkannt.
            # Sicherstellen, dass das Ende von stderr (meist der wichtigste Teil) enthalten ist.
            error_preview = run_reply
            if len(run_reply) > 3000:
                error_preview = "..." + run_reply[-3000:]
            logs.append(f"[SYSTEM] Script-Fehler in Lauf {i+1} erkannt. Kritischer Teil:\n{error_preview}")
            logs.append("Bitte analysiere den obigen Traceback und korrigiere den Code.")
            return "\n\n".join(logs)
            
        key = tuple(sorted(missing))
        if key in seen_pkg_sets:
            logs.append(f"[SYSTEM] Wiederholter Fehler bei Modulen {missing}. Automatische Installation gestoppt. Bitte prüfe, ob die Paketnamen korrekt sind oder installiere sie manuell.")
            return "\n\n".join(logs)
            
        seen_pkg_sets.add(key)
        install_action = {"kind": "install_python_packages", "packages": missing}
        logs.append(f"[SYSTEM] Versuche fehlende Module zu installieren: {missing}")
        _, install_reply = _execute_action(install_action)
        logs.append(f"--- INSTALLATION ---\n{install_reply}")
        
    logs.append("[SYSTEM] Maximale Anzahl an automatischen Korrekturversuchen (4) erreicht. Bitte korrigiere das Script oder die Abhängigkeiten manuell.")
    return "\n\n".join(logs)

def _is_script_syntax_issue(text: str, script_type: str) -> bool:
    low = str(text or "").strip().lower()
    if not low:
        return False
    st = str(script_type or "").strip().lower()
    if st == "python":
        markers = [
            "python-syntaxfehler",
            "syntaxerror",
            "indentationerror",
            "taberror",
            "invalid syntax",
        ]
        return any(m in low for m in markers)
    if st == "powershell":
        markers = [
            "powershell-syntaxfehler",
            "parsererror",
            "parseexception",
            "unexpected token",
            "missing ')' in method call",
        ]
        return any(m in low for m in markers)
    return False

def _is_agent_managed_script_for_repair(cfg: Dict[str, Any], action: Dict[str, Any]) -> bool:
    src = str(action.get("source", "") or "").strip().lower()
    if src in {"script_create", "script_reuse", "self_improve", "agent_planned", "llm_planned", "react_loop"}:
        return True
    script_path = str(action.get("script_path", "") or "").strip()
    if not script_path:
        return False
    p: Optional[Path] = None
    with contextlib.suppress(Exception):
        p = Path(script_path).resolve()
    if p is None:
        return False
    name_low = p.name.lower()
    if name_low.startswith("auto_") or name_low.startswith("self_improve_"):
        return True
    with contextlib.suppress(Exception):
        scripts_dir = (_workspace_abs(cfg) / "scripts").resolve()
        if _is_within(scripts_dir, p):
            return True
    with contextlib.suppress(Exception):
        if _find_script_memory_by_path(cfg, str(p)):
            return True
    return False

def _attempt_script_syntax_repair(
    cfg: Dict[str, Any],
    action: Dict[str, Any],
    error_text: str,
) -> Tuple[bool, Dict[str, Any], str]:
    act = dict(action or {})
    script_type = str(act.get("script_type", "") or "").strip().lower()
    if script_type not in {"python", "powershell"}:
        return False, act, ""
    if not _is_script_syntax_issue(error_text, script_type):
        return False, act, ""
    if not _is_agent_managed_script_for_repair(cfg, act):
        return False, act, ""

    script_path = str(act.get("script_path", "") or "").strip()
    script_text = str(act.get("script", "") or "")
    if (not script_text.strip()) and script_path:
        with contextlib.suppress(Exception):
            script_text = Path(script_path).read_text(encoding="utf-8-sig", errors="ignore")
    if not script_text.strip():
        return False, act, ""

    fixed_code = script_text
    changed = False
    notes: List[str] = []

    if script_type == "python":
        fixed_code, changed, issues = _validate_and_fix_script(
            cfg=cfg,
            script_code=script_text,
            script_path=script_path,
            script_type=script_type,
        )
        notes.extend(str(x) for x in issues[:6] if str(x).strip())
    else:
        sanitized, applied = _sanitize_script_static(script_text)
        if applied and sanitized.strip() and sanitized != script_text:
            fixed_code = sanitized
            changed = True
            notes.extend(str(x) for x in applied[:6] if str(x).strip())
        if not changed:
            try:
                from app.code_validation_pipeline import validate_and_fix as _cvp_fix
                _cvp_ok, _cvp_code, _cvp_errors = _cvp_fix(
                    code=script_text,
                    language="powershell",
                    cfg=cfg,
                    max_retries=3,
                    context=str(error_text)[:500],
                )
                if _cvp_ok and _cvp_code.strip() and _cvp_code != script_text:
                    fixed_code = _cvp_code
                    changed = True
                    notes.append("llm_ps_syntax_fix")
            except Exception as exc:
                _audit_event("script_auto_fix_error", {"error": str(exc)[:220], "script_type": "powershell"})

        if changed:
            try:
                _execute_script_validate_action(
                    {
                        "kind": "script_validate",
                        "script_type": "powershell",
                        "script": fixed_code,
                        "script_path": script_path,
                    }
                )
            except Exception:
                return False, act, ""

    if (not changed) or (not str(fixed_code).strip()) or str(fixed_code) == str(script_text):
        return False, act, ""

    if script_path:
        with contextlib.suppress(Exception):
            Path(script_path).write_text(fixed_code, encoding="utf-8")
    act["script"] = fixed_code
    if script_path:
        act["script_path"] = script_path

    info = ", ".join(notes[:4]) if notes else "syntax_auto_fix"
    _audit_event(
        "script_syntax_auto_repair",
        {
            "script_path": script_path,
            "script_type": script_type,
            "info": info[:220],
        },
    )
    tool_store.log("script_syntax_auto_repair", f"{script_type} | {Path(script_path).name if script_path else '(inline)'} | {info}")
    return True, act, info

def _retry_script_after_syntax_repair(
    cfg: Dict[str, Any],
    action: Dict[str, Any],
    reply: str,
) -> Tuple[bool, str, Dict[str, Any], bool]:
    act = dict(action or {})
    if str(act.get("kind", "")).strip().lower() != "script_exec":
        return False, reply, act, False
    script_type = str(act.get("script_type", "") or "").strip().lower()
    if not _is_script_syntax_issue(reply, script_type):
        return False, reply, act, False
    repaired, repaired_action, info = _attempt_script_syntax_repair(cfg, act, reply)
    if not repaired:
        return False, reply, act, False
    retry_reply = ""
    retry_ok = False
    try:
        if script_type == "python":
            retry_reply = _shell_command_script_with_auto_deps(repaired_action, max_rounds=2)
            tool_store.log("python_exec", "Erneut ausgefuehrt nach Syntax-Auto-Reparatur")
        else:
            _, retry_reply = _execute_action(repaired_action)
            tool_store.log("powershell_exec", "Erneut ausgefuehrt nach Syntax-Auto-Reparatur")
        retry_ok = _script_exec_reply_ok(retry_reply) and (not _tool_reply_looks_error(retry_reply))
    except Exception as exc:
        retry_reply = f"Auto-Reparatur-Run fehlgeschlagen: {exc}"
        retry_ok = False
    merged = (
        f"{reply}\n\n"
        f"Auto-Reparatur (Syntax) angewendet: {info or 'ok'}\n\n"
        f"Retry:\n{retry_reply}"
    )
    return True, merged, repaired_action, retry_ok

def _normalize_action_paths(action: Dict[str, Any]) -> Dict[str, Any]:
    """
    Wandelt relative Pfade in Action-Parametern zu absoluten Pfaden um.

    Strategie:
    - Absolute Pfade → unverändert
    - Relative Pfade die bereits existieren → relativ zu ROOT_DIR auflösen
    - Relative Pfade die NICHT existieren (neue Dateien) + Write-Operationen
      → relativ zu ROOT_DIR/data/workspace/ auflösen
      Verhindert dass nackte Dateinamen wie 'file.bat' im K.AI-Root landen
    - Strings ohne Pfad-Trennzeichen (COM4, URLs etc.) → unverändert
    """
    _PATH_FIELDS = {"path", "target", "source", "file", "destination", "output_path",
                    "input_path", "file_path", "dir", "directory"}
    _WRITE_KINDS = {
        "fs_write_file", "fs_write", "write_file", "fs_append_file", "append_file",
        "fs_touch", "touch_file", "fs_mkdir", "fs_move_file", "fs_copy_file",
    }
    kind = str(action.get("kind", "")).strip()
    workspace = ROOT_DIR / "data" / "workspace"
    result = dict(action)
    for field in _PATH_FIELDS:
        val = result.get(field)
        if not val or not isinstance(val, str):
            continue
        stripped = val.strip()
        # Schon absolut → nichts tun
        if Path(stripped).is_absolute():
            continue
        # Kein Pfad-Trennzeichen → kein Pfad (z.B. COM4, hostname, plain keyword)
        if '/' not in stripped and '\\' not in stripped:
            # Ausnahme: nackte Dateinamen mit Endung bei Write-Operationen → workspace
            if kind in _WRITE_KINDS and '.' in stripped and not stripped.startswith('.'):
                result[field] = str((workspace / stripped).resolve())
            continue
        # Relativ mit Trennzeichen: zuerst prüfen ob ROOT_DIR-relativ existiert
        candidate = (ROOT_DIR / stripped).resolve()
        if candidate.exists():
            result[field] = str(candidate)
        elif kind in _WRITE_KINDS:
            # Neue Datei bei Write → workspace als Basis
            # Strip redundant workspace-prefix the LLM sometimes adds (e.g. "data/workspace/file.txt")
            try:
                _rel = Path(stripped).relative_to(Path("data") / "workspace")
            except ValueError:
                _rel = Path(stripped)
            result[field] = str((workspace / _rel).resolve())
    return result


def _run_action_with_policy(
    cfg: Dict[str, Any],
    message: str,
    action: Dict[str, Any],
    note: str,
    deny_log: str,
    allowlist_for_remember: bool,
    dialog_key: str = "",
    pre_approved: bool = False,
) -> Dict[str, Any]:
    cancelled = _cancelled_reply("vor Aktion")
    if cancelled:
        return cancelled
    action = _normalize_action_paths(action)  # Relative Pfade → absolut (ROOT_DIR-relativ)
    mode = execution_mode(cfg)
    lesson_hint = _lesson_hint_for_action(cfg, action, message)
    _audit_event(
        "policy_run_action_start",
        {"mode": mode, "kind": str(action.get("kind", "")), "note": str(note)[:200]},
    )
    deny_decision = deny_if_mode_deny(cfg)
    if deny_decision and not deny_decision.ok:
        tool_store.log(deny_log, deny_decision.message)
        _audit_event("policy_decision", {"allowed": False, "reason": deny_decision.code, "message": deny_decision.message})
        return {"ok": False, "reply": deny_decision.message}

    scope_decision = check_script_exec_scope(
        cfg,
        action=action,
        workspace=_workspace_abs(cfg),
        is_within=_is_within,
        role_hint=_role_windows_hint,
    )
    if scope_decision and not scope_decision.ok:
        tool_store.log(deny_log, scope_decision.message)
        _audit_event("policy_decision", {"allowed": False, "reason": scope_decision.code, "message": scope_decision.message})
        return {"ok": False, "reply": scope_decision.message}

    if str(action.get("kind", "")) == "script_exec" and bool(action.get("validate_before_run", True)):
        _validate_script_text = str(action.get("script", "") or "")
        _validate_script_path = str(action.get("script_path", "") or "").strip()
        _validate_script_type = str(action.get("script_type", "") or "").strip().lower()
        if (not _validate_script_text.strip()) and _validate_script_path:
            with contextlib.suppress(Exception):
                _validate_script_text = Path(_validate_script_path).read_text(encoding="utf-8-sig", errors="ignore")
        validate_action = {
            "kind": "script_validate",
            "script_type": _validate_script_type,
            "script": _validate_script_text,
            "script_path": _validate_script_path,
        }
        try:
            t_val, r_val = _execute_action(validate_action)
            tool_store.log(t_val, "Vor Ausfuehrung validiert")
        except Exception as exc:
            repair_attempted = False
            repair_info = ""
            validation_recovered = False
            if _is_script_syntax_issue(str(exc), _validate_script_type):
                repair_attempted = True
                repaired, repaired_action, repair_info = _attempt_script_syntax_repair(cfg, action, str(exc))
                if repaired:
                    action = dict(repaired_action)
                    _validate_script_text = str(action.get("script", "") or "")
                    _validate_script_path = str(action.get("script_path", "") or "").strip()
                    validate_action = {
                        "kind": "script_validate",
                        "script_type": _validate_script_type,
                        "script": _validate_script_text,
                        "script_path": _validate_script_path,
                    }
                    try:
                        t_val, r_val = _execute_action(validate_action)
                        tool_store.log(t_val, "Vor Ausfuehrung validiert (nach Syntax-Auto-Reparatur)")
                        validation_recovered = True
                    except Exception as exc2:
                        tool_store.log("script_validate_error", str(exc2))
                        _record_execution_lesson(cfg, message=message, action=action, success=False, error_text=f"validation: {exc2}")
                        suffix = f" (Auto-Reparatur versucht: {repair_info})" if repair_info else ""
                        return {"ok": False, "reply": f"Script-Validierung fehlgeschlagen: {exc2}{suffix}"}
                else:
                    tool_store.log("script_validate_error", f"Syntaxfehler erkannt, Auto-Reparatur nicht moeglich: {exc}")
            if validation_recovered:
                pass
            elif (not repair_attempted) or (not _is_script_syntax_issue(str(exc), _validate_script_type)):
                tool_store.log("script_validate_error", str(exc))
                _record_execution_lesson(cfg, message=message, action=action, success=False, error_text=f"validation: {exc}")
                return {"ok": False, "reply": f"Script-Validierung fehlgeschlagen: {exc}"}
            else:
                _record_execution_lesson(cfg, message=message, action=action, success=False, error_text=f"validation: {exc}")
                suffix = f" (Auto-Reparatur versucht: {repair_info})" if repair_info else " (Auto-Reparatur nicht moeglich)"
                return {"ok": False, "reply": f"Script-Validierung fehlgeschlagen: {exc}{suffix}"}

    if str(action.get("kind", "")) == "script_exec" and str(action.get("script_type", "")) == "python":
        missing = _missing_python_packages(str(action.get("script", "")))
        if missing:
            install_action = {
                "kind": "install_python_packages",
                "packages": missing,
                "run_after_install": action,
                "auto_resolve_deps": True,
            }
            install_note = f"Fehlende Python-Pakete installieren: {', '.join(missing)}"
            try:
                t1, r1 = _execute_action(install_action)
                tool_store.log(t1, "Ausgefuehrt vor Script-Run")
                r2 = _shell_command_script_with_auto_deps(action, max_rounds=4)
                tool_store.log("python_exec", "Ausgefuehrt nach Paket-Installation (auto-resolve)")
                reply = f"{r1}\n\n{r2}"
                script_ok = _script_exec_reply_ok(r2) and (not _tool_reply_looks_error(reply))
                retried, merged_reply, repaired_action, retry_ok = _retry_script_after_syntax_repair(cfg, action, reply)
                if retried:
                    reply = merged_reply
                    action = repaired_action
                    script_ok = retry_ok
                with contextlib.suppress(Exception):
                    _remember_session_artifact_from_result(cfg, dialog_key, action, reply, message)
                _record_execution_lesson(
                    cfg,
                    message=message,
                    action=action,
                    success=bool(script_ok),
                    reply_text=reply if script_ok else "",
                    error_text="" if script_ok else reply[:10000],
                )
                _persist_conversation(cfg, message, reply, 0.82)
                _audit_event(
                    "policy_decision",
                    {
                        "allowed": True,
                        "reason": "auto_install_and_run" if script_ok else "auto_install_and_run_failed",
                        "mode": mode,
                    },
                )
                return {"ok": bool(script_ok), "reply": reply}
            except Exception as exc:
                tool_store.log("script_exec_error", str(exc))
                _record_execution_lesson(cfg, message=message, action=action, success=False, error_text=str(exc))
                return {"ok": False, "reply": f"Abhaengigkeiten/Script fehlgeschlagen: {exc}\n{_role_windows_hint(cfg)}"}

    try:
        if str(action.get("kind", "")) == "script_exec" and str(action.get("script_type", "")) == "python":
            reply = _shell_command_script_with_auto_deps(action, max_rounds=4)
            tool_store.log("python_exec", f"Ausgefuehrt ({mode})")
        else:
            tool_name, reply = _execute_action(action)
            tool_store.log(tool_name, f"Ausgefuehrt ({mode})")
        reply_has_error = _tool_reply_looks_error(reply)
        script_ok = _script_exec_reply_ok(reply) if str(action.get("kind", "")) == "script_exec" else (not reply_has_error)
        retried, merged_reply, repaired_action, retry_ok = _retry_script_after_syntax_repair(cfg, action, reply)
        if retried:
            reply = merged_reply
            action = repaired_action
            reply_has_error = _tool_reply_looks_error(reply)
            script_ok = retry_ok
        with contextlib.suppress(Exception):
            _remember_session_artifact_from_result(cfg, dialog_key, action, reply, message)
        _record_execution_lesson(
            cfg,
            message=message,
            action=action,
            success=bool(script_ok),
            reply_text=reply if script_ok else "",
            error_text="" if script_ok else reply[:2000],
        )
        _persist_conversation(cfg, message, reply, 0.8)
        _audit_event(
            "policy_decision",
            {
                "allowed": True,
                "reason": "execute_no_approval" if script_ok else "execute_failed",
                "mode": mode,
            },
        )
        return {"ok": script_ok, "reply": reply}
    except Exception as exc:
        tool_store.log("script_exec_error", str(exc))
        _record_execution_lesson(cfg, message=message, action=action, success=False, error_text=str(exc))
        return {"ok": False, "reply": f"Script fehlgeschlagen: {exc}\n{_role_windows_hint(cfg)}"}

def _handle_script_request(message: str, cfg: Dict[str, Any], source: str = "api", dialog_key: str = "") -> Optional[Dict[str, Any]]:
    req = _extract_script_request(message, cfg)
    if not req:
        return None

    script_type = req["script_type"]
    script = req["script"]
    timeout_sec = int(cfg.get("security", {}).get("script_timeout", 180) or 180)
    timeout_sec = max(60, min(1800, timeout_sec))
    action = {
        "kind": "script_exec",
        "script_type": script_type,
        "script": script,
        "script_path": str(req.get("script_path", "") or ""),
        "script_owner_role": str(req.get("script_owner_role", "user") or "user"),
        "timeout_sec": timeout_sec,
        "source": source,
        "validate_before_run": bool(req.get("validate_before_run", True)),
    }
    note = f"Script-Ausfuehrung ({script_type}, timeout={timeout_sec}s)"
    return _run_action_with_policy(
        cfg=cfg,
        message=message,
        action=action,
        note=note,
        deny_log="script_denied",
        allowlist_for_remember=True,
        dialog_key=dialog_key,
    )

def _handle_filesystem_request(message: str, cfg: Dict[str, Any], dialog_key: str = "") -> Optional[Dict[str, Any]]:
    analyzed: Dict[str, Any] = {}
    routing_cfg = cfg.get("routing", {}) if isinstance(cfg.get("routing", {}), dict) else {}
    heuristics_enabled = bool(routing_cfg.get("heuristics_enabled", False))
    # Follow-up pronouns like "zeige mir die datei" / "loesche es" must resolve
    # context first; otherwise generic list handlers may consume the request.
    if heuristics_enabled:
        augmented = _augment_followup_with_llm_first(message, cfg, dialog_key=dialog_key)
        if augmented and augmented != message:
            analyzed = analyze_filesystem_request(augmented, cfg, ROOT_DIR)
            if analyzed.get("handled"):
                _audit_event("filesystem_followup_augmented", {"orig": str(message)[:220], "augmented": str(augmented)[:220]})
                message = augmented
    if not analyzed.get("handled"):
        analyzed = analyze_filesystem_request(message, cfg, ROOT_DIR)
    if not analyzed.get("handled"):
        low = str(message or "").lower()
        if _has_any(low, ["loesch", "lösch", "delete", "entferne", "remove"]) and _has_any(
            low, [" es", " das", "dies", "diese", "dieses", "ihn", "sie"]
        ):
            return {
                "ok": True,
                "reply": "Bitte nenne den exakten Pfad fuer das Loeschen, z. B. `C:\\temp` oder `data\\workspace\\ordner`.",
            }
        return None

    allowed_fs_kinds = {"read_file", "write_file"}
    action = analyzed.get("action", {}) if isinstance(analyzed.get("action", {}), dict) else {}
    kind = str(action.get("kind", "") or "").strip().lower()
    tool_name = str(analyzed.get("tool", "") or "").strip()
    if kind and kind not in allowed_fs_kinds:
        return None
    if tool_name and tool_name not in {"fs_read_file", "fs_list_entries", "fs_list_files", "fs_list_dirs", "fs_write_file"}:
        # Block legacy filesystem actions; use shell_command instead.
        return None

    has_action = bool(analyzed.get("action"))
    is_risky = bool(analyzed.get("risky"))
    admin_required = bool(analyzed.get("admin_required", False))

    if not has_action and not is_risky:
        tool_store.log(analyzed.get("tool", "fs_tool"), "Heuristische Tool-Ausfuehrung")
        reply = analyzed.get("reply", "")
        _persist_conversation(cfg, message, reply, 0.75)
        _audit_event("filesystem", {"mode": execution_mode(cfg), "decision": "heuristic_reply"})
        return {"ok": True, "reply": reply}

    mode = execution_mode(cfg)
    deny_decision = deny_if_mode_deny(cfg)
    if deny_decision and not deny_decision.ok:
        tool_store.log("fs_denied", deny_decision.message)
        _audit_event("policy_decision", {"allowed": False, "reason": deny_decision.code, "domain": "filesystem"})
        return {"ok": False, "reply": deny_decision.message}

    action = analyzed.get("action", {})
    kind = str(action.get("kind", "") or "").strip().lower() if isinstance(action, dict) else ""
    if kind == "export_entries_to_file":
        raw_src = str(action.get("path", "") or "").strip()
        raw_out = str(action.get("out_path", "") or "").strip()
        low_src = raw_src.lower()
        m = re.search(r"^(.+?)\s+in\s+eine\s+textdatei\s+unter\s+(.+)$", low_src, flags=re.IGNORECASE)
        if m:
            src = str(m.group(1) or "").strip()
            dst = str(m.group(2) or "").strip()
            action = dict(action)
            action["path"] = src
            if raw_out:
                action["out_path"] = raw_out
            else:
                dst_path = Path(dst)
                if dst_path.suffix.lower() != ".txt":
                    fname = "ordnerliste.txt" if _has_any(str(message or "").lower(), ["ordner", "verzeichnis"]) else "dateiliste.txt"
                    dst_path = dst_path / fname
                action["out_path"] = str(dst_path)
        analyzed["action"] = action
    path_decision = validate_action_paths(cfg, ROOT_DIR, action)
    if not path_decision.ok:
        tool_store.log("fs_denied_path", path_decision.message)
        _audit_event("policy_decision", {"allowed": False, "reason": path_decision.code, "domain": "filesystem"})
        return {"ok": False, "reply": path_decision.message}

    admin_decision = require_admin_for_risky(
        cfg,
        is_risky=is_risky,
        admin_required=admin_required,
        role_hint=_role_windows_hint,
    )
    if admin_decision and not admin_decision.ok:
        tool_store.log("fs_denied", admin_decision.message)
        _audit_event("policy_decision", {"allowed": False, "reason": admin_decision.code, "domain": "filesystem"})
        return {"ok": False, "reply": admin_decision.message}

    if not is_risky:
        try:
            tool_name, reply = _execute_action(action)
            tool_store.log(tool_name, "Ausgefuehrt (admin_required)")
            _record_execution_lesson(cfg, message=message, action=action, success=True, reply_text=reply)
            _persist_conversation(cfg, message, reply, 0.8)
            _audit_event("filesystem", {"mode": mode, "decision": "execute_non_risky", "tool": tool_name})
            # Compound request: execute follow-up steps after successful drive map
            follow_up = analyzed.get("follow_up", "")
            if follow_up:
                fu_result = _handle_filesystem_request(str(follow_up), cfg, dialog_key)
                if fu_result and fu_result.get("ok") and fu_result.get("reply"):
                    reply = reply + "\n\n" + str(fu_result["reply"])
            return {"ok": True, "reply": reply}
        except Exception as exc:
            tool_store.log("fs_action_error", str(exc))
            _record_execution_lesson(cfg, message=message, action=action, success=False, error_text=str(exc))
            return {"ok": False, "reply": f"Aktion fehlgeschlagen: {exc}"}

    risky_admin_decision = require_admin_for_risky_scope(
        cfg,
        is_risky=is_risky,
        action=action,
        workspace=_workspace_abs(cfg),
        is_within=_is_within,
        role_hint=_role_windows_hint,
    )
    if risky_admin_decision and not risky_admin_decision.ok:
        tool_store.log("fs_denied", risky_admin_decision.message)
        _audit_event("policy_decision", {"allowed": False, "reason": risky_admin_decision.code, "domain": "filesystem"})
        return {"ok": False, "reply": risky_admin_decision.message}

    note = analyzed.get("note", "Riskante Aktion")
    try:
        tool_name, reply = _execute_action(action)
        tool_store.log(tool_name, f"Ausgefuehrt (risky_direct): {note}")
        _record_execution_lesson(cfg, message=message, action=action, success=True, reply_text=reply)
        _persist_conversation(cfg, message, reply, 0.8)
        _audit_event("filesystem", {"mode": mode, "decision": "execute_risky_direct", "tool": tool_name})
        return {"ok": True, "reply": reply}
    except Exception as exc:
        tool_store.log("fs_action_error", str(exc))
        _record_execution_lesson(cfg, message=message, action=action, success=False, error_text=str(exc))
        return {"ok": False, "reply": f"Aktion fehlgeschlagen: {exc}"}

