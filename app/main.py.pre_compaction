def _si_patches_dir() -> Path:
    d = Path("data/patches")
    d.mkdir(parents=True, exist_ok=True)
    return d

def _si_fallback_dir() -> Path:
    d = Path("data/patch_fallback")
    d.mkdir(parents=True, exist_ok=True)
    return d

def _si_patch_id() -> str:
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    rand = uuid.uuid4().hex[:6]
    return f"patch_{stamp}_{rand}"

def _si_load_patches(status: Optional[str] = None) -> List[Dict[str, Any]]:
    patches: List[Dict[str, Any]] = []
    d = _si_patches_dir()
    for f in sorted(d.glob("patch_*.json"), reverse=True):
        with contextlib.suppress(Exception):
            p: Dict[str, Any] = json.loads(f.read_text(encoding="utf-8"))
            if status is None or p.get("status") == status:
                patches.append(p)
    return patches

def _si_save_patch(patch: Dict[str, Any]) -> str:
    pid = str(patch.get("id", "unknown"))
    path = _si_patches_dir() / f"{pid}.json"
    with contextlib.suppress(Exception):
        path.write_text(json.dumps(patch, ensure_ascii=False, indent=2), encoding="utf-8")
        return str(path)
    return ""

def _si_get_patch(patch_id: str) -> Optional[Dict[str, Any]]:
    path = _si_patches_dir() / f"{patch_id}.json"
    if not path.exists():
        return None
    with contextlib.suppress(Exception):
        return json.loads(path.read_text(encoding="utf-8"))  # type: ignore[return-value]
    return None

def _si_resolve_path(file_path: str) -> Path:
    """Löst einen Datei-Pfad gegen ROOT_DIR auf, wenn er relativ ist. Normalisiert Slashes."""
    normalized = os.path.normpath(file_path)
    p = Path(normalized)
    if p.is_absolute():
        return p
    return ROOT_DIR / p

def _si_backup_file(file_path: str, patch_id: str) -> str:
    """Backup einer Datei nach data/patch_fallback/<patch_id>/ vor der Änderung."""
    src = _si_resolve_path(file_path)
    if not src.exists():
        return ""
    backup_dir = _si_fallback_dir() / patch_id
    backup_dir.mkdir(parents=True, exist_ok=True)
    dst = backup_dir / src.name
    with contextlib.suppress(Exception):
        dst.write_bytes(src.read_bytes())
        return str(dst)
    return ""

def _si_syntax_check_content(content: str, file_path: str) -> Optional[str]:
    """Syntax-Check für Python-Dateien via py_compile auf einem Temp-File.
    Gibt None zurück wenn OK, sonst Fehlermeldung."""
    if not file_path.endswith(".py"):
        return None
    tmp_path = ""
    try:
        with tempfile.NamedTemporaryFile(suffix=".py", mode="w", encoding="utf-8", delete=False) as tf:
            tf.write(content)
            tmp_path = tf.name
        py_compile.compile(tmp_path, doraise=True)
        return None
    except py_compile.PyCompileError as e:
        return str(e).replace(tmp_path, file_path)
    except Exception as e:
        return str(e)
    finally:
        with contextlib.suppress(Exception):
            if tmp_path:
                Path(tmp_path).unlink(missing_ok=True)

def _si_extract_code_context(signals: List[Dict[str, Any]], max_chars: int = 1500) -> str:
    """Extrahiert relevante Code-Zeilen aus betroffenen Dateien basierend auf Fehlersignalen.
    Sucht Funktionsnamen/Fehlertexte in .py-Dateien und liefert Kontext (±15 Zeilen)."""
    context_parts: List[str] = []
    seen_files: Dict[str, str] = {}

    # Kandidaten-Dateien nach Priorität
    candidate_files = ["app/main.py", "app/gateway.py", "app/llm_router.py", "app/chroma_memory.py"]

    # Funktion: suche Schlüsselbegriff in Datei, gib Kontext zurück
    def _find_in_file(filepath: str, term: str, ctx: int = 15) -> str:
        try:
            lines = Path(filepath).read_text(encoding="utf-8", errors="ignore").splitlines()
        except Exception:
            return ""
        term_lower = term.lower().strip()
        if not term_lower or len(term_lower) < 5:
            return ""
        for i, line in enumerate(lines):
            if term_lower in line.lower():
                start = max(0, i - ctx)
                end = min(len(lines), i + ctx + 1)
                snippet = "\n".join(lines[start:end])
                return f"# {filepath} (Zeile {i + 1} ±{ctx}):\n{snippet}"
        return ""

    for sig in signals[:4]:
        msg = str(sig.get("last_message", "")).strip()
        key = str(sig.get("key", ""))

        # Traceback-Dateireferenz parsen: 'File "app/foo.py", line N, in func_name'
        tb_match = re.search(r'File ["\']([^"\']+\.py)["\'],\s*line\s*(\d+)', msg)
        func_match = re.search(r'\bin\s+(\w{4,})\b', msg)

        if tb_match:
            fp = tb_match.group(1)
            line_no = int(tb_match.group(2))
            try:
                lines = Path(fp).read_text(encoding="utf-8", errors="ignore").splitlines()
                start = max(0, line_no - 16)
                end = min(len(lines), line_no + 15)
                snippet = "\n".join(lines[start:end])
                part = f"# {fp} (Zeile {line_no} ±15):\n{snippet}"
                if fp not in seen_files:
                    seen_files[fp] = part
                    context_parts.append(part[:600])
            except Exception:
                pass

        elif func_match:
            func_name = func_match.group(1)
            for fp in candidate_files:
                if fp in seen_files:
                    continue
                snippet = _find_in_file(fp, f"def {func_name}")
                if snippet:
                    seen_files[fp] = snippet
                    context_parts.append(snippet[:500])
                    break

        elif "llm:" in key or "tool:" in key:
            # Kein präziser Kontext möglich, kurzen Fehlermeldungsauszug direkt nutzen
            short = msg[:200]
            if short and short not in "\n".join(context_parts):
                context_parts.append(f"# Fehlermeldung ({key}): {short}")

    combined = "\n\n".join(context_parts)
    return combined[:max_chars] if combined else ""

def _si_restore_patch(patch_id: str) -> Dict[str, Any]:
    """Alle durch einen Patch veränderten Dateien aus dem Fallback-Backup wiederherstellen."""
    backup_dir = _si_fallback_dir() / patch_id
    if not backup_dir.exists():
        return {"ok": False, "message": f"Kein Backup für Patch {patch_id} gefunden"}
    patch = _si_get_patch(patch_id)
    if not patch:
        return {"ok": False, "message": f"Patch {patch_id} nicht gefunden"}
    restored: List[str] = []
    errors: List[str] = []
    for change in patch.get("changes", []):
        file_path = str(change.get("file", ""))
        if not file_path:
            continue
        backup_file = backup_dir / Path(file_path).name
        if backup_file.exists():
            with contextlib.suppress(Exception):
                Path(file_path).write_bytes(backup_file.read_bytes())
                restored.append(file_path)
        elif change.get("type") == "create":
            target = Path(file_path)
            with contextlib.suppress(Exception):
                if target.exists():
                    target.unlink()
                    restored.append(f"Gelöscht (neu erstellt): {file_path}")
        else:
            errors.append(f"Kein Backup: {file_path}")
    patch["status"] = "restored"
    patch["restored_at"] = datetime.now().isoformat()
    _si_save_patch(patch)
    tool_store.log("self_improve_patch", f"restore {patch_id}: {len(restored)} Dateien wiederhergestellt")
    ok = len(errors) == 0
    msg = f"{len(restored)} Datei(en) wiederhergestellt" + (f"; Fehler: {', '.join(errors)}" if errors else "")
    return {"ok": ok, "message": msg, "restored": restored, "errors": errors}

def _si_apply_change(change: Dict[str, Any], patch_id: str) -> Dict[str, Any]:
    """Einzelne Änderung anwenden. Backup wird immer zuerst erstellt."""
    ctype = str(change.get("type", ""))
    file_path = str(change.get("file", ""))
    if not file_path:
        return {"ok": False, "message": "Kein Dateipfad angegeben"}
    target = _si_resolve_path(file_path)

    if ctype == "replace":
        search = str(change.get("search", "")).strip()
        replace = str(change.get("replace", ""))
        if not target.exists():
            return {"ok": False, "message": f"Datei nicht gefunden: {file_path}"}
        content = target.read_text(encoding="utf-8", errors="ignore")
        
        # 1. Exakter Match
        if search in content:
            new_content = content.replace(search, replace, 1)
        else:
            # 2. Fuzzy Match (zeilenweise, ignoriert Einrückung)
            content_lines = content.splitlines()
            search_lines = search.splitlines()
            
            def _norm(s): return s.strip()
            
            found_idx = -1
            for i in range(len(content_lines) - len(search_lines) + 1):
                match = True
                for j in range(len(search_lines)):
                    if _norm(content_lines[i+j]) != _norm(search_lines[j]):
                        match = False
                        break
                if match:
                    found_idx = i
                    break
            
            if found_idx != -1:
                # Wir ersetzen die Zeilen, behalten aber (falls möglich) die Einrückung der ersten Zeile
                indent = ""
                orig_first_line = content_lines[found_idx]
                m = re.match(r"^(\s*)", orig_first_line)
                if m: indent = m.group(1)
                
                new_lines = replace.splitlines()
                # Einrückung auf alle neuen Zeilen anwenden (einfache Heuristik)
                indented_replace = [indent + line if line.strip() else line for line in new_lines]
                
                content_lines[found_idx : found_idx + len(search_lines)] = indented_replace
                new_content = "\n".join(content_lines)
            else:
                return {"ok": False, "message": f"Suchtext nicht gefunden in {file_path} (auch nicht via Fuzzy-Search)"}

        # Syntax-Check vor dem Schreiben (nur .py)
        syn_err = _si_syntax_check_content(new_content, file_path)
        if syn_err:
            return {"ok": False, "message": f"Syntax-Fehler (Patch nicht angewendet): {syn_err}"}
        backup = _si_backup_file(file_path, patch_id)
        target.write_text(new_content, encoding="utf-8")
        return {"ok": True, "message": f"Ersetzt in {file_path} (Fuzzy OK)", "backup": backup}

    if ctype == "create":
        content = str(change.get("content", ""))
        if target.exists():
            return {"ok": False, "message": f"Datei existiert bereits: {file_path}. Nutze 'replace'."}
        # Syntax-Check vor dem Schreiben (nur .py)
        syn_err = _si_syntax_check_content(content, file_path)
        if syn_err:
            return {"ok": False, "message": f"Syntax-Fehler (Datei nicht erstellt): {syn_err}"}
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(content, encoding="utf-8")
        return {"ok": True, "message": f"Erstellt: {file_path}", "backup": ""}

    if ctype == "json_merge":
        data = change.get("data", {})
        if not isinstance(data, dict):
            return {"ok": False, "message": "'data' muss ein Objekt sein"}
        if target.exists():
            backup = _si_backup_file(file_path, patch_id)
            raw = target.read_bytes()
            enc = "utf-8-sig" if raw.startswith(b"\xef\xbb\xbf") else "utf-8"
            try:
                existing: Dict[str, Any] = json.loads(raw.decode(enc))
            except Exception:
                existing = {}
        else:
            backup = ""
            existing = {}

        def _deep_merge(base: Dict[str, Any], overlay: Dict[str, Any]) -> None:
            for k, v in overlay.items():
                if k in base and isinstance(base[k], dict) and isinstance(v, dict):
                    _deep_merge(base[k], v)
                else:
                    base[k] = v

        _deep_merge(existing, data)
        target.write_text(json.dumps(existing, ensure_ascii=False, indent=2), encoding="utf-8")
        return {"ok": True, "message": f"JSON gemergt: {file_path}", "backup": backup}

    if ctype == "append":
        content = str(change.get("content", ""))
        target.parent.mkdir(parents=True, exist_ok=True)
        backup = _si_backup_file(file_path, patch_id) if target.exists() else ""
        with target.open("a", encoding="utf-8") as fh:
            fh.write("\n" + content)
        return {"ok": True, "message": f"Angehängt: {file_path}", "backup": backup}

    return {"ok": False, "message": f"Unbekannter Änderungstyp: {ctype}"}

def _si_apply_patch(patch_id: str) -> Dict[str, Any]:
    patch = _si_get_patch(patch_id)
    if not patch:
        return {"ok": False, "message": f"Patch nicht gefunden: {patch_id}"}
    if patch.get("status") == "applied":
        return {"ok": False, "message": "Patch wurde bereits angewendet"}
    if patch.get("status") == "rejected":
        return {"ok": False, "message": "Patch wurde abgelehnt"}
    changes = patch.get("changes", [])
    if not changes:
        return {"ok": False, "message": "Patch enthält keine Änderungen"}
    results: List[Dict[str, Any]] = []
    all_ok = True
    for i, change in enumerate(changes):
        result = _si_apply_change(change, patch_id)
        results.append({"index": i, "file": change.get("file", ""), **result})
        if not result.get("ok"):
            all_ok = False
            break  # stop on first failure; vorherige Backups bleiben erhalten
    patch["status"] = "applied" if all_ok else "failed"
    patch["applied_at"] = datetime.now().isoformat()
    patch["apply_results"] = results
    # Post-Apply Syntax-Check aller geänderten .py-Dateien
    if all_ok:
        syntax_check: Dict[str, str] = {}
        for r in results:
            fp = str(r.get("file", ""))
            if fp.endswith(".py") and _si_resolve_path(fp).exists():
                content = _si_resolve_path(fp).read_text(encoding="utf-8", errors="ignore")
                err = _si_syntax_check_content(content, fp)
                syntax_check[fp] = err if err else "OK"
        if syntax_check:
            patch["syntax_check"] = syntax_check
            any_bad = any(v != "OK" for v in syntax_check.values())
            if any_bad:
                patch["status"] = "failed"
                all_ok = False
                tool_store.log("self_improve_patch", f"post-syntax-fail {patch_id}: {syntax_check}")
    _si_save_patch(patch)
    msg = f"{len(results)} Änderung(en) angewendet (Fallback: data/patch_fallback/{patch_id}/)" if all_ok else f"Fehlgeschlagen: {results[-1].get('message', '')}"
    tool_store.log("self_improve_patch", f"apply {patch_id} ok={all_ok} changes={len(results)}")
    return {"ok": all_ok, "message": msg, "results": results, "syntax_check": patch.get("syntax_check", {})}

def _si_reject_patch(patch_id: str) -> Dict[str, Any]:
    patch = _si_get_patch(patch_id)
    if not patch:
        return {"ok": False, "message": f"Patch nicht gefunden: {patch_id}"}
    patch["status"] = "rejected"
    patch["rejected_at"] = datetime.now().isoformat()
    _si_save_patch(patch)
    tool_store.log("self_improve_patch", f"reject {patch_id}")
    return {"ok": True, "message": "Patch abgelehnt"}

def _si_analyze_with_llm(signals: List[Dict[str, Any]], cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    """Fehlersignale per LLM analysieren und Patch-Vorschlag als JSON erzeugen."""
    if not signals:
        return None
    router = LLMRouter(cfg)
    sig_text = "\n".join(
        f"- {s['key']} (severity={s.get('severity',0)}, count={s.get('count',0)}): {str(s.get('last_message',''))[:300]}"
        for s in signals[:6]
    )
    # Code-Kontext aus betroffenen Dateien extrahieren
    code_ctx = _si_extract_code_context(signals)
    code_section = f"\nRELEVANTER CODE-KONTEXT:\n{code_ctx}\n" if code_ctx else ""
    # Echte Projektstruktur ermitteln – nur editierbare Dateien
    def _si_project_files() -> str:
        try:
            lines = []
            for p in sorted(ROOT_DIR.rglob("*")):
                if p.is_file() and p.suffix in {".py", ".json", ".ps1", ".md", ".txt", ".html"}:
                    rel = p.relative_to(ROOT_DIR).as_posix()
                    skip_dirs = {"__pycache__", ".venv", ".git", "patch_fallback", "node_modules"}
                    if not any(part in skip_dirs for part in p.parts):
                        lines.append(rel)
            return "\n".join(lines[:80])
        except Exception:
            return ""
    file_list = _si_project_files()
    file_section = f"\nVORHANDENE PROJEKTDATEIEN (nur diese Pfade dürfen verwendet werden):\n{file_list}\n" if file_list else ""
    prompt = (
        "Du bist ein Python-Backend-Debugger für das KAIA-Agent-System (FastAPI + ChromaDB).\n"
        "Analysiere folgende Fehlersignale und erstelle EINEN konkreten Patch-Vorschlag als JSON.\n\n"
        f"FEHLERSIGNALE:\n{sig_text}\n"
        f"{file_section}"
        f"{code_section}\n"
        "REGELN:\n"
        "- Antworte NUR mit einem JSON-Objekt (kein Markdown, keine Erklärungen davor/danach)\n"
        "- Nur Änderungen die du mit Sicherheit als korrekt beurteilen kannst\n"
        "- Bevorzuge kleine, chirurgische Änderungen (replace bevorzugt)\n"
        "- Bei replace: 'search' muss exakt so im Code stehen wie angegeben\n"
        "- 'file' MUSS aus der obigen Dateiliste stammen – keine erfundenen Pfade!\n"
        "- risk: low=config/neue Datei, medium=skill-Datei, high=core code (main.py etc.)\n\n"
        'JSON-FORMAT:\n'
        '{"title":"...","root_cause":"...","risk":"low|medium|high","signal_keys":["..."],'
        '"changes":[{"file":"rel/pfad.py","type":"replace","search":"alter text",'
        '"replace":"neuer text","description":"Was diese Änderung bewirkt"}]}\n\n'
        "change types: replace (suchen+ersetzen in Datei), create (neue Datei anlegen), "
        "json_merge (Felder in JSON-Config mergen), append (ans Dateiende anhängen)"
    )
    try:
        result = router.chat(prompt)
        text = str(result.text if hasattr(result, "text") else "")
        m = re.search(r"\{.*\}", text, re.DOTALL)
        if not m:
            return None
        proposal: Dict[str, Any] = json.loads(m.group(0))
        if not isinstance(proposal.get("changes"), list) or not proposal.get("title"):
            return None
        patch_id = _si_patch_id()
        patch: Dict[str, Any] = {
            "id": patch_id,
            "status": "proposed",
            "created_at": datetime.now().isoformat(),
            "applied_at": None,
            "rejected_at": None,
            "restored_at": None,
            "title": str(proposal.get("title", "Unbenannter Patch"))[:200],
            "root_cause": str(proposal.get("root_cause", ""))[:500],
            "risk": str(proposal.get("risk", "medium")),
            "signal_keys": proposal.get("signal_keys", []),
            "changes": proposal.get("changes", []),
        }
        _si_save_patch(patch)
        tool_store.log("self_improve_patch", f"proposed {patch_id}: {patch['title'][:80]}")
        return patch
    except Exception as exc:
        tool_store.log("self_improve_patch", f"analyze_error={exc}")
        return None

def _handle_self_improve_request(message: str, cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
