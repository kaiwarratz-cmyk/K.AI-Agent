def _save_session_to_disk(key: str) -> None:
    """Speichert Session auf Disk."""
    if not key or key not in _session_history:
        return
    try:
        _session_dir.mkdir(parents=True, exist_ok=True)
        # Sanitize key für Dateinamen (ersetze : und andere problematische Zeichen)
        safe_key = key.replace(":", "_").replace("/", "_").replace("\\", "_")
        session_file = _session_dir / f"{safe_key}.json"
        
        with _session_lock:
            history_list = list(_session_history[key])
        
        data = {
            "dialog_key": key,
            "updated_at": datetime.now().isoformat(),
            "history": history_list
        }
        session_file.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")
    except Exception as e:
        print(f"[WARN] Session-Save fehlgeschlagen für {key}: {e}")


def _load_session_from_disk(key: str) -> None:
    """Lädt Session von Disk."""
    if not key:
        return
    try:
        safe_key = key.replace(":", "_").replace("/", "_").replace("\\", "_")
        session_file = _session_dir / f"{safe_key}.json"
        
        if not session_file.exists():
            return
        
        data = json.loads(session_file.read_text(encoding="utf-8"))
        history_list = data.get("history", [])
        
        if history_list:
            with _session_lock:
                # Konsistent mit _update_session_history (20 turns * 2)
                max_items = 40
                _session_history[key] = deque(history_list, maxlen=max_items)
            print(f"[INFO] Session geladen für {key}: {len(history_list)} Nachrichten")
    except Exception as e:
        print(f"[WARN] Session-Load fehlgeschlagen für {key}: {e}")


