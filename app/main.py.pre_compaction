@app.post("/api/config/llm")
def set_llm(payload: LLMConfigRequest) -> Dict[str, Any]:
    cfg = _cfg()
    providers = cfg.get("providers", {})
    if payload.provider_id not in providers:
        raise HTTPException(status_code=400, detail="Provider nicht konfiguriert")
    provider_cfg = providers.get(payload.provider_id, {}) if isinstance(providers.get(payload.provider_id, {}), dict) else {}
    if not _provider_enabled(provider_cfg):
        raise HTTPException(status_code=400, detail="Provider ist deaktiviert.")
    if _provider_requires_api_key(provider_cfg) and not str(provider_cfg.get("api_key", "") or "").strip():
        raise HTTPException(status_code=400, detail="Fuer diesen Provider ist kein API-Key hinterlegt (Setup/API Keys).")
    allowed_models = provider_cfg.get("models", []) if isinstance(provider_cfg.get("models", []), list) else []
    allowed_model_names = [str(m).strip() for m in allowed_models if str(m).strip()]
    if allowed_model_names and str(payload.model).strip() not in allowed_model_names:
        raise HTTPException(status_code=400, detail="Modell ist fuer diesen Provider nicht in config.json freigeschaltet.")
    cfg.setdefault("llm", {})
    cfg["llm"]["active_provider_id"] = payload.provider_id
    cfg["llm"]["active_model"] = payload.model
    if payload.temperature is not None:
        t = float(payload.temperature)
        if t < 0.0 or t > 2.0:
            raise HTTPException(status_code=400, detail="temperature muss zwischen 0.0 und 2.0 liegen")
        cfg["llm"]["temperature"] = t
    # Keep provider default model in sync with active selection to avoid
    # split-brain config state between llm.active_model and providers.*.default_model.
    cfg.setdefault("providers", {})
    if isinstance(cfg["providers"].get(payload.provider_id, {}), dict):
        cfg["providers"][payload.provider_id]["default_model"] = payload.model
        models = cfg["providers"][payload.provider_id].get("models", [])
        if not isinstance(models, list):
            models = []
        model_names = [str(m).strip() for m in models if str(m).strip()]
        if payload.model not in model_names:
            model_names.append(payload.model)
        cfg["providers"][payload.provider_id]["models"] = model_names
    save_config(cfg)
    tool_store.log(
        "config",
        f"LLM gesetzt: {payload.provider_id}/{payload.model} (temp={cfg.get('llm', {}).get('temperature', 0.2)})",
    )
    return {"ok": True}

@app.post("/api/config/provider")
def set_provider_config(payload: ProviderConfigRequest) -> Dict[str, Any]:
    cfg = _cfg()
    pid = str(payload.provider_id or "").strip()
    if not pid:
        raise HTTPException(status_code=400, detail="provider_id fehlt")
    providers = cfg.setdefault("providers", {})
    provider_cfg = providers.get(pid)
    if not isinstance(provider_cfg, dict):
        defaults = _default_provider_cfg(pid)
        if not isinstance(defaults, dict):
            raise HTTPException(status_code=400, detail="Provider nicht konfiguriert")
        provider_cfg = defaults

    if pid.lower() == "ollama":
        provider_cfg["api_key_required"] = False

    if payload.base_url is not None:
        base_url = str(payload.base_url or "").strip()
        if pid.lower() == "ollama":
            base_url = _normalize_ollama_base_url(base_url)
        if base_url:
            provider_cfg["base_url"] = base_url
    if payload.enabled is not None:
        provider_cfg["enabled"] = bool(payload.enabled)

    providers[pid] = provider_cfg

    if payload.enabled is False:
        llm = cfg.setdefault("llm", {})
        active_pid = str(llm.get("active_provider_id", "")).strip()
        if active_pid == pid:
            fallback = _pick_first_enabled_provider(cfg, exclude={pid})
            if fallback:
                llm["active_provider_id"] = fallback[0]
                llm["active_model"] = fallback[1]
            else:
                llm["active_provider_id"] = ""

    save_config(cfg)
    tool_store.log("config", f"Provider gesetzt: {pid} enabled={bool(provider_cfg.get('enabled', True))}")
    return {
        "ok": True,
        "provider_id": pid,
        "enabled": bool(provider_cfg.get("enabled", True)),
        "base_url": str(provider_cfg.get("base_url", "") or ""),
    }

@app.post("/api/config/security")
def set_security(payload: SecurityConfigRequest) -> Dict[str, Any]:
    cfg = _cfg()
    cfg.setdefault("security", {})
    
    # Vorhandene Werte laden oder Standard setzen
    role = cfg["security"].get("active_role", "user")
    mode = cfg["security"].get("execution_mode", "deny")

    if payload.active_role is not None:
        role = payload.active_role.strip().lower()
        if role not in {"user", "admin"}:
            raise HTTPException(status_code=400, detail="active_role muss user oder admin sein")
        cfg["security"]["active_role"] = role
        
    if payload.execution_mode is not None:
        mode = payload.execution_mode.strip().lower()
        if mode not in {"deny", "unrestricted"}:
            mode = "unrestricted"
        cfg["security"]["execution_mode"] = mode
    
    # Script Timeout
    if payload.script_timeout is not None:
        timeout = max(60, min(1800, int(payload.script_timeout)))
        cfg["security"]["script_timeout"] = timeout

    # Messenger reply timeout (reply_timeout_sec)
    if payload.reply_timeout_sec is not None:
        try:
            mt = max(60, min(3600, int(payload.reply_timeout_sec)))
        except Exception:
            mt = 600
        cfg.setdefault("messenger", {})
        cfg["messenger"]["reply_timeout_sec"] = mt
    
    save_config(cfg)
    tool_store.log("config", f"Security gesetzt: role={role}, mode={mode}, timeout={cfg['security'].get('script_timeout', 180)}")
    return {"ok": True}

