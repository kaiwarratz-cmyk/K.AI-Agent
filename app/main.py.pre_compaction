def _last_json_blob(raw: str) -> Optional[Dict[str, Any]]:
    if not raw:
        return None
    chunks = [c.strip() for c in raw.split("\n---\n") if c.strip()]
    for chunk in reversed(chunks):
        try:
            obj = json.loads(chunk)
            if isinstance(obj, dict):
                return obj
        except Exception:
            with contextlib.suppress(Exception):
                obj2 = ast.literal_eval(chunk)
                if isinstance(obj2, dict):
                    return obj2
            continue
    return None

def _find_relevant_script_memory(cfg: Dict[str, Any], message: str) -> Optional[Dict[str, Any]]:
    lower = message.lower()
    if not _has_any(lower, ["script", "skript", ".py", ".ps1", "python", "powershell"]):
        return None
    items = _memory_store(cfg).search_by_kind(kind="script", limit=40)
    if not items:
        return None

    parsed: list[Dict[str, Any]] = []
    active_role = str(cfg.get("security", {}).get("active_role", "user")).lower()
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not blob:
            continue
        created_by = str(blob.get("created_by_role", "user")).lower()
        if active_role == "user" and created_by == "admin":
            continue
        parsed.append(blob)
    if not parsed:
        return None

    for blob in parsed:
        name = str(blob.get("name", "")).lower()
        path = str(blob.get("path", "")).lower()
        if name and name in lower:
            return blob
        if path and path in lower:
            return blob

    if _has_any(lower, ["letzte", "zuletzt", "last script", "vorhin", "gerade"]):
        return parsed[0]
    return parsed[0]

def _find_script_memory_by_path(cfg: Dict[str, Any], script_path: str) -> Optional[Dict[str, Any]]:
    want = str(script_path or "").strip().lower()
    if not want:
        return None
    items = _memory_store(cfg).search_by_kind(kind="script", limit=60)  # 120 → 60
    active_role = str(cfg.get("security", {}).get("active_role", "user")).lower()
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not isinstance(blob, dict):
            continue
        created_by = str(blob.get("created_by_role", "user")).lower()
        if active_role == "user" and created_by == "admin":
            continue
        p = str(blob.get("path", "")).strip().lower()
        if p and p == want:
            return blob
    return None

def _recover_pending_from_recent_script_context(cfg: Dict[str, Any]) -> bool:
    return False

def _inject_script_context(cfg: Dict[str, Any], message: str) -> str:
    parts = [message]
    
    # Always provide a brief summary of the last 5 scripts to make the LLM aware of its capabilities
    items = _memory_store(cfg).search_by_kind(kind="script", limit=10)
    recent_scripts = []
    active_role = str(cfg.get("security", {}).get("active_role", "user")).lower()
    for item in items:
        b = _last_json_blob(str(item.get("content", "")))
        if not b:
            continue
        if active_role == "user" and str(b.get("created_by_role", "user")).lower() == "admin":
            continue
        p = str(b.get("path", ""))
        req = str(b.get("request_text", ""))
        if p and req and p not in [x[0] for x in recent_scripts]:
            recent_scripts.append((p, req))
            if len(recent_scripts) >= 5:
                break
                
    if recent_scripts:
        lines = ["\nBekannte, verfuegbare Scripts (kannst du via script_exec ausfuehren):"]
        for p, r in recent_scripts:
            lines.append(f"- {p} (Zweck: {r})")
        parts.append("\n".join(lines))

    # Detailed context if explicitly requested
    blob = _find_relevant_script_memory(cfg, message)
    if blob:
        path = str(blob.get("path", ""))
        language = str(blob.get("language", ""))
        code = str(blob.get("code", ""))[:2000]
        if code:
            parts.append(
                f"\nKontext aus gespeichertem Script:\npath: {path}\nlanguage: {language}\ncode:\n{code}"
            )
            
    return "\n".join(parts)

def _build_llm_message(cfg: Dict[str, Any], message: str, turns: int = 20) -> str:
    """Build LLM message with Context Manager and Semantic Recall."""
    # Build base context via new context manager
    try:
        from app.context_manager import build_context
        from app.task_state import get_task_state_manager
        dk = str(_dialog_key_ctx.get("") or "").strip()
        _tsm = get_task_state_manager()
        _ts = _tsm.get_state(dk) if dk else None
        with _session_lock:
            _hist_for_ctx = list(_session_history.get(dk, deque())) if dk else []
        llm_message = build_context(message, dk or "default", _hist_for_ctx, _ts)
        llm_message = _inject_script_context(cfg, llm_message)
        llm_message = _with_persona_prompt(llm_message, include_agent_rules=True)
        return llm_message
    except Exception as e:
        print(f"[DEBUG] Context Manager Fehler: {e}")
        tool_store.log("context_error", f"Fallback zu semantischem Recall: {e}")

    # Fallback: Semantische Suche in ChromaDB (Manuell)
    semantic_parts = []
    try:
        print(f"[DEBUG] Starte manuellen Chroma-Recall für: {message[:30]}...")
        from app.chroma_memory import ChromaMemoryStore
        ms = ChromaMemoryStore(cfg)
        facts = ms.search(message, limit=3, collection_name="important", min_similarity=0.65)
        facts = [f for f in facts if "improvement_signal" not in str(f.get('text', ''))]
        if facts:
            print(f"[DEBUG] {len(facts)} Fakten gefunden.")
            semantic_parts.append("\n[ERINNERUNG AN NUTZERFAKTEN]:")
            for f in facts: semantic_parts.append(f"- {f.get('text', '')}")
        workflows = ms.search(message, limit=2, collection_name="workflow_success", min_similarity=0.65)
        if workflows:
            print(f"[DEBUG] {len(workflows)} Workflows gefunden.")
            semantic_parts.append("\n[ERINNERUNG AN ERFOLGREICHE AUFGABEN]:")
            for w in workflows: semantic_parts.append(f"- {w.get('text', '')}")
    except Exception as e:
        print(f"[DEBUG] Manueller Recall Fehler: {e}")

    # Legacy context building + Semantic Mix
    llm_message = _inject_conversation_context(cfg, message, turns=turns)
    if semantic_parts:
        llm_message += "\n" + "\n".join(semantic_parts)
        
    llm_message = _inject_script_context(cfg, llm_message)
    llm_message = _inject_structured_entity_context(llm_message)
    llm_message = _enrich_short_followup(cfg, llm_message, message)
    llm_message = _with_persona_prompt(llm_message, include_agent_rules=True)
    return llm_message

def _enrich_short_followup(cfg: Dict[str, Any], llm_message: str, original_message: str) -> str:
    """
    Reichert ALLE kurzen Nachrichten (≤6 Wörter) mit der letzten Assistant-Nachricht an.
    Keine Pattern-Matching - das LLM entscheidet selbst, ob der Kontext relevant ist.
    """
    word_count = len(original_message.strip().split())
    
    # Nur bei sehr kurzen Nachrichten Kontext hinzufügen
    if word_count > 6:
        return llm_message
    
    # Hole die letzte Assistant-Nachricht aus der Session
    dk = str(_dialog_key_ctx.get("") or "").strip()
    if not dk:
        return llm_message
    
    with _session_lock:
        hist = list(_session_history.get(dk, deque()))
    
    if not hist:
        return llm_message
    
    # Finde die letzte Assistant-Nachricht
    last_assistant_msg = ""
    for item in reversed(hist):
        if str(item.get("role", "")).lower() == "assistant":
            last_assistant_msg = str(item.get("text", "")).strip()
            break
    
    if not last_assistant_msg:
        return llm_message
    
    # Füge die letzte Assistant-Nachricht als Kontext hinzu (gekürzt auf 400 Zeichen)
    last_msg_preview = last_assistant_msg[:400] + "..." if len(last_assistant_msg) > 400 else last_assistant_msg
    
    enrichment = (
        f"\n\n[LETZTE ASSISTANT-NACHRICHT]: \"{last_msg_preview}\"\n"
        f"[AKTUELLE NUTZER-NACHRICHT]: \"{original_message}\"\n"
        f"Hinweis: Dies ist eine kurze Nachricht. Falls sie sich auf die obige Assistant-Nachricht bezieht, nutze diesen Kontext."
    )
    
    return llm_message + enrichment

def _is_information_query(message: str) -> bool:
    lower = message.strip().lower()
    if not lower:
        return False
    if _is_explicit_web_query(lower):
        return True
    if _needs_factual_web_verification(lower):
        return True
    if "?" in lower:
        return True
    starters = (
        "wer ",
        "was ",
        "wann ",
        "wo ",
        "warum ",
        "wieso ",
        "wie ",
        "which ",
        "what ",
        "when ",
        "where ",
        "why ",
        "how ",
    )
    return lower.startswith(starters)


def _is_explicit_web_query(message: str) -> bool:
    lower = str(message or "").strip().lower()
    if not lower:
        return False
    if "http://" in lower or "https://" in lower:
        return True
    has_web_marker = _has_any(
        lower,
        [
            "internet",
            "im web",
            "websuche",
            "online",
            "google",
            "duckduckgo",
            "wikipedia",
            "news",
            "nachrichten",
            "recherchiere",
            "recherche",
        ],
    )
    if not has_web_marker:
        return False
    has_query_intent = _has_any(
        lower,
        [
            "suche",
            "finde",
            "search",
            "look up",
            "lookup",
            "infos",
            "informationen",
            "aktuell",
            "latest",
        ],
    )
    return has_query_intent

def _should_enforce_tool_binding(message: str, interpretation: Optional[Dict[str, Any]]) -> bool:
    if not isinstance(interpretation, dict):
        return False
    intent = str(interpretation.get("intent", "") or "").strip().lower()
    try:
        conf = float(interpretation.get("confidence", 0.0) or 0.0)
    except Exception:
        conf = 0.0
    if conf < 0.62:
        return False
    if intent not in {"filesystem", "script", "cron"}:
        return False
    text = str(message or "").strip()
    lower = text.lower()
    entities = interpretation.get("entities", {}) if isinstance(interpretation.get("entities", {}), dict) else {}
    if (
        _is_help_command(text)
        or _is_clear_conversation_command(text)
        or _is_memory_show_command(text)
        or _is_memory_delete_command(text)
        or _is_cron_jobs_command(text)
    ):
        return False
    if _is_internal_memory_query(text) or bool(re.search(r"\bmerke\s+dir\b", lower)):
        return False
    ent_path = str(entities.get("path", "") or "").strip()
    if intent == "filesystem":
        has_path = bool(_extract_any_path(text) or ent_path)
        has_fs_words = _has_any(lower, ["datei", "dateien", "ordner", "verzeichnis", "pfad", "laufwerk", "freigabe"])
        has_fs_verb = bool(re.search(r"\b(zeige|zeig|liste|list|lies|lese|schreibe|write|kopier|copy|verschieb|move|loesch|lösch|delete|count|anzahl|wie viele)\b", lower))
        return bool(has_path or (has_fs_words and has_fs_verb))
    if intent == "script":
        return _has_any(lower, ["script", "skript", "python", "powershell", "pwsh", "screenshot", "automatis"])
    if intent == "cron":
        has_cron_time = _has_any(lower, ["minute", "minuten", "stunden", "uhr", "hour", "hours", "morgen", "today", "tomorrow"])
        has_cron_verb = _has_any(lower, ["erinnere", "remind", "cron", "schedule", "alle ", "every ", "jede "])
        return bool(has_cron_time and has_cron_verb)
    return False

def _is_internal_memory_query(message: str) -> bool:
    lower = message.strip().lower()
    if not lower:
        return False
    patterns = [
        r"(was\s+(wei[sß]t|weisst|wei.t|merkst)\s+du\s+(ueber|über|u.ber|.ber)\s+mich)",
        r"(hast\s+du\s+dir\s+.*gemerkt)",
        r"(was\s+hast\s+du\s+dir\s+gemerkt)",
        r"(was\s+hatten\s+wir\s+zu\s+)",
        r"(woran\s+erinnerst\s+du\s+dich)",
        r"(remember\s+what\s+we\s+said)",
        r"(what\s+did\s+we\s+decide)",
    ]
    return any(re.search(p, lower, flags=re.IGNORECASE) for p in patterns)

def _is_source_provenance_query(message: str) -> bool:
    lower = str(message or "").strip().lower()
    if not lower:
