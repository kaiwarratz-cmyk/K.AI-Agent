@app.post("/api/messenger/telegram/flush-backlog")
def api_telegram_flush_backlog() -> Dict[str, Any]:
    cfg = _cfg()
    msg_cfg = cfg.get("messenger", {}) if isinstance(cfg.get("messenger", {}), dict) else {}
    tg_cfg = msg_cfg.get("telegram", {}) if isinstance(msg_cfg.get("telegram", {}), dict) else {}
    token = str(tg_cfg.get("token", "") or "").strip()
    if not token:
        return {"ok": False, "message": "Telegram Token fehlt."}

    ws = _workspace_abs(cfg)
    ws.mkdir(parents=True, exist_ok=True)
    offset_path = ws / ".tg_offset"
    old_offset = 0
    try:
        if offset_path.exists():
            old_offset = int(str(offset_path.read_text(encoding="utf-8") or "0").strip() or "0")
    except Exception:
        old_offset = 0

    latest_update_id: Optional[int] = None
    updates_count = 0
    try:
        with httpx.Client(timeout=20, trust_env=False) as client:
            res = client.get(
                f"https://api.telegram.org/bot{token}/getUpdates",
                params={"timeout": 0, "limit": 100, "allowed_updates": ["message"]},
            )
            res.raise_for_status()
            body = res.json() if isinstance(res.json(), dict) else {}
    except Exception as exc:
        return {"ok": False, "message": f"Telegram API Fehler: {exc}"}

    if not bool(body.get("ok", False)):
        return {"ok": False, "message": f"Telegram API meldet Fehler: {str(body)[:300]}"}

    updates = body.get("result", []) if isinstance(body.get("result", []), list) else []
    updates_count = len(updates)
    for upd in updates:
        try:
            uid = int(upd.get("update_id", 0))
        except Exception:
            uid = 0
        if uid > 0 and (latest_update_id is None or uid > latest_update_id):
            latest_update_id = uid

    new_offset = old_offset
    if isinstance(latest_update_id, int):
        new_offset = max(old_offset, latest_update_id + 1)

    try:
        offset_path.write_text(str(new_offset), encoding="utf-8")
    except Exception as exc:
        return {"ok": False, "message": f"Offset konnte nicht geschrieben werden: {exc}"}

    skipped_updates = max(0, new_offset - old_offset)
    tool_store.log(
        "telegram_flush_backlog",
        f"old_offset={old_offset} new_offset={new_offset} latest_update_id={latest_update_id} updates_seen={updates_count}",
    )
    return {
        "ok": True,
        "message": "Telegram Backlog verworfen.",
        "offset_path": str(offset_path),
        "old_offset": old_offset,
        "new_offset": new_offset,
        "latest_update_id": latest_update_id,
        "updates_seen": updates_count,
        "skipped_updates": skipped_updates,
    }

