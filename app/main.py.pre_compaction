                "domain": str(item.get("domain", "") or ""),
                "query": str(query or "")[:220],
                "provider": "duckduckgo_html",
                "created_at": ts,
            }
        )

def _query_terms(text: str) -> list[str]:
    terms = re.findall(r"[a-zA-Z0-9äöüÄÖÜß]{3,}", text.lower())
    stop = {
        "und",
        "oder",
        "aber",
        "nicht",
        "mehr",
        "noch",
        "bitte",
        "kannst",
        "kann",
        "man",
        "macht",
        "machen",
        "wie",
        "was",
        "wann",
        "warum",
        "wieso",
        "wo",
        "können",
        "ich",
        "mich",
        "mir",
        "mein",
        "meine",
        "meinen",
        "du",
        "dein",
        "deine",
        "habe",
        "hast",
        "eine",
        "einer",
        "eines",
        "dieser",
