class MCPRegistryDownloadRequest(BaseModel):
    detail: str
    name: Optional[str] = None


@app.post("/api/mcp/registry/download")
def api_mcp_registry_download(payload: MCPRegistryDownloadRequest) -> Dict[str, Any]:
    import re
    import os
    import pathlib
    import httpx

    detail = str(payload.detail or "").strip()
    name = str(payload.name or "").strip() or "download"
    if not detail or not detail.startswith("http"):
        return {"ok": False, "message": "Keine gueltige URL uebergeben."}
    downloads_dir = os.path.join(os.path.dirname(__file__), "..", "data", "mcp_registry_downloads")
    downloads_dir = os.path.abspath(downloads_dir)
    os.makedirs(downloads_dir, exist_ok=True)

    # If GitHub URL, try to download zip from main/master branch
    try:
        zip_urls = []
        if "github.com" in detail:
            # extract owner/repo
            m = re.search(r"github.com/([^/]+/[^/]+)", detail)
            if m:
                owner_repo = m.group(1).rstrip("/")
                zip_urls.append(f"https://github.com/{owner_repo}/archive/refs/heads/main.zip")
                zip_urls.append(f"https://github.com/{owner_repo}/archive/refs/heads/master.zip")
                zip_urls.append(f"https://api.github.com/repos/{owner_repo}/zipball/main")
        # fallback: try the detail URL itself
        zip_urls.append(detail)

        saved_path = None
        for url in zip_urls:
            try:
                with httpx.Client(timeout=30.0) as client:
                    r = client.get(url)
                    if r.status_code == 200 and r.content:
                        safe_name = re.sub(r"[^A-Za-z0-9_.-]", "_", name)
                        filename = f"{safe_name}.zip"
                        target = os.path.join(downloads_dir, filename)
                        with open(target, "wb") as fh:
                            fh.write(r.content)
                        saved_path = target
                        break
            except Exception:
                continue
        if not saved_path:
            return {"ok": False, "message": "Download nicht moeglich (keine zip gefunden)."}
        return {"ok": True, "message": f"Heruntergeladen: {saved_path}", "path": saved_path}
    except Exception as exc:
        return {"ok": False, "message": str(exc)}

