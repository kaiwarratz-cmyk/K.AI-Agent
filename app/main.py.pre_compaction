def _register_subprocess(trace_id: str, proc: subprocess.Popen) -> None:
    """Registriert einen Subprocess für späteres Killing bei Cancellation."""
    if not trace_id or not proc:
        return
    with _subprocess_registry_lock:
        if trace_id not in _subprocess_registry:
            _subprocess_registry[trace_id] = []
        _subprocess_registry[trace_id].append(proc)

def _kill_all_subprocesses(trace_id: str) -> None:
    """Killt alle Child-Prozesse des K.AI-Prozesses (radikal aber effektiv)."""
    try:
        # Hole den aktuellen Prozess
        current_proc = psutil.Process(os.getpid())
        # Hole alle Child-Prozesse
        children = current_proc.children(recursive=True)

        for child in children:
            try:
                if child.is_running():
                    child.terminate()
                    try:
                        child.wait(timeout=2)
                    except psutil.TimeoutExpired:
                        child.kill()  # Erzwinge Beendigung
                    tool_store.log("subprocess_killed", f"PID {child.pid} terminated")
            except Exception as e:
                tool_store.log("subprocess_kill_error", f"Fehler beim Killen von PID {child.pid}: {e}")
    except Exception as e:
        tool_store.log("subprocess_kill_system_error", f"Critical error in _kill_all_subprocesses: {e}")

    # Cleanup registrierte Prozesse (falls vorhanden)
    with _subprocess_registry_lock:
        _subprocess_registry.pop(trace_id, None)

def _cleanup_subprocesses(trace_id: str) -> None:
    """Cleanup nach Job-Abschluss."""
    with _subprocess_registry_lock:
        _subprocess_registry.pop(trace_id, None)
    # Persistente Python-Session des Jobs beenden
    with contextlib.suppress(Exception):
        from app.tools import python_exec as _py_mod
        _py_mod.cleanup_session(trace_id)

def _heal_unc_path(path: str) -> str:
    """Heilt UNC-Pfade: /Medianas/... → \\\\Medianas\\... und /Medianas\\... → \\\\Medianas\\..."""
    if not path:
        return path
    path = str(path).strip()
    # Normalisiere Forward-Slashes zu Backslashes zuerst (//server → \\server)
    path = path.replace("/", "\\")
    # LLM over-escaping: \\\\\\\\server\\ → \\server (>2 führende Backslashes → exakt 2)
    import re as _re
    if _re.match(r"^\\{3,}", path):
        path = "\\\\" + path.lstrip("\\")
    elif path.startswith("\\") and not path.startswith("\\\\"):
        # Single leading backslash → kein UNC, bleibt unverändert (Windows root-relative)
        pass
    return path

def _register_file(trace_id: str, path: str, description: str = "") -> None:
    """Registriert eine erstellte/modifizierte Datei für den Job.

    🚨 AUTOMATISCH: Schreibt Datei-Notiz auch in den Plan!
    """
    if not trace_id or not path:
        return
    import time
    from datetime import datetime

    with _file_registry_lock:
        if trace_id not in _file_registry:
            _file_registry[trace_id] = []
        ts = time.time()
        _file_registry[trace_id].append((str(path), ts, str(description)))

    # 🚨 AUTOMATISCH: Notiere die Datei AGGRESSIV im Plan
    # Das LLM MUSS diese sehen und nutzen!
    try:
        from app.context_manager import ContextManager
        ctx_mgr = ContextManager()
        timestamp = datetime.fromtimestamp(ts).strftime("%H:%M:%S")
        plan_entry = (
            f"\n🚨🚨🚨 DATEI ERSTELLT - DU MUSST DIESE JETZT NUTZEN! 🚨🚨🚨\n"
            f"Timestamp: [{timestamp}]\n"
            f"📁 **PFAD**: `{path}`\n"
            f"📝 **INHALT**: {description}\n"
            f"⚡ **ACTION**: Öffne diese Datei SOFORT mit open() oder sys_python_exec!\n"
            f"           Oder versende mit send_messenger_file wenn Nutzer eine Datei brauchte!\n"
            f"🚨🚨🚨\n"
        )
        ctx_mgr.update_plan(plan_entry)
    except Exception as e:
        tool_store.log("file_registry_plan_error", f"Konnte Datei nicht im Plan notieren: {e}")

def _get_registered_files(trace_id: str) -> List[str]:
    """Gibt alle registrierten Dateien für diesen Job zurück."""
    if not trace_id:
        return []
    with _file_registry_lock:
        files = _file_registry.get(trace_id, [])
        return [f[0] for f in files]

def _get_file_registry_text(trace_id: str) -> str:
    """Gibt eine formatierte Liste aller Dateien für das LLM zurück."""
    if not trace_id:
        return "(keine Dateien)"
    with _file_registry_lock:
        files = _file_registry.get(trace_id, [])
    if not files:
        return "(noch keine Dateien erstellt)"
    text = "Erstellte Dateien in diesem Job:\n"
    for path, ts, desc in sorted(files, key=lambda x: x[1]):
        desc_str = f" - {desc}" if desc else ""
        text += f"  • {path}{desc_str}\n"
    return text

def _cleanup_file_registry(trace_id: str) -> None:
    """Cleanup nach Job-Abschluss."""
    with _file_registry_lock:
        _file_registry.pop(trace_id, None)
