def _skill_matches_for_text(message: str) -> List[Dict[str, Any]]:
    low = str(message or "").strip().lower()
    if not low:
        return []
    reg = _skills_snapshot()
    out: List[Dict[str, Any]] = []
    skills = reg.get("skills", []) if isinstance(reg.get("skills", []), list) else []
    for s in skills:
        if not isinstance(s, dict):
            continue
        sid = str(s.get("id", "") or "").strip()
        sname = str(s.get("name", sid) or sid).strip()
        if not sid:
            continue
        sid_low = sid.lower()
        sname_low = sname.lower()
        tools = s.get("tools", []) if isinstance(s.get("tools", []), list) else []
        tool_hits: List[Dict[str, Any]] = []
        for t in tools:
            if not isinstance(t, dict):
                continue
            tid = str(t.get("id", "") or "").strip()
            kind = str(t.get("kind", "") or "").strip()
            if not tid or not kind:
                continue
            if (tid.lower() in low) or (kind.lower() in low):
                tool_hits.append({"id": tid, "kind": kind})
        skill_hit = (sid_low in low) or (sname_low and sname_low in low) or (f"{sid_low}skill" in low)
        if skill_hit or tool_hits:
            out.append(
                {
                    "skill_id": sid,
                    "skill_name": sname,
                    "enabled": bool(s.get("enabled", False)),
                    "tool_hits": tool_hits,
                    "tools": tools,
                }
            )
    return out

def _skill_param_names_for_kind(kind: str) -> tuple[List[str], List[str]]:
    spec = _action_schemas().get(str(kind or "").strip(), {})
    req = spec.get("required", {}) if isinstance(spec.get("required", {}), dict) else {}
    opt = spec.get("optional", {}) if isinstance(spec.get("optional", {}), dict) else {}
    req_names = [str(k) for k in req.keys() if str(k).strip()]
    opt_names = [str(k) for k in opt.keys() if str(k).strip()]
    return req_names, opt_names

def _skill_cron_clarification_message(message: str, action: Dict[str, Any]) -> Optional[str]:
    # If LLM already provided a structured nested action, no clarification needed
    if isinstance(action.get("action"), dict) and action.get("action"):
        return None
    low = str(message or "").strip().lower()
    asks_cron = _has_any(low, ["alle ", "every ", "cron", "minute", "minuten", "stunden", "hour", "hours", "uhr"])
    asks_exec = _has_any(low, ["skill", "ausfuehr", "ausführ", "fuehre", "führe", "nutze", "verwende", "run", "execute"])
    if not (asks_cron and asks_exec):
        return None
    hits = _skill_matches_for_text(message)
    if not hits:
        return None
    hit = hits[0]
    sid = str(hit.get("skill_id", "") or "").strip()
    sname = str(hit.get("skill_name", sid) or sid).strip()
    enabled = bool(hit.get("enabled", False))
    tool_hits = hit.get("tool_hits", []) if isinstance(hit.get("tool_hits", []), list) else []
    tools = hit.get("tools", []) if isinstance(hit.get("tools", []), list) else []
    if not enabled:
        missing = _skill_missing_required_secrets(_cfg(), sid)
        if missing:
            return (
                f"Skill `{sid}` ist aktuell nicht aktivierbar. Fehlende Pflicht-Secrets: {', '.join(missing)}. "
                f"Setze zuerst die Secrets (WebUI: Skills -> Secret setzen) und aktiviere dann den Skill."
            )
        return f"Skill `{sid}` ({sname}) ist aktuell deaktiviert. Bitte zuerst aktivieren (`/skill enable {sid}`)."
    if not tool_hits:
        lines = [f"Fuer Skill `{sid}` brauche ich das konkrete Tool und die Pflichtparameter."]
        if tools:
            lines.append("Verfuegbare Tools:")
            for t in tools[:6]:
                if not isinstance(t, dict):
                    continue
                tid = str(t.get("id", "") or "").strip()
                kind = str(t.get("kind", "") or "").strip()
                req, opt = _skill_param_names_for_kind(kind)
                req_txt = ", ".join(req) if req else "-"
                opt_txt = ", ".join(opt) if opt else "-"
                lines.append(f"- {tid} (kind={kind}) | required: {req_txt} | optional: {opt_txt}")
        lines.append("Beispiel: Erstelle einen Cronjob alle 5 Minuten und nutze gmail_list_messages mit query=\"is:unread\" max_results=5.")
        return "\n".join(lines)
    sel = tool_hits[0]
    kind = str(sel.get("kind", "") or "").strip()
    tid = str(sel.get("id", "") or kind).strip()
    req, opt = _skill_param_names_for_kind(kind)
    nested = action.get("action", {}) if isinstance(action.get("action", {}), dict) else {}
    missing_req = [p for p in req if (p not in nested) or (isinstance(nested.get(p), str) and not str(nested.get(p)).strip())]
    if missing_req:
        req_txt = ", ".join(req) if req else "-"
        opt_txt = ", ".join(opt) if opt else "-"
        return (
            f"Fuer `{tid}` fehlen Pflichtparameter: {', '.join(missing_req)}.\n"
            f"required: {req_txt}\n"
            f"optional: {opt_txt}\n"
            f"Beispiel: Erstelle einen Cronjob alle 5 Minuten und nutze {tid} mit "
            + " ".join([f"{p}=..." for p in req[:4]])
            + "."
        )
    return None

