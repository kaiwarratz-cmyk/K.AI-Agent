            if step == "self_improve":
                save_status = _handle_last_save_status_query(message, cfg)
                if save_status:
                    return _ret(save_status, "save_status_followup")

            if step == "self_improve":
                self_improve_result = _handle_self_improve_request(message, cfg)
                if self_improve_result:
