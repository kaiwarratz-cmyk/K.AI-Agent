def _execute_action(action: Dict[str, Any]) -> tuple[str, str]:
    cfg = _cfg()
    dialog_key = str(_dialog_key_ctx.get("") or "").strip()
    msg_platform = str(_messenger_platform_ctx.get("") or "").strip()
    src = f"messenger:{msg_platform}" if msg_platform else ("webui" if dialog_key == "webui" else "")

    # send_messenger_file braucht dialog_key — hier behandeln bevor Execution Plane
    if str(action.get("kind", "")).strip() == "send_messenger_file":
        file_path = str(action.get("path", action.get("file_path", "")))
        caption = str(action.get("caption", "") or "")
        reply = _send_messenger_file(cfg, dialog_key, file_path, caption)
        return "send_messenger_file", reply

    if _execution_plane_enabled(cfg):
        started = execution_plane_runtime.ensure_started(cfg, log_fn=lambda m: tool_store.log("execution_plane", m))
        if started:
            try:
                return execution_plane_runtime.execute_action(
                    cfg,
                    action,
                    trace_id=_current_trace_id(),
                    note="main_dispatch",
                    source=src,
                    dialog_key=dialog_key,
                )
            except Exception as exc:
                tool_store.log("execution_plane_error", str(exc))
                ep_cfg = _execution_plane_cfg(cfg)
                if not bool(ep_cfg.get("fallback_to_local", True)):
                    raise
        else:
            ep_cfg = _execution_plane_cfg(cfg)
            if not bool(ep_cfg.get("fallback_to_local", True)):
                raise RuntimeError("Execution-Plane nicht verfuegbar und fallback_to_local=false")
    return _execute_action_local(action)


