            if step == "personal_facts":
                secret_cmd = _handle_secret_commands(message, cfg, dialog_key=dialog_key)
                if secret_cmd:
                    return _ret(secret_cmd, "secret_store")

            if step == "personal_facts":
                source_meta = _handle_source_provenance_query(message)
                if source_meta:
