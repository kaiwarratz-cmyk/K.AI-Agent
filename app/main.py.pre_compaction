def _handle_memory_commands(message: str, cfg: Dict[str, Any], dialog_key: str) -> Optional[Dict[str, Any]]:
    text = message.strip()
    if not text:
        return None
    lower = text.lower()
    lower_no_slash = lower[1:].strip() if lower.startswith("/") else lower
    state = _memory_dialog_get(dialog_key)
    if state:
        phase = str(state.get("phase", ""))
        if phase == "pick_scope":
            if lower in {"alles", "all"}:
                _memory_dialog_set(dialog_key, {"phase": "confirm", "scope": "all"})
                return {"ok": True, "reply": "Du hast 'alles' gewÃ¤hlt. Nun lÃ¶schen? (ja/nein)"}
            if lower in {"kontext", "context", "nur kontext"}:
                _memory_dialog_set(dialog_key, {"phase": "confirm", "scope": "conversation"})
                return {"ok": True, "reply": "Du hast 'nur Kontext' gewÃ¤hlt. Nun lÃ¶schen? (ja/nein)"}
            if lower in {"nein", "abbrechen", "cancel"}:
                _memory_dialog_clear(dialog_key)
                return {"ok": True, "reply": "LÃ¶schdialog abgebrochen."}
            return {"ok": True, "reply": "Bitte antworte mit 'alles' oder 'kontext'."}
        if phase == "confirm":
            if lower in {"ja", "j"}:
                scope = str(state.get("scope", "conversation"))
                if scope == "all":
                    deleted = _memory_store(cfg).delete_all()
                    with _session_lock:
                        cleared = len(_session_history)
                        _session_history.clear()
                        _session_semantic_ctx.clear()
                    reply = (
                        f"Gedächtnis gelöscht (alles): {deleted} Einträge, {cleared} Session(s) gelöscht.\n"
                        "Hinweis: Interne Systemeinträge können danach wieder neu entstehen "
                        "(z. B. Episode/Session-Metadaten)."
                    )
                else:
                    stats = _clear_conversation_context(cfg)
                    reply = (
                        f"Gedächtnis gelöscht (nur Kontext): {stats['deleted_db']} Einträge, "
                        f"{stats['cleared_sessions']} Session(s) gelöscht.\n"
                        "Hinweis: Script/Web/Profile/Important bleiben erhalten."
                    )
                _memory_dialog_clear(dialog_key)
                tool_store.log("memory_clear", reply)
                return {"ok": True, "reply": reply}
            if lower in {"nein", "n", "abbrechen", "cancel"}:
                _memory_dialog_clear(dialog_key)
                return {"ok": True, "reply": "LÃ¶schdialog abgebrochen."}
            return {"ok": True, "reply": "Bitte antworte mit 'ja' oder 'nein'."}

    if _is_memory_show_command(text):
        return {"ok": True, "reply": _memory_summary(cfg)}
    recent_match = re.search(
        r"(?:zeige|show)\s+gedaechtnis\s+(?:letzte|recent)\s+eintraege(?:\s+(\d{1,2}))?(?:\s+(conversation|script|web))?",
        lower_no_slash,
    )
    if recent_match:
        n_raw = recent_match.group(1)
        kind_raw = recent_match.group(2)
        n = int(n_raw) if n_raw else 5
        kind = str(kind_raw) if kind_raw else None
        return {"ok": True, "reply": _memory_recent_details(cfg, kind=kind, limit=n)}
    recent_match_alt = re.search(
        r"(?:letzte|recent)\s+gedaechtnis(?:\s+eintraege)?(?:\s+(\d{1,2}))?(?:\s+(conversation|script|web))?",
        lower_no_slash,
    )
    if recent_match_alt:
        n_raw = recent_match_alt.group(1)
        kind_raw = recent_match_alt.group(2)
        n = int(n_raw) if n_raw else 5
        kind = str(kind_raw) if kind_raw else None
        return {"ok": True, "reply": _memory_recent_details(cfg, kind=kind, limit=n)}
    if _is_memory_delete_command(text):
        _memory_dialog_set(dialog_key, {"phase": "pick_scope"})
        return {"ok": True, "reply": "Was soll gelÃ¶scht werden? 'alles' oder 'kontext'."}
    return None

def _handle_script_memory_request(message: str, cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    lower = message.lower()
    wants_list = _has_any(lower, ["liste scripts", "zeige scripts", "welche scripts", "letzte scripts"])
    wants_content = _has_any(lower, ["script inhalt", "inhalt vom script", "letztes script"])
    if not wants_list and not wants_content:
        return None

    items = _memory_store(cfg).search_by_kind(kind="script", limit=20)
    blobs: list[Dict[str, Any]] = []
    active_role = str(cfg.get("security", {}).get("active_role", "user")).lower()
    for item in items:
        b = _last_json_blob(str(item.get("content", "")))
        if not b:
            continue
        created_by = str(b.get("created_by_role", "user")).lower()
        if active_role == "user" and created_by == "admin":
            continue
        blobs.append(b)
    if not blobs:
        return {"ok": True, "reply": "Keine gespeicherten Scripts im Gedaechtnis gefunden."}

    if wants_content:
        hit = _find_relevant_script_memory(cfg, message) or blobs[0]
        code = str(hit.get("code", "")).strip()
        preview = code[:2400] + ("\n... (gekuerzt)" if len(code) > 2400 else "")
        reply = f"Script: {hit.get('path', '')}\nTyp: {hit.get('language', '')}\n\n{preview}"
        return {"ok": True, "reply": reply}

    lines = []
    for b in blobs[:8]:
        p = str(b.get("path", ""))
        lang = str(b.get("language", ""))
        lines.append(f"- {p} ({lang})")
    return {"ok": True, "reply": "Gespeicherte Scripts:\n" + "\n".join(lines)}

def _profile_get_field(cfg: Dict[str, Any], field: str) -> Optional[str]:
    items = _memory_store(cfg).search_by_kind(kind="profile", limit=60)
    want = field.strip().lower()
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not isinstance(blob, dict):
            continue
        f = str(blob.get("field", "")).strip().lower()
        if f != want:
            continue
        value = str(blob.get("value", "")).strip()
        if value:
            return value
    return None

def _important_get_field(cfg: Dict[str, Any], field: str) -> Optional[str]:
    items = _memory_store(cfg).search_by_kind(kind="important", limit=240)
    want = field.strip().lower()
    best_value = ""
    best_score = -1.0
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not isinstance(blob, dict):
            continue
        f = str(blob.get("field", "")).strip().lower()
        if f != want:
            continue
        value = str(blob.get("value", "")).strip()
        if not value:
            continue
        score = float(blob.get("importance", item.get("confidence", 0.0)) or 0.0)
        if score > best_score:
            best_score = score
            best_value = value
    return best_value or None

def _recent_user_messages(cfg: Dict[str, Any], limit: int = 120) -> List[str]:
    items = _memory_store(cfg).search_by_kind(kind="conversation", limit=max(10, limit))
    messages: List[str] = []
    for item in reversed(items):
        blob = _last_json_blob(str(item.get("content", "")))
        if not isinstance(blob, dict):
            continue
        user = str(blob.get("user", "")).strip()
        if not user:
