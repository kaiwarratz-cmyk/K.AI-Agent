def _extract_important_facts_from_user(user_msg: str) -> List[Dict[str, Any]]:
    text = user_msg.strip()
    lower = text.lower()
    facts: List[Dict[str, Any]] = []
    is_question_like = ("?" in text) or bool(
        re.match(r"^\s*(wer|was|wann|wo|warum|wieso|wie|which|what|when|where|why|how)\b", lower)
    )
    if is_question_like and not lower.startswith("merke dir"):
        return []

    patterns = [
        (r"\bich\s+mag\s+(.+)$", "preference", 0.76),
        (r"\bich\s+bevorzuge\s+(.+)$", "preference", 0.82),
        (r"\blieblingsfarbe\s*(?:ist|:)?\s*([a-zäöüß0-9._-]+)\b", "preference", 0.95),
        (r"\blieblingsessen\s*(?:ist|:)?\s*([a-zäöüß0-9._-]+)\b", "preference", 0.95),
        (r"\bmein\s+passwort\s*(?:ist|:)?\s*([^\s]+)", "secret_hint", 0.98),
        (r"\bmerke\s+dir\s*[:\s]+(.+)$", "important_note", 0.9),
        (r"\bmir\s+ist\s+wichtig,\s*(.+)$", "priority", 0.88),
        (r"\bder\s+bot\s+soll\s+(.+)$", "requirement", 0.9),
        (r"\bdu\s+sollst\s+(.+)$", "requirement", 0.88),
        (r"\bbitte\s+immer\s+(.+)$", "requirement", 0.86),
        (r"\bmein\s+ziel\s+ist\s+(.+)$", "goal", 0.84),
        (r"\bdeadline\s*(?:ist|:)?\s*(.+)$", "deadline", 0.9),
        (r"\bfaellig\s*(?:am|bis)?\s*(.+)$", "deadline", 0.88),
        (r"\b(?:unser|mein)\s+projektname\s*(?:ist|:)\s*([a-z0-9._-]+)\b", "project_name", 0.92),
        (r"\bprojekt\s*(?:heisst|heißt|name)\s*(?:ist|:)?\s*([a-z0-9._-]+)\b", "project_name", 0.9),
    ]
    temporal_hints = ("heute", "morgen", "gestern", "diese woche", "naechste woche", "next week", "today", "tomorrow")
    durable_hints = ("immer", "grundsaetzlich", "grundsätzlich", "dauerhaft", "langfristig", "always")
    for regex, field, base_score in patterns:
        m = re.search(regex, lower, flags=re.IGNORECASE)
        if not m:
            continue
        value = m.group(1).strip(" .")
        if len(value) < 3:
            continue
        score = float(base_score)
        value_lower = value.lower()
        if any(h in value_lower for h in temporal_hints):
            score -= 0.22
        if any(h in value_lower for h in durable_hints):
            score += 0.08
        score = max(0.0, min(1.0, score))
        facts.append({"field": field, "value": value, "importance": round(score, 3)})

    # Generic "merke dir" path (if it is not handled by dedicated profile command).
    m_note = re.search(r"^\s*merke\s+dir\s*:?\s*(.+?)\s*$", text, flags=re.IGNORECASE)
    if m_note:
        value = m_note.group(1).strip(" .")
        if len(value) >= 3:
            facts.append({"field": "note", "value": value, "importance": 0.82})

    # De-duplicate
    out: List[Dict[str, Any]] = []
    seen: set[str] = set()
    for f in facts:
        k = f"{f['field']}::{f['value'].lower()}"
        if k in seen:
            continue
        seen.add(k)
        out.append(f)
    return out[:6]

def _persist_important_facts(cfg: Dict[str, Any], user_msg: str, assistant_msg: str) -> None:
    facts = _extract_important_facts_from_user(user_msg)
    if not facts:
        return
    store = _memory_store(cfg)
    existing = store.search_by_kind(kind="important", limit=50)  # 140 → 50

    def _best_existing_for_field(field: str) -> Optional[Dict[str, Any]]:
        field_l = field.lower()
        best: Optional[Dict[str, Any]] = None
        best_score = -1.0
        for item in existing:
            blob = _last_json_blob(str(item.get("content", "")))
            if not isinstance(blob, dict):
                continue
            if str(blob.get("field", "")).lower() != field_l:
                continue
            sc = float(blob.get("importance", item.get("confidence", 0.0)) or 0.0)
            if sc > best_score:
                best_score = sc
                best = blob
        return best

    for f in facts:
        importance = float(f.get("importance", 0.0) or 0.0)
        if importance < 0.72:
            continue
        field = str(f["field"])
        value = str(f["value"])
        best = _best_existing_for_field(field)
        supersedes = None
        if best:
            prev_value = str(best.get("value", ""))
            if prev_value and prev_value.lower() != value.lower() and field in {"requirement", "goal", "deadline", "priority", "project_name"}:
                supersedes = prev_value
        key = f"{f['field']}:{f['value'][:120].lower()}"
        store.upsert_memory(
            "important",
            key,
            {
                "field": field,
                "value": value,
                "importance": round(importance, 3),
                "source": "auto_extract",
                "from_user": user_msg[:400],
                "assistant_reply": assistant_msg[:400],
                "supersedes": supersedes,
            },
            confidence=max(0.72, min(0.97, importance)),
        )

def _maybe_auto_llm_memory_fact(cfg: Dict[str, Any], user_msg: str) -> None:
    mem_cfg = cfg.get("memory", {}) if isinstance(cfg.get("memory", {}), dict) else {}
    if not bool(mem_cfg.get("auto_llm_enabled", False)):
        return
    msg = str(user_msg or "").strip()
    if not msg:
        return
    try:
        max_chars = int(mem_cfg.get("auto_llm_max_chars", 220) or 220)
    except Exception:
        max_chars = 220
    if len(msg) > max_chars:
        return
    # Skip short question-only messages to avoid noisy memory writes.
    if "?" in msg and len(msg) < 120:
        return
    try:
        min_conf = float(mem_cfg.get("auto_llm_min_confidence", 0.82) or 0.82)
    except Exception:
        min_conf = 0.82
    semantic = _llm_classify_memory_fact(cfg, msg)
    if not isinstance(semantic, dict):
        return
    if bool(semantic.get("needs_clarification", False)):
        return
    if not bool(semantic.get("should_store", False)):
        return
    try:
        conf = float(semantic.get("confidence", 0.0) or 0.0)
    except Exception:
        conf = 0.0
    if conf < min_conf:
        return
    _persist_semantic_memory_fact(cfg, semantic, msg)

