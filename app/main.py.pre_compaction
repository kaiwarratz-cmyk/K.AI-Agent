def _is_instance_of_type(value: Any, expected: type) -> bool:
    if expected is bool:
        if isinstance(value, bool): return True
        if str(value).lower() in ("true", "false", "1", "0"): return True
        return False
    if expected is int:
        if isinstance(value, int) and not isinstance(value, bool): return True
        try: 
            int(value)
            return True
        except: return False
    if expected is float:
        if (isinstance(value, float) or isinstance(value, int)) and not isinstance(value, bool): return True
        try:
            float(value)
            return True
        except: return False
    if expected is list: return isinstance(value, list)
    if expected is dict: return isinstance(value, dict)
    if expected is str: return isinstance(value, (str, int, float, bool))
    return isinstance(value, expected)

def _validate_action_schema(action: Dict[str, Any]) -> tuple[bool, str]:
    if not isinstance(action, dict):
        return False, "Action muss ein Objekt sein."
    kind = str(action.get("kind", "") or "").strip()
    if not kind:
        return False, "Action.kind fehlt."
    spec = _action_schemas().get(kind)
    if spec is None:
        return False, f"Unbekannte Action.kind: {kind}"
    if bool(spec.get("allow_any", False)):
        required = spec.get("required", {}) if isinstance(spec.get("required", {}), dict) else {}
        for key in required.keys():
            if key not in action:
                # Schema fail debug logged internally
                return False, f"Pflichtfeld fehlt: {key}"
        return True, "OK"
    required = spec.get("required", {}) if isinstance(spec.get("required", {}), dict) else {}
    optional = spec.get("optional", {}) if isinstance(spec.get("optional", {}), dict) else {}
    # Meta-Felder global erlauben
    meta_fields = {"auto_resolve_deps", "run_after_install", "timeout_sec", "timeout_seconds", "timeout", "source", "trace_id"}
    allowed_keys = set(required.keys()) | set(optional.keys()) | {"kind", "message", "dialog_key"} | meta_fields
    
    # Aliase für Timeout auflösen (Mutation von action ist hier OK da lokaler Scope)
    if "timeout_seconds" in action and "timeout_sec" not in action:
        action["timeout_sec"] = action.pop("timeout_seconds")
    if "timeout" in action and "timeout_sec" not in action:
        action["timeout_sec"] = action.pop("timeout")

    # Extra-Felder sind kein Grund mehr fuer einen harten Abbruch, 
    # wir filtern sie einfach spaeter aus. (Robuster)
    # extra = [k for k in action.keys() if k not in allowed_keys]
    # if extra:
    #     return False, f"Unerlaubte Action-Felder: {', '.join(sorted(extra))}"

    # --- Validierung gegen Definition ---
    for key, typ in required.items():
        if key not in action:
            return False, f"Pflichtfeld fehlt: {key}"
        val = action.get(key)
        if not _is_instance_of_type(val, typ):
            return False, f"Falscher Typ fuer {key}: erwartet {typ.__name__}"
        if typ is str and not str(val).strip():
            hint = ""
            if key == "content" and kind in {"write_file", "append_file"}:
                hint = " Tipp: Wenn du nicht weißt, was du schreiben sollst, erstelle zuerst ein Script mit script_create, das den Inhalt generiert."
            elif key == "host" and kind == "net_list_shares":
                hint = " SOFORT-AKTION: Setze done=True und frage den Nutzer: 'Welchen Hostnamen oder welche IP-Adresse soll ich verwenden (z.B. MEDIANAS, 192.168.1.x)?' Starte KEINE weiteren Iterations oder mem_update_plan-Aufrufe!"
            return False, f"Leerer String fuer Pflichtfeld: {key}{hint}"
    for key, typ in optional.items():
        if key not in action:
            continue
        val = action.get(key)
        if val is None:
            continue
        if not _is_instance_of_type(val, typ):
            return False, f"Falscher Typ fuer {key}: erwartet {typ.__name__}"
    if kind == "script_exec":
        script_txt = str(action.get("script", "") or "").strip()
        script_path = str(action.get("script_path", "") or "").strip()
        if (not script_txt) and (not script_path):
            return False, "script_exec braucht script oder script_path."
    if kind == "cron_create":
        schedule = str(action.get("schedule", "") or "").strip()
        run_at = str(action.get("run_at", "") or "").strip()
        interval = action.get("interval_sec", None)
        has_interval = isinstance(interval, int) and not isinstance(interval, bool) and int(interval) > 0
        if (not schedule) and (not run_at) and (not has_interval):
            return False, "cron_create braucht schedule oder run_at oder interval_sec."
        nested = action.get("action", None)
        if nested is not None:
            if not isinstance(nested, dict):
                return False, "cron_create.action muss ein Objekt sein."
            nk = str(nested.get("kind", "") or "").strip().lower()
            if not nk:
                return False, "cron_create.action.kind fehlt."
            if nk.startswith("cron_"):
                return False, "cron_create.action darf keine cron_* Action sein."
            ok_nested, err_nested = _validate_action_schema(nested)
            if not ok_nested:
                # Fehlende subject-Felder in gmail-Actions auto-auffuellen
                # damit cron_create nicht an Pflichtfeld-Pruefung scheitert
                if "gmail_send_email" in nk and "subject" in err_nested:
                    nested.setdefault("subject", "Automatische Benachrichtigung")
                    ok_nested, err_nested = _validate_action_schema(nested)
                # react_plan-Steps werden zur Laufzeit validiert
                if nk == "react_plan":
                    ok_nested = True
                    err_nested = ""
            if not ok_nested:
                return False, f"cron_create.action ungueltig: {err_nested}"
    if kind in {"cron_delete", "cron_pause", "cron_resume", "cron_test"}:
        job_id = str(action.get("job_id", "") or "").strip()
        if not job_id:
            return False, f"{kind} braucht job_id."
    return True, ""
