            "ok": True,
            "reply": "Keine akuten Fehlersignale gefunden. Selbstverbesserung aktuell: stabil.",
        }
    _persist_improvement_signals(cfg, signals)
    lines = ["Selbstverbesserung: erkannte Signale (priorisiert):"]
