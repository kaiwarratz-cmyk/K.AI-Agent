def _with_persona_prompt(user_prompt: str, include_agent_rules: bool = False) -> str:
    agent_rules = _agent_rules_text(context=user_prompt) if include_agent_rules else ""
    persona = _persona_text()
    if not agent_rules and not persona:
        return user_prompt
    parts: List[str] = []
    if agent_rules:
        parts.append(f"SYSTEM / AGENT-RICHTLINIEN (AGENTS.md):\n{agent_rules}")
    if persona:
        parts.append(f"SYSTEM / PERSONA (persona.txt):\n{persona}")
    parts.append(f"Nutzeranfrage:\n{user_prompt}")
    return "\n\n".join(parts)

def _agent_rules_text(context: str = "", max_chars_full: int = 5000) -> str:
    try:
        if not AGENTS_RULES_FILE.exists():
            return ""
        text = AGENTS_RULES_FILE.read_text(encoding="utf-8-sig", errors="ignore").strip()
        if not text:
            return ""
        lower = (context or "").lower()
        complex_or_risky = _has_any(
            lower,
            [
                "script",
                "skript",
                "python:",
                "powershell:",
                "delete",
                "loesch",
                "verschieb",
                "move",
                "kopier",
                "copy",
                "install",
                "admin",
                "allowlist",
                "unrestricted",
                "deny",
                "security",
                "risk",
                "gefaehr",
                "gefähr",
            ],
        )
        if complex_or_risky:
            return text[:max_chars_full]

        # Short mode for simple prompts to reduce token usage.
        short_lines = [
            "Autonom und ergebnisorientiert handeln.",
            "Analyse -> Umsetzung -> Verifikation (mindestens ein sinnvoller Schnelltest).",
            "Sicherheits-, Rollen- und Execution-Mode-Regeln strikt einhalten.",
            "Bei Mehrdeutigkeit plausibelste Option waehlen und Annahme kurz nennen.",
            "Nur bei echten Blockern rueckfragen.",
        ]
        return "\n".join(short_lines)
    except Exception:
        return ""

