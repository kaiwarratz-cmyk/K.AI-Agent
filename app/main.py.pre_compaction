def _skill_kind_from_token(token: str) -> str:
    t = str(token or "").strip().lower()
    if not t:
        return ""
    reg = _skills_snapshot()
    for tool in reg.get("tools", []) if isinstance(reg.get("tools", []), list) else []:
        if not isinstance(tool, dict):
            continue
        tid = str(tool.get("id", "") or "").strip().lower()
        kind = str(tool.get("kind", "") or "").strip()
        if t == tid or t == str(kind).strip().lower():
            return str(kind or "").strip()
    return ""

def _parse_explicit_skill_action(message: str) -> tuple[Optional[Dict[str, Any]], Optional[str]]:
    text = str(message or "").strip()
    if not text:
        return None, None
    m = re.search(r"(?:^|\b(?:und|dann)\b\s+)(?:nutze|verwende|use)\s+([a-zA-Z0-9_:-]+)\s+mit\s+(.+)$", text, flags=re.IGNORECASE)
    if not m:
        return None, None
    token = str(m.group(1) or "").strip()
    args_txt = str(m.group(2) or "").strip()
    kind = _skill_kind_from_token(token)
    if not kind:
        return None, f"Unbekanntes Skill-Tool: `{token}`."
    req, opt = _skill_param_names_for_kind(kind)
    expected = {k: _action_schemas().get(kind, {}).get("required", {}).get(k, str) for k in req}
    expected.update({k: _action_schemas().get(kind, {}).get("optional", {}).get(k, str) for k in opt})
    pairs: Dict[str, str] = {}
    key_spans = list(re.finditer(r"([a-zA-Z_][a-zA-Z0-9_]*)\s*=", args_txt))
    for i, mm in enumerate(key_spans):
        k = str(mm.group(1) or "").strip()
        if not k:
            continue
        start = mm.end()
        end = key_spans[i + 1].start() if i + 1 < len(key_spans) else len(args_txt)
        v = str(args_txt[start:end] or "").strip()
        if v.endswith(","):
            v = v[:-1].strip()
        if (v.startswith('"') and v.endswith('"')) or (v.startswith("'") and v.endswith("'")):
            v = v[1:-1]
        if k:
            pairs[k] = v
    action: Dict[str, Any] = {"kind": kind}
    for k, raw in pairs.items():
        typ = expected.get(k, str)
        try:
            if typ is int:
                action[k] = int(str(raw).strip())
            elif typ is float:
                action[k] = float(str(raw).strip())
            elif typ is bool:
                action[k] = str(raw).strip().lower() in {"1", "true", "ja", "yes", "on"}
            elif typ is list:
                rv = str(raw).strip()
                parts = []
                if rv.startswith("[") and rv.endswith("]"):
                    rv = rv[1:-1]
                for sep in ["|", ";", ","]:
                    if sep in rv:
                        parts = [x.strip().strip('"').strip("'") for x in rv.split(sep)]
                        break
                if not parts:
                    parts = [rv.strip().strip('"').strip("'")] if rv else []
                action[k] = [x for x in parts if x]
            else:
                action[k] = str(raw)
        except Exception:
            action[k] = str(raw)
    missing = [k for k in req if (k not in action) or (isinstance(action.get(k), str) and not str(action.get(k)).strip())]
    if missing:
        return (
            None,
            f"Fuer `{token}` fehlen Pflichtparameter: {', '.join(missing)}.\n"
            f"required: {', '.join(req) if req else '-'}\n"
            f"optional: {', '.join(opt) if opt else '-'}",
        )
    return action, None

