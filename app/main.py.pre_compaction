@app.post("/api/skills/secret")
def api_skills_secret(payload: SkillSecretUpsertRequest) -> Dict[str, Any]:
    sid = str(payload.skill_id or "").strip()
    alias = SecretStore.normalize_alias(str(payload.alias or ""))
    value = str(payload.value or "").strip()
    if not sid:
        raise HTTPException(status_code=400, detail="skill_id fehlt")
    if not alias:
        raise HTTPException(status_code=400, detail="alias fehlt")
    if not value:
        raise HTTPException(status_code=400, detail="value darf nicht leer sein")
    items = _skills_items_with_secret_status(_cfg())
    hit = None
    for item in items:
        if str(item.get("id", "") or "").strip().lower() == sid.lower():
            hit = item
            break
    if not isinstance(hit, dict):
        raise HTTPException(status_code=404, detail=f"Skill nicht gefunden: {sid}")
    declared = set()
    for sec in hit.get("secrets", []) if isinstance(hit.get("secrets", []), list) else []:
        if isinstance(sec, dict):
            a = SecretStore.normalize_alias(str(sec.get("alias", "") or ""))
            if a:
                declared.add(a)
    if declared and alias not in declared:
        raise HTTPException(status_code=400, detail=f"Alias `{alias}` ist fuer Skill `{sid}` nicht deklariert")
    store = _secret_store(_cfg())
    existed = bool(store.has_alias(alias))
    store.upsert_secret(
        alias=alias,
        value=value,
        meta={"source": "skill_ui", "skill_id": sid, "dialog_key": "webui"},
    )
    existing_cfg = hit.get("config", {}) if isinstance(hit.get("config", {}), dict) else {}
    active_alias = SecretStore.normalize_alias(str(existing_cfg.get("token_secret", "") or ""))
    if not active_alias:
        active_alias = SecretStore.normalize_alias(str(hit.get("active_token_alias", "") or ""))
    if not active_alias:
        active_alias = "gmail_access_token" if sid.lower() == "gmail" else alias
    # Important: do not auto-switch token_secret to whichever secret was set.
    # Token alias changes must happen explicitly via skill config.
    _skills_reload()
    fp = SecretStore.fingerprint(value)
    tool_store.log("secret_store", f"{'update' if existed else 'create'} alias={alias} fingerprint={fp} skill_id={sid}")
    return {"ok": True, "alias": alias, "updated": existed, "fingerprint": fp, "active_token_alias": active_alias}

