    reply = "\n".join(lines) + "\n\n" + str(run.get("reply", ""))
    _persist_conversation(cfg, message, reply, 0.8)
    return {"ok": True, "reply": reply}

# Intent-basierte Filterung - diese Intents brauchen keinen Kontext
_NO_CONTEXT_INTENTS = {
    "help", "clear_context", "clear_memory", "memory_clear",
    "version", "status", "ping", " uptime",
    "befehle", "commands", "kommandos",
    "cron_list", "cron_status",
}

# Thematische Kategorien für Kontext
_TOPIC_CATEGORIES = {
    "filesystem": ["datei", "dateien", "ordner", "verzeichnis", "pfad", "laufwerk", "freigabe", "script", "skript", "copy", "move", "delete", "rename"],
    "web": ["suche", "search", "web", "internet", "google", "wikipedia"],
    "email": ["email", "mail", "gmail", "nachricht", "senden"],
    "chat": ["chat", "unterhaltung", "frage", "antwort", "hallo", "moin", "servus"],
    "script": ["python", "script", "code", "programm", "ausführen", "execute"],
    "system": ["system", "windows", "linux", "cmd", "powershell", "bash"],
}

def _detect_topic(text: str) -> set:
    """Erkennt thematische Kategorien im Text."""
    lower = (text or "").lower()
    topics = set()
    for topic, keywords in _TOPIC_CATEGORIES.items():
        if any(kw in lower for kw in keywords):
            topics.add(topic)
    return topics

def _calculate_message_complexity(message: str) -> int:
    """Berechnet die Komplexität einer Nachricht (1-10)."""
    words = message.strip().split()
    word_count = len(words)
    
    # Indikatoren für Komplexität
    has_question = "?" in message
    has_code = any(x in message for x in ["```", "def ", "function ", "script", "python"])
    has_path = bool(re.search(r"[a-zA-Z]:\\|\\\\|/", message))
    has_conditional = any(x in message.lower() for x in ["wenn", "if", "falls", "aber", "oder", "und auch"])
    has_numbers = bool(re.search(r"\d+", message))
    
    complexity = 1
    
    if word_count > 20:
        complexity += 2
    elif word_count > 10:
        complexity += 1
        
    if has_question:
        complexity += 1
        
    if has_code:
        complexity += 2
        
    if has_path:
        complexity += 1
        
    if has_conditional:
        complexity += 1
        
    if has_numbers:
        complexity += 1
        
    return min(10, max(1, complexity))

def _needs_context_llm(message: str, kontext_vorschau: str) -> bool:
    """Entscheidet ob Kontext aus vorheriger Unterhaltung nötig ist.
    Rein heuristisch – kein LLM-Call (spart Latenz)."""
    if not kontext_vorschau.strip():
        return False
    lower_msg = message.lower()
    chain_words = [
        "es", "das", "dort", "dam", "dafuer", "dafür", "damit", "dazu",
        "weiter", "nochmal", "besprochen", "vorhin",
        "diesen", "diese", "dies", "der text", "die antwort",
        "mir", "mich", "dich",
    ]
    return any(w in lower_msg for w in chain_words)

def _filter_context_by_intent(message: str, kontext: str) -> str:
    """Punkt 2: Intent-basierte Filterung - kein Kontext bei klaren Intents."""
    lower_msg = message.lower().strip()
    
    # Prüfe auf explizite Kommandos
    for intent in _NO_CONTEXT_INTENTS:
        if lower_msg.startswith(intent) or lower_msg == intent:
            return ""
    
    # Prüfe auf /befehle /help etc.
    if lower_msg.startswith("/") and len(lower_msg.split()) <= 2:
        return ""
    
    return kontext

def _filter_context_by_topic(message: str, kontext: str) -> str:
    """Punkt 3: Thematische Kategorisierung - filtert thematisch unpassenden Kontext."""
    if not kontext.strip():
        return kontext
    
    msg_topics = _detect_topic(message)
    
    if not msg_topics:
        # Keine Themen erkannt - behalte Kontext wenn es ein Follow-up ist
        return kontext
    
    # Extrahiere Themen aus dem Kontext
    kontext_topics = _detect_topic(kontext)
    
    if not kontext_topics:
        return kontext
    
    # Prüfe thematische Überschneidung
    if msg_topics & kontext_topics:
        return kontext  # Themen passen
    
    # Prüfe ob es ein Follow-up ist (dann behalten wir Kontext)
    lower_msg = message.lower()
    followup_indicators = ["es", "das", "dort", "dam", "dafuer", "dafür", "damit", "weiter"]
    if any(ind in lower_msg for ind in followup_indicators):
        return kontext
    
    # Keine thematische Übereinstimmung und kein Follow-up
    return ""

def _get_dynamic_turns(message: str, kontext: str) -> int:
    """Punkt 4: Dynamische Turn-Anzahl - komplexere Anfragen brauchen mehr Kontext."""
    complexity = _calculate_message_complexity(message)
    base_turns = 20
    lower_msg = message.lower()
    
    # Sehr kurze Followups (z.B. "dann mach das", "ok", "weiter") brauchen VIEL Kontext
    word_count = len(message.strip().split())
    if word_count <= 4 and any(w in lower_msg for w in ["dann", "das", "es", "dort", "weiter", "ok", "mach", "tue", "führe", "starte"]):
        return min(base_turns, 18)  # Erhöht von 15 auf 18
    
    # Follow-up → immer mehr Kontext
    if any(w in lower_msg for w in ["es", "das", "dort", "dam", "dafuer", "dafür", "weiter", "und unter", "und in", "und auf", "und bei", "und dann"]):
        return min(base_turns, 15)
    if complexity <= 3:
        return 4
    elif complexity <= 5:
        return 8
    elif complexity <= 7:
        return 15
    else:
        return base_turns

def _smart_context_filter(message: str, kontext: str) -> str:
    """Kombiniert alle 4 Filterstrategien für intelligenten Kontext."""
    if not kontext.strip():
        return kontext
    
    # 1. Intent-basierte Filterung (zuerst - schnellste)
    kontext = _filter_context_by_intent(message, kontext)
    if not kontext.strip():
        return message
    
    # 2. Thematische Filterung
    kontext = _filter_context_by_topic(message, kontext)
    if not kontext.strip():
        return message
    
    # 3. LLM-basierte Relevanzprüfung (teuerste - zuletzt)
    if _needs_context_llm(message, kontext):
        return kontext
    
    # Kein Kontext nötig
    return message

def _inject_conversation_context(cfg: Dict[str, Any], message: str, turns: int = 20) -> str:
    if _is_greeting_message(message):
        # Greetings must not pull stale follow-up context.
        return message
    message_terms = set(_query_terms(message))
    lower_msg = (message or "").strip().lower()
    short_followup = len(message.strip().split()) <= 3
    chain_followup = short_followup or bool(
        re.search(
            r"\b(dafuer|dafür|darauf|damit|dazu|dies|das|es|besprochen|vorhin|nochmal|weiter|anschliessend|anschließend)\b"
            r"|und\s+(unter|in|auf|bei|dann|danach|auch|dort|da)\b",
            lower_msg,
            flags=re.IGNORECASE,
        )
    )
    medium_followup = len(message.strip().split()) <= 12 and ("?" in lower_msg or _has_any(lower_msg, ["wie", "was", "welche", "welcher"]))
    fs_query_now = _has_any(lower_msg, ["datei", "dateien", "ordner", "verzeichnis", "pfad", "laufwerk", "freigabe", "filesystem", "script", "skript"])

