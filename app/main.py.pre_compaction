def _emit_script_stream(script_type: str, stream: str, line: str, source: str, timeout_sec: int) -> None:
    txt = str(line or "").replace("\r", " ").strip()
    if not txt:
        return
    payload = {
        "ts": datetime.now().isoformat(),
        "script_type": str(script_type or ""),
        "stream": str(stream or "stdout"),
        "line": txt[:800],
        "source": str(source or ""),
        "timeout_sec": int(timeout_sec or 0),
        "trace_id": _current_trace_id(),
    }
    hook = _script_stream_hook_ctx.get(None)
    if callable(hook):
        with contextlib.suppress(Exception):
            hook(dict(payload))
    _cli_live_emit(
        "observation",
        {
            "kind": f"{str(script_type or '').strip().lower() or 'script'}_exec_stream",
            "message": f"[{payload['stream']}] {payload['line']}",
        },
    )

def _cli_live_one_line(text: Any, max_len: int = 260) -> str:
    try:
        raw = str(text or "")
    except Exception:
        raw = ""
    raw = re.sub(r"\s+", " ", raw).strip()
    if len(raw) <= max_len:
        return raw
    return raw[: max_len - 3].rstrip() + "..."

def _cli_live_term_width(default: int = 120) -> int:
    try:
        cols = int(shutil.get_terminal_size(fallback=(default, 40)).columns)
    except Exception:
        cols = default
    return max(88, min(140, cols))

def _cli_live_wrap_lines(text: Any, width: int, max_lines: int = 80) -> List[str]:
    raw = str(text or "")
    raw = raw.replace("\r\n", "\n").replace("\r", "\n")
    if not raw.strip():
        return ["-"]
    out: List[str] = []
    truncated = False
    for part in raw.split("\n"):
        if part == "":
            out.append("")
        else:
            wrapped = textwrap.wrap(
                part,
                width=max(10, width),
                replace_whitespace=False,
                drop_whitespace=False,
                break_long_words=False,
                break_on_hyphens=False,
            )
            if not wrapped:
                out.append("")
            else:
                out.extend(wrapped)
        if len(out) >= max_lines:
            truncated = True
            break
    if len(out) > max_lines:
        out = out[:max_lines]
    if truncated and len(out) == max_lines:
        out[-1] = _cli_live_one_line(out[-1], max_len=max(10, width - 28)) + " ... (gekuerzt)"
    return out

def _cli_live_value(value: Any, max_len: int = 200) -> Any:
    if value is None:
        return None
    if isinstance(value, (bool, int, float)):
        return value
    if isinstance(value, str):
        return _cli_live_one_line(value, max_len=max_len)
    try:
        packed = json.dumps(value, ensure_ascii=False)
    except Exception:
        packed = str(value)
    return _cli_live_one_line(packed, max_len=max_len)

def _cli_live_action_preview(action: Dict[str, Any]) -> Dict[str, Any]:
    out: Dict[str, Any] = {}
    if not isinstance(action, dict):
        return out
    sensitive_keys = {"token", "api_key", "password", "secret", "auth_token", "access_token", "refresh_token"}
    large_keys = {"script", "code", "content", "html_body", "body"}
    for k, v in action.items():
        key = str(k or "").strip()
        if not key:
            continue
        low_key = key.lower()
        if low_key in sensitive_keys:
            out[key] = "***"
            continue
        if low_key in large_keys:
            sz = len(str(v or ""))
            out[key] = f"<{sz} chars>"
            continue
        out[key] = _cli_live_value(v, max_len=180)
    return out

def _cli_anim_clear_line() -> None:
    global _cli_anim_line_len
    try:
        with _cli_anim_lock:
            line_len = int(_cli_anim_line_len or 0)
            _cli_anim_line_len = 0
        if line_len > 0:
            sys.stdout.write("\r" + (" " * line_len) + "\r")
            sys.stdout.flush()
    except Exception:
        pass

def _cli_anim_worker() -> None:
    global _cli_anim_line_len
    # Originale Frames & Styles
    frames = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
    idx = 0
    while not _cli_anim_stop.is_set():
        try:
            with _cli_anim_lock:
                jobs = int(_cli_anim_active_jobs or 0)
                label = str(_cli_anim_label or "")
                last_len = int(_cli_anim_line_len or 0)
            
            if jobs > 0:
                spinner = frames[idx % len(frames)]
                display_label = label if label else "Agent arbeitet"
                
                # Abschneiden der Zeile, damit das Windows Terminal keinen Return-Bug auslöst
                term_w = _cli_live_term_width()
                max_l = max(10, term_w - 20)
                if len(display_label) > max_l:
                    display_label = display_label[:max_l] + "..."
                
                # Springende Punkte (dynamisch)
                dots = "." * ((idx % 3) + 1)
                txt = f"  \033[96m{spinner}\033[0m \033[93m{display_label}{dots}\033[0m"
                
                pad = " " * max(0, last_len - (len(txt) - 10)) # -10 wegen ANSI-Codes
                sys.stdout.write("\r" + txt + pad)
                sys.stdout.flush()
                
                with _cli_anim_lock:
                    _cli_anim_line_len = len(display_label) + 10
                idx += 1
            else:
                if last_len > 0:
                    sys.stdout.write("\r" + (" " * (last_len + 15)) + "\r")
                    sys.stdout.flush()
                    with _cli_anim_lock:
                        _cli_anim_line_len = 0
            time.sleep(0.08) # Schneller fuer fluessige Animation
        except Exception:
            time.sleep(0.2)
    _cli_anim_clear_line()

def _cli_log_handler(tool: str, note: str) -> None:
    """Zentrale Funktion fuer grafische CLI-Logs im Hauptfenster."""
    _cli_anim_clear_line()
    
    # Icons fuer verschiedene Phasen und Tools
    icons = {
        "thinking": "🧠",
        "thought": "🧠",
        "plan": "🧠",
        "action": "🛠️",
        "call": "🛠️",
        "result": "✅",
        "observation": "✅",
        "web_search": "🌐",
        "script_exec": "💻",
        "read_file": "📂",
        "write_file": "💾",
        "cron_job": "⏰",
        "messenger": "💬",
        "execution_plane": "💎",
        "direct_tool": "⚙️",
        "llm_action": "🤖",
        "error": "❌",
        "fail": "❌",
        "ok": "✅",
        "done": "🏁",
        "start": "🚀"
    }
    
    icon = "⚙️"
    t_low = str(tool).lower()
    for k, v in icons.items():
        if k in t_low:
            icon = v
            break
            
    clr = "\033[90m" # Standard: Grau
    if any(k in t_low for k in ["error", "fail", "timeout"]): 
        clr = "\033[91m" # Rot
    elif any(k in t_low for k in ["ok", "success", "done", "result", "observation"]): 
        clr = "\033[92m" # Gruen
    elif any(k in t_low for k in ["thinking", "thought", "plan"]): 
        clr = "\033[93m" # Gelb
    elif any(k in t_low for k in ["action", "call", "web", "script"]): 
        clr = "\033[96m" # Cyan
    
    # Text-Verschoenerung (Nur Icon und Nachricht, wenn vorhanden)
    if str(note or "").strip():
        msg = f"  {icon} {clr}\033[0m{note}"
        print(msg)

def _cli_anim_ensure_thread() -> None:
    global _cli_anim_thread
    with _cli_anim_lock:
        alive = bool(_cli_anim_thread and _cli_anim_thread.is_alive())
        if alive:
            return
        _cli_anim_stop.clear()
        _cli_anim_thread = threading.Thread(target=_cli_anim_worker, daemon=True, name="cli-live-anim")
        _cli_anim_thread.start()

def _cli_anim_job_start(label: str = "") -> None:
    _cli_anim_ensure_thread()
    with _cli_anim_lock:
        global _cli_anim_active_jobs, _cli_anim_label
        _cli_anim_active_jobs = int(_cli_anim_active_jobs or 0) + 1
        if str(label or "").strip():
            _cli_anim_label = str(label or "").strip()

def _cli_anim_job_touch(label: str = "") -> None:
    if not str(label or "").strip():
        return
    with _cli_anim_lock:
        if int(_cli_anim_active_jobs or 0) > 0:
            global _cli_anim_label
            _cli_anim_label = str(label or "").strip()

def _cli_anim_job_end() -> None:
    with _cli_anim_lock:
        global _cli_anim_active_jobs, _cli_anim_label
        _cli_anim_active_jobs = max(0, int(_cli_anim_active_jobs or 0) - 1)
        if _cli_anim_active_jobs == 0:
            _cli_anim_label = ""

def _cli_live_emit(event: str, payload: Dict[str, Any]) -> None:
    """Strukturiert alle Agenten-Events in grafische CLI-Logs um."""
    try:
        row = payload if isinstance(payload, dict) else {"value": str(payload)}
        msg_raw = row.get("message", row.get("reply", row.get("reasoning", "")))
        
        if isinstance(msg_raw, (dict, list)):
            with contextlib.suppress(Exception):
                msg_raw = json.dumps(msg_raw, ensure_ascii=False, indent=2)
        
        msg_txt = str(msg_raw or "").strip()
        raw_event = str(event or "").strip().lower()
        kind = str(row.get("kind", "")).strip().lower()
        
        # Phase bestimmen
        phase_map = {
            "thought": "thinking",
            "action_start": "action",
            "observation": "result",
            "react_done": "done",
            "react_start": "start",
            "iteration_error": "error",
            "max_iterations": "error"
        }
        
        label = phase_map.get(raw_event, raw_event)
        if kind and label == raw_event: label = kind

        # Animation updaten (im Hintergrund)
        first_line = _cli_live_one_line(msg_txt.splitlines()[0] if msg_txt else "", max_len=120)
        _cli_anim_job_touch(f"{label.upper()} {first_line}".strip())
        
        # AUSGABE INS HAUPTFENSTER via Icon-Handler
        # Wir filtern hier technisches Rauschen (wie leere Events oder reine Trace-Infos)
        if label and msg_txt:
            display_note = msg_txt
            
            # Spezielle Behandlung fuer Gedanken (mehrzeilig, eingerueckt)
            if label in ["thinking", "thought", "plan"]:
                # Wir erlauben hier mehr Text, damit man den Plan lesen kann
                if len(msg_txt) > 800:
                    display_note = msg_txt[:800] + "..."
                
                # Wir rufen den Handler auf, der die Gedanken schoen formatiert
                _cli_log_handler(label, display_note)
            else:
                # Normale Tool-Ergebnisse etc. (leicht gekuerzt falls extrem lang)
                if label == "result" and len(msg_txt) > 300:
                    display_note = msg_txt[:300].replace("\n", " ") + "..."
                
                _cli_log_handler(label, display_note)
                 
    except Exception:
        pass

def _audit_event(stage: str, payload: Dict[str, Any]) -> None:
    try:
        cfg = _cfg()
        log_cfg = cfg.get("logging", {}) if isinstance(cfg.get("logging", {}), dict) else {}
        if not bool(log_cfg.get("enabled", True)):
            return
        verbose = bool(log_cfg.get("verbose", True))
        if (not verbose) and str(stage or "") not in {"request", "response"}:
            return
        path_raw = str(log_cfg.get("audit_log_path", "data/logs/audit.log") or "data/logs/audit.log")
        log_path = Path(path_raw)
        if not log_path.is_absolute():
            log_path = (ROOT_DIR / log_path).resolve()
        def _clean_payload(obj: Any) -> Any:
            if isinstance(obj, dict):
                return {k: _clean_payload(v) for k, v in obj.items()}
            if isinstance(obj, list):
                return [_clean_payload(i) for i in obj]
            if isinstance(obj, Path):
                return str(obj).replace("\\", "/")
            if isinstance(obj, str) and (":\\" in obj or "\\\\" in obj or (obj.startswith("\\") and len(obj) > 1)):
                return obj.replace("\\", "/")
            return obj

        trace_id = _current_trace_id()
        row = {
            "ts": datetime.now().isoformat(),
            "trace_id": trace_id,
            "stage": str(stage or "").strip()[:80],
            "payload": _clean_payload(payload) if isinstance(payload, dict) else {"value": str(payload)},
        }
        log_path.parent.mkdir(parents=True, exist_ok=True)
        with log_path.open("a", encoding="utf-8") as f:
            f.write(json.dumps(row, ensure_ascii=False) + "\n")
        with _audit_lock:
            _audit_recent.appendleft(row)
    except Exception:
        pass

