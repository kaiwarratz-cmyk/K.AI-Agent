        "drucker",
        "printer",
    ]
    has_action = any(w in low for w in action_words)
    has_target = any(w in low for w in target_words)
    return bool(has_action and has_target)

def _update_session_history(cfg: Dict[str, Any], key: str, user_message: str, assistant_message: str, turns: int) -> None:
    max_items = max(2, turns * 2)
    with _session_lock:
        if key not in _session_history:
            # Versuche zuerst von Disk zu laden
            _load_session_from_disk(key)
        
        if key not in _session_history:
            _session_history[key] = deque(maxlen=max_items)
        
        q = _session_history[key]
        if q.maxlen != max_items:
            q = deque(list(q), maxlen=max_items)
            _session_history[key] = q
        q.append({"role": "user", "text": user_message[:3000]})
        q.append({"role": "assistant", "text": assistant_message[:5000]})
    
    # Speichere auf Disk
    _save_session_to_disk(key)
    
    _update_session_semantic_context(key, user_message, assistant_message)
    _update_session_summary(cfg, key, user_message, assistant_message)

def _infer_topic_candidate(text: str) -> str:
    t = str(text or "").strip()
    if not t:
        return ""
    low = t.lower()
    m = re.search(r"\b(?:was\s+ist|wer\s+ist|wo\s+liegt|what\s+is|who\s+is|where\s+is)\s+(.+?)(?:\?|$)", low, flags=re.IGNORECASE)
    if m:
        cand = str(m.group(1) or "").strip(" .,!?:;\"'").replace("?", "").strip()
        if cand and not re.search(r"([a-z]:\\|\\\\|/)", cand, flags=re.IGNORECASE) and len(cand) >= 3:
            return cand
    # Assistant style: "X ist eine Stadt ..."
    m2 = re.search(r"\b([A-ZÄÖÜ][A-Za-zÄÖÜäöüß-]{2,})\s+ist\b", t)
    if m2:
        cand = str(m2.group(1) or "").strip()
        if cand not in {"Ich", "Die", "Der", "Das", "Wenn", "Ja", "Nein", "Bitte"}:
            return cand
    m3 = re.search(r"\bin\s+([A-ZÄÖÜ][A-Za-zÄÖÜäöüß-]{2,})\s+leben\b", t)
    if m3:
        cand = str(m3.group(1) or "").strip()
        if cand not in {"Ich", "Die", "Der", "Das", "Wenn", "Ja", "Nein", "Bitte", "Laut"}:
            return cand
    m4 = re.search(r"\b(?:einwohner|menschen)\b.*\bin\s+([A-ZÄÖÜ][A-Za-zÄÖÜäöüß-]{2,})\b", t)
    if m4:
        cand = str(m4.group(1) or "").strip()
        if cand not in {"Ich", "Die", "Der", "Das", "Wenn", "Ja", "Nein", "Bitte", "Laut"}:
            return cand
    return ""

def _update_session_semantic_context(dialog_key: str, user_message: str, assistant_message: str) -> None:
    key = str(dialog_key or "").strip()
    if not key:
        return
    user_path = _extract_any_path(user_message)
    assistant_path = _extract_any_path(assistant_message)
    topic_user = _infer_topic_candidate(user_message)
    topic_assistant = _infer_topic_candidate(assistant_message)
    # Collect entities first (OUTSIDE the lock)
    entities = {}
    def _collect_entity(name: str, value: str, confidence: float, source: str) -> None:
        if not value:
            return
        entities[name] = {
            "value": str(value),
            "confidence": f"{max(0.0, min(1.0, float(confidence))):.2f}",
            "source": str(source),
            "ts": datetime.now().isoformat()
        }

    if user_path:
        _collect_entity("last_path", str(user_path), 0.92, "user")

    m_file_user = re.search(r"\b([A-Za-z0-9._-]+\.[A-Za-z0-9]{2,8})\b", str(user_message or ""))
    if m_file_user:
        _collect_entity("last_file", str(m_file_user.group(1) or "").strip(), 0.75, "user")

    if topic_user and not _extract_any_path(topic_user):
        _collect_entity("last_topic", str(topic_user), 0.88, "user")
    elif topic_assistant and not _extract_any_path(topic_assistant):
        _collect_entity("last_topic", str(topic_assistant), 0.8, "assistant")

    drive_u = _extract_drive_letter(str(user_message or ""))
    if drive_u:
        _collect_entity("last_drive", str(drive_u), 0.86, "user")

    m_script = re.search(r"([A-Za-z]:\\[^\n`\"]+\.(?:py|ps1|bat))", str(assistant_message or ""), flags=re.IGNORECASE)
    if m_script:
        script_path = str(m_script.group(1) or "").strip()
        _collect_entity("last_script", script_path, 0.82, "assistant")

    user_low = str(user_message or "").strip().lower()
    if _has_any(user_low, ["keine ordner", "ohne ordner", "keine verzeichnisse", "ohne verzeichnisse", "nur dateien", "files only"]):
        _collect_entity("list_pref", "files_only", 0.9, "user")
    elif _has_any(user_low, ["keine dateien", "ohne dateien", "nur ordner", "nur verzeichnisse", "folders only", "dirs only"]):
        _collect_entity("list_pref", "dirs_only", 0.9, "user")
    elif _has_any(user_low, ["dateien und ordner", "ordner und dateien", "beides", "alles anzeigen"]):
        _collect_entity("list_pref", "both", 0.86, "user")

    # Update session context (INSIDE the lock, very briefly)
    with _session_lock:
        ctx = dict(_session_semantic_ctx.get(key, {}))
        for name, data in entities.items():
            ctx[name] = data["value"]
            ctx[f"{name}_confidence"] = data["confidence"]
            ctx[f"{name}_source"] = data["source"]
            ctx[f"{name}_ts"] = data["ts"]
        _session_semantic_ctx[key] = ctx

def _get_session_semantic_context(dialog_key: str) -> Dict[str, str]:
    key = str(dialog_key or "").strip()
    if not key:
        return {}
    with _session_lock:
        return dict(_session_semantic_ctx.get(key, {}))


def _set_pending_path_request(dialog_key: str, original_query: str) -> None:
    key = str(dialog_key or "").strip()
    if not key:
        return
    with _session_lock:
        ctx = dict(_session_semantic_ctx.get(key, {}))
        ctx["pending_path_request"] = "1"
        ctx["pending_path_query"] = str(original_query or "").strip()
        ctx["pending_path_ts"] = datetime.now().isoformat()
        _session_semantic_ctx[key] = ctx


def _consume_pending_path_request(dialog_key: str) -> str:
    key = str(dialog_key or "").strip()
    if not key:
        return ""
    with _session_lock:
        ctx = dict(_session_semantic_ctx.get(key, {}))
        if str(ctx.get("pending_path_request", "0")) != "1":
            return ""
        query = str(ctx.get("pending_path_query", "") or "").strip()
        ctx["pending_path_request"] = "0"
        ctx["pending_path_query"] = ""
        _session_semantic_ctx[key] = ctx
        return query

def _memory_cfg_value(cfg: Dict[str, Any], key: str, default: Any) -> Any:
    mem = cfg.get("memory", {}) if isinstance(cfg.get("memory", {}), dict) else {}
    return mem.get(key, default)

def _session_summary_state(cfg: Dict[str, Any], dialog_key: str) -> Dict[str, Any]:
    key = str(dialog_key or "").strip()
    if not key:
        return {}
    items = _memory_store(cfg).search_by_kind(kind="session_summary", limit=120)
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not isinstance(blob, dict):
            continue
        if str(blob.get("dialog_key", "")).strip() != key:
            continue
        out = dict(blob)
        hs = out.get("highlights", [])
        out["highlights"] = [str(x) for x in hs if str(x).strip()] if isinstance(hs, list) else []
        return out
    return {}

def _is_low_value_chat_line(text: str) -> bool:
    t = str(text or "").strip().lower()
    if not t:
        return True
    if _is_greeting_message(t):
        return True
    if _is_approval_answer(t):
        return True
    if (
        _is_help_command(t)
        or _is_memory_show_command(t)
        or _is_memory_delete_command(t)
        or _is_clear_conversation_command(t)
        or _is_cron_jobs_command(t)
    ):
        return True
    if len(t.split()) <= 2 and t in {"ok", "okay", "ja", "nein", "test", "danke"}:
        return True
    return False

def _shorten_one_line(text: str, max_chars: int = 120) -> str:
    t = re.sub(r"\s+", " ", str(text or "").strip())
    if len(t) <= max_chars:
        return t
    return t[: max(8, max_chars - 3)].rstrip() + "..."

def _update_session_summary(cfg: Dict[str, Any], dialog_key: str, user_message: str, assistant_message: str) -> None:
    if not bool(_memory_cfg_value(cfg, "session_summary_enabled", True)):
        return
    key = str(dialog_key or "").strip()
    if not key:
        return
    state = _session_summary_state(cfg, key)
    highlights = list(state.get("highlights", [])) if isinstance(state.get("highlights", []), list) else []
    if not _is_low_value_chat_line(user_message):
        highlights.append(_shorten_one_line(user_message, 120))
    # Keep assistant highlights only when they look like stable factual answer or operation result.
    asst_low = str(assistant_message or "").strip().lower()
    if (
        str(assistant_message or "").strip()
        and not _is_low_value_chat_line(assistant_message)
        and _has_any(asst_low, ["gespeichert", "geloescht", "verbunden", "antwort", "fakten", "deadline", "projekt", "modell", "provider", "erstellt", "bericht", "grafik", "tabelle", "script"])
    ):
        highlights.append("assistant: " + _shorten_one_line(assistant_message, 110))
    # Deduplicate while preserving recency.
    dedup: List[str] = []
    seen: set[str] = set()
    for h in reversed(highlights):
        k = h.lower().strip()
        if not k or k in seen:
            continue
        seen.add(k)
        dedup.append(h)
    dedup.reverse()
    max_h = int(_memory_cfg_value(cfg, "session_summary_max_highlights", 24) or 24)
    max_h = max(6, min(60, max_h))
    highlights = dedup[-max_h:]

    sem = _get_session_semantic_context(key)
    payload = {
        "dialog_key": key,
        "highlights": highlights,
        "last_topic": str(sem.get("last_topic", "") or "").strip(),
        "last_path": str(sem.get("last_path", "") or "").strip(),
        "last_drive": str(sem.get("last_drive", "") or "").strip(),
        "updated_at": datetime.now().isoformat(),
    }
    _memory_store(cfg).upsert_memory("session_summary", key, payload, confidence=0.78)

def _session_summary_prompt_text(cfg: Dict[str, Any], dialog_key: str) -> str:
    state = _session_summary_state(cfg, dialog_key)
    if not state:
        return ""
    parts: List[str] = []
    topic = str(state.get("last_topic", "") or "").strip()
    path = str(state.get("last_path", "") or "").strip()
    drive = str(state.get("last_drive", "") or "").strip()
    highlights = state.get("highlights", []) if isinstance(state.get("highlights", []), list) else []
    if topic:
        parts.append(f"topic={topic}")
    if path:
        parts.append(f"path={path}")
    if drive:
        parts.append(f"drive={drive}")
    if highlights:
        # Erhöht von 6 auf 12 Highlights für besseren Langzeit-Kontext
        parts.append("highlights: " + " | ".join(str(x) for x in highlights[-12:]))
    txt = " ; ".join(p for p in parts if p)
    max_chars = int(_memory_cfg_value(cfg, "session_summary_prompt_chars", 420) or 420)
    max_chars = max(120, min(1400, max_chars))
    return _shorten_one_line(txt, max_chars)

def _inject_structured_entity_context(message: str) -> str:
    dk = str(_dialog_key_ctx.get("") or "").strip()
    if not dk:
        return message
    sem = _get_session_semantic_context(dk)
    if not sem:
        return message
    lower = str(message or "").strip().lower()
    wants_fs = _has_any(lower, ["datei", "dateien", "ordner", "verzeichnis", "pfad", "laufwerk", "freigabe", "script", "skript"])

    lines: List[str] = []
    topic = str(sem.get("last_topic", "") or "").strip()
    path = str(sem.get("last_path", "") or "").strip()
    drive = str(sem.get("last_drive", "") or "").strip()
    file_name = str(sem.get("last_file", "") or "").strip()
    script = str(sem.get("last_script", "") or "").strip()
    if topic and (not wants_fs):
        lines.append(f"topic={topic}")
    if wants_fs:
        if path:
            lines.append(f"path={path}")
        if drive:
            lines.append(f"drive={drive}")
        if file_name:
            lines.append(f"file={file_name}")
        if script:
            lines.append(f"script={script}")
    if not lines:
        return message
    return f"Strukturierter Session-Kontext:\n" + "\n".join(lines[:6]) + f"\n\n{message}"

def _build_task_state(message: str, cfg: Dict[str, Any], source: str, dialog_key: str) -> TaskState:
    raw_message = str(message or "").strip()
    # Fast-path fuer lokale Kommandos: kein LLM-Roundtrip notwendig.
    if _is_help_command(raw_message):
        sig = detect_signals(raw_message)
        return TaskState(
            message_original=raw_message,
            message_working=raw_message,
            source=source,
            dialog_key=dialog_key,
            signals=sig,
            interpretation={
                "intent": "help",
                "confidence": 1.0,
                "multi_step": "no",
                "needs_clarification": False,
            },
            steps=["help", "llm"],
            factual_domain="",
            needs_verification=False,
        )
    if _is_clear_conversation_command(raw_message):
        sig = detect_signals(raw_message)
        return TaskState(
            message_original=raw_message,
            message_working=raw_message,
            source=source,
            dialog_key=dialog_key,
            signals=sig,
            interpretation={
                "intent": "clear_context",
                "confidence": 1.0,
                "multi_step": "no",
                "needs_clarification": False,
            },
            steps=["clear_context", "llm"],
            factual_domain="",
            needs_verification=False,
        )

    routing_cfg = cfg.get("routing", {}) if isinstance(cfg.get("routing", {}), dict) else {}
    llm_first = bool(routing_cfg.get("llm_first", False))
    det_fallback = bool(routing_cfg.get("deterministic_fallback", True))
    promote_cb = (lambda m, s: s) if llm_first and not det_fallback else (lambda m, s: _hybrid_promote_tool_intent(cfg, m, s))
    task_state_timeout_sec = int(routing_cfg.get("task_state_timeout_sec", 45) or 45)
    task_state_timeout_sec = max(5, min(180, task_state_timeout_sec))
    _state_q: "queue.Queue[Tuple[str, Any]]" = queue.Queue(maxsize=1)

    def _task_state_runner() -> None:
        try:
            state_local = gateway_build_task_state(
                message=message,
                source=source,
                dialog_key=dialog_key,
                augment_followup=lambda m: _augment_followup_with_llm_first(m, cfg, dialog_key=dialog_key),
                llm_interpret=lambda m, s: _llm_interpret_message(cfg, m, s),
                apply_interpretation=_apply_interpretation,
                promote_tool_intent=promote_cb,
                detect_factual_domain=_detect_factual_domain,
                needs_verification=_needs_factual_web_verification,
            )
            _state_q.put(("ok", state_local), timeout=0.1)
        except Exception as exc:
            with contextlib.suppress(Exception):
                _state_q.put(("err", exc), timeout=0.1)

    try:
        from app.trace_utils import start_thread_with_trace
        start_thread_with_trace(_task_state_runner, name=f"KAI-task-state-{str(source or 'src')}", daemon=True)
    except Exception:
        threading.Thread(
            target=_task_state_runner,
            daemon=True,
            name=f"KAI-task-state-{str(source or 'src')}",
        ).start()

    fallback_signals = detect_signals(message)
    fallback_factual = _detect_factual_domain(message)
    fallback_state = TaskState(
        message_original=message,
        message_working=message,
        source=source,
        dialog_key=dialog_key,
        signals=fallback_signals,
        interpretation={
            "intent": "unknown",
            "confidence": 0.0,
            "multi_step": "no",
            "needs_clarification": False,
        },
        steps=build_plan(fallback_signals),
        factual_domain=fallback_factual,
        needs_verification=bool(fallback_factual) or _needs_factual_web_verification(message),
    )

    try:
        status, payload = _state_q.get(timeout=float(task_state_timeout_sec))
        if status == "ok" and isinstance(payload, TaskState):
            state = payload
        else:
            with contextlib.suppress(Exception):
                tool_store.log("routing_timeout", f"task_state_error source={source}: {payload}")
            state = fallback_state
    except queue.Empty:
        with contextlib.suppress(Exception):
            tool_store.log("routing_timeout", f"task_state_timeout>{task_state_timeout_sec}s source={source}")
        state = fallback_state

    interp = state.interpretation if isinstance(state.interpretation, dict) else {}
    intent = str(interp.get("intent", "") or "").strip().lower()
    try:
        conf = float(interp.get("confidence", 0.0) or 0.0)
    except Exception:
        conf = 0.0
    # LLM-first routing: high-confidence interpreted intent gets priority,
    # while deterministic fallbacks are still preserved.
    if conf >= _intent_threshold(cfg, intent) and intent in {
        "filesystem",
        "script",
        "cron",
        "knowledge_or_web",
        "answer_and_save",
        "memory_query",
        "help",
        "clear_context",
        "chat",
    }:
        intent_first: List[str] = []
        if intent == "clear_context":
            intent_first = ["clear_context", "llm"]
        elif intent == "help":
            intent_first = ["help", "llm"]
        elif intent == "memory_query":
            if _is_internal_memory_query(message):
                intent_first = ["personal_facts", "memory_only_qa", "knowledge_or_web", "llm"]
            else:
                intent_first = ["knowledge_or_web", "llm"]
        elif intent == "answer_and_save":
            intent_first = ["answer_and_save", "knowledge_or_web", "llm"]
        elif intent == "script":
            intent_first = ["script_memory", "script_create", "script_exec", "filesystem", "llm"]
        elif intent == "cron":
            intent_first = ["filesystem", "llm"]
        elif intent == "filesystem":
            intent_first = ["filesystem", "script_exec", "llm"]
        elif intent == "knowledge_or_web":
            intent_first = ["knowledge_or_web", "llm"]
        else:
            intent_first = ["knowledge_or_web", "llm"]

        core_prefix = ["help", "memory_commands", "clear_context", "personal_facts", "self_improve"]
        merged: List[str] = []
        for s in core_prefix + intent_first + list(state.steps or []):
            if s and s not in merged:
                merged.append(s)
        state.steps = merged
    return state


def _run_with_timeout(timeout_sec: float, fn: Callable[[], Any]) -> Tuple[bool, Any, Optional[Exception]]:
    timeout = max(1.0, min(600.0, float(timeout_sec or 0.0)))
    q: "queue.Queue[Tuple[str, Any]]" = queue.Queue(maxsize=1)

    def _worker() -> None:
        try:
            q.put(("ok", fn()), timeout=0.1)
        except Exception as exc:
            with contextlib.suppress(Exception):
                q.put(("err", exc), timeout=0.1)

    try:
        from app.trace_utils import start_thread_with_trace
        start_thread_with_trace(_worker, name="KAI-timeout-call")
    except Exception:
        threading.Thread(target=_worker, daemon=True, name="KAI-timeout-call").start()
    try:
        status, payload = q.get(timeout=timeout)
    except queue.Empty:
        return True, None, None
    if status == "err":
        return False, None, payload if isinstance(payload, Exception) else Exception(str(payload))
    return False, payload, None

def _build_action_catalog_text(cfg: Dict[str, Any], intent: str = "") -> str:
    """Kompakter Katalogtext aus _TOOL_DESCRIPTIONS und _ACTION_SCHEMA für LLM-Prompts.
    Enthält Pflichtfelder mit Typen damit der Planner vollständige params liefern kann.
    
    Args:
        cfg: Config
        intent: Optional Intent für dynamische Tool-Priorisierung
    """
    type_map = {str: "string", int: "int", float: "float", bool: "bool", list: "list", dict: "dict"}
    
    # Dynamische Tool-Priorisierung basierend auf Intent
    mcp_priority = list(
        dict.fromkeys(
            _mcp_tool_names()
            + ["shell_command", "mcp_registry_search", "mcp_registry_prepare", "mcp_registry_install"]
        )
    )
    intent_priority = {
        "filesystem": mcp_priority + ["list_entries", "read_file", "write_file", "script_exec", "script_create"],
        "script": mcp_priority + ["script_exec", "script_create", "install_python_packages", "install_nodejs_packages"],
        "cron": mcp_priority + ["cron_create", "cron_list", "cron_delete", "cron_pause", "cron_resume"],
    }
    
    # Hole priorisierte Tools für Intent
    priority_tools = intent_priority.get(intent, []) if intent else []
    all_tools = list(_TOOL_DESCRIPTIONS.keys())
    core_mode = _cli_core_enabled(cfg)
    if core_mode:
        core_tools = _cli_core_allowed_action_kinds(intent or "filesystem", cfg=cfg)
        if core_tools:
            all_tools = list(dict.fromkeys(core_tools))
    
    # Baue sortierte Tool-Liste: Priorität zuerst, dann Rest
    if priority_tools:
        priority_filtered = [t for t in priority_tools if t in all_tools]
        remaining = [t for t in all_tools if t not in priority_filtered]
        sorted_tools = priority_filtered + remaining
    else:
        sorted_tools = all_tools

    # Skill-Tools aus action_schemas ergänzen (nicht in _TOOL_DESCRIPTIONS enthalten)
    _skill_extra = [k for k in _action_schemas().keys() if k not in set(sorted_tools)]
    sorted_tools = sorted_tools + _skill_extra

    lines: List[str] = []
    if core_mode:
        strict_min = bool(_cli_core_cfg(cfg).get("strict_minimal", True))
        lines.append("CLI-CORE-MODUS AKTIV: Nutze nur den kompakten Kernsatz + vorhandene MCP-Tools.")
        if strict_min:
            lines.append("STRICT-MINIMAL aktiv: keine Legacy-Builtins im Standardpfad.")
        lines.append("Standardpfad: erst bestehendes MCP-Tool, dann shell_command, danach optional Registry.")
    else:
        lines.append("HINWEIS: Für direkte Ausführung nutze shell_command. Nur wenn das nicht sinnvoll ist: MCP-Registry durchsuchen. Externe MCP-Server nur nach Bestaetigung.")
    schemas_all = _action_schemas()
    for kind in sorted_tools[:80]:
        schema_entry = schemas_all.get(kind, {}) if isinstance(schemas_all.get(kind, {}), dict) else {}
        if not isinstance(schema_entry, dict) or (not schema_entry):
            continue
        entry = _TOOL_DESCRIPTIONS.get(kind, {}) if isinstance(_TOOL_DESCRIPTIONS.get(kind, {}), dict) else {}
        desc = str(
            entry.get("desc")
            or schema_entry.get("description")
            or f"Execute action: {kind}"
        ).strip()
        params_desc = entry.get("params", {}) if isinstance(entry.get("params", {}), dict) else {}
        required_fields = schema_entry.get("required", {}) if isinstance(schema_entry.get("required", {}), dict) else {}
        required_str = ""
        if required_fields:
            parts = [f"{k}({type_map.get(v, 'any')})" for k, v in required_fields.items()]
            required_str = " | required: " + ", ".join(parts)
        param_list = ", ".join(params_desc.keys()) if isinstance(params_desc, dict) else ""
        lines.append(
            f"- {kind}: {desc}"
            + (f" | params: {param_list}" if param_list and not required_str else "")
            + required_str
        )
    return "\n".join(lines)

# ─────────────────────────────────────────────────────────────────────────────
# ReAct Multi-Step Planner
# Analog zum Copilot-CLI-Muster: Reason → Act → Observe → Repeat
# Ein LLM-Call erstellt einen geordneten Plan (steps[]), dann sequentielle
# Ausführung mit Ergebnis-Rückführung via {{steps.N.field}}-Referenzen.
# ─────────────────────────────────────────────────────────────────────────────

_REACT_MAX_STEPS = 6
_REACT_MULTI_DOMAIN_CONNECTORS = re.compile(
    r"\b(und\s+dann|und\s+danach|und\s+anschlie[sß]end|danach\s+(?:soll|sende|erstelle|lege|schicke|speichere|starte|richte)|"
    r"und\s+(?:dann\s+)?lege(?:\s+\w+){0,3}\s+cron|und\s+schicke|und\s+sende|und\s+erstelle|"
    r"und\s+speichere|und\s+starte|und\s+richte|dann\s+(?:soll|erstelle|lege|starte|sende|schicke|richte)|"
    r"lege\s+danach|danach\s+(?:einen?\s+)?cron|anschlie[sß]end\s+(?:soll|einen?)|"
    r"f[uü]hr[e]\s+(?:es\s+)?(?:einmal\s+)?(?:sofort\s+)?aus\s+und|,\s*f[uü]hr)\b",
    re.IGNORECASE,
)

def _is_multi_step_request(message: str) -> bool:
    """Erkennt Anfragen die mehrere distinkte Aktions-Domains kombinieren."""
    low = (message or "").lower()
    # Muss mindestens einen Konnektor enthalten
    if not _REACT_MULTI_DOMAIN_CONNECTORS.search(low):
        return False
    # Zähle wie viele unterschiedliche Action-Domains vorkommen
    domains = 0
    if _has_any(low, ["script", "skript", ".py", ".ps1", "python", "powershell", "programmier"]):
        domains += 1
    if re.search(r"\bcron(?:job)?\b|alle\s+\d+\s*(?:minuten|stunden|sekunden|tage)\b", low):
        domains += 1
    if _has_any(low, ["mail", "email", "e-mail", "schicke.*anhang", "sende.*anhang"]):
        domains += 1
    if _has_any(low, ["screenshot", "bildschirmfoto", "screenshot"]) or re.search(r"screen\s*shot", low):
        domains += 1
    if _has_any(low, ["datei", "ordner", "verzeichnis", "pfad", "kopier", "verschieb", "lösch"]):
        domains += 1
    if _has_any(low, ["web", "suche", "news", "webseite", "url", "http"]):
        domains += 1
    return domains >= 2

def _resolve_step_refs(value: Any, step_results: List[Dict[str, Any]]) -> Any:
    """Löst {{steps.N.field}}-Referenzen in Action-Dicts auf.
    Erweitert _resolve_step_templates: unterstützt beliebige Felder (nicht nur .reply)."""
    if isinstance(value, str):
        def _sub(m: re.Match) -> str:
            idx = int(m.group(1))
            field = m.group(2)
            if idx < len(step_results):
                r = step_results[idx]
                # "result" and "reply" are aliases — LLM uses both
                if field == "result":
                    return str(r.get("reply", r.get("result", m.group(0))))
                return str(r.get(field, m.group(0)))
            return m.group(0)
        return re.sub(r"\{\{steps\.(\d+)\.([a-zA-Z_]+)\}\}", _sub, value)
    if isinstance(value, dict):
        return {k: _resolve_step_refs(v, step_results) for k, v in value.items()}
    if isinstance(value, list):
        return [_resolve_step_refs(v, step_results) for v in value]
    return value

# Bekannte interne Muster die in standalone Scripts nicht funktionieren
_SCRIPT_BAD_PATTERNS: List[tuple] = [
    (re.compile(r"^\s*from\s+app\b", re.MULTILINE), "interne app-Imports"),
    (re.compile(r"^\s*import\s+app\b", re.MULTILINE), "interne app-Imports"),
    (re.compile(r"\b_handle_\w+\s*\(", re.MULTILINE), "interne _handle_*-Funktionen"),
    (re.compile(r"\b_llm_\w+\s*\(", re.MULTILINE), "interne _llm_*-Funktionen"),
    (re.compile(r"\b_audit_event\s*\(", re.MULTILINE), "interne _audit_event-Aufrufe"),
    (re.compile(r"\bapproval_manager\b", re.MULTILINE), "interner approval_manager"),
]

# Deterministischer Ersetzungskatalog: (Pattern, Ersatz, Beschreibung)
# Reihenfolge ist wichtig: spezifischere Regeln zuerst.
_SCRIPT_STATIC_FIXES: List[tuple] = [
    # ── Import-Zeilen entfernen ──────────────────────────────────────────
    (re.compile(r"^[ \t]*from\s+app\.[\w.]+\s+import\s+[^\n]+\n?", re.MULTILINE),
     "", "from app.* import entfernt"),
    (re.compile(r"^[ \t]*import\s+app\.[\w.]+[^\n]*\n?", re.MULTILINE),
     "", "import app.* entfernt"),
    (re.compile(r"^[ \t]*sys\.path\.insert\(0,\s*['\"]\.['\"]\)[^\n]*\n?", re.MULTILINE),
     "", "sys.path.insert(0,'.') entfernt"),

    # ── Interne Funktionsaufrufe ersetzen ────────────────────────────────
    # Wenn ein interner Aufruf in einer Zuweisung steht → ganze Zeile sicher ersetzen
    # Verhindert Syntax-Fehler durch Teilersetzung in verschachtelten Ausdrücken
    (re.compile(r"^([ \t]*\w+\s*=\s*)[^\n]*\b_handle_\w+\s*\([^\n]*\n?", re.MULTILINE),
     r'\1None  # [entfernt: interner _handle_*-Aufruf]\n', "Zuweisung mit _handle_* → None"),
    (re.compile(r"^([ \t]*\w+\s*=\s*)[^\n]*\b_llm_\w+\s*\([^\n]*\n?", re.MULTILINE),
     r'\1None  # [entfernt: interner _llm_*-Aufruf]\n', "Zuweisung mit _llm_* → None"),
    (re.compile(r"^([ \t]*\w+\s*=\s*)[^\n]*\bLLMRouter\s*\([^\n]*\n?", re.MULTILINE),
     r'\1None  # [entfernt: LLMRouter intern]\n', "Zuweisung mit LLMRouter → None"),

    # _audit_event → Kommentar, Einrückung erhalten
    (re.compile(r"^([ \t]*)_audit_event\s*\([^\n]*\n?", re.MULTILINE),
     r'\1# [LOG: audit_event entfernt]\n', "_audit_event → Kommentar"),

    # approval_manager-Zuweisung → None (damit Folge-if-Blöcke nicht orphaned werden)
    (re.compile(r"^([ \t]*\w+\s*=\s*)[^\n]*\bapproval_manager\b[^\n]*\n?", re.MULTILINE),
     r'\1None  # [entfernt: approval_manager]\n', "Zuweisung mit approval_manager → None"),

    # approval_manager standalone → Kommentar, Einrückung erhalten
    (re.compile(r"^([ \t]*)[^\n]*\bapproval_manager\b[^\n]*\n?", re.MULTILINE),
     r'\1# [entfernt: approval_manager nicht verfügbar]\n', "approval_manager entfernt"),

    # _handle_filesystem_*(cfg, ...) → os.listdir / pathlib-Äquivalente
    (re.compile(r"\b_handle_filesystem_list\s*\([^)]*\)", re.MULTILINE),
     '__import__("os").listdir(".")', "_handle_filesystem_list → os.listdir"),
    (re.compile(r"\b_handle_filesystem_read\s*\([^)]*\)", re.MULTILINE),
     'open(__file__).read()', "_handle_filesystem_read → open"),

    # _handle_gmail_list(cfg, query, n) → Stub mit leerem Ergebnis + Hinweis
    (re.compile(r"\b_handle_gmail_list\s*\([^)]*\)", re.MULTILINE),
     '[]  # TODO: Gmail-Zugriff via IMAP oder Gmail API implementieren',
     "_handle_gmail_list → stub"),

    # _handle_send_* / _handle_gmail_send → Stub
    (re.compile(r"\b_handle_(?:send|gmail_send)\w*\s*\([^)]*\)", re.MULTILINE),
     'None  # TODO: Mail-Versand via smtplib implementieren',
     "_handle_send_* → stub"),

    # Alle verbleibenden _handle_*(…) standalone → Kommentar, Einrückung erhalten
    (re.compile(r"^([ \t]*)_handle_\w+\s*\([^\n]*\n?", re.MULTILINE),
     r'\1# [entfernt: interne _handle_*-Funktion]\n', "_handle_* standalone → Kommentar"),

    # Alle verbleibenden _handle_*(…) in Ausdrücken
    (re.compile(r"\b_handle_\w+\s*\([^)]{0,120}\)", re.MULTILINE),
     'None  # [entfernt: interne _handle_*-Funktion]',
     "_handle_* → None-stub"),

    # Alle verbleibenden _llm_*(…) standalone → Kommentar, Einrückung erhalten
    (re.compile(r"^([ \t]*)_llm_\w+\s*\([^\n]*\n?", re.MULTILINE),
     r'\1# [entfernt: interne _llm_*-Funktion]\n', "_llm_* standalone → Kommentar"),

    # Alle verbleibenden _llm_*(…) in Ausdrücken
    (re.compile(r"\b_llm_\w+\s*\([^)]{0,120}\)[^\n]*", re.MULTILINE),
     'None  # [entfernt: interne _llm_*-Funktion]',
     "_llm_* → None-stub"),

    # LLMRouter in Ausdrücken
    (re.compile(r"\bLLMRouter\s*\([^)]*\)[^\n]*", re.MULTILINE),
     'None  # [entfernt: LLMRouter intern]',
     "LLMRouter → stub"),
]

def _sanitize_script_static(script_code: str) -> tuple:
    """Wendet deterministische Ersetzungsregeln auf generierten Script-Code an.
    Entfernt/ersetzt alle bekannten internen Abhängigkeiten ohne LLM.
    Gibt (bereinigter_code, angewendete_fixes) zurück."""
    code = script_code
    applied: List[str] = []
    for pattern, replacement, label in _SCRIPT_STATIC_FIXES:
        new_code, count = pattern.subn(replacement, code)
        if count > 0:
            code = new_code
            applied.append(f"{label} ({count}x)")
    # Doppelte Leerzeilen bereinigen
    code = re.sub(r"\n{3,}", "\n\n", code)
    return code, applied

def _validate_and_fix_script(
    cfg: Dict[str, Any],
    script_code: str,
    script_path: str = "",
    script_type: str = "python",
) -> tuple:
    """Korrekturschicht für generierte Scripts. Zwei Stufen:
    Stufe 1 (deterministisch): _sanitize_script_static – entfernt/ersetzt alle bekannten
                               internen Muster ohne LLM, immer zuverlässig.
    Stufe 2 (LLM-Fallback):   Nur wenn nach Stufe 1 noch Syntax-Fehler vorhanden sind.
    Gibt (fixed_code, did_fix, issues_found) zurück."""
    import ast as _ast
    did_fix = False
    all_issues: List[str] = []

    # ── Stufe 1: Deterministischer Static-Sanitizer ────────────────────
    sanitized, applied_fixes = _sanitize_script_static(script_code)
    if applied_fixes:
        script_code = sanitized
        all_issues.extend(applied_fixes)
        did_fix = True

    if script_type != "python":
        # ── Stufe 1b (PS): Syntax-Check nach static fix ──────────────────
        from app.code_validation_pipeline import check_syntax as _cvp_check, validate_and_fix as _cvp_fix
        ps_syntax_error = _cvp_check(script_code, "powershell")
        if ps_syntax_error:
            all_issues.append(ps_syntax_error)
            # ── Stufe 2 (PS): LLM-Fix mit Multi-Retry Loop ───────────────
            try:
                _cvp_ok, _cvp_code, _cvp_errors = _cvp_fix(
                    code=script_code,
                    language="powershell",
                    cfg=cfg,
                    max_retries=3,
                )
                if _cvp_ok and _cvp_code.strip() and _cvp_code != script_code:
                    script_code = _cvp_code
                    did_fix = True
                elif _cvp_errors:
                    all_issues.extend(_cvp_errors[-2:])
            except Exception as exc:
                _audit_event("script_auto_fix_error", {"error": str(exc)[:200], "script_type": "powershell"})
        if did_fix and script_path:
            try:
                Path(script_path).write_text(script_code, encoding="utf-8")
            except Exception:
                pass
        return script_code, did_fix, all_issues

    # ── Stufe 1b: Syntax-Check nach static fix ─────────────────────────
    syntax_error: Optional[str] = None
    try:
        _ast.parse(script_code)
    except SyntaxError as se:
        syntax_error = f"SyntaxError Zeile {se.lineno}: {se.msg}"
        all_issues.append(syntax_error)

    # Restliche interne Muster noch vorhanden?
    remaining_bad = []
    for pattern, label in _SCRIPT_BAD_PATTERNS:
        if pattern.search(script_code):
            remaining_bad.append(label)
    all_issues.extend(remaining_bad)

    # ── Stufe 2: LLM-Fix mit Multi-Retry Loop (bis zu 3 Versuche) ─────
    if syntax_error or remaining_bad:
        try:
            from app.code_validation_pipeline import validate_and_fix as _cvp_fix
            _cvp_ok, _cvp_code, _cvp_errors = _cvp_fix(
                code=script_code,
                language="python",
                cfg=cfg,
                max_retries=3,
            )
            if _cvp_ok and _cvp_code.strip() and _cvp_code != script_code:
                script_code = _cvp_code
                did_fix = True
            elif _cvp_errors:
                all_issues.extend(_cvp_errors[-2:])  # letzte 2 Fehler für Audit
        except Exception as exc:
            _audit_event("script_auto_fix_error", {"error": str(exc)[:200]})

    if did_fix and script_path:
        try:
            Path(script_path).write_text(script_code, encoding="utf-8")
        except Exception:
            pass

    if did_fix or all_issues:
        _audit_event("script_auto_fixed", {
            "script_path": script_path,
            "static_fixes": applied_fixes,
            "remaining_issues": remaining_bad,
            "syntax_fixed": bool(syntax_error),
        })

    return script_code, did_fix, all_issues

