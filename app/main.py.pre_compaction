@LocalActionDispatcher.register("mcp_registry_search")
def _h_mcp_reg_search(kind, action):
    from app.mcp_registry import search_registry_sources
    query = str(action.get("query", "") or "").strip()
    limit = int(action.get("limit", 15) or 15)
    items = search_registry_sources(_cfg(), query, limit=limit)
    if not items:
        return kind, "Keine Registry-Ergebnisse gefunden."
    lines = []
    for i, it in enumerate(items[:limit], 1):
        if it.get("error"):
            lines.append(f"{i}. FEHLER: {it['error']}")
            continue
        src_id = it.get("source_id", "")
        name = it.get("name", "")
        title = it.get("title", "")
        desc = (it.get("description") or "")[:100]
        install_type = it.get("install_type", "local")
        src_type = it.get("source_type", "")
        # Tag: lokal installierbar vs Remote-Service
        if install_type == "remote":
            tag = "[REMOTE - gehosteter Service, NICHT installierbar - ignorieren!]"
        elif install_type == "npm_stdio":
            tag = "[✅ npm+stdio - SOFORT installierbar]"
        elif install_type == "local":
            tag = "[npm - installierbar (kein stdio bestätigt)]"
        elif src_type == "github":
            tag = "[GitHub - manuell konfigurierbar, kein npm garantiert]"
        else:
            tag = "[unbekannt - evtl. installierbar, evtl. nicht]"
        display = f"{name}" + (f' "{title}"' if title and title.lower() != name.lower() else "")
        lines.append(f"{i}. {tag}\n   name={name!r}  source_id={src_id!r}\n   {display} — {desc}")
    header = (
        "Gefundene MCP-Server:\n"
        "Tags: [✅ npm+stdio] = SOFORT installierbar | "
        "[npm installierbar] = wahrscheinlich OK | "
        "[GitHub] = manuell, unsicher | "
        "[REMOTE] = NICHT installierbar, ignorieren!\n"
        "Reihenfolge: ✅ npm+stdio zuerst probieren! Bei Fehler: nächstes Ergebnis. KEIN git/npm-Install!\n"
        "(name= und source_id= EXAKT wie angegeben für mcp_registry_install verwenden)\n"
    )
    return kind, header + "\n".join(lines)

