    lower = msg.lower()
    if _extract_script_creation_request(msg, cfg):
        return True
    if _extract_script_request(msg, cfg):
        return True
    action_verbs = [
        "mach ",
        "mache ",
        "fertige ",
        "anfertige ",
        "anfertigen ",
        "erzeug ",
        "erstelle ",
        "create ",
        "nimm ",
        "nehme ",
        "take ",
        "fuehre ",
        "ausfuehren",
        "run ",
        "starte ",
        "start ",
    ]
    action_objects = ["screenshot", "bildschirmfoto", "screen shot", "aufnahme", "script", "skript", "datei erstellen"]
    screenshot_make = bool(
        re.search(
            r"\b(fertige|anfertige|anfertigen|mach\w*|mache\w*|erstelle\w*|create\w*|take\w*|capture\w*|nimm\w*|nehme\w*)\b.*\b(screenshot|bildschirmfoto|screen\s*shot)\b",
            lower,
            flags=re.IGNORECASE,
        )
        or re.search(
