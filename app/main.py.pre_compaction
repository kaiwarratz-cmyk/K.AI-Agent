        seen.add(t)
        out.append(t)
    return out[:10]

def _memory_text_for_match(item: Dict[str, Any]) -> str:
    blob = _last_json_blob(str(item.get("content", "")))
    if isinstance(blob, dict):
        parts: list[str] = []
        for k in ("user", "assistant", "query", "summary", "path", "name", "language", "field", "value"):
            v = blob.get(k)
            if v is None:
                continue
            parts.append(str(v))
        if parts:
            return " | ".join(parts)
    return str(item.get("content", ""))

def _parse_updated_at(raw: str) -> Optional[datetime]:
    s = str(raw or "").strip()
    if not s:
        return None
    try:
        # sqlite CURRENT_TIMESTAMP usually: YYYY-MM-DD HH:MM:SS
        if "T" not in s and " " in s:
            s = s.replace(" ", "T", 1)
        if s.endswith("Z"):
            s = s[:-1] + "+00:00"
        dt = datetime.fromisoformat(s)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return dt
    except Exception:
        return None

def _recency_factor(updated_at: str) -> float:
    dt = _parse_updated_at(updated_at)
    if not dt:
        return 1.0
    age_days = max(0.0, (datetime.now(timezone.utc) - dt).total_seconds() / 86400.0)
    # Mild decay after ~30d, still keeps durable facts useful.
    return 1.0 / (1.0 + (age_days / 45.0))

def _format_datetime_readable(raw: Any, fallback: str = "-") -> str:
    s = str(raw or "").strip()
    if not s:
        return fallback
    dt = _parse_updated_at(s)
    if not isinstance(dt, datetime):
        return s
    with contextlib.suppress(Exception):
        dt = dt.astimezone()
    stamp = dt.strftime("%d.%m.%Y %H:%M:%S")
    off = dt.strftime("%z")
    if off and len(off) == 5:
        off = f"{off[:3]}:{off[3:]}"
    if off:
        return f"{stamp} (UTC{off})"
    return stamp

def _format_interval_readable(interval_sec: Any) -> str:
    try:
        sec = int(interval_sec or 0)
    except Exception:
        sec = 0
    if sec <= 0:
        return "-"
    if sec % 86400 == 0:
        return f"alle {sec // 86400} Tag(e)"
    if sec % 3600 == 0:
        return f"alle {sec // 3600} Stunde(n)"
    if sec % 60 == 0:
        return f"alle {sec // 60} Minute(n)"
    return f"alle {sec} Sekunde(n)"

def _text_digest(value: str) -> str:
    s = str(value or "")
    return hashlib.sha1(s.encode("utf-8", errors="ignore")).hexdigest()

def _memory_hits_for_query(cfg: Dict[str, Any], query: str, limit: int = 4) -> list[Dict[str, Any]]:
    terms = _query_terms(query)
    if not terms:
        return []
    items = _memory_store(cfg).list_all(limit=50)  # 140 → 50
    scored: list[tuple[float, int, Dict[str, Any], str]] = []
    kind_weight = {
        "important": 2.2,
        "profile": 2.0,
        "script": 1.4,
        "web": 1.2,
        "conversation": 0.6,
    }
    min_score = 1 if len(terms) <= 2 else 2
    for item in items:
        text = _memory_text_for_match(item)
        lower = text.lower()
        score = sum(1 for t in terms if t in lower)
        if score < min_score:
            continue
        kind = str(item.get("kind", "")).lower()
        conf = float(item.get("confidence", 0.7) or 0.7)
        rec = _recency_factor(str(item.get("updated_at", "")))
        weighted = float(score) * float(kind_weight.get(kind, 1.0)) * (0.6 + 0.6 * conf) * (0.65 + 0.7 * rec)
        scored.append((weighted, score, item, text))
    scored.sort(key=lambda x: (x[0], x[1]), reverse=True)
    # Prefer specific memory over generic conversation if available.
    has_specific = any(str(s[2].get("kind", "")).lower() in {"important", "profile", "script", "web"} for s in scored)
    if has_specific:
        scored = [s for s in scored if str(s[2].get("kind", "")).lower() != "conversation"] + [
            s for s in scored if str(s[2].get("kind", "")).lower() == "conversation"
        ]
    out: list[Dict[str, Any]] = []
    for weighted, score, item, text in scored[:limit]:
        out.append(
            {
                "score": score,
                "weighted_score": round(weighted, 3),
                "kind": str(item.get("kind", "")),
                "updated_at": str(item.get("updated_at", "")),
                "text": text[:500],
            }
        )
    return out

def _extract_knowledge_topic(message: str) -> str:
    text = message.strip()
    lower = text.lower()
    patterns = [
        r"(?:was\s+wei(?:ss|ß)t\s+du\s+(?:über|ueber)\s+)(.+)\??$",
        r"(?:was\s+hatten\s+wir\s+zu\s+)(.+)\??$",
        r"(?:wie\s+ist\s+der\s+stand\s+zu\s+)(.+)\??$",
        r"(?:fasse\s+(?:den\s+)?stand\s+zu\s+)(.+)\s+zusammen$",
        r"(?:what\s+do\s+you\s+know\s+about\s+)(.+)\??$",
    ]
    for p in patterns:
        m = re.search(p, lower, flags=re.IGNORECASE)
        if m:
            topic = m.group(1).strip(" ?.")
            if topic:
                return topic
    return text

def _format_memory_hits_response(topic: str, hits: List[Dict[str, Any]]) -> str:
    if not hits:
        return ""
    # Prefer structured facts first, then context.
    ordered = sorted(
        hits,
        key=lambda h: (
            {"important": 0, "profile": 1, "script": 2, "web": 3, "conversation": 4}.get(str(h.get("kind", "")), 5),
            -float(h.get("weighted_score", 0)),
        ),
    )
    lines = [f"Gefundener Wissensstand zu: {topic}"]
    seen: set[str] = set()
    count = 0
    for h in ordered:
        txt = str(h.get("text", "")).strip()
        if not txt:
            continue
        key = txt.lower()
        if key in seen:
            continue
        seen.add(key)
        kind = str(h.get("kind", "memory"))
        lines.append(f"- [{kind}] {txt}")
        count += 1
        if count >= 5:
            break
    if count == 0:
        return ""
    return "\n".join(lines)

def _answer_from_memory_or_web(cfg: Dict[str, Any], message: str) -> Optional[str]:
    if not _is_information_query(message):
        return None
    if _is_source_provenance_query(message):
        return None

    topic = _extract_knowledge_topic(message)
    if _is_internal_memory_query(message):
        hits = _memory_hits_for_query(cfg, topic, limit=6)
        if hits:
            text = _format_memory_hits_response(topic, hits)
            if text:
                return text
    if _is_explicit_web_query(message) or _needs_factual_web_verification(message):
        verified = _web_verified_answer(cfg, topic or message)
        if verified:
            return verified
    return None

def _needs_factual_web_verification(message: str) -> bool:
    lower = (message or "").strip().lower()
    if not lower:
        return False
    dynamic_markers = [
        "aktuell",
        "aktuellste",
        "heute",
        "latest",
        "current",
        "news",
        "neueste",
        "stand heute",
        "dieses jahr",
        "this year",
    ]
    high_risk_entities = [
        "praesident",
        "präsident",
        "president",
        "kanzler",
        "prime minister",
        "ceo",
        "minister",
        "governor",
        "wahl",
        "election",
        "zins",
        "inflation",
        "kurs",
        "preis",
        "aktie",
        "bitcoin",
    ]
    asks_for_complete_list = bool(re.search(r"\b(liste|alle|complete list|vollstaendig)\b", lower))
    asks_time_sensitive = _has_any(lower, dynamic_markers)
    mentions_risk_entity = _has_any(lower, high_risk_entities)
    return asks_time_sensitive or (mentions_risk_entity and asks_for_complete_list) or (
        mentions_risk_entity and ("wer ist" in lower or "who is" in lower)
    )

def _web_verified_answer(cfg: Dict[str, Any], query: str, draft: str = "") -> Optional[str]:
    q = _normalize_web_query(query)
    if not q:
        return None
    web_cfg = cfg.get("web", {}) if isinstance(cfg.get("web", {}), dict) else {}
    try:
        max_sources = int(web_cfg.get("max_sources_default", 5) or 5)
    except Exception:
        max_sources = 5
    max_sources = max(3, min(8, max_sources))
    hits = _duckduckgo_search(cfg, q, limit=max_sources)
    if not hits:
        return None
    _register_web_sources(q, hits)

    evidence_lines: List[str] = []
    for i, item in enumerate(hits[:max_sources], start=1):
        title = str(item.get("title", "") or "(ohne Titel)")
        url = str(item.get("url", "") or "")
        domain = str(item.get("domain", "") or "")
        snippet = str(item.get("snippet", "") or "")
        evidence_lines.append(
            f"{i}. {title}\n"
            f"URL: {url}\n"
            f"Domain: {domain}\n"
            f"Snippet: {snippet}"
        )
    evidence_text = "\n\n".join(evidence_lines)
    today = datetime.now().strftime("%Y-%m-%d")
    prompt = (
        "Nutze ausschliesslich die folgenden Web-Treffer als Grundlage.\n"
        "Aufgabe: Beantworte die Frage praezise auf Deutsch.\n"
        "Regeln:\n"
        "- Kein Meta-Text, keine Tool-Erklaerungen.\n"
        "- Wenn Information zeitkritisch ist: nenne den Stand als Datum (YYYY-MM-DD).\n"
        "- Wenn etwas unklar ist, benenne es kurz.\n"
        "- Danach Abschnitt 'Quellen:' mit nummerierten URLs.\n\n"
        f"Heutiges Datum: {today}\n"
        f"Frage: {q}\n"
        f"Vorentwurf (optional): {str(draft or '')[:900]}\n\n"
        f"Treffer:\n{evidence_text}"
    )
    try:
        router = LLMRouter(cfg)
        res = router.chat(prompt)
        reply = sanitize_user_facing_reply(str(res.text or "").strip())
        if reply:
            return reply
    except Exception as exc:
        tool_store.log("web_verify_error", f"llm_synthesis_failed: {exc}")

    lines = [f"Web-Treffer zu: {q}", ""]
    for i, item in enumerate(hits[:max_sources], start=1):
        title = str(item.get("title", "") or "(ohne Titel)")
        url = str(item.get("url", "") or "")
        domain = str(item.get("domain", "") or "")
        snippet = str(item.get("snippet", "") or "")
        lines.append(f"{i}. {title} ({domain})")
        if snippet:
            lines.append(f"   {snippet}")
        lines.append(f"   {url}")
    return "\n".join(lines)

