            lower,
            flags=re.IGNORECASE,
        )
    )
    if screenshot_make:
        return True
    return _has_any(lower, action_verbs) and _has_any(lower, action_objects)

def _find_recent_shareable_file(cfg: Dict[str, Any], hint_text: str) -> Optional[Path]:
    workspace = _workspace_abs(cfg)
    if not workspace.exists():
        return None
    terms = set(_query_terms(hint_text))
    screenshot_terms = {"screenshot", "screen", "bild", "bildschirmfoto"}
    image_ext = {".png", ".jpg", ".jpeg", ".bmp", ".gif", ".webp"}
    text_ext = {".txt", ".md", ".log", ".json", ".yaml", ".yml", ".csv"}
    asks_visual = bool(screenshot_terms.intersection(terms))
    now = time.time()
    best: Optional[Path] = None
    best_score = -1.0
    blocked = {".py", ".ps1", ".bat", ".cmd", ".sh"}
    # Interne Bot-Ordner und System-Dateien nie automatisch zurückgeben
    internal_dirs = {"reports", "__pycache__", ".git"}
    # Punkt-Dateien (versteckte/interne Dateien) ausschließen
    blocked_names = {".tg_offset", ".env", ".gitignore"}
    for p in workspace.rglob("*"):
        try:
            if not p.is_file():
                continue
            if p.suffix.lower() in blocked:
                continue
            if p.name.startswith(".") or p.name in blocked_names:
                continue
            if p.name.lower().startswith("self_improve_") or p.name.lower().startswith("auto_self_improve_"):
                continue
            # Dateien in internen Unterordnern ausschließen
            rel_parts = {part.lower() for part in p.relative_to(workspace).parts[:-1]}
            if rel_parts.intersection(internal_dirs):
                continue
            st = p.stat()
            age_sec = max(1.0, now - float(st.st_mtime))
            name_l = p.name.lower()
            score = 0.0
            if terms:
                overlap = sum(1 for t in terms if t in name_l)
                score += overlap * 2.0
            if any(k in name_l for k in screenshot_terms):
                score += 3.0
            ext = p.suffix.lower()
            if asks_visual:
                if ext in image_ext:
                    score += 5.0
                elif ext in text_ext:
                    score -= 3.0
            recency = 1.0 / (1.0 + age_sec / 3600.0)
            score += recency * 2.5
            # Keine pure-recency-Treffer: ohne Term-Übereinstimmung muss Score > Schwellwert liegen
            if terms and overlap == 0 and score < 2.0:
                continue
            if score > best_score:
                best_score = score
                best = p.resolve()
        except Exception:
            continue
    if asks_visual and best is not None and best.suffix.lower() not in image_ext:
        return None
    return best

def _is_recent_file(path: Path, max_age_sec: int = 600) -> bool:
    try:
        if not path.exists() or not path.is_file():
            return False
        age = time.time() - float(path.stat().st_mtime)
        return age <= float(max_age_sec)
    except Exception:
        return False


def _is_shareable_session_artifact(path: Path, cfg: Optional[Dict[str, Any]] = None) -> bool:
    try:
        p = path.resolve()
        if not p.exists() or not p.is_file():
            return False
    except Exception:
        return False

    name_low = p.name.lower()
    if name_low in {
        ".tg_offset",
        ".env",
        ".gitignore",
        "intent_feedback.jsonl",
        "messenger_delivery.log",
        "audit.log",
        "execution_plane.log",
        "errors.log",
    }:
        return False
    if name_low.startswith("self_improve_") or name_low.startswith("auto_self_improve_"):
        return False

    def _within(base: Path, cand: Path) -> bool:
        try:
            cand.resolve().relative_to(base.resolve())
            return True
        except Exception:
            return False

    cfg_local = cfg if isinstance(cfg, dict) else _cfg()
    ws = _workspace_abs(cfg_local)
    blocked_roots = [
        (ROOT_DIR / "data" / "logs").resolve(),
        (ROOT_DIR / ".tmp").resolve(),
        (ws / "reports").resolve(),
    ]
    for b in blocked_roots:
        if _within(b, p):
            return False
    return True


