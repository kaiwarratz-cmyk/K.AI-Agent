def _infer_artifact_from_reply(cfg: Dict[str, Any], reply: str) -> Optional[Path]:
    """LLM-basierte Extraktion von Dateipfaden aus Agent-Antworten."""
    text = str(reply or "").strip()
    if not text:
        return None
    
    # LLM-basierte Extraktion - keine starren Regex-Patterns mehr
    try:
        router = LLMRouter(cfg)
        schema: Dict[str, Any] = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "file_path": {"type": "string"},
                "found": {"type": "boolean"},
            },
            "required": ["file_path", "found"],
        }
        prompt = (
            "Extrahiere den Dateipfad aus der folgenden Agent-Antwort.\n"
            "Wenn ein Dateipfad erwähnt wird (z.B. nach 'Datei geschrieben:', 'Gespeichert unter:', 'Screenshot:', etc.), "
            "gib ihn vollständig zurück. Achte auf Pfade mit Leerzeichen und Sonderzeichen.\n"
            "Wenn kein Dateipfad gefunden wird, setze found=false.\n\n"
            f"Agent-Antwort:\n{text[:500]}\n\n"
            'Antwort als JSON: {"file_path": "C:\\\\path\\\\to\\\\file.ext", "found": true}'
        )
        try:
            obj = router.chat_json(prompt=prompt, schema_name="extract_file_path_v1", schema=schema)
        except Exception:
            raw = router.chat(prompt)
            obj = _extract_json_dict(str(raw.text or ""))
        
        if isinstance(obj, dict) and obj.get("found") and obj.get("file_path"):
            cand = Path(str(obj["file_path"]).strip())
            if cand.exists() and cand.is_file() and _is_shareable_session_artifact(cand, cfg):
                return cand.resolve()
    except Exception as exc:
        tool_store.log("llm_artifact_extract_error", str(exc))
    
    return None


def _artifact_from_action_payload(cfg: Dict[str, Any], action: Dict[str, Any]) -> Optional[Path]:
    if not isinstance(action, dict):
        return None
    ws = _workspace_abs(cfg)
    key_order = [
        "script_path",
        "output_path",
        "file_path",
        "pdf_path",
        "target_path",
        "save_path",
        "out_path",
        "path",
    ]
    for k in key_order:
        raw = str(action.get(k, "") or "").strip().strip("`").strip("\"'")
        if not raw:
            continue
        cand = _extract_any_path(raw) or raw
        if not cand:
            continue
        try:
            p = Path(cand)
            if not p.is_absolute():
                p = (ws / p).resolve()
            else:
                p = p.resolve()
            if p.exists() and p.is_file() and _is_shareable_session_artifact(p, cfg):
                return p
        except Exception:
            continue
    return None


def _remember_session_artifact_from_result(
    cfg: Dict[str, Any],
    dialog_key: str,
    action: Dict[str, Any],
    reply: str,
    message: str,
) -> None:
    key = str(dialog_key or "").strip()
    if not key:
        return
    direct = _artifact_from_action_payload(cfg, action)
    if direct is not None:
        _set_session_last_artifact(key, direct)
        return
    inferred = _infer_artifact_from_reply(cfg, reply)
    if inferred is not None:
        _set_session_last_artifact(key, inferred)
        return
    with contextlib.suppress(Exception):
        hint = str(message or "")
        p = _find_recent_shareable_file(cfg, hint)
        if not p:
            p = _find_recent_shareable_file(cfg, "screenshot")
        if not p:
            p = _find_recent_shareable_file(cfg, "")
        if p and p.exists() and p.is_file():
            _set_session_last_artifact(key, p)

