        '$b.Save($p)\\n$g.Dispose()\\n$b.Dispose()\\nWrite-Output $p"}\n'
        '  ],\n'
        '  "reasoning": "SetProcessDPIAware liefert physische Pixel (korrekt bei DPI-Skalierung). VirtualScreen erfasst alle Monitore."\n'
        "}\n\n"
        "ACTION CATALOG:\n" + catalog_text[:4000] + "\n\n"
        "NUTZERANWEISUNG: " + message[:600] + "\n\n"
        'Antworte als JSON: {"steps": [...], "reasoning": "..."}\n'
        "Jeder Step MUSS alle required-Felder aus dem Catalog befüllen."
    )
    if core_mode:
        prompt += (
            "\n\nCLI-CORE-MODUS AKTIV:\n"
            "- Plane nur Actions aus dem Core-Catalog.\n"
            "- Bevorzuge bestehende MCP-Tools.\n"
            "- Falls direkter Code nötig: shell_command nutzen."
        )
    try:
        router = LLMRouter(cfg)
        raw_result = router.chat(prompt=prompt)
        raw_text = raw_result.text if hasattr(raw_result, "text") else str(raw_result)
        if not raw_text:
            return None
        # JSON aus Antwort extrahieren (LLM kann Markdown-Wrapper hinzufügen)
        json_match = re.search(r"\{.*\}", raw_text, re.DOTALL)
        if not json_match:
            _audit_event("react_plan_error", {"dialog_key": dialog_key, "error": "no JSON in response"})
            return None
        result = json.loads(json_match.group(0))
        if not isinstance(result, dict):
            return None
        steps = result.get("steps")
        if not isinstance(steps, list) or len(steps) < 2:
            return None
        # Validiere jeden Step grob
        valid_steps = []
        for step in steps[:_REACT_MAX_STEPS]:
            if not isinstance(step, dict):
                continue
            kind = str(step.get("kind", "") or "").strip()
            if not kind:
                continue
            valid_steps.append(step)
        if len(valid_steps) < 2:
            return None
        _audit_event("react_plan", {
            "dialog_key": dialog_key,
