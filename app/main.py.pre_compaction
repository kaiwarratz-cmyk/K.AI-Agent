def _memory_store(cfg: Dict[str, Any]) -> ChromaMemoryStore:
    global _memory_store_cache, _memory_store_cache_path
    db_path = ROOT_DIR / cfg.get("memory", {}).get("db_path", "data/chroma_memory")
    db_path_str = str(db_path)
    if _memory_store_cache is None or _memory_store_cache_path != db_path_str:
        _memory_store_cache = ChromaMemoryStore(db_path)
        _memory_store_cache_path = db_path_str
    return _memory_store_cache

def _secret_store(cfg: Dict[str, Any]) -> SecretStore:
    sec = cfg.get("security", {}) if isinstance(cfg.get("security", {}), dict) else {}
    raw = str(sec.get("secrets_db_path", "data/secrets.db") or "data/secrets.db")
    p = Path(raw)
    db_path = p if p.is_absolute() else (ROOT_DIR / p)
    return SecretStore(db_path)

