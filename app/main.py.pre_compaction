            "steps_preview": [str(s.get("kind", "?")) for s in valid_steps],
        })
        return valid_steps
    except Exception as exc:
        _audit_event("react_plan_error", {"dialog_key": dialog_key, "error": str(exc)[:200]})
        return None

def _send_telegram_reply(cfg: Dict[str, Any], dialog_key: str, text: str) -> None:
    """Sendet eine Nachricht direkt an Telegram (für /api/chat Endpoint)."""
    if not dialog_key.startswith("telegram:"):
        return
    
    chat_id = dialog_key.split(":", 1)[1]
    tg = cfg.get("messenger", {}).get("telegram", {}) if isinstance(cfg.get("messenger", {}).get("telegram", {}), dict) else {}
    token = str(tg.get("token", "") or "").strip()
    
    if not token or not chat_id:
        tool_store.log("telegram_send_error", "Token oder Chat-ID fehlt")
        return
    
    import httpx as _httpx
    import time
    
    msg = str(text or "").strip()
    if not msg:
        return
    
    # Escape Markdown-Zeichen
    safe_text = msg.replace("_", "\\_").replace("*", "\\*").replace("[", "\\[").replace("`", "\\`")
    
    # Retry-Logik
    max_retries = 3
    retry_delay = 1
    
    for attempt in range(max_retries):
        try:
            with _httpx.Client(timeout=20, trust_env=False) as _c:
                # Chunking für lange Nachrichten
                chunk_size = 3900
                all_chunks_ok = True
                for i in range(0, len(safe_text), chunk_size):
                    chunk = safe_text[i:i + chunk_size]
                    resp = _c.post(
                        f"https://api.telegram.org/bot{token}/sendMessage",
                        json={"chat_id": chat_id, "text": chunk, "parse_mode": "Markdown"},
                    )
                    
                    if resp.status_code == 200:
                        tool_store.log("telegram_reply_sent", f"Antwort gesendet: {chunk[:80]}")
                        continue  # Nächster Chunk
                    elif resp.status_code == 400:
                        # Markdown-Fehler → ohne parse_mode
                        resp = _c.post(
                            f"https://api.telegram.org/bot{token}/sendMessage",
                            json={"chat_id": chat_id, "text": msg[i:i + chunk_size]},
                        )
                        if resp.status_code == 200:
                            tool_store.log("telegram_reply_sent", f"Antwort gesendet (plain): {chunk[:80]}")
                            continue
                    elif resp.status_code == 429:
                        # Rate-Limiting
                        retry_after = resp.json().get("parameters", {}).get("retry_after", 5)
                        tool_store.log("telegram_rate_limit", f"Warte {retry_after}s")
                        time.sleep(retry_after)
                        continue
                    
                    # Fehler
                    if attempt < max_retries - 1:
                        tool_store.log("telegram_retry", f"Versuch {attempt + 1} fehlgeschlagen (Status {resp.status_code}), retry...")
                        time.sleep(retry_delay * (attempt + 1))
                        all_chunks_ok = False
                        break
                    else:
                        tool_store.log("telegram_send_failed", f"Nach {max_retries} Versuchen fehlgeschlagen (Status {resp.status_code})")
                        all_chunks_ok = False
                        break
                if all_chunks_ok:
                    return
        except Exception as e:
            if attempt < max_retries - 1:
                tool_store.log("telegram_retry", f"Versuch {attempt + 1} Exception: {e}, retry...")
                time.sleep(retry_delay * (attempt + 1))
            else:
                tool_store.log("telegram_send_exception", f"Nach {max_retries} Versuchen Exception: {e}")

def _send_messenger_file(cfg: Dict[str, Any], dialog_key: str, file_path: str, caption: str = "") -> str:
    """Sendet eine Datei an den aktiven Messenger-Chat (Telegram oder Discord).
    Wählt automatisch den richtigen API-Endpoint je nach Dateityp:
    - Audio (.mp3, .ogg, .wav, .m4a, .opus) → sendVoice (abspielbar im Chat)
    - Video (.mp4, .mov, .avi)               → sendVideo (Player im Chat)
    - Bilder (.jpg, .png, .gif, .webp)       → sendPhoto (Vorschau im Chat)
    - Alles andere                           → sendDocument
    """
    import httpx as _httpx
    from pathlib import Path as _Path

    p = _Path(file_path)
    if not p.exists():
        return f"Datei nicht gefunden: {file_path}"
    if not p.is_file():
        return f"Pfad ist kein File: {file_path}"

    ext = p.suffix.lower()
    _AUDIO_EXTS = {".mp3", ".ogg", ".oga", ".wav", ".m4a", ".opus"}
    _VIDEO_EXTS = {".mp4", ".mov", ".avi", ".mkv"}
    _IMAGE_EXTS = {".jpg", ".jpeg", ".png", ".gif", ".webp"}

    cap = caption[:1024] if caption else ""

    try:
        if dialog_key.startswith("telegram:"):
            chat_id = dialog_key.split(":", 1)[1]
            tg = cfg.get("messenger", {}).get("telegram", {}) if isinstance(cfg.get("messenger", {}).get("telegram", {}), dict) else {}
            token = str(tg.get("token", "") or "").strip()
            if not token or not chat_id:
                return "Telegram Token oder Chat-ID fehlt."
            base = f"https://api.telegram.org/bot{token}"
            with _httpx.Client(timeout=60, trust_env=False) as _c:
                with open(p, "rb") as fh:
                    if ext in _AUDIO_EXTS:
                        endpoint = f"{base}/sendVoice"
                        files = {"voice": (p.name, fh)}
                        file_type = "Voice"
                    elif ext in _VIDEO_EXTS:
                        endpoint = f"{base}/sendVideo"
                        files = {"video": (p.name, fh)}
                        file_type = "Video"
                    elif ext in _IMAGE_EXTS:
                        endpoint = f"{base}/sendPhoto"
                        files = {"photo": (p.name, fh)}
                        file_type = "Photo"
                    else:
                        endpoint = f"{base}/sendDocument"
                        files = {"document": (p.name, fh)}
                        file_type = "Document"
                    resp = _c.post(endpoint, data={"chat_id": chat_id, "caption": cap}, files=files)
            if resp.status_code == 200 and resp.json().get("ok"):
                tool_store.log("messenger_file_sent", f"Telegram ({file_type}): {p.name} -> {chat_id}")
                return f"Datei '{p.name}' erfolgreich als {file_type} an Telegram gesendet."
            return f"Telegram-Fehler {resp.status_code}: {resp.text[:200]}"

        elif dialog_key.startswith("discord:") or dialog_key.startswith("dc:"):
            channel_id = dialog_key.split(":", 1)[1]
            dc = cfg.get("messenger", {}).get("discord", {}) if isinstance(cfg.get("messenger", {}).get("discord", {}), dict) else {}
            token = str(dc.get("token", "") or "").strip()
            if not token or not channel_id:
                return "Discord Token oder Channel-ID fehlt."
            headers = {"Authorization": f"Bot {token}"}
            # Discord unterstützt keinen separaten Voice/Video Endpoint — alle Typen via files[]
            with _httpx.Client(timeout=60, trust_env=False) as _c:
                with open(p, "rb") as fh:
                    resp = _c.post(
                        f"https://discord.com/api/v10/channels/{channel_id}/messages",
                        headers=headers,
                        data={"content": caption or ""},
                        files={"files[0]": (p.name, fh)},
                    )
            if resp.status_code in (200, 201):
                tool_store.log("messenger_file_sent", f"Discord: {p.name} -> {channel_id}")
                return f"Datei '{p.name}' erfolgreich an Discord gesendet."
            return f"Discord-Fehler {resp.status_code}: {resp.text[:200]}"

        return f"Unbekannter Messenger-Dialog: {dialog_key}"
    except Exception as exc:
        tool_store.log("messenger_file_error", str(exc))
        return f"Fehler beim Senden: {exc}"


def _send_messenger_typing(cfg: Dict[str, Any], dialog_key: str, platform: str) -> None:
    """Sendet einen Typing-Indikator an den entsprechenden Messenger (Fire-and-Forget)."""
    def _run_typing():
        try:
            if platform == "telegram" and dialog_key.startswith("telegram:"):
                chat_id = dialog_key.split(":", 1)[1]
                tg = cfg.get("messenger", {}).get("telegram", {}) if isinstance(cfg.get("messenger", {}).get("telegram", {}), dict) else {}
                token = str(tg.get("token", "") or "").strip()
                if token and chat_id:
                    with httpx.Client(timeout=5, trust_env=False) as _c:
                        _c.post(f"https://api.telegram.org/bot{token}/sendChatAction", json={"chat_id": chat_id, "action": "typing"})
            elif platform == "discord" and dialog_key:
                channel_id = dialog_key.split(":", 1)[1] if ":" in dialog_key else dialog_key
                dc = cfg.get("messenger", {}).get("discord", {}) if isinstance(cfg.get("messenger", {}).get("discord", {}), dict) else {}
                token = str(dc.get("token", "") or "").strip()
                if token and channel_id:
                    headers = {"Authorization": f"Bot {token}"}
                    with httpx.Client(timeout=5, trust_env=False) as _c:
                        _c.post(f"https://discord.com/api/v10/channels/{channel_id}/typing", headers=headers)
        except Exception:
            pass
    
    # Immer in eigenem Thread starten um Hauptthread NIEMALS zu blockieren
    threading.Thread(target=_run_typing, daemon=True).start()

def _react_push_status(text: str, cfg: Dict[str, Any], dialog_key: str, is_thought: bool = False) -> None:
    """
    Sendet Zwischenstatus nur an den Kanal der Anfrage (Telegram ODER WebUI – kein Cross-Channel).

    is_thought=True: Gedanken werden als NEUE Nachrichten gesendet
    is_thought=False: Aktionen/Beobachtungen werden als NEUE Nachrichten gesendet (KEINE Editierung!)
    WICHTIG: ALLE Nachrichten erhalten eindeutige message_ids, NICHTS wird überschrieben!
    """
    try:
        # DEBUG: Logge ALLE eingehenden Status-Meldungen zur Diagnose
        tool_store.log("react_status_call", f"[{'THOUGHT' if is_thought else 'ACTION'}] {text[:100]}")
        # Quiet Mode Filterung (global für alle Kanäle)
        ui_cfg = cfg.get("ui", {}) if isinstance(cfg.get("ui", {}), dict) else {}
        quiet_mode = bool(ui_cfg.get("quiet_mode", False))
        show_thinking = bool(ui_cfg.get("show_thinking", True))  # Default: True
        show_actions = bool(ui_cfg.get("show_actions", True))    # Default: True

        # Wenn Quiet Mode NICHT aktiv, zeige alles
        if quiet_mode:
            # Quiet Mode aktiv → prüfe is_thought Parameter (nicht Text-Analyse!)
            # Das ist VIEL zuverlässiger als Text zu analysieren
            if is_thought and not show_thinking:
                tool_store.log("react_status_filtered", f"Gedanke unterdrückt (Quiet Mode): {text[:80]}")
                return

            if not is_thought and not show_actions:
                tool_store.log("react_status_filtered", f"Aktion unterdrückt (Quiet Mode): {text[:80]}")
                return
        
        if dialog_key.startswith("telegram:"):
            chat_id = dialog_key.split(":", 1)[1]
            tg = cfg.get("messenger", {}).get("telegram", {}) if isinstance(cfg.get("messenger", {}).get("telegram", {}), dict) else {}
            token = str(tg.get("token", "") or "").strip()
            if not token or not chat_id: return

            import httpx as _httpx
            import time

            # Simple text without aggressive escaping to keep icons alive
            import html
            clean_text = html.escape(text)

            # WICHTIG: ALLE Nachrichten werden als NEUE Nachrichten gesendet (KEINE Editierung!)
            # Grund: Wenn wir editieren, überschreiben wir die vorherigen Ausgaben
            # Besser: Viele Nachrichten als Ausgaben zu sehen, statt Ausgaben zu verlieren
            for attempt in range(2):
                try:
                    with _httpx.Client(timeout=20, trust_env=False) as _c:
                        resp = _c.post(
                            f"https://api.telegram.org/bot{token}/sendMessage",
                            json={"chat_id": chat_id, "text": clean_text, "parse_mode": "HTML"},
                        )
                        if resp.status_code == 200:
                            new_msg_id = (resp.json().get("result") or {}).get("message_id")
                            tool_store.log("telegram_message_sent", f"Nachricht gesendet (HTML): msg_id={new_msg_id}, is_thought={is_thought}")
                            return
                        # Fallback: plain text (HTML-Parsing fehlgeschlagen)
                        tool_store.log("telegram_message_fallback", f"HTML-Modus fehlgeschlagen ({resp.status_code}), verwende Fallback")
                        resp2 = _c.post(
                            f"https://api.telegram.org/bot{token}/sendMessage",
                            json={"chat_id": chat_id, "text": text},
                        )
                        if resp2.status_code == 200:
                            tool_store.log("telegram_message_sent", f"Nachricht gesendet (Fallback): is_thought={is_thought}")
                            return
                        # Beide Versuche fehlgeschlagen
                        tool_store.log("telegram_message_error", f"Nachricht konnte nicht gesendet werden (HTML: {resp.status_code}, Fallback: {resp2.status_code})")
                        return
                except Exception as e:
                    tool_store.log("telegram_message_exception", f"Versuch {attempt+1}/2 fehlgeschlagen: {str(e)[:100]}")
                    if attempt == 0:
                        time.sleep(1)
                    else:
                        return  # Nach 2 Versuchen abbrechen
        elif dialog_key.startswith("discord:") or dialog_key.startswith("dc:"):
            # Discord: Status über Bot-API senden (kein Webhook nötig)
            try:
                dc = cfg.get("messenger", {}).get("discord", {}) if isinstance(cfg.get("messenger", {}).get("discord", {}), dict) else {}
                channel_id = dialog_key.split(":", 1)[1] if ":" in dialog_key else ""
                token = str(dc.get("token", "") or "").strip()
                webhook_url = str(dc.get("webhook_url", "") or "").strip() or str(dc.get("webhook", "") or "").strip()

                if not channel_id:
                    tool_store.log("discord_status_skipped", "Keine Channel-ID in dialog_key")
                elif webhook_url:
                    import httpx as _httpx
                    safe_text = text[:1900]
                    resp = _httpx.Client(timeout=20, trust_env=False).post(
                        webhook_url, json={"content": safe_text, "username": "K.AI"}
                    )
                    if resp.status_code in [200, 204]:
                        tool_store.log("discord_status_sent", f"Status gesendet (webhook): {text[:80]}")
                        return
                    else:
                        tool_store.log("discord_status_error", f"Webhook fehlgeschlagen: {resp.status_code}")
                elif token:
                    import httpx as _httpx
                    resp = _httpx.Client(timeout=20, trust_env=False).post(
                        f"https://discord.com/api/v10/channels/{channel_id}/messages",
                        headers={"Authorization": f"Bot {token}", "Content-Type": "application/json"},
                        json={"content": text[:1900]},
                    )
                    if resp.status_code in [200, 201]:
                        tool_store.log("discord_status_sent", f"Status gesendet (bot-api): {text[:80]}")
                        return
                    else:
                        tool_store.log("discord_status_error", f"Bot-API fehlgeschlagen: {resp.status_code} {resp.text[:100]}")
                else:
                    tool_store.log("discord_status_skipped", "Kein Token und kein Webhook konfiguriert")
            except Exception as discord_err:
                tool_store.log("discord_status_exception", f"Discord-Fehler: {discord_err}")
        else:
            # WebUI oder unbekannter Kanal → WebUI-Queue
            _webui_push_notification(text, source="react_plan", platform="webui", target="webui")
    except Exception as e:
        tool_store.log("react_push_status_error", f"Fehler: {e}")

def _execute_react_plan(
    message: str,
    steps: List[Dict[str, Any]],
    cfg: Dict[str, Any],
    dialog_key: str = "",
    approved: bool = False,
) -> Dict[str, Any]:
    """Führt einen ReAct-Plan sequentiell aus.
    Gibt ein kombiniertes Ergebnis mit allen Schritt-Replies zurück.
    approved=True überspringt den Approval-Check (bereits erteilt)."""
    step_results: List[Dict[str, Any]] = []
    reply_parts: List[str] = []
    mode = execution_mode(cfg)

    # ── Temporäre Plan-Datei für komplexe Aufgaben ──────────────────────
    _task_planner = None
    try:
        from app.task_planner import get_planner
        _planner_inst = get_planner(cfg)
        if _planner_inst.should_plan(message) and len(steps) > 1:
            _planner_inst.create_hierarchical_plan(message, steps)
            _task_planner = _planner_inst
            _react_push_status(_planner_inst.get_summary(), cfg, dialog_key)
    except Exception as exc:
        tool_store.log("task_planner_error", f"Plan-Datei konnte nicht erstellt werden: {exc}")

    for i, step in enumerate(steps):
        # Abbruch-Check
        trace_id = _trace_id_ctx.get()
        if _job_is_cancelled(trace_id):
            _react_push_status(f"❌ Job abgebrochen bei Schritt {i+1}/{len(steps)}", cfg, dialog_key)
            return {"ok": False, "reply": f"Job wurde abgebrochen (Schritt {i+1}/{len(steps)})."}

        # Referenzen aus vorherigen Schritten einsetzen
        resolved = _resolve_step_refs(dict(step), step_results)
        # message einbetten für stabilen action_hash (Allowlist-Matching)
        if not resolved.get("message"):
            resolved["message"] = str(message).strip().lower()
        kind = str(resolved.get("kind", "") or "").strip()

        # ── Status-Push: Schritt gestartet ──
        _react_push_status(f"⏳ Schritt {i+1}/{len(steps)} `{kind}` läuft...", cfg, dialog_key)
        if _task_planner:
            _task_planner.update_step(i, "running")
        # ── Korrekturschicht: Script vor Ausführung prüfen und ggf. fixen ──
        if kind == "script_create" and resolved.get("script"):
            raw_code = str(resolved["script"])
            script_path = str(resolved.get("script_path", ""))
            script_type = str(resolved.get("script_type", "python"))
            fixed_code, did_fix, issues = _validate_and_fix_script(
                cfg, raw_code, script_path, script_type
            )
            if did_fix:
                resolved = dict(resolved)
                resolved["script"] = fixed_code
                _audit_event("react_script_corrected", {
                    "step": i, "issues": issues, "script_path": script_path
                })

        try:
            result = _run_llm_planned_action(
                cfg=cfg,
                message=message,
                action=resolved,
                note=f"react_step_{i}:{kind}",
                dialog_key=dialog_key,
                pre_approved=approved,
            )
        except Exception as exc:
            result = {"ok": False, "reply": f"Fehler in Schritt {i+1} ({kind}): {exc}"}

        ok = bool(result.get("ok", False))
        reply = str(result.get("reply", ""))

        # Timeout mit Teiloutput: wenn script_exec timeoutet aber stdout enthält Ergebnisse → als Erfolg werten
        if not ok and kind in {"script_exec", "powershell_exec", "python_exec"} and "returncode=-124" in reply:
            stdout_lines = [ln for ln in reply.splitlines() if ln.strip() and not ln.startswith("returncode") and not ln.startswith("stdout:") and not ln.startswith("stderr:")]
            if stdout_lines:
                ok = True
                reply = "returncode=0 (Timeout – Teilergebnisse)\n\nstdout:\n" + "\n".join(stdout_lines)
                _audit_event("react_script_timeout_partial", {"dialog_key": dialog_key, "step": i, "lines": len(stdout_lines)})

        # Ersten gültigen Dateipfad aus dem Output extrahieren
        _file_path_m = re.search(
            r'([A-Za-z]:\\[^\n\r"\'<>|?*]+\.(?:png|jpg|jpeg|gif|bmp|txt|csv|json|md|pdf|zip|log))',
            reply, re.IGNORECASE
        )
        _extracted_file_path = _file_path_m.group(1).strip() if _file_path_m else ""

        # Ergebnis-Metadaten für Referenzierung sammeln
        step_result: Dict[str, Any] = {
            "ok": ok,
            "reply": reply,
            # Bei Fehler/Timeout kein Fehlertext als output weitergeben (write_file würde sonst Fehlertext speichern)
            "output": reply if ok else "",
            # Erster extrahierter Dateipfad aus dem Output (z.B. nach script_exec)
            "file_path": _extracted_file_path,
            "kind": kind,
            # Für script_create: script_path aus Step-Definition übernehmen
            "script_path": str(resolved.get("script_path", "")),
            # Für cron_create: job_id aus Reply extrahieren
            "job_id": "",
        }
        if kind == "cron_create" and reply:
            m_jid = re.search(r"(cron-[a-f0-9]+)", reply)
            if m_jid:
                step_result["job_id"] = m_jid.group(1)

        step_results.append(step_result)
        label = f"Schritt {i+1}/{len(steps)} `{kind}`"
        if ok:
            short_reply = reply[:120].replace("\n", " ").strip()
            _react_push_status(f"✅ {label} abgeschlossen" + (f": {short_reply}" if short_reply else ""), cfg, dialog_key)
            reply_parts.append(f"✅ {label}: {reply[:300]}")
            if _task_planner:
                _task_planner.update_step(i, "done")
        else:
            short_reply = reply[:120].replace("\n", " ").strip()
            _react_push_status(f"❌ {label} fehlgeschlagen: {short_reply}", cfg, dialog_key)
            reply_parts.append(f"❌ {label}: {reply[:300]}")
            if _task_planner:
                _task_planner.update_step(i, "failed")
            # Bei Fehler: abbrechen
            break

        _audit_event("react_step_done", {
            "dialog_key": dialog_key,
            "step": i,
            "kind": kind,
            "ok": ok,
            "reply_preview": reply[:120],
        })

    all_ok = all(r.get("ok", False) for r in step_results)
    combined_reply = "\n\n".join(reply_parts)
    if all_ok:
        combined_reply = f"**Plan abgeschlossen ({len(step_results)} Schritte):**\n\n" + combined_reply
    else:
        # Finde den fehlgeschlagenen Schritt und hänge dessen Antwort explizit an
        failed_idx = next((i for i, r in enumerate(step_results) if not r.get("ok")), -1)
        if failed_idx != -1:
            err_detail = step_results[failed_idx].get("reply", "Unbekannter Fehler")
            combined_reply = f"**Plan fehlgeschlagen in Schritt {failed_idx+1}:**\n\n{combined_reply}\n\n**Fehlermeldung:**\n{err_detail}"
        else:
            combined_reply = f"**Plan teilweise ausgeführt:**\n\n" + combined_reply

    # ── Plan-Datei archivieren ───────────────────────────────────────────
    if _task_planner:
        # TaskPlanner kümmert sich intern um den Status
        pass

    return {"ok": all_ok, "reply": combined_reply}

def _execute_react_plan_with_retry(
    message: str,
    steps: List[Dict[str, Any]],
    cfg: Dict[str, Any],
    dialog_key: str = "",
    approved: bool = False,
    retry_count: int = 0,
) -> Dict[str, Any]:
    """
    Führt ReAct-Plan aus mit automatischem Retry bei Fehler.
    Bei Fehler wird LLM um alternativen Plan gebeten.
    """
    react_cfg = cfg.get("react", {}) if isinstance(cfg.get("react", {}), dict) else {}
    max_retries = int(react_cfg.get("max_retries", 3))
    retry_enabled = bool(react_cfg.get("retry_enabled", True))
    
    # Plan ausführen
    _audit_event("react_loop_start", {"trace_id": _trace_id_ctx.get(), "message": message[:100]})
    result = _execute_react_plan(message, steps, cfg, dialog_key, approved)
    
    # Erfolg oder Retry deaktiviert oder Max erreicht
    if result.get("ok") or not retry_enabled or retry_count >= max_retries:
        if not result.get("ok") and retry_count >= max_retries:
            result["reply"] = f"**Maximale Versuche ({max_retries + 1}) erreicht.**\n\n" + result.get("reply", "")
        return result
    
    # Fehler → Retry
    error_msg = result.get("reply", "Unbekannter Fehler")
    
    # Extrahiere nur die Fehlerzeile für klarere LLM-Instruktion
    error_lines = [line for line in error_msg.split("\n") if "❌" in line or "Fehler" in line]
    short_error = error_lines[0] if error_lines else error_msg[:200]
    
    tool_store.log("react_retry", f"Versuch {retry_count + 1} fehlgeschlagen: {short_error[:100]}")
    _react_push_status(f"🔄 Versuch {retry_count + 1}/{max_retries + 1} fehlgeschlagen, erstelle alternativen Plan...", cfg, dialog_key)
    
    # Neuen Plan vom LLM anfordern mit Fehlerkontext
    # WICHTIG: Kurze, prägnante Nachricht damit sie nicht abgeschnitten wird (max 600 Zeichen in _llm_plan_react)
    retry_message = f"""FEHLER beim vorherigen Plan: {short_error}

Ursprüngliche Anfrage: {message[:300]}

ERSTELLE ALTERNATIVEN PLAN der diesen Fehler vermeidet!
KRITISCH: Wenn Tools Parameter wie url, output_dir brauchen, müssen diese EXPLIZIT angegeben oder aus vorherigen Schritten kommen!"""
    
    # LLM um neuen Plan bitten
    try:
        tool_store.log("react_retry", f"Fordere neuen Plan an (Versuch {retry_count + 2}/{max_retries + 1})")
        new_steps = _llm_plan_react(retry_message, cfg, dialog_key)
        
        if not new_steps or not isinstance(new_steps, list):
            tool_store.log("react_retry", f"Kein neuer Plan erhalten, gebe auf")
            return result  # Kein neuer Plan möglich, gib ursprünglichen Fehler zurück
        
        tool_store.log("react_retry", f"Neuer Plan mit {len(new_steps)} Schritten erhalten")
        
        # Rekursiv mit neuem Plan
        return _execute_react_plan_with_retry(
            message=message,
            steps=new_steps,
            cfg=cfg,
            dialog_key=dialog_key,
            approved=approved,
            retry_count=retry_count + 1
        )
    except Exception as exc:
        # Bei Fehler beim Retry, gib ursprünglichen Fehler zurück
        tool_store.log("react_retry_error", f"Retry fehlgeschlagen: {exc}")
        return result

def _auto_extract_facts_bg(
    cfg: Dict[str, Any],
    message: str,
    steps: List[Dict[str, Any]],
    final_reply: str,
    ctx_mgr: Any,
    mem_save_called: bool,
) -> None:
    """
    ChatGPT-Style Auto-Memory: extrahiert automatisch Fakten aus abgeschlossenen Jobs.
    Läuft als Daemon-Thread im Hintergrund — keine Latenz für den Nutzer.
    Sicherheitsnetz wenn das LLM mem_save_fact vergessen hat.
    """
    if not steps or len(steps) < 2:
        return  # Zu kurzer Job, nichts Sinnvolles zu extrahieren

    def _worker():
        try:
            from app.llm_router import LLMRouter

            # Bestehende Fakten-Keys — keine Duplikate speichern
            existing = set(ctx_mgr.read_facts_with_meta().keys())

            # Kompakte Job-Zusammenfassung (max 2000 Zeichen)
            steps_lines = []
            for s in steps[-15:]:
                kind = s.get("kind", "?")
                reply_snippet = str(s.get("reply", ""))[:120].replace("\n", " ")
                ok = "✅" if s.get("ok") else "❌"
                steps_lines.append(f"{ok} {kind}: {reply_snippet}")
            steps_text = "\n".join(steps_lines)

            existing_str = ", ".join(sorted(existing)) if existing else "keine"

            prompt = (
                f"Aufgabe des Nutzers: {message[:200]}\n\n"
                f"Ausgeführte Schritte:\n{steps_text}\n\n"
                f"Ergebnis: {final_reply[:200]}\n\n"
                f"Bereits gespeicherte Fakten (nicht nochmal speichern): {existing_str}\n\n"
                "Extrahiere maximal 6 Fakten die bei ZUKÜNFTIGEN ähnlichen Aufgaben nützlich sind.\n\n"
                "WICHTIG: Der 'value' muss ein vollständiger natürlicher Satz auf Deutsch sein — "
                "kein key=value Format, sondern eine echte Aussage die man direkt lesen kann.\n\n"
                "Beispiele für GUTE natürliche Sätze als value:\n"
                "- 'arduino-cli Version 1.4.1 ist installiert unter C:\\Users\\...\\arduino-cli.exe'\n"
                "- 'Das ESP32-Paket esp32 3.1.3 ist installiert, Board-FQBN: esp32:esp32:esp32'\n"
                "- 'Der COM-Port des ESP32 ist COM5'\n"
                "- 'Die Bibliothek X wird korrekt so importiert: from X import Y; y = Y(session, cfg)'\n"
                "- 'Y(email, pwd) funktioniert NICHT — korrekter Aufruf: Y(session, cfg)'\n\n"
                "Schlüssel (key) Konventionen — kurz und eindeutig:\n"
                "- Installierte Tools/Pakete: pkg_NAME\n"
                "- Pfade/Konfiguration: cfg_NAME oder tool_NAME\n"
                "- Hardware: hw_NAME\n"
                "- API/Bibliotheks-Nutzung: api_NAME\n"
                "- Services/Credentials: svc_NAME\n\n"
                "NICHT speichern: allgemeines Wissen, temporäre Daten, bereits bekannte Fakten.\n"
                "BESONDERS WERTVOLL: Wenn Trial-and-Error nötig war um die richtige API-Nutzung zu finden.\n"
                "Wenn nichts Neues: leere Liste.\n"
                'Antworte NUR als JSON: {"facts": [{"key": "...", "value": "vollständiger natürlicher Satz..."}]}'
            )

            router = LLMRouter(cfg)
            result = router.chat_json(prompt, "auto_fact_extract", {
                "type": "object",
                "properties": {
                    "facts": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "key": {"type": "string"},
                                "value": {"type": "string"},
                            },
                            "required": ["key", "value"],
                        },
                    }
                },
                "required": ["facts"],
            })

            if not isinstance(result, dict):
                return
            saved = 0
            for fact in result.get("facts", []):
                k = str(fact.get("key", "")).strip()
                v = str(fact.get("value", "")).strip()
                if k and v and len(k) < 80 and len(v) < 400 and k not in existing:
                    ctx_mgr.save_fact(k, v)
                    saved += 1
            if saved:
                tool_store.log("auto_fact_extract", f"{saved} Fakten automatisch gespeichert.")
        except Exception as e:
            tool_store.log("auto_fact_extract_error", f"{e}")

    threading.Thread(target=_worker, daemon=True, name="K.AI-auto-fact-extract").start()


def _summarize_and_update_session(
    cfg: Dict[str, Any],
    message: str,
    steps: List[Dict[str, Any]],
    final_reply: str,
    ctx_mgr: Any = None,
    mem_save_called: bool = False,
):
    """
    Markiert den Abschluss einer Aufgabe im TaskStateManager.
    Startet automatische Fact-Extraktion im Hintergrund (ChatGPT-Style).
    """
    try:
        from app.task_state import get_task_state_manager
        dk = str(_dialog_key_ctx.get("") or "default").strip()
        get_task_state_manager().complete_task(dk, success=True, final_reply=final_reply[:500])
        tool_store.log("memory_update", f"Session {dk} abgeschlossen.")
    except Exception as e:
        tool_store.log("memory_error", f"Fehler bei Session-Update: {e}")

    # Phase 2: Agent-State speichern (persistente Identität über Sitzungen)
    if ctx_mgr is not None:
        try:
            dk = str(_dialog_key_ctx.get("") or "default").strip()
            _prev_state = ctx_mgr.load_agent_state(dk)
            # Bekannte APIs/Libs aus Steps extrahieren
            _learned = list(_prev_state.get("learned_apis", []))
            for step in steps:
                _tool = str(step.get("tool", ""))
                _code = str(step.get("code", "") or step.get("args", {}).get("code", ""))
                if "import " in _code:
                    import re as _re2
                    for m in _re2.findall(r"import\s+(\w+)", _code):
                        if m not in _learned and m not in {"sys", "os", "re", "json", "time", "io"}:
                            _learned.append(m)
            # Bekannte Fehler aus fehlgeschlagenen Steps
            _errors = list(_prev_state.get("known_errors", []))
            for step in steps:
                _err = str(step.get("stderr", "") or "")
                import re as _re3
                _exc = _re3.search(r'\b([A-Za-z_]\w*(?:Error|Exception))\b', _err)
                if _exc and _exc.group(1) not in _errors:
                    _errors.append(_exc.group(1))
            _new_state = {
                "current_task": message[:120],
                "last_action": steps[-1].get("tool", "unknown") if steps else "unknown",
                "learned_apis": _learned[:15],
                "known_errors": _errors[:10],
                "session_count": _prev_state.get("session_count", 0) + 1,
            }
            ctx_mgr.save_agent_state(dk, _new_state)
        except Exception:
            pass

    # Auto-Fact-Extraktion im Hintergrund (nur wenn ctx_mgr übergeben wurde)
    if ctx_mgr is not None:
        _auto_extract_facts_bg(cfg, message, steps, final_reply, ctx_mgr, mem_save_called)




def _execute_react_loop(
    message: str,
    cfg: Dict[str, Any],
    dialog_key: str = "",
    max_iterations: Optional[int] = None,
    plan_path: Optional[str] = None,
    trace_id: Optional[str] = None,
    reset_plan: bool = True,
    intent: str = "",
    images: Optional[List[Dict[str, Any]]] = None,
) -> Dict[str, Any]:
    """
    K.AI V3.7 - High-Performance Stable ReAct Loop.

    OPT-M1A: Persona/Rules werden per lru_cache gecacht (kein Disk-IO pro Aufruf).
    OPT-M1B: LLMRouter einmalig vor der while-Schleife erstellt.
    OPT-M1C: get_pinned_context() nutzt TTL-Cache im ContextManager.
    """
    from app.tool_registry import build_catalog_text
    from app.execution_validator import ExecutionValidator
    from app.context_manager import ContextManager
    import functools
    import threading
    import time
    import html

    validator = ExecutionValidator()
    ctx_mgr = ContextManager()
    # Phase 3: System-Knowledge einmalig laden (nur wenn noch nicht vorhanden)
    try:
        ctx_mgr.load_system_knowledge()
    except Exception:
        pass
    # Trace-spezifische plan.md — verhindert Überschreiben durch parallele Runs auf dieselbe Anfrage
    _tid = str(trace_id or _new_trace_id())
    _trace_id_ctx.set(_tid)  # ContextVar explizit setzen → sys_python_exec bekommt korrekte trace_id für persistente Session
    ctx_mgr.plan_file = ctx_mgr.workspace / f"plan_{_tid[:8]}.md"

    # OPT-M1A: Persona + Agent-Rules einmalig laden und cachen.
    # Vorher: Disk-IO bei JEDEM _execute_react_loop()-Aufruf.
    @functools.lru_cache(maxsize=1)
    def _cached_persona_and_rules() -> tuple:
        _persona = ""
        for p_file in ["persona.md", "persona.txt", "persona", "PERSONA.md"]:
            p_path = Path(p_file)
            if p_path.exists():
                try:
                    _persona = p_path.read_text(encoding="utf-8")
                except Exception:
                    pass
                break
        _rules = ""
        for a_file in ["agent.md", "AGENTS.md", "rules.md", "agent"]:
            a_path = Path(a_file)
            if a_path.exists():
                try:
                    _rules = a_path.read_text(encoding="utf-8")
                except Exception:
                    pass
                break
        return _persona, _rules

    persona, agent_rules = _cached_persona_and_rules()


    from app.tool_registry import build_catalog_text
    tool_docs = build_catalog_text(intent=intent)

    # Dynamically append enabled skill tools to the catalog
    _skill_reg = _skills_snapshot()
    _skill_tools = _skill_reg.get("tools", []) if isinstance(_skill_reg.get("tools", []), list) else []
    _action_schemas = _skill_reg.get("action_schemas", {}) if isinstance(_skill_reg.get("action_schemas", {}), dict) else {}
    if _skill_tools:
        _skill_lines = ["\n\n🔧 SKILL TOOLS (aktiviert):"]
        for _st in _skill_tools:
            _kind = str(_st.get("kind", "") or "")
            _desc = str(_st.get("description", "") or "")
            _schema = _action_schemas.get(_kind, {})
            _req_fields = list(_schema.get("required", {}).keys()) if isinstance(_schema.get("required", {}), dict) else []
            _opt_fields = list(_schema.get("optional", {}).keys()) if isinstance(_schema.get("optional", {}), dict) else []
            _params = ", ".join(_req_fields + [f"[{f}]" for f in _opt_fields])
            _skill_lines.append(f"  - {_kind}({_params}): {_desc}")
        tool_docs += "\n".join(_skill_lines)

    # Dynamically append installed MCP tools (from cache) so LLM knows them from the start
    try:
        from app.mcp_tools import get_cached_mcp_tools
        _mcp_cached = get_cached_mcp_tools()
        if _mcp_cached:
            _mcp_lines = ["\n\n⚙️ MCP TOOLS (installiert, direkt per kind aufrufbar):"]
            for _mt in _mcp_cached[:40]:
                _fn = _mt.get("function", {}) or {}
                _mname = _fn.get("name") or _mt.get("name", "")
                _mdesc = str(_fn.get("description", "") or "")[:100]
                _mparams = list((_fn.get("parameters", {}) or {}).get("properties", {}).keys()) if isinstance((_fn.get("parameters", {}) or {}).get("properties"), dict) else []
                _mparams_str = ", ".join(_mparams[:5])
                if _mname:
                    _mcp_lines.append(f"  - {_mname}({_mparams_str}): {_mdesc}")
            if len(_mcp_lines) > 1:
                tool_docs += "\n".join(_mcp_lines)
    except Exception:
        pass

    # Config-Flag: natives Tool Calling (Standard: an)
    _react_cfg = cfg.get("react", {}) if isinstance(cfg.get("react"), dict) else {}
    _use_native_tools = bool(_react_cfg.get("use_native_tools", True))

    # Aktive Tool-Liste für natives Tool Calling (Intent-gefiltert + MCP + Skills)
    _active_tools: list = []
    if _use_native_tools:
        from app.tool_registry import CORE_TOOLS, WEB_TOOL_NAMES
        _NO_WEB_INTENTS = {"script", "filesystem", "cron", "answer_and_save"}
        # Für reine Wissensantworten (answer_and_save) auch mem_update_plan weglassen.
        # web_search + web_fetch_smart bleiben IMMER verfügbar — aktuelle Infos brauchen Web-Zugriff.
        _ANSWER_ONLY_EXCLUDE = (WEB_TOOL_NAMES - {"web_search", "web_fetch_smart"}) | {"mem_update_plan", "mem_save_fact"}
        _active_tools = [t for t in CORE_TOOLS
                         if intent not in _NO_WEB_INTENTS
                         or t["function"]["name"] not in (
                             _ANSWER_ONLY_EXCLUDE if intent == "answer_and_save" else WEB_TOOL_NAMES
                         )]
        # MCP-Tools als native Tool-Schemas hinzufügen
        try:
            from app.mcp_tools import get_cached_mcp_tools
            for _mt in get_cached_mcp_tools()[:40]:
                _fn = _mt.get("function", {}) or {}
                _mname = _fn.get("name", "")
                if _mname:
                    _active_tools.append(_mt)
        except Exception:
            pass
        # Skill-Tools: Schema enthält Python-type-Objekte → nicht JSON-serialisierbar → überspringen

    _is_messenger = dialog_key and ":" in dialog_key and dialog_key.split(":")[0] in {"telegram", "discord"}

    if _use_native_tools:
        # Nativer System-Prompt: kein JSON-Format, kein Tool-Catalog als Text
        _messenger_hint = (
            "\nWenn der Nutzer eine Datei angefordert hat, rufe send_messenger_file auf."
            if _is_messenger else ""
        )
        _multistep_hint = (
            "\nMEHRTEILIGE AUFGABEN: Führe ALLE nötigen Schritte in einem Durchgang aus, bevor du antwortest. "
            "Beispiel: Code schreiben → kompilieren → flashen → Datei senden. "
            "Erst wenn alle Teile erledigt sind, gib eine abschließende Text-Antwort ohne weiteren Tool-Call."
        )
        from app.prompt_manager import build_system_prompt
        system_prompt = build_system_prompt(
            persona=persona,
            agent_rules=agent_rules,
            system_env_info=SYSTEM_ENV_INFO,
            messenger_hint=_messenger_hint,
            multistep_hint=_multistep_hint,
            is_legacy_json=False,
            tool_docs=tool_docs
        )
    else:
        # Legacy JSON-Modus (Fallback)
        _messenger_hint = (
            "\n6. DATEI-VERSAND: Wenn der Nutzer eine Datei angefordert hat, rufe send_messenger_file auf. "
            "Nur ein Tool-Call zählt — schreiben reicht nicht.\n"
            if _is_messenger else ""
        )
        from app.prompt_manager import build_system_prompt
        system_prompt = build_system_prompt(
            persona=persona,
            agent_rules=agent_rules,
            system_env_info=SYSTEM_ENV_INFO,
            messenger_hint=_messenger_hint,
            multistep_hint="",
            is_legacy_json=True,
            tool_docs=tool_docs
        )

    history = [{"role": "system", "content": system_prompt}]
    # Gesprächskontext – ChatGPT-Style: immer die letzten N Turns als echter user/assistant Thread.
    # Das LLM entscheidet selbst ob eine neue Nachricht eine Fortsetzung oder ein neues Thema ist.
    # Letzten 5 Exchanges (10 Turns). Lange Turns werden sauber gekürzt (kein Abbruch mitten im Satz).
    if dialog_key:
        with _session_lock:
            # FIX 4a: Nach Bot-Restart History von Disk laden (CRUCIAL für "weiter"!)
            if dialog_key not in _session_history or not _session_history[dialog_key]:
                _load_session_from_disk(dialog_key)
            _prev_turns = list(_session_history.get(dialog_key, deque()))
        if _prev_turns:
            for _t in _prev_turns[-10:]:
                _role = "user" if str(_t.get("role", "")).lower() == "user" else "assistant"
                _limit = 3000 if _role == "user" else 5000
                _txt = str(_t.get("text", "")).strip()
                if len(_txt) > _limit:
                    # Sauber am letzten Satzende kürzen statt hart abschneiden
                    _cut = _txt[:_limit]
                    _last_stop = max(_cut.rfind(". "), _cut.rfind(".\n"), _cut.rfind("! "), _cut.rfind("? "))
                    _txt = (_cut[:_last_stop + 1] if _last_stop > _limit // 2 else _cut) + " [...]"
                if _txt:
                    history.append({"role": _role, "content": _txt})
    _aufgabe_msg: Dict[str, Any] = {"role": "user", "content": f"AUFGABE: {message}"}
    if images:
        _aufgabe_msg["_images"] = images  # LLM-Router wandelt diese in Vision-Blöcke um
        _audit_event("vision_images_injected", {"count": len(images), "files": [img.get("filename","?") for img in images]})
    history.append(_aufgabe_msg)

    # Semantisches Fact-Retrieval (ChatGPT-Style via ChromaDB Embeddings, Fallback: neueste Fakten)
    # Format basiert auf Forschung (MemGPT, Mem0, ChatGPT Memory):
    # XML-Tags + explizite "DO NOT re-check" Instruktion → LLM überspringt redundante Tool-Calls.
    try:
        _relevant_facts = ctx_mgr.retrieve_relevant_facts(message, top_k=8)
        # agent_state-Fakten ausfiltern (interne Metadaten, kein nützliches Vorwissen)
        _relevant_facts = {k: v for k, v in _relevant_facts.items()
                           if not k.startswith("agent_state_")}
        if _relevant_facts:
            # Natural language format (MemGPT/Mem0/ChatGPT Memory Ansatz):
            # Wert ist ein vollständiger Satz — kein key: value Format anzeigen
            _fact_lines = []
            for _fk, _fmeta in _relevant_facts.items():
                _val = _fmeta.get("value", "").strip()
                _ts = str(_fmeta.get("timestamp", ""))[:16]
                if _val:
                    _fact_lines.append(f"- {_val}  [verifiziert: {_ts}]")
            if _fact_lines:
                history[-1]["content"] += (
                    "\n\n<long_term_memory>\n"
                    "Die folgenden Fakten wurden durch vorherige erfolgreiche Jobs verifiziert.\n"
                    "Sie sind VERIFIZIERTE TATSACHEN. Rufe KEINE Tools auf um sie erneut zu prüfen.\n"
                    "Behandle sie wie direkt sichtbare Informationen.\n\n"
                    + "\n".join(_fact_lines)
                    + "\n\nWenn ein Fakt hier abdeckt was du sonst per Tool-Call herausfinden würdest"
                    " → ÜBERSPRINGE diesen Tool-Call und nutze den Fakt direkt.\n"
                    "Veralteten Fakt aktualisieren: mem_save_fact(key, neuer_wert) | löschen: mem_delete_fact(key)\n"
                    "</long_term_memory>"
                )
    except Exception:
        pass

    # Phase 2: Agent-Identity Injection (Zustand aus vorherigen Sitzungen)
    try:
        if dialog_key:
            _agent_state = ctx_mgr.load_agent_state(dialog_key)
            if _agent_state:
                _identity_parts = []
                if _agent_state.get("current_task"):
                    _identity_parts.append(f"Zuletzt gearbeitet an: {_agent_state['current_task']}")
                if _agent_state.get("learned_apis"):
                    _identity_parts.append(f"Bekannte APIs/Libs: {', '.join(_agent_state['learned_apis'])}")
                if _agent_state.get("known_errors"):
                    _identity_parts.append(f"Bekannte Fehler: {', '.join(_agent_state['known_errors'][:3])}")
                sc = _agent_state.get("session_count", 0)
                if sc:
                    _identity_parts.append(f"Sessions bisher: {sc}")
                if _identity_parts:
                    history[-1]["content"] += (
                        "\n\n[AGENT_IDENTITY — Dein Zustand aus vorherigen Sitzungen]\n"
                        + "\n".join(f"- {p}" for p in _identity_parts)
                    )
    except Exception:
        pass

    iteration, max_iter = 0, (max_iterations or 50)
    _critical_errors = 0  # Zählt aufeinanderfolgende System-Exceptions (unabhängig von iteration)
    all_steps_log = []
    _llm_consecutive_errors = 0  # LLM-Verbindungsfehler separat zählen
    _consecutive_tool_failures = 0  # 🚨 ABORT-SYSTEM: Zählt Tool-Fehler hintereinander
    _last_action_kind = None  # Erkennt Loops: macht LLM immer das Gleiche?
    _error_type_counts: Dict[str, int] = {}  # Exception-Typ → Häufigkeit (Fix: gleiche Exception 3× → Abbruch)
    _tool_call_frequency: Dict[str, int] = {}  # 🚨 ANTI-LOOP: Zählt Aufrufe pro Tool über alle Iterationen

    # OPT-M1B: LLMRouter EINMALIG vor der Schleife erstellen.
    # Vorher: neue Instanz bei JEDER der 50 Iterationen!
    from app.llm_router import LLMRouter
    router = LLMRouter(cfg)

    
    _cli_live_emit("start", {"message": f"Aufgabe gestartet: {message[:100]}..."})
    _cli_anim_job_start("K.AI V3 Engine aktiv")
    # Stop-Event zurücksetzen – verhindert dass altes Abort-Signal den neuen Job sofort stoppt
    with contextlib.suppress(Exception):
        from app.tools import python_exec as _py_mod
        _py_mod._stop_event.clear()

    typing_active = True
    def typing_worker():
        while typing_active:
            with contextlib.suppress(Exception):
                _pt = dialog_key.split(":", 1)[0] if ":" in dialog_key else ""
                if _pt in {"telegram", "discord"}:
                    _send_messenger_typing(cfg, dialog_key, _pt)
            time.sleep(4)
    
    t_thread = threading.Thread(target=typing_worker, daemon=True)
    t_thread.start()

    _consecutive_local_only = 0  # Zählt aufeinanderfolgende mem_*-only Iterationen
    _tool_call_counts: dict = {}  # {(kind, key_param): count} für Loop-Erkennung
    _mem_save_called = False      # Wurde mem_save_fact in diesem Job aufgerufen?
    _real_action_count = 0        # Anzahl echter Tool-Calls (exkl. mem_* und mem_update_plan)
    _mem_save_reminder_sent = False  # Verhindert doppelten Reminder
    _pre_reminder_reply: str = ""  # Eigentliche Aufgaben-Antwort vor dem Fakten-Reminder
    _code_modified_in_job = False
    _test_executed_in_job = False
    _test_reminder_sent = False
    _consecutive_tool_failures = 0

    # 🚨 WICHTIG: Neue Job = Neue plan.md (verhindert Vermischung mit alten Jobs!)
    # Bei Recovery-Calls (reset_plan=False) wird der Plan NICHT zurückgesetzt –
    # der Recovery-Loop soll auf dem bestehenden Plan (inkl. PDF-Pfade etc.) aufbauen!
    if reset_plan:
        try:
            ctx_mgr.plan_file.write_text(
                f"# Plan für Job {trace_id}\n\n"
                f"## Aufgabe\n{message[:200]}...\n\n"
                f"## Strategie\n(Wird vom LLM mit mem_update_plan gefüllt)\n\n"
                f"## Fortschritt\n",
                encoding="utf-8"
            )
        except Exception as e:
            tool_store.log("plan_init_error", f"Konnte plan.md nicht initialisieren: {e}")

    # 🚨 INITIALISIERE File Registry für DIESEN Job (verhindert Vermischung mit anderen Jobs)
    with _file_registry_lock:
        if trace_id in _file_registry:
            # Falls alte Registry existiert, löschen (Job sollte neu sein)
            _file_registry[trace_id] = []
        else:
            _file_registry[trace_id] = []

    # Background-Watchdog: sendet sofortige Bestätigung wenn Nutzer während laufendem Job schreibt.
    # Läuft alle 3s, checkt nur ob eine neue Nachricht PENDING ist (peek, kein pop).
    # Die eigentliche Verarbeitung passiert im loop (pop_followup_for_dialog).
    _followup_ack_sent: set = set()  # Verhindert doppelte Acks für dieselbe Nachricht
    _watchdog_active = threading.Event()
    _watchdog_active.set()

    def _followup_watchdog():
        import time as _time
        while _watchdog_active.is_set():
            _time.sleep(3)
            if not _watchdog_active.is_set():
                break
            try:
                if not _chat_queue or not dialog_key:
