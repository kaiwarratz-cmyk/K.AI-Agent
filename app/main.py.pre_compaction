@app.post("/api/scripts/cleanup")
def api_scripts_cleanup() -> Dict[str, Any]:
    """Entfernt alle Registry-Einträge deren Datei nicht mehr existiert."""
    registry_path = ROOT_DIR / "data" / "script_registry.json"
    if not registry_path.exists():
        return {"ok": True, "removed": 0}
    with contextlib.suppress(Exception):
        entries = json.loads(registry_path.read_text(encoding="utf-8"))
        if not isinstance(entries, list):
            return {"ok": True, "removed": 0}
        before = len(entries)
        kept = [
            e for e in entries
            if e.get("path") and Path(str(e.get("path"))).exists()
        ]
        removed = before - len(kept)
        registry_path.write_text(json.dumps(kept, ensure_ascii=False, indent=2), encoding="utf-8")
        return {"ok": True, "removed": removed}
    return {"ok": False, "error": "Fehler beim Bereinigen"}

@app.get("/api/scripts")
def api_scripts() -> Dict[str, Any]:
    """Gibt alle registrierten Scripts zurück inkl. Whitelist-Status."""
    registry_path = ROOT_DIR / "data" / "script_registry.json"
    entries: list = []
    if registry_path.exists():
        with contextlib.suppress(Exception):
            entries = json.loads(registry_path.read_text(encoding="utf-8"))
    if not isinstance(entries, list):
        entries = []
    # Bekannte Pfade aus Registry
    known_paths: set = {str(e.get("path", "")).lower() for e in entries if e.get("path")}
    # Workspace/scripts direkt scannen – Scripts die nicht in Registry sind ergänzen
    with contextlib.suppress(Exception):
        scripts_dir = _workspace_abs(_cfg()) / "scripts"
        if scripts_dir.exists():
            for fp in sorted(scripts_dir.glob("*.py")) + sorted(scripts_dir.glob("*.ps1")):
                if str(fp).lower() not in known_paths:
                    script_type = "python" if fp.suffix == ".py" else "powershell"
                    entries.append({
                        "path": str(fp),
                        "name": fp.name,
                        "type": script_type,
                        "created_at": datetime.fromtimestamp(fp.stat().st_mtime, tz=timezone.utc).isoformat(),
                        "origin": "unknown",
                        "description": "",
                        "action_hash": "",
                    })
    result = []
    for e in entries:
        item = dict(e)
        action_hash = str(e.get("action_hash", "") or "")
        item["whitelisted"] = bool(action_hash) and action_hash in set()
        item["exists"] = Path(str(e.get("path", "") or "")).exists()
        result.append(item)
    return {"ok": True, "count": len(result), "items": result}


@app.get("/api/tools/tree")
def api_tools_tree(refresh_mcp: int = 0, include_disabled_dynamic: int = 1) -> Dict[str, Any]:
    from app.mcp_tools import get_cached_mcp_tools, mcp_available, refresh_mcp_tools
    from app.tool_registry import CORE_TOOLS

    cfg = _cfg()
    if bool(int(refresh_mcp or 0)):
        with contextlib.suppress(Exception):
            refresh_mcp_tools(cfg)

    # Core tools come from built-in catalog.
    core_items: List[Dict[str, Any]] = []
    for t in CORE_TOOLS:
        func = t.get("function", {}) if isinstance(t, dict) else {}
        if not isinstance(func, dict):
            continue
        name = str(func.get("name", "")).strip()
        if not name:
            continue
        core_items.append(
            {
                "kind": "tool",
                "source": "core",
                "name": name,
                "description": str(func.get("description", "")).strip(),
            }
        )

    # MCP tools grouped by server.
    mcp_ok, mcp_msg = mcp_available()
    mcp_tools: List[Dict[str, Any]] = []
    if mcp_ok:
        for t in get_cached_mcp_tools():
            if not isinstance(t, dict):
                continue
            func = t.get("function", {}) if isinstance(t.get("function", {}), dict) else {}
            meta = t.get("mcp_meta", {}) if isinstance(t.get("mcp_meta", {}), dict) else {}
            name = str(func.get("name", "")).strip()
            if not name:
                continue
            mcp_tools.append(
                {
                    "name": name,
                    "description": str(func.get("description", "")).strip(),
                    "server": str(meta.get("server", "")).strip() or "unknown",
                    "original_name": str(meta.get("original_name", "")).strip(),
                }
            )
    mcp_tools.sort(key=lambda x: (str(x.get("server", "")).lower(), str(x.get("name", "")).lower()))

    mcp_servers: Dict[str, List[Dict[str, Any]]] = {}
    for t in mcp_tools:
        srv = str(t.get("server", "")).strip() or "unknown"
        mcp_servers.setdefault(srv, []).append(t)

    mcp_tree: List[Dict[str, Any]] = []
    for srv in sorted(mcp_servers.keys(), key=lambda x: str(x).lower()):
        children: List[Dict[str, Any]] = []
        for t in mcp_servers.get(srv, []):
            children.append(
                {
                    "kind": "tool",
                    "source": "mcp",
                    "name": str(t.get("name", "")),
                    "description": str(t.get("description", "")),
                    "server": srv,
                    "original_name": str(t.get("original_name", "")),
                }
            )
        mcp_tree.append({"kind": "group", "name": srv, "path": f"mcp/{srv}", "children": children})

    # Skills grouped by skill id/name with nested tool kinds.
    skill_items = _skills_items_with_secret_status(cfg)
    skills_tree: List[Dict[str, Any]] = []
    skill_tools_count = 0
    for s in skill_items:
        if not isinstance(s, dict):
            continue
        sid = str(s.get("id", "")).strip()
        sname = str(s.get("name", sid)).strip() or sid
        if not sid:
            continue
        tools_raw = s.get("tools", []) if isinstance(s.get("tools", []), list) else []
        children: List[Dict[str, Any]] = []
        for t in tools_raw:
            if not isinstance(t, dict):
                continue
            kind = str(t.get("kind", "")).strip()
            if not kind:
                continue
            children.append(
                {
                    "kind": "tool",
                    "source": "skill",
                    "name": kind,
                    "description": str(t.get("description", "")).strip() or f"Skill-Tool ({sid})",
                    "skill_id": sid,
                    "skill_name": sname,
                    "enabled": bool(s.get("enabled", False)),
                }
            )
        children.sort(key=lambda x: str(x.get("name", "")).lower())
        skill_tools_count += len(children)
        skills_tree.append(
            {
                "kind": "group",
                "name": sname,
                "path": f"skills/{sid}",
                "skill_id": sid,
                "enabled": bool(s.get("enabled", False)),
                "missing_required": list(s.get("missing_required", []))
                if isinstance(s.get("missing_required", []), list)
                else [],
                "children": children,
            }
        )
    skills_tree.sort(key=lambda x: str(x.get("name", "")).lower())

    return {
        "ok": True,
        "backend": {},
        "counts": {
            "core": len(core_items),
            "mcp": len(mcp_tools),
