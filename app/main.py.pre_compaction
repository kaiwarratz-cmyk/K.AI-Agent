def _native_tools_for_allowed_kinds(allowed_kinds: List[str]) -> List[Dict[str, Any]]:
    schemas = _action_schemas()
    tools: List[Dict[str, Any]] = []
    for kind in allowed_kinds:
        spec = schemas.get(str(kind), {}) if isinstance(schemas.get(str(kind), {}), dict) else {}
        json_schema = spec.get("json_schema") if isinstance(spec.get("json_schema", {}), dict) else None
        req = spec.get("required", {}) if isinstance(spec.get("required", {}), dict) else {}
        opt = spec.get("optional", {}) if isinstance(spec.get("optional", {}), dict) else {}
        desc_entry = _TOOL_DESCRIPTIONS.get(str(kind), {}) if isinstance(_TOOL_DESCRIPTIONS.get(str(kind), {}), dict) else {}
        tool_desc = str(
            spec.get("description")
            or desc_entry.get("desc", "")
            or f"Execute action: {kind}."
        ).strip()
        param_descs = desc_entry.get("params", {}) if isinstance(desc_entry.get("params", {}), dict) else {}
        if json_schema:
            tools.append(
                {
                    "type": "function",
                    "function": {
                        "name": str(kind),
                        "description": tool_desc,
                        "parameters": json_schema,
                    },
                }
            )
        else:
            props: Dict[str, Any] = {}
            req_keys: List[str] = []
            for k, t in req.items():
                kk = str(k or "").strip()
                if not kk:
                    continue
                p: Dict[str, Any] = dict(_json_schema_for_python_type(t))
                pd = str(param_descs.get(kk, "") or "").strip()
                if pd:
                    p["description"] = pd
                props[kk] = p
                req_keys.append(kk)
            for k, t in opt.items():
                kk = str(k or "").strip()
                if not kk:
                    continue
                p = dict(_json_schema_for_python_type(t))
                pd = str(param_descs.get(kk, "") or "").strip()
                if pd:
                    p["description"] = pd
                props.setdefault(kk, p)
            tools.append(
                {
                    "type": "function",
                    "function": {
                        "name": str(kind),
                        "description": tool_desc,
                        "parameters": {
                            "type": "object",
                            "additionalProperties": False,
                            "properties": props,
                            "required": sorted(list(dict.fromkeys(req_keys))),
                        },
                    },
                }
            )
    return tools

def _normalize_llm_action(cfg: Dict[str, Any], intent: str, message: str, action: Dict[str, Any]) -> Dict[str, Any]:
    out = dict(action or {})
    kind = str(out.get("kind", "") or "").strip().lower()
    i = str(intent or "").strip().lower()
    msg_low = str(message or "").strip().lower()

    # Flatten model outputs that mirror schema docs, e.g. {"req": {...}, "opt": {...}}.
    for k in ("req", "required", "opt", "optional", "options", "params", "param", "arguments", "args"):
        v = out.get(k)
        if isinstance(v, dict):
            for kk, vv in v.items():
                out.setdefault(str(kk), vv)
    out.pop("req", None)
    out.pop("required", None)
    out.pop("opt", None)
    out.pop("optional", None)
    out.pop("options", None)
    out.pop("params", None)
    out.pop("param", None)
    out.pop("arguments", None)
    out.pop("args", None)

    # Falls das LLM 'param' als Einzelwert nutzt, auf den einzigen Pflichtparameter mappen
    _act_schemas = _action_schemas()
    if kind in _act_schemas:
        spec = _act_schemas[kind]
        req_keys = list(spec.get("required", {}).keys())
        # Wenn 'param' noch da ist (weil es kein dict war), mappen wir es
        if "param" in action and len(req_keys) == 1 and req_keys[0] not in out:
            out[req_keys[0]] = action["param"]

    alias = {
        "copy_chunked": "copy_file_chunked",
        "list_cron_jobs": "cron_list",
        "cron_jobs": "cron_list",
        "create_cron_job": "cron_create",
        "add_cron_job": "cron_create",
        "remove_cron_job": "cron_delete",
        "test_cron_job": "cron_test",
    }
    if kind in alias:
        out["kind"] = alias[kind]
        kind = out["kind"]

    # If user explicitly asks for files AND folders, force tree copy/move
    # instead of files-only variants.
    files_and_folders_phrase = bool(
        re.search(r"(dateien\s+und\s+ordner|files?\s+and\s+folders?)", msg_low, flags=re.IGNORECASE)
    )
    if files_and_folders_phrase and kind in {"copy_all_files", "move_all_files"}:
        if kind == "copy_all_files":
            src = str(out.get("src_dir", "") or out.get("src", "") or out.get("source", "") or "").strip()
            dst = str(out.get("dst_dir", "") or out.get("dst", "") or out.get("destination", "") or "").strip()
            out["kind"] = "copy_path"
            if src:
                out["src"] = src
            if dst:
                out["dst"] = dst
            out.pop("src_dir", None)
            out.pop("dst_dir", None)
            out.pop("ext", None)
            out.pop("recursive", None)
            kind = "copy_path"
        elif kind == "move_all_files":
            src = str(out.get("src_dir", "") or out.get("src", "") or out.get("source", "") or "").strip()
            dst = str(out.get("dst_dir", "") or out.get("dst", "") or out.get("destination", "") or "").strip()
            out["kind"] = "move_path"
            if src:
                out["src"] = src
            if dst:
                out["dst"] = dst
            out.pop("src_dir", None)
            out.pop("dst_dir", None)
            out.pop("ext", None)
            out.pop("recursive", None)
            kind = "move_path"

    if kind == "copy_file_chunked":
        if "src" not in out:
            src = str(out.get("src_path", "") or out.get("source", "") or out.get("path", "") or "").strip()
            if src:
                out["src"] = src
        if "dst" not in out:
            dst = str(out.get("dst_path", "") or out.get("destination", "") or out.get("target", "") or "").strip()
            if dst:
                out["dst"] = dst
        if ("src" not in out or "dst" not in out) and (" von " in f" {msg_low} " and " nach " in f" {msg_low} "):
            paths = re.findall(r"([a-zA-Z]:\\[^\\n]+?\\.[a-zA-Z0-9]{2,8})", str(message or ""))
            if len(paths) >= 2:
                out.setdefault("src", paths[0])
                out.setdefault("dst", paths[1])
        out.pop("path", None)
        out.pop("src_path", None)

    if kind in {"cron_delete", "cron_pause", "cron_resume"}:
        if "job_id" not in out:
            maybe = str(out.get("id", "") or out.get("name", "") or "").strip()
            if maybe:
                out["job_id"] = maybe
    if kind == "cron_create":
        if "task" not in out:
            maybe_task = str(out.get("prompt", "") or out.get("name", "") or "").strip()
            if maybe_task:
                out["task"] = maybe_task
        nested_action = out.get("action")
        if isinstance(nested_action, str):
            maybe_obj = _extract_json_dict(nested_action)
            if isinstance(maybe_obj, dict):
                nested_action = maybe_obj
                out["action"] = maybe_obj
            else:
                out.pop("action", None)
                nested_action = None
        elif nested_action is not None and not isinstance(nested_action, dict):
            out.pop("action", None)
            nested_action = None
        if isinstance(nested_action, dict):
            nk = str(nested_action.get("kind", "") or "").strip().lower()
            if nk.startswith("cron_"):
                out.pop("action", None)
            else:
                out["action"] = _normalize_llm_action(cfg, "filesystem", message, nested_action)
        if "interval_sec" not in out:
            m_ev = re.search(r"alle\s+(\d+)\s*(sekunden|sek|s|minuten|min|m|stunden|h|tage|d)", msg_low, flags=re.IGNORECASE)
            if not m_ev:
                m_ev = re.search(r"every\s+(\d+)\s*(seconds?|secs?|s|minutes?|mins?|m|hours?|h|days?|d)", msg_low, flags=re.IGNORECASE)
            if m_ev:
                n = int(m_ev.group(1))
                u = str(m_ev.group(2) or "").lower()
                mult = 1
                if u.startswith("m") and u not in {"ms"}:
                    mult = 60
                elif u.startswith("h"):
                    mult = 3600
                elif u.startswith("t") or u.startswith("d"):
                    mult = 86400
                out["interval_sec"] = max(1, n * mult)
        run_at_raw = str(out.get("run_at", "") or "").strip()
        if run_at_raw and _cron_parse_run_at_iso(run_at_raw) is None:
            rv = run_at_raw.lower()
            m_tom = re.match(r"^(?:tomorrow|morgen)(?:\s+um|\s+at)?\s*(\d{1,2})(?::(\d{2}))?$", rv, flags=re.IGNORECASE)
            if m_tom:
                hh = int(m_tom.group(1))
                mm = int(m_tom.group(2) or "0")
                now_local = datetime.now().astimezone()
                target_local = now_local.replace(hour=hh, minute=mm, second=0, microsecond=0) + timedelta(days=1)
                out["run_at"] = _cron_local_dt_to_utc_iso(target_local)
            else:
                m_at = re.match(r"^(?:today|heute)?(?:\s*um|\s*at)?\s*(\d{1,2})(?::(\d{2}))?$", rv, flags=re.IGNORECASE)
                if m_at:
                    hh = int(m_at.group(1))
                    mm = int(m_at.group(2) or "0")
                    now_local = datetime.now().astimezone()
                    target_local = now_local.replace(hour=hh, minute=mm, second=0, microsecond=0)
                    if target_local <= now_local:
                        target_local = target_local + timedelta(days=1)
                    out["run_at"] = _cron_local_dt_to_utc_iso(target_local)
                else:
                    parsed_from_msg = _cron_parse_natural_create(str(message or ""))
                    if isinstance(parsed_from_msg, dict) and str(parsed_from_msg.get("run_at", "") or "").strip():
                        out["run_at"] = str(parsed_from_msg.get("run_at", "") or "").strip()
        if "action" not in out:
            path_hint = _extract_any_path(str(message or "")) or str(out.get("path", "") or "").strip()
            low_msg = str(message or "").lower()
            has_exec_words = _has_any(low_msg, ["ausfuehr", "ausführ", "fuehre", "führe", "run", "execute", "starte", "start"])
            has_read_words = _has_any(low_msg, ["lies", "lese", "read", "inhalt"])
            has_list_words = _has_any(low_msg, ["liste", "list", "dateien", "ordner", "verzeichnis"])
            if path_hint:
                p = Path(path_hint)
                suffix = p.suffix.lower()
                if has_exec_words and suffix in {".py", ".ps1"} and p.exists() and p.is_file():
                    with contextlib.suppress(Exception):
                        script_txt = p.read_text(encoding="utf-8-sig", errors="ignore")
                        if script_txt.strip():
                            out["action"] = {
                                "kind": "script_exec",
                                "script_type": "python" if suffix == ".py" else "powershell",
                                "script": script_txt,
                                "script_path": str(p),
                                "timeout_sec": 180,
                            }
                elif has_read_words and suffix:
                    out["action"] = {"kind": "read_file", "path": str(p)}
                elif has_list_words:
                    out["action"] = {"kind": "list_entries", "path": str(p), "want": "files"}
            if ("action" not in out) and _has_any(low_msg, ["screenshot", "bildschirmfoto"]):
                ps_script = (
                    "Add-Type -AssemblyName System.Windows.Forms; "
                    "Add-Type -AssemblyName System.Drawing; "
                    "Add-Type -TypeDefinition 'using System.Runtime.InteropServices; public class DpiH { [DllImport(\"user32.dll\")] public static extern bool SetProcessDPIAware(); }'; "
                    "[DpiH]::SetProcessDPIAware() | Out-Null; "
                    "$bounds=[System.Windows.Forms.SystemInformation]::VirtualScreen; "
                    "$bmp=New-Object System.Drawing.Bitmap($bounds.Width,$bounds.Height); "
                    "$g=[System.Drawing.Graphics]::FromImage($bmp); "
                    "$g.CopyFromScreen($bounds.Location,[System.Drawing.Point]::Empty,$bounds.Size); "
                    "$out=Join-Path (Resolve-Path '.') ('cron_screenshot_' + (Get-Date -Format 'yyyyMMdd_HHmmss') + '.png'); "
                    "$bmp.Save($out,[System.Drawing.Imaging.ImageFormat]::Png); "
                    "$g.Dispose(); $bmp.Dispose(); "
                    "Write-Output ('Screenshot gespeichert: ' + $out)"
                )
                out["action"] = {"kind": "script_exec", "script_type": "powershell", "script": ps_script}
            if ("action" not in out) and has_list_words and (not path_hint):
                out["action"] = {"kind": "list_entries", "path": str(_workspace_abs(cfg)), "want": "files"}
        if "action" not in out:
            with contextlib.suppress(Exception):
                parsed = analyze_filesystem_request(str(message or ""), cfg, ROOT_DIR)
                pa = parsed.get("action") if isinstance(parsed, dict) else None
                if isinstance(pa, dict):
                    pk = str(pa.get("kind", "") or "").strip().lower()
                    if pk and not pk.startswith("cron_"):
                        out["action"] = _normalize_llm_action(cfg, "filesystem", message, pa)
        if "task" not in out:
            q = str(out.get("query", "") or "").strip()
            if q:
                out["task"] = q
        if "task" not in out and isinstance(out.get("action", {}), dict):
            ak = str(out.get("action", {}).get("kind", "") or "").strip()
            if ak:
                out["task"] = f"Cron action: {ak}"
        if "task" not in out:
            parsed_from_msg = _cron_parse_natural_create(str(message or ""))
            if isinstance(parsed_from_msg, dict):
                msg_task = str(parsed_from_msg.get("task", "") or "").strip()
                if msg_task:
                    out["task"] = msg_task
        if "task" not in out:
            out["task"] = "Cron-Erinnerung"
        if "change_only" not in out:
            change_words = _has_any(
                msg_low,
                [
                    "nur bei aender",
                    "nur bei änder",
                    "wenn sich",
                    "sobald sich",
                    "falls sich",
                    "nur wenn neu",
                    "only if changed",
                    "on change",
                ],
            )
            if change_words:
                out["change_only"] = True
        out.pop("dst_path", None)
        out.pop("source", None)
        out.pop("destination", None)
        out.pop("target", None)

    if str(out.get("kind", "")).strip() == "list_entries":
        asks_files_only = _has_any(msg_low, ["datei", "dateien", "files"]) and not _has_any(msg_low, ["ordner", "verzeichnis", "dirs", "folders"])
        asks_dirs_only = _has_any(msg_low, ["ordner", "verzeichnis", "verzeichnisse", "dirs", "folders"]) and not _has_any(msg_low, ["datei", "dateien", "files"])
        if asks_files_only:
            out["want"] = "files"
        elif asks_dirs_only:
            out["want"] = "dirs"
        # Export intent: "in eine Textdatei" should map to export_entries_to_file.
        if _has_any(msg_low, ["in eine textdatei", "als textdatei", "in textdatei", "exportiere", "schreibe alle"]):
            src_path = str(out.get("path", "") or "").strip() or _extract_any_path(message)
            out_path = str(out.get("out_path", "") or out.get("target_path", "") or out.get("dst", "") or "").strip()
            if not out_path:
                path_hits = re.findall(r"([A-Za-z]:\\[^\n\r\"`]+)", str(message or ""))
                if len(path_hits) >= 2:
                    out_path = str(path_hits[-1]).strip().rstrip(".,;")
                elif len(path_hits) == 1:
                    out_path = str(path_hits[0]).strip().rstrip(".,;")
            if out_path and Path(out_path).suffix.lower() != ".txt":
                fname = "ordnerliste.txt" if _has_any(msg_low, ["ordner", "verzeichnis"]) else "dateiliste.txt"
                out_path = str(Path(out_path) / fname)
            if src_path and out_path:
                out["kind"] = "export_entries_to_file"
                out["path"] = src_path
                out["out_path"] = out_path
                kind = "export_entries_to_file"

    if str(out.get("kind", "")).strip() == "export_entries_to_file":
        out_path_raw = str(out.get("out_path", "") or "").strip()
        if out_path_raw:
            m_out = re.search(r".+\s+in\s+eine\s+textdatei\s+unter\s+(.+)$", out_path_raw, flags=re.IGNORECASE)
            if m_out:
                out["out_path"] = str(m_out.group(1) or "").strip()
        
        # Wenn Quellpfad ein Netzlaufwerk ist, Ausgabe standardmäßig im Workspace
        src_path = str(out.get("path", "") or "").strip()
        out_path = str(out.get("out_path", "") or "").strip()
        if src_path and out_path:
            # Prüfe ob Quellpfad ein Netzlaufwerk ist (X:, Y:, Z: oder UNC-Pfad)
            src_upper = src_path.upper()
            is_network = (
                src_upper.startswith("\\\\") or 
                (len(src_upper) >= 2 and src_upper[0] in "XYZUVW" and src_upper[1] == ":")
            )
            # Prüfe ob Ausgabepfad auch auf Netzlaufwerk zeigt
            out_upper = out_path.upper()
            out_is_network = (
                out_upper.startswith("\\\\") or 
                (len(out_upper) >= 2 and out_upper[0] in "XYZUVW" and out_upper[1] == ":")
            )
            
            if is_network and out_is_network:
                # Umleitung auf Workspace
                ws_raw = str(_cfg().get("workspace", "data\\workspace") or "data\\workspace")
                ws = Path(ws_raw)
                if not ws.is_absolute():
                    ws = (ROOT_DIR / ws).resolve()
                fname = Path(out_path).name or "export.txt"
                out["out_path"] = str((ws / fname).resolve())
                tool_store.log("export_redirect", f"Ausgabe von Netzlaufwerk auf Workspace umgeleitet: {fname}")

    # Coerce values to expected schema types to survive small model format drift.
    spec = _action_schemas().get(str(out.get("kind", "") or "").strip(), {})
    req = spec.get("required", {}) if isinstance(spec.get("required", {}), dict) else {}
    opt = spec.get("optional", {}) if isinstance(spec.get("optional", {}), dict) else {}
    expected = dict(req)
    expected.update(opt)
    for key, typ in expected.items():
        if key not in out:
            continue
        val = out.get(key)
        if typ is str:
            if isinstance(val, list):
                val = val[0] if val else ""
            if val is None:
                val = ""
            out[key] = str(val)
        elif typ is bool:
            if isinstance(val, str):
                out[key] = str(val).strip().lower() in {"1", "true", "yes", "ja"}
            else:
                out[key] = bool(val)
        elif typ is int:
            try:
                out[key] = int(val)
            except Exception:
                pass
        elif typ is float:
            try:
                out[key] = float(val)
            except Exception:
                pass
        elif typ is list:
            if isinstance(val, list):
                out[key] = val
            elif isinstance(val, tuple):
                out[key] = list(val)
            elif isinstance(val, str):
                raw = str(val or "").strip()
                if not raw:
                    out[key] = []
                else:
                    parts = [p.strip() for p in re.split(r"[,\n;]+", raw) if str(p).strip()]
                    if len(parts) <= 1 and " " in raw and key == "packages":
                        parts = [p.strip() for p in raw.split() if p.strip()]
                    out[key] = parts if parts else [raw]
            elif val is None:
                out[key] = []
            else:
                out[key] = [val]

    # Kind-specific normalization for common drift patterns.
    if str(out.get("kind", "")).strip() == "bulk_delete_ext":
        if "folder" not in out:
            folder = str(out.get("path", "") or out.get("dir", "") or out.get("directory", "") or "").strip()
            if not folder:
                folder = _extract_any_path(message)
            if folder:
                out["folder"] = folder
        ext_raw = str(out.get("ext", "") or "").strip()
        if not ext_raw:
            m_ext = re.search(r"\.([a-z0-9]{1,12})\b", msg_low, flags=re.IGNORECASE)
            if m_ext:
                ext_raw = f".{str(m_ext.group(1) or '').lower()}"
        if ext_raw and (not ext_raw.startswith(".")):
            out["ext"] = f".{ext_raw.lstrip('.')}"
        elif ext_raw:
            out["ext"] = ext_raw
        if "recursive" not in out and _has_any(msg_low, ["rekursiv", "recursive", "unterordner"]):
            out["recursive"] = True
        # Never allow write-file style payload fields on delete intents.
        out.pop("content", None)

    if str(out.get("kind", "")).strip() == "watch_path":
        if "path" not in out:
            watch_path = str(out.get("folder", "") or out.get("dir", "") or out.get("directory", "") or "").strip()
            if watch_path:
                out["path"] = watch_path
        if "interval_sec" in out:
            try:
                out["interval_sec"] = float(out.get("interval_sec"))
            except Exception:
                pass

    if str(out.get("kind", "")).strip() == "install_python_packages":
        pkgs = out.get("packages")
        if not isinstance(pkgs, list):
            pkgs = []
        norm: List[str] = []
        for p in pkgs:
            s = str(p or "").strip().strip("\"'")
            if not s:
                continue
            norm.extend([t for t in re.split(r"\s+", s) if t])
        if not norm:
            m = re.search(
                r"(?:paket(?:e)?|package(?:s)?)\s+([a-z0-9][a-z0-9_\-\.]*(?:\s*[,\s]\s*[a-z0-9][a-z0-9_\-\.]*)*)",
                msg_low,
                flags=re.IGNORECASE,
            )
            if m:
                raw_names = str(m.group(1) or "").strip()
                norm = [n.strip() for n in re.split(r"[,\s]+", raw_names) if n.strip()]
        if norm:
            out["packages"] = list(dict.fromkeys(norm))

    if str(out.get("kind", "")).strip() == "script_create":
        script_type = str(out.get("script_type", "") or "").strip().lower()
        
        # Mapping: script_type -> file extension
        script_type_map = {
            "python": ".py",
            "powershell": ".ps1",
            "batch": ".bat",
            "cmd": ".cmd",
            "bash": ".sh",
            "shell": ".sh",
            "javascript": ".js",
            "nodejs": ".js",
            "typescript": ".ts",
            "ruby": ".rb",
            "perl": ".pl",
            "php": ".php",
            "lua": ".lua",
            "r": ".r",
            "go": ".go",
            "rust": ".rs",
            "java": ".java",
            "c": ".c",
            "cpp": ".cpp",
            "csharp": ".cs",
        }
        
        # Auto-detect script_type wenn nicht gesetzt oder ungültig
        if script_type not in script_type_map:
            if _has_any(msg_low, ["powershell", "pwsh"]):
                script_type = "powershell"
            elif _has_any(msg_low, ["batch", "bat", "cmd"]):
                script_type = "batch"
            elif _has_any(msg_low, ["bash", "shell", "sh"]):
                script_type = "bash"
            elif _has_any(msg_low, ["javascript", "js", "node"]):
                script_type = "javascript"
            else:
                script_type = "python"  # Default
            out["script_type"] = script_type
        
        script_path = str(out.get("script_path", "") or "").strip()
        valid_exts = set(script_type_map.values())
        ext = Path(script_path).suffix.lower() if script_path else ""
        
        if (not script_path) or (ext not in valid_exts):
            ws_raw = str(_cfg().get("workspace", "data\\workspace") or "data\\workspace")
            ws = Path(ws_raw)
            if not ws.is_absolute():
                ws = (ROOT_DIR / ws).resolve()
            scripts_dir = (ws / "scripts").resolve()
            scripts_dir.mkdir(parents=True, exist_ok=True)
            ts = int(time.time())
            file_ext = script_type_map.get(script_type, ".txt")
            fname = f"auto_{script_type}_{ts}{file_ext}"
            out["script_path"] = str(scripts_dir / fname)

    # Drop unknown fields for the selected action kind after all mappings.
    final_kind = str(out.get("kind", "") or "").strip()
    final_spec = _action_schemas().get(final_kind)
    if isinstance(final_spec, dict) and not bool(final_spec.get("allow_any", False)):
        req2 = final_spec.get("required", {}) if isinstance(final_spec.get("required", {}), dict) else {}
        opt2 = final_spec.get("optional", {}) if isinstance(final_spec.get("optional", {}), dict) else {}
        allowed = set(req2.keys()) | set(opt2.keys()) | {"kind"}
        out = {k: v for k, v in out.items() if k in allowed}

    return out

def _direct_tool_execution(cfg: Dict[str, Any], message: str) -> Optional[Dict[str, Any]]:
    """
    DIREKTE TOOL-CALLS: LLM sieht alle Tools und entscheidet selbst.
    Keine Intent-Zwischenschicht - das LLM wählt direkt die richtigen Tools.
    """
    try:
        tool_store.log("direct_tool_start", f"message={message[:100]}")
        
        # Config vorbereiten
        plan_cfg = json.loads(json.dumps(cfg))
        llm_cfg = plan_cfg.setdefault("llm", {})
        llm_cfg["temperature"] = 0.1
        
        # Tool-Definitions holen
        tool_defs = _get_tool_definitions_for_direct_calls(plan_cfg, message=message)
        
        if not tool_defs:
            tool_store.log("direct_tool", "no_tools")
            return None

        if _looks_operational_request(message):
            tool_defs = _reorder_tools_mcp_first(tool_defs)
        
        tool_store.log("direct_tool", f"tools_count={len(tool_defs)}")
        
        # Router erstellen
        router = LLMRouter(plan_cfg)
        
        # LLM mit Tools aufrufen
        tool_calls = router.chat_tool_calls(
            prompt=message,
            tools=tool_defs,
        )
        
        if not tool_calls:
            tool_store.log("direct_tool", "no_tool_calls")
            return None
        
        tool_store.log("direct_tool", f"calls={len(tool_calls)}")
        
        # Tool-Calls ausführen
        results = []
        for tc in tool_calls:
            tool_name = tc.get("name", "")
            args = tc.get("arguments", {}) or tc.get("input", {})
            
            # Tool ausführen
            action = {"kind": tool_name}
            action.update(args)
            
            tool_name_exec, reply = _execute_action(action)
            
            if tool_name_exec:
                results.append(f"[{tool_name}] {reply}")
            else:
                results.append(f"[{tool_name}] Fehler: {reply}")
        
        if results:
            final_reply = "\n\n".join(results)
            tool_store.log("direct_tool_result", f"result={final_reply[:200]}")
            return {"ok": True, "reply": final_reply}
    
    except Exception as e:
        tool_store.log("direct_tool_error", str(e))
    
    return None

def _get_tool_definitions_for_direct_calls(
    cfg: Dict[str, Any],
    *,
    message: str = "",
    intent: str = "",
) -> List[Dict[str, Any]]:
    """Returns tool definitions for direct LLM calls. Falls back to _native_tools_for_allowed_kinds."""
    inferred_intent = str(intent or "").strip().lower()
    if not inferred_intent and _looks_operational_request(message):
        inferred_intent = "filesystem"
    allowed_core = _allowed_action_kinds_for_intent(inferred_intent or "filesystem") if _cli_core_enabled(cfg) else []
    try:
        from app.smart_system import get_tool_manager
        tool_mgr = get_tool_manager(cfg)
        tools = tool_mgr.get_tools_for_llm(intent=None, use_native_calling=True)
        if tools:
            # Merge with native schemas to ensure all action kinds exist (e.g. dynamic/mcp management).
            if allowed_core:
                native = _native_tools_for_allowed_kinds(allowed_core)
            else:
                native = _native_tools_for_allowed_kinds(list(_action_schemas().keys()))
            by_name = {t.get("function", {}).get("name", ""): t for t in tools if isinstance(t, dict)}
            for t in native:
                name = t.get("function", {}).get("name", "")
                if name and name not in by_name:
                    tools.append(t)
            if allowed_core:
                allow_set = set(allowed_core)
                tools = [
                    t
                    for t in tools
                    if str((t.get("function", {}) if isinstance(t, dict) else {}).get("name", "")).strip() in allow_set
                ]
            return tools
    except Exception as e:
        tool_store.log("tool_manager_error", str(e))
    # Reliable fallback: build from all known schemas with good descriptions
    all_kinds = list(allowed_core) if allowed_core else list(_action_schemas().keys())
    return _native_tools_for_allowed_kinds(all_kinds)

def _get_tool_summary_for_prompt(intent: Optional[str] = None, format: str = "detailed") -> str:
    """Generiert Tool-Uebersicht aus Smart-System."""
    try:
        from app.smart_system import get_tool_manager
        from app.config import load_config
        
        cfg = load_config()
        tool_mgr = get_tool_manager(cfg)
        
        return tool_mgr.get_tool_summary(
            intent=intent,
            max_tools=15,
            format=format
        )
    except Exception:
        # Fallback
        return """VERFÜGBARE TOOLS:
- read_file: Datei lesen
- write_file: Datei schreiben
- list_entries: Dateien/Ordner auflisten
- script_exec: Script ausfuehren
- script_create: Script erstellen"""


def _reorder_tools_mcp_first(tools: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    def _is_mcp(t: Dict[str, Any]) -> bool:
        if not isinstance(t, dict):
            return False
        if "mcp_meta" in t:
            return True
        func = t.get("function", {}) if isinstance(t.get("function", {}), dict) else {}
        name = str(func.get("name", "")).strip()
        return name.startswith("mcp_")

    mcp = [t for t in tools if _is_mcp(t)]
    other = [t for t in tools if not _is_mcp(t)]
    return mcp + other

def _llm_direct_decide_and_act(cfg: Dict[str, Any], message: str) -> Optional[Dict[str, Any]]:
    """
    DIREKTE LLM-STEUERUNG mit Smart-System-Integration.
    LLM entscheidet selbst basierend auf verfügbaren Tools.
    """
    try:
        tool_store.log("llm_direct_start", f"message={message[:100]}")
        
        # Hole Chat-History für Kontext
        turns = _get_dynamic_turns(message, "")
        context = _inject_conversation_context(cfg, message, turns)
        
        # Dynamische Tool-Liste aus Smart-System
        tool_summary = _get_tool_summary_for_prompt(format="llm-optimized")
        
        _SYSTEM_DIRECT = (
            "Du bist ein autonomer KI-Assistent mit Zugriff auf Tools und ein persistentes Langzeitgedächtnis (ChromaDB). "
            "Du erinnerst dich an Fakten, Präferenzen und frühere Aufgaben über Sessions hinweg. "
            "Wenn du im Kontext Informationen unter '[ERINNERUNG AN NUTZERFAKTEN]' oder '[ERINNERUNG AN ERFOLGREICHE AUFGABEN]' siehst, "
            "behandle diese als dein eigenes Wissen und antworte entsprechend. Sage niemals, dass du zustandslos bist. "
            "WICHTIG: Wenn du versprichst, eine Datei zu erstellen, musst du das passende Tool TATSÄCHLICH AUFRUFEN. "
            "Tool-Prioritaet: (1) vorhandene MCP-Tools, (2) shell_command fuer direkte Ausfuehrung, "
            "(3) mcp_registry_search, (4) script_exec als Fallback."
        )
        if context:
            prompt = (
                f"{_SYSTEM_DIRECT}\n\n"
                f"BISHERIGER GESPRÄCHSVERLAUF:\n{context}\n\n"
                f"AKTUELLE NACHRICHT: {message}"
            )
        else:
            prompt = f"{_SYSTEM_DIRECT}\n\nNACHRICHT: {message}"
        
        # Hole Tool-Definitionen
        tool_defs = _get_tool_definitions_for_direct_calls(cfg, message=message)
        
        if not tool_defs:
            tool_store.log("llm_direct", "no tools")
            return None

        if _looks_operational_request(message):
            tool_defs = _reorder_tools_mcp_first(tool_defs)

        # Hard-Prioritaet: Wenn MCP vorhanden ist, built-in FS-Tools ausblenden
        def _has_mcp(tools: List[Dict[str, Any]]) -> bool:
            for t in tools:
                if not isinstance(t, dict):
                    continue
                if "mcp_meta" in t:
                    return True
                func = t.get("function", {}) if isinstance(t.get("function", {}), dict) else {}
                name = str(func.get("name", "")).strip()
                if name.startswith("mcp_"):
                    return True
            return False

        if _has_mcp(tool_defs):
            def _keep(t: Dict[str, Any]) -> bool:
                func = t.get("function", {}) if isinstance(t.get("function", {}), dict) else {}
                name = str(func.get("name", "")).strip()
                # keep scripts, shell_command, mcp, cron, gmail, print
                if name.startswith("mcp_"):
                    return True
                if name in {"script_exec", "script_create", "script_validate", "install_python_packages", "install_nodejs_packages", "shell_command"}:
                    return True
                if name.startswith("cron_") or name.startswith("gmail_") or name in {"print_file", "list_printers", "screenshot_email"}:
                    return True
                return False
            tool_defs = [t for t in tool_defs if _keep(t)]
        
        tool_store.log("llm_direct", f"tools={len(tool_defs)}")
        
        router = LLMRouter(cfg)
        
        # Verwende Tool-Calls
        try:
            tool_calls = router.chat_tool_calls(
                prompt=prompt,
                tools=tool_defs,
            )
        except Exception as tool_err:
            tool_store.log("llm_direct_tool_err", str(tool_err))
            return None
        
        if tool_calls and len(tool_calls) > 0:
            tool_store.log("llm_direct", f"tool_calls={len(tool_calls)}")
            
            # Führe alle Tool-Calls aus
            results = []
            for tc in tool_calls:
                tool_name = tc.get("name", "").strip()
                if not tool_name:
                    tool_store.log("llm_direct_error", "tool_call ohne name übersprungen")
                    continue
                args = tc.get("arguments", {}) or tc.get("input", {})
                
                # Baue Action
                action = {"kind": tool_name}
                action.update(args)
                
                tool_name_exec, reply = _execute_action(action)
                
                if tool_name_exec:
                    results.append(f"[{tool_name}] {reply}")
                else:
                    results.append(f"[{tool_name}] Fehler: {reply}")
            
            if results:
                final_reply = "\n\n".join(results)
                return {"ok": True, "reply": final_reply}
            # Alle tool_calls hatten leere Namen → deterministische Handler sollen greifen
            return None
        
        # Keine Tool-Calls - normale Antwort
        _EMPTY_PLACEHOLDERS = {"(leere antwort)", "(keine antwort)", "(leere Antwort)", "(keine Antwort)"}
        response = router.chat(prompt)
        if response and response.text and str(response.text).strip() not in _EMPTY_PLACEHOLDERS:
            return {"ok": True, "reply": str(response.text).strip()}
        
    except Exception as e:
        tool_store.log("llm_direct_error", str(e))
    
    return None

def _llm_select_tool(cfg: Dict[str, Any], message: str, available_tools: List[str]) -> Optional[str]:
    """
    Expliziter LLM-Call: Welches Tool passt am besten zur Nutzeranfrage?
    
    Args:
        cfg: Konfiguration
        message: Nutzeranfrage
        available_tools: Liste verfügbarer Tool-Namen
    
    Returns:
        Tool-Name (z.B. "script_exec") oder None bei Fehler
    """
    if not available_tools:
        return None
    
    try:
        # Tool-Beschreibungen aus Action-Schemas extrahieren
        schemas = _action_schemas()
        tool_descriptions: List[str] = []
        
        for tool_name in available_tools:
            spec = schemas.get(tool_name, {})
            desc = str(spec.get("description", "") or "").strip()
            if not desc:
                # Fallback-Beschreibungen für wichtige Tools
                if tool_name == "gmail_list_messages":
                    desc = "Listet Gmail-Nachrichten auf"
                elif tool_name == "write_file":
                    desc = "Schreibt Text in eine Datei"
                else:
                    desc = f"Tool: {tool_name}"
            
            tool_descriptions.append(f"- {tool_name}: {desc}")
        
        # Prompt für Tool-Selection
        prompt = (
            "Du bist ein Tool-Selector. Wähle das BESTE Tool für diese Anfrage.\n\n"
            f"Anfrage: {message}\n\n"
            "Verfügbare Tools:\n"
            + "\n".join(tool_descriptions)
            + "\n\n"
            "WICHTIGE REGELN:\n"
            "- Bevorzuge Dynamic/MCP-Tools und Scripts (script_exec/script_create), wenn geeignet.\n"
            "- Bei 'gmail', 'email', 'mail' → gmail_list_messages oder gmail_send_email*\n"
            "- Bei 'druck', 'print', 'printer' → print_file/list_printers\n"
            "- Bei 'cron', 'zeitplan' → cron_*\n\n"
            "Antworte NUR mit dem Tool-Namen, nichts anderes. Kein Markdown, keine Erklärung."
        )
        
        # LLM-Call mit niedriger Temperatur für deterministische Auswahl
        router = LLMRouter(cfg)
        response = router.chat(prompt, system_prompt="Du bist ein präziser Tool-Selector. Antworte nur mit dem Tool-Namen.")
        
        if not response or not response.text:
            return None
        
        selected = str(response.text).strip().lower()
        
        # Validierung: Ist das gewählte Tool verfügbar?
        available_lower = [t.lower() for t in available_tools]
        if selected in available_lower:
            # Original-Case zurückgeben
            idx = available_lower.index(selected)
            return available_tools[idx]
        
        # Fuzzy-Match: Tool-Name könnte in der Antwort enthalten sein
        for tool in available_tools:
            if tool.lower() in selected:
                return tool
        
        tool_store.log("tool_selection_failed", f"LLM wählte '{selected}', nicht in {available_tools}")
        return None
        
    except Exception as exc:
        tool_store.log("tool_selection_error", str(exc))
        return None

def _llm_plan_action(cfg: Dict[str, Any], message: str, interpretation: Optional[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
    if not isinstance(interpretation, dict):
        return None
    intent = str(interpretation.get("intent", "") or "").strip().lower()
    try:
        conf = float(interpretation.get("confidence", 0.0) or 0.0)
    except Exception:
        conf = 0.0
    if intent not in {"filesystem", "script", "cron", "answer_and_save"}:
        if _looks_operational_request(message):
            intent = "filesystem"
            conf = max(conf, 0.7)
        else:
            return None

    if conf < _intent_threshold(cfg, intent):
        return None
    if _is_help_command(message) or _is_clear_conversation_command(message):
        return None
    if _is_memory_show_command(message) or _is_memory_delete_command(message):
        return None
    try:
        # Planner must be deterministic and stable across retries.
        # Use a copied config to avoid mutating runtime settings.
        plan_cfg = json.loads(json.dumps(cfg))
        llm_cfg = plan_cfg.setdefault("llm", {})
        llm_cfg["temperature"] = 0.0
        active_provider = str(llm_cfg.get("active_provider_id", "") or "").strip()
        active_model = str(llm_cfg.get("active_model", "") or "").strip()
        # Keep planner on active provider/model to reduce variability from failover.
        llm_cfg["fallback_provider_ids"] = []
        providers_cfg = plan_cfg.get("providers", {}) if isinstance(plan_cfg.get("providers", {}), dict) else {}
        if active_provider and isinstance(providers_cfg.get(active_provider, {}), dict):
            p_cfg = providers_cfg.get(active_provider, {})
            if active_model:
                p_cfg["default_model"] = active_model
                models = p_cfg.get("models", [])
                model_names: List[str] = []
                if isinstance(models, list):
                    for m in models:
                        if isinstance(m, dict):
                            name = str(m.get("name", "")).strip()
                            if name:
                                model_names.append(name)
                        elif isinstance(m, str):
                            name = str(m).strip()
                            if name:
                                model_names.append(name)
                if active_model not in model_names:
                    p_cfg["models"] = list(models) + [active_model]
            plan_cfg["providers"] = {active_provider: p_cfg}
        router = LLMRouter(plan_cfg)
        active_pcfg = plan_cfg.get("providers", {}).get(active_provider, {}) if isinstance(plan_cfg.get("providers", {}), dict) else {}
        provider_type = str(active_pcfg.get("type", "") or "").strip().lower()
        tool_profile = resolve_tool_profile(provider_type=provider_type, model=active_model, provider_id=active_provider)
        allowed_kinds = _allowed_action_kinds_for_intent(intent)
        
        # Patch 18: Tool-Selection als Hint (nicht als harte Einschränkung)
        selected_tool = str(interpretation.get("selected_tool", "") or "").strip()
        tool_selection_hint = ""
        if selected_tool and selected_tool in allowed_kinds:
            tool_selection_hint = f"\n\nWICHTIG: Bevorzuge das Tool '{selected_tool}' für diese Anfrage."
            tool_store.log("tool_selection_hint", f"Empfehle {selected_tool} für '{message[:50]}'")
        
        if intent == "answer_and_save":
            # Add only tools from skills that match the user text (e.g., Gmail),
            # so planner stays compact but still tool-capable.
            skill_kinds: List[str] = []
            for hit in _skill_matches_for_text(message):
                tools = hit.get("tools", []) if isinstance(hit.get("tools", []), list) else []
                for t in tools:
                    if not isinstance(t, dict):
                        continue
                    k = str(t.get("kind", "") or "").strip()
                    if k:
                        skill_kinds.append(k)
            # Extra safety for common wording when skill matching is fuzzy.
            low_msg = str(message or "").lower()
            if "gmail" in low_msg and "gmail_list_messages" in _action_schemas():
                skill_kinds.append("gmail_list_messages")
            allowed_kinds = list(dict.fromkeys(list(allowed_kinds) + skill_kinds))
        fields_lines: List[str] = []
        for k in allowed_kinds:
            spec = _action_schemas().get(k)
            if not isinstance(spec, dict):
                continue
            req = spec.get("required", {}) if isinstance(spec.get("required", {}), dict) else {}
            req_keys = ",".join(sorted(req.keys()))
            fields_lines.append(f"- {k}: req=[{req_keys}]")
        schema: Dict[str, Any] = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "action": {"type": "object"},
                "actions": {"type": "array", "items": {"type": "object"}},
                "note": {"type": "string"},
                "needs_clarification": {"type": "boolean"},
                "clarification_question": {"type": "string"},
                "confidence": {"type": "number"},
            },
            "required": ["note", "needs_clarification", "clarification_question", "confidence"],
        }
        prompt_base = (
            "Gib NUR JSON gemaess Schema aus. Keine Erklaerungen.\n"
            "Aufgabe: Erzeuge ausfuehrbare Tool-Action(s) fuer die Nutzeranfrage.\n"
            "Regeln: bevorzugt `actions` (Liste), `action` nur als Fallback; "
            "nur erlaubte `kind`; alle Pflichtfelder setzen; bei Unklarheit needs_clarification=true.\n"
            "Fuer verkettete Schritte darfst du {{steps.0.reply}} in Feldern nutzen.\n\n"
            "MCP/TOOL-PRIORITAET (VERBINDLICH):\n"
            "- 1) Zuerst vorhandene MCP-Tools nutzen (inkl. gecachte Server-Tools).\n"
            "- 2) Wenn kein passendes existiert: shell_command für direkte Ausführung nutzen.\n"
            "- 3) Nur wenn externe Server nötig sind: MCP-Registry durchsuchen (mcp_registry_search). Externe MCP-Server nur nach ausdruecklicher Bestaetigung einbinden.\n"
            "- 4) Script-Ausfuehrung (script_exec/script_create) erst als naechster Fallback.\n"
            "- 5) Klassische Built-in Tool-Calls zuletzt als Absicherung.\n\n"
            "TOOL-DESIGN (WICHTIG):\n"
            "- Neu erstellte MCP-Tools immer generisch parametrisieren (z.B. path/root_path + pattern/ext/query).\n"
            "- Keine Einweg-Tools mit festem Laufwerk/Dateiendung in Name oder harter Logik.\n"
            "- Ziel: ein Tool fuer ganze Aufgabengruppe statt je Anfrage ein neues Spezial-Tool.\n\n"
            "SUCHE-STRATEGIE (WICHTIG):\n"
            "- Bei Anfragen wie 'suche/finde ... von X auf Y': X ist Suchbegriff/Filter, NICHT Teil des Pfads.\n"
            "- Wenn eine erste Suche 0 Treffer liefert, versuche automatisch eine zweite Strategie per script_exec "
            "(rekursiv, Name/Pattern-Filter, groesseres Timeout), statt sofort abzubrechen.\n\n"
            "KRITISCH - TEMPLATE-SYNTAX VERBOT:\n"
            "- NIEMALS Template-Syntax wie {{...}} oder {steps...} in Dateiinhalte schreiben!\n"
            "- Bei write_file/filesystem: Immer ECHTE, KONKRETE Daten verwenden!\n"
            "- {{steps.0.reply}} ist NUR für Parameter-Verkettung, NICHT für Dateiinhalte!\n"
            "- Beispiel FALSCH: content='Ergebnis: {{steps.0.reply}}'\n"
            "- Beispiel RICHTIG: Nutze die tatsächlichen Daten aus vorherigen Schritten\n\n"
            "Erlaubte Actions (nur req-Felder):\n"
            + "\n".join(fields_lines)
            + "\n\n"
            f"Intent={intent}; confidence={conf:.2f}"
            + tool_selection_hint
            + f"\nNutzeranfrage: {message}"
        )
        prompt_retry = (
            prompt_base
            + "\n\n"
            + "WICHTIG RETRY: Gib ausschliesslich valides JSON gemaess Schema aus. "
            + "Kein Markdown, kein Erklaertext, kein Codeblock."
        )
        obj: Optional[Dict[str, Any]] = None
        strategy_order = tool_profile.get("strategy_order", []) if isinstance(tool_profile.get("strategy_order", []), list) else []
        native_enabled = bool(tool_profile.get("native_tools", {}).get("enabled", False)) if isinstance(tool_profile.get("native_tools", {}), dict) else False
        try:
            max_rounds = int(cfg.get("llm", {}).get("plan_retry_rounds", 4) or 4)
        except Exception:
            max_rounds = 4
        max_rounds = max(1, min(6, max_rounds))
        for round_idx in range(1, max_rounds + 1):
            round_prompt = prompt_base if round_idx == 1 else prompt_retry
            for strategy in strategy_order:
                s = str(strategy or "").strip().lower()
                if not s:
                    continue
                if s == "native_tools":
                    if not native_enabled:
                        continue
                    try:
                        native_actions = router.chat_tool_calls(
                            prompt=round_prompt,
                            tools=_native_tools_for_allowed_kinds(allowed_kinds),
                            provider_id=active_provider,
                            model=active_model,
                            temperature=0.0,
                            profile=tool_profile,
                        )
                        if isinstance(native_actions, list) and native_actions:
                            obj = {
                                "actions": [dict(x) for x in native_actions if isinstance(x, dict)],
                                "note": "LLM-Action (native_tools)",
                                "needs_clarification": False,
                                "clarification_question": "",
                                "confidence": conf,
                            }
                            break
                    except Exception as exc_native:
                        tool_store.log("llm_action_plan_retry", f"round={round_idx} strategy=native_tools err={exc_native}")
                        obj = None
                        continue
                if s == "json_schema":
                    round_schema = "action_plan_v1" if round_idx == 1 else "action_plan_v1_retry"
                    try:
                        obj = router.chat_json(prompt=round_prompt, schema_name=round_schema, schema=schema)
                        if isinstance(obj, dict):
                            break
                    except Exception as exc_json:
                        tool_store.log("llm_action_plan_retry", f"round={round_idx} strategy=json_schema err={exc_json}")
                        obj = None
                        continue
                if s == "json_text":
                    try:
                        raw = router.chat(round_prompt)
                        obj = _extract_json_dict(str(raw.text or ""))
                        if isinstance(obj, dict):
                            break
                    except Exception as exc_text:
                        tool_store.log("llm_action_plan_retry", f"round={round_idx} strategy=json_text err={exc_text}")
                        obj = None
                        continue
            if isinstance(obj, dict):
                break
            if round_idx < max_rounds:
                time.sleep(0.2 * round_idx)
        if not isinstance(obj, dict):
            return None
        # Model may return wrapper object ({actions:[...]}/{action:{...}})
        # or directly the action object ({kind:..., ...}).
        actions: List[Dict[str, Any]] = []
        if "kind" in obj:
            actions = [dict(obj)]
            obj = {
                "actions": actions,
                "note": "",
                "needs_clarification": False,
                "clarification_question": "",
                "confidence": conf,
            }
        if bool(obj.get("needs_clarification", False)):
            q = str(obj.get("clarification_question", "") or "").strip()
            return {"needs_clarification": True, "clarification_question": q}
        raw_actions = obj.get("actions")
        if isinstance(raw_actions, list):
            actions = [dict(x) for x in raw_actions if isinstance(x, dict)]
        if not actions:
            raw_action = obj.get("action")
            if isinstance(raw_action, dict):
                actions = [dict(raw_action)]
        if not actions:
            return None
        normalized_actions: List[Dict[str, Any]] = []
        low_msg = str(message or "").lower()
        screenshot_send_combo = bool(
            _has_any(low_msg, ["screenshot", "bildschirmfoto", "screen shot"])
            and _has_any(low_msg, ["schick", "sende", "send"])
        )
        for raw_act in actions[:8]:
            action = _normalize_llm_action(cfg, intent, message, raw_act)
            if screenshot_send_combo and str(action.get("kind", "") or "").strip().lower() in {"script_exec", "script_create"}:
                has_explicit_path = bool(str(action.get("script_path", "") or "").strip()) or bool(_extract_any_path(message))
                if not has_explicit_path:
                    return {
                        "needs_clarification": True,
                        "clarification_question": "Soll ich zuerst einen Screenshot erstellen und ihn danach senden?",
                    }
            if str(action.get("kind", "") or "").strip() not in set(allowed_kinds):
                # Treat this as a planner miss. This message is internal and should not be user-facing.
                tool_store.log(
                    "llm_action_plan_invalid_kind",
                    f"intent={intent} kind={str(action.get('kind', '') or '').strip()}",
                )
                continue
            ok, err = _validate_action_schema(action)
            if not ok:
                return {
                    "needs_clarification": True,
                    "clarification_question": f"Ich brauche praezisere Angaben ({err}).",
                }
            normalized_actions.append(action)
        if not normalized_actions:
            return None
        # LLM-first with robust fallback:
        # if user clearly asked for save but model returned only gmail_list_messages,
        # append write_file as second step using step output template.
        if len(normalized_actions) == 1:
            only = normalized_actions[0]
            only_kind = str(only.get("kind", "") or "").strip().lower()
            wants_save = _wants_save_output(message)
            if only_kind == "gmail_list_messages" and wants_save:
                normalized_actions.append(
                    {
                        "kind": "write_file",
                        "path": f"workspace/{_generic_output_filename(message, intent='save')}",
                        "content": "{{steps.0.reply}}",
                    }
                )
        note = str(obj.get("note", "") or "").strip() or f"LLM-Action: {normalized_actions[0].get('kind', '')}"
        try:
            action_conf = float(obj.get("confidence", 0.0) or 0.0)
        except Exception:
            action_conf = 0.0
        out = {
            "actions": normalized_actions,
            "note": note,
            "confidence": max(0.0, min(1.0, action_conf)),
        }
        if len(normalized_actions) == 1:
            out["action"] = normalized_actions[0]
        return out
    except Exception as exc:
        tool_store.log("llm_action_plan_error", str(exc))
        return None

def _llm_self_check_solved(cfg: Dict[str, Any], message: str, reply: str, steps: Optional[List[Any]] = None) -> Dict[str, Any]:
    fallback = {
        "solved": False,
        "confidence": 0.0,
        "reason": "llm_self_check_unavailable",
        "next_action_hint": "",
    }
    try:
        router = LLMRouter(cfg)
        schema: Dict[str, Any] = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "solved": {"type": "boolean"},
                "confidence": {"type": "number"},
                "reason": {"type": "string"},
                "next_action_hint": {"type": "string"},
                "file_delivery_expected": {"type": "boolean"},
            },
            "required": ["solved", "confidence", "reason", "next_action_hint", "file_delivery_expected"],
        }

        # Tool-Schritte für Kontext aufbereiten (inkl. Ergebnis-Snippet)
        steps_info = ""
        if steps:
            executed = []
            for s in steps:
                if isinstance(s, dict) and s.get("kind"):
                    result_snippet = str(s.get("result") or s.get("reply") or "")[:150].replace("\n", " ")
                    executed.append(f"- {s.get('kind')} (ok={s.get('ok')}): {result_snippet}")
            if executed:
                steps_info = "\nAusgeführte Werkzeuge:\n" + "\n".join(executed[:15])

        prompt = (
            "Pruefe streng, ob die Nutzeraufgabe wirklich geloest wurde.\n"
            "Bedenke, dass der Agent manchmal nur Fragen mit Text beantworten muss, ohne Tools zu nutzen.\n"
            "Antworte NUR als JSON gemaess Schema.\n"
            "- solved=true nur wenn das erkennbare Ziel erreicht ist.\n"
            "- solved=false bei Teil-Erfolg/unklar/Abbruch.\n"
            "- file_delivery_expected=true NUR wenn der Nutzer explizit eine Datei als Anhang/Download "
            "zugeschickt haben wollte (nicht: eine Datei erstellen, bearbeiten oder anzeigen).\n"
            "WICHTIG – Ankündigungs-Falle: Wenn die Antwort zukünftige Arbeit ankündigt die der Agent\n"
            "NOCH NICHT ausgeführt hat (z.B. 'werde ich implementieren', 'werde ich beginnen',\n"
            "'werde ich erstellen', 'werde nun', 'als nächstes werde ich'), dann ist die Aufgabe\n"
            "NICHT abgeschlossen — solved=false. Der Agent hat nur geplant, nicht gehandelt.\n"
            "WICHTIG – Mehrere Teilaufgaben: Wenn der Nutzer mehrere Dinge verlangt hat (z.B. 'mach X\n"
            "und erstelle auch Y'), prüfe JEDE Teilaufgabe einzeln. solved=true nur wenn ALLE erledigt sind.\n"
            "Wenn auch nur eine Teilaufgabe fehlt → solved=false.\n"
            "WICHTIG – Interne Antworten: Wenn die Antwort nur interne System-Meldungen enthält\n"
            "(z.B. 'Es gibt keine neuen Fakten', 'Fakten gespeichert', 'Plan aktualisiert') ohne\n"
            "echte Nutzerantwort → solved=false, der Nutzer hat keine hilfreiche Antwort erhalten.\n"
            f"Nutzerauftrag: {message}\n"
            f"{steps_info}\n"
            f"Resultierende Antwort an Nutzer: {str(reply or '')[:4000]}"
        )
        obj = router.chat_json(prompt=prompt, schema_name="solution_check_v2", schema=schema)
        if isinstance(obj, dict):
            conf_raw = float(obj.get("confidence", 0.0) or 0.0)
            if conf_raw > 1.0 and conf_raw <= 10.0:
                conf_raw = conf_raw / 10.0
            conf_raw = max(0.0, min(1.0, conf_raw))
            return {
                "solved": bool(obj.get("solved", False)),
                "confidence": conf_raw,
                "reason": str(obj.get("reason", "") or "").strip(),
                "next_action_hint": str(obj.get("next_action_hint", "") or "").strip(),
                "file_delivery_expected": bool(obj.get("file_delivery_expected", False)),
            }
    except Exception:
        pass
    return fallback

def _run_filesystem_action_with_policy(cfg: Dict[str, Any], message: str, action: Dict[str, Any], note: str) -> Dict[str, Any]:
    cancelled = _cancelled_reply("vor Aktion")
    if cancelled:
        return cancelled
    def _workspace_fallback_for_action(local_action: Dict[str, Any], reason: str) -> Tuple[Dict[str, Any], str]:
        ws = _workspace_abs(cfg).resolve()
        kind_local = str(local_action.get("kind", "") or "").strip().lower()
        out = dict(local_action)
        default_ext = ".txt"
        if kind_local == "write_json_file":
            default_ext = ".json"
        raw_target = str(out.get("out_path" if kind_local == "export_entries_to_file" else "path", "") or "").strip()
        generic = _generic_output_filename(message, intent="save")
        name = _path_filename_hint(raw_target, fallback=generic)
        if not _is_valid_windows_filename(name):
            name = generic
        if "." not in Path(name).name:
            stem = Path(name).name
            name = f"{stem}{default_ext}" if stem else f"output{default_ext}"
        fallback_target = str((ws / name).resolve())
        if kind_local == "export_entries_to_file":
            out["out_path"] = fallback_target
        else:
            out["path"] = fallback_target
        msg = (
            f"Hinweis: Zielpfad wurde auf Workspace umgeleitet ({reason}).\n"
            f"Neues Ziel: {fallback_target}"
        )
        return out, msg

    def _target_parent_missing(local_action: Dict[str, Any]) -> bool:
        kind_local = str(local_action.get("kind", "") or "").strip().lower()
        key = "out_path" if kind_local == "export_entries_to_file" else "path"
        raw = str(local_action.get(key, "") or "").strip()
        if not raw:
            return False
        with contextlib.suppress(Exception):
            p = Path(raw)
            if not (p.is_absolute() or raw.startswith("\\\\")):
                return False
            parent = p if _path_looks_like_directory(raw) else p.parent
            if not str(parent):
                return False
            return not parent.exists()
        return False

    kind = str(action.get("kind", "") or "").strip().lower()
    fallback_prefix = ""
    if kind == "export_entries_to_file":
        # Recover malformed parser outputs like
        # "c:\\temp in eine textdatei unter c:\\temp".
        raw_src = str(action.get("path", "") or "").strip()
        raw_out = str(action.get("out_path", "") or "").strip()
        low_src = raw_src.lower()
        m = re.search(r"^(.+?)\s+in\s+eine\s+textdatei\s+unter\s+(.+)$", low_src, flags=re.IGNORECASE)
        if m:
            src = str(m.group(1) or "").strip()
            dst = str(m.group(2) or "").strip()
            action = dict(action)
            action["path"] = src
            if raw_out:
                action["out_path"] = raw_out
            else:
                dst_path = Path(dst)
                if dst_path.suffix.lower() != ".txt":
                    fname = "ordnerliste.txt" if _has_any(str(message or "").lower(), ["ordner", "verzeichnis"]) else "dateiliste.txt"
                    dst_path = dst_path / fname
                action["out_path"] = str(dst_path)
        elif raw_out:
            m_out = re.search(r".+\s+in\s+eine\s+textdatei\s+unter\s+(.+)$", raw_out, flags=re.IGNORECASE)
            if m_out:
                action = dict(action)
                action["out_path"] = str(m_out.group(1) or "").strip()
    if kind in {"write_file", "append_file", "write_json_file", "touch_file", "export_entries_to_file"}:
        if _target_parent_missing(action):
            # Try to create the missing parent directory — only redirect to workspace if that fails
            _created_dir = False
            try:
                _key = "out_path" if kind == "export_entries_to_file" else "path"
                _raw = str(action.get(_key, "") or "").strip()
                if _raw:
                    _p = Path(_raw)
                    _parent = _p if _path_looks_like_directory(_raw) else _p.parent
                    _parent.mkdir(parents=True, exist_ok=True)
                    _created_dir = True
            except Exception as _mkdir_err:
                tool_store.log("mkdir_failed", f"Konnte Verzeichnis nicht erstellen: {_mkdir_err}")
            if not _created_dir:
                action, fallback_prefix = _workspace_fallback_for_action(action, "Zielpfad existiert nicht")
    if kind == "read_file":
        raw_path = str(action.get("path", "") or "").strip()
        if raw_path:
            with contextlib.suppress(Exception):
                p = Path(raw_path).resolve()
                if p.exists() and p.is_dir():
                    latest = _latest_file_in_dir(p)
                    if latest is not None:
                        action = dict(action)
                        action["path"] = str(latest)
                        note = f"{note} (read_file_dir_fallback={latest.name})"
                    else:
                        return {
                            "ok": True,
                            "reply": (
                                f"Unter `{p}` konnte ich keine konkrete Datei zum Lesen bestimmen. "
                                "Bitte nenne den exakten Dateipfad."
                            ),
                        }
    mode = execution_mode(cfg)
    deny_decision = deny_if_mode_deny(cfg)
    if deny_decision and not deny_decision.ok:
        return {"ok": False, "reply": deny_decision.message}
    path_decision = validate_action_paths(cfg, ROOT_DIR, action)
    if not path_decision.ok:
        if kind in {"write_file", "append_file", "write_json_file", "touch_file", "export_entries_to_file"}:
            redirected, hint = _workspace_fallback_for_action(action, "Pfadregel/Berechtigung")
            second_decision = validate_action_paths(cfg, ROOT_DIR, redirected)
            if second_decision.ok:
                action = redirected
                fallback_prefix = (fallback_prefix + "\n" + hint).strip()
            else:
                return {"ok": False, "reply": path_decision.message}
        else:
            return {"ok": False, "reply": path_decision.message}
    is_risky, admin_required = _action_policy_flags(action)
    admin_decision = require_admin_for_risky(
        cfg,
        is_risky=is_risky,
        admin_required=admin_required,
        role_hint=_role_windows_hint,
    )
    if admin_decision and not admin_decision.ok:
        return {"ok": False, "reply": admin_decision.message}
    risky_scope_decision = require_admin_for_risky_scope(
        cfg,
        is_risky=is_risky,
        action=action,
        workspace=_workspace_abs(cfg),
        is_within=_is_within,
        role_hint=_role_windows_hint,
    )
    if risky_scope_decision and not risky_scope_decision.ok:
        return {"ok": False, "reply": risky_scope_decision.message}
    try:
        tool_name, reply = _execute_action(action)
        tool_store.log(tool_name, f"Ausgefuehrt (llm_action, mode={mode}): {note}")
        _record_execution_lesson(cfg, message=message, action=action, success=True, reply_text=reply)
        final_reply = f"{fallback_prefix}\n{reply}".strip() if fallback_prefix else reply
        with contextlib.suppress(Exception):
            _remember_session_artifact_from_result(
                cfg,
                str(_dialog_key_ctx.get("") or ""),
                action,
                reply,
                message,
            )
        _persist_conversation(cfg, message, final_reply, 0.82)
        return {"ok": True, "reply": final_reply}
    except Exception as exc:
        if kind in {"write_file", "append_file", "write_json_file", "touch_file", "export_entries_to_file"}:
            redirected, hint = _workspace_fallback_for_action(action, f"Schreibfehler: {exc}")
            try:
                tool_name, reply = _execute_action(redirected)
                tool_store.log(tool_name, f"Ausgefuehrt (llm_action,fallback, mode={mode}): {note}")
                final_reply = f"{(fallback_prefix + chr(10) + hint).strip()}\n{reply}".strip()
                _record_execution_lesson(cfg, message=message, action=redirected, success=True, reply_text=final_reply)
                with contextlib.suppress(Exception):
                    _remember_session_artifact_from_result(
                        cfg,
                        str(_dialog_key_ctx.get("") or ""),
                        redirected,
                        reply,
                        message,
                    )
                _persist_conversation(cfg, message, final_reply, 0.82)
                return {"ok": True, "reply": final_reply}
            except Exception as exc2:
                _record_execution_lesson(cfg, message=message, action=redirected, success=False, error_text=str(exc2))
                return {"ok": False, "reply": f"Aktion fehlgeschlagen: {exc2}"}
        _record_execution_lesson(cfg, message=message, action=action, success=False, error_text=str(exc))
        return {"ok": False, "reply": f"Aktion fehlgeschlagen: {exc}"}

def _run_virtual_action(
    cfg: Dict[str, Any],
    message: str,
    action: Dict[str, Any],
    note: str,
    *,
    dialog_key: str = "",
) -> Dict[str, Any]:
    cancelled = _cancelled_reply("vor Aktion")
    if cancelled:
        return cancelled
    kind = str(action.get("kind", "") or "").strip().lower()
    if kind == "cron_list":
        return {"ok": True, "reply": _cron_jobs_overview(active_only=bool(action.get("active_only", False)))}
    if kind == "cron_create":
        if (not str(action.get("dialog_key", "") or "").strip()) and str(dialog_key or "").strip():
            action = dict(action)
            action["dialog_key"] = str(dialog_key)
        if not bool(action.get("change_only", False)):
            low_msg = str(message or "").lower()
            if _has_any(
                low_msg,
                [
                    "nur bei aender",
                    "nur bei änder",
                    "wenn sich",
                    "sobald sich",
                    "falls sich",
                    "nur wenn neu",
                    "only if changed",
                    "on change",
                ],
            ):
                action = dict(action)
                action["change_only"] = True
        # Nur Text-Parsing nutzen wenn LLM KEINE nested action mitgeliefert hat
        if not isinstance(action.get("action"), dict):
            explicit_nested, explicit_err = _parse_explicit_skill_action(str(message or ""))
            gmail_nested, gmail_err = _gmail_action_from_text(str(message or ""))
            if isinstance(explicit_nested, dict):
                action = dict(action)
                action["action"] = explicit_nested
            elif explicit_err:
                return {"ok": False, "reply": explicit_err}
            elif isinstance(gmail_nested, dict):
                action = dict(action)
                action["action"] = gmail_nested
            elif gmail_err:
                return {"ok": False, "reply": gmail_err}
        nested = action.get("action", None)
        if not isinstance(nested, dict) or not nested:
            with contextlib.suppress(Exception):
                parsed = analyze_filesystem_request(str(message or ""), cfg, ROOT_DIR)
                pa = parsed.get("action") if isinstance(parsed, dict) else None
                if isinstance(pa, dict):
                    pk = str(pa.get("kind", "") or "").strip().lower()
                    if pk and not pk.startswith("cron_"):
                        action = dict(action)
                        action["action"] = _normalize_llm_action(cfg, "filesystem", str(message or ""), dict(pa))
        if not str(action.get("platform", "") or "").strip():
            p = str(_messenger_platform_ctx.get("") or "").strip()
            if p:
                action = dict(action)
                action["platform"] = p
            elif str(dialog_key or "").strip().lower() == "webui":
                action = dict(action)
                action["platform"] = "webui"
        if not str(action.get("target", "") or "").strip():
            t = str(_messenger_target_ctx.get("") or "").strip()
            if t:
                action = dict(action)
                action["target"] = t
            elif str(dialog_key or "").strip().lower() == "webui":
                action = dict(action)
                action["target"] = "webui"
        clarification = _skill_cron_clarification_message(message, action)
        if clarification:
            return {"ok": False, "reply": clarification}
        res = _cron_create_from_action(action)
        _record_execution_lesson(
            cfg,
            message=message,
            action=action,
            success=bool(res.get("ok", False)),
            reply_text=str(res.get("reply", "")),
        )
        return {"ok": bool(res.get("ok", False)), "reply": str(res.get("reply", ""))}
    if kind == "cron_delete":
        res = _cron_delete_job(str(action.get("job_id", "") or ""))
        return {"ok": bool(res.get("ok", False)), "reply": str(res.get("reply", ""))}
    if kind == "cron_pause":
        res = _cron_update_job_state(str(action.get("job_id", "") or ""), False)
        return {"ok": bool(res.get("ok", False)), "reply": str(res.get("reply", ""))}
    if kind == "cron_resume":
        res = _cron_update_job_state(str(action.get("job_id", "") or ""), True)
        return {"ok": bool(res.get("ok", False)), "reply": str(res.get("reply", ""))}
    if kind == "cron_test":
        res = _cron_run_now(cfg, str(action.get("job_id", "") or ""))
        return {"ok": bool(res.get("ok", False)), "reply": str(res.get("reply", ""))}
    if kind == "print_file":
        file_path = str(action.get("file_path", "") or "").strip()
        if not file_path:
            return {"ok": False, "reply": "print_file braucht einen file_path."}
        printer_name = str(action.get("printer_name", "") or "").strip() or None
        try:
            copies = int(action.get("copies", 1) or 1)
        except Exception:
            copies = 1
        try:
            result = print_file(file_path=file_path, printer_name=printer_name, copies=copies)
        except Exception as exc:
            return {"ok": False, "reply": f"print_file fehlgeschlagen: {exc}"}
        tool_store.log("print_file", f"Gedruckt: {file_path} auf {result.get('printer')}")
        reply = f"Gedruckt: {file_path} auf {result.get('printer')} ({copies} Kopien)"
        _record_execution_lesson(cfg, message=message, action=action, success=True, reply_text=reply)
        return {"ok": True, "reply": reply}
    if kind == "list_printers":
        try:
            printers = list_printers()
        except Exception as exc:
            return {"ok": False, "reply": f"list_printers fehlgeschlagen: {exc}"}
        if not printers:
            return {"ok": True, "reply": "Keine Drucker gefunden."}
        lines = ["Verfügbare Drucker:"]
        for p in printers:
            default_marker = " (Standard)" if p.get("is_default") else ""
            lines.append(f"- {p.get('name')}{default_marker} - Status: {p.get('status')}")
        reply = "\n".join(lines)
        _record_execution_lesson(cfg, message=message, action=action, success=True, reply_text=reply)
        return {"ok": True, "reply": reply}
    return {"ok": False, "reply": f"Unbekannte virtuelle Action: {kind}"}

def _skill_render_template(value: Any, ctx: Dict[str, Any]) -> Any:
    if isinstance(value, str):
        out = str(value)
        for k, v in ctx.items():
            out = out.replace("{{" + str(k) + "}}", str(v))
        return out
    if isinstance(value, dict):
        return {str(k): _skill_render_template(v, ctx) for k, v in value.items()}
    if isinstance(value, list):
        return [_skill_render_template(v, ctx) for v in value]
    return value

def _skill_secret_value(cfg: Dict[str, Any], alias: str) -> str:
    a = SecretStore.normalize_alias(str(alias or ""))
    if not a:
        return ""
    store = _secret_store(cfg)
    row = store.get_secret(a)
    if not isinstance(row, dict):
        return ""
    val = str(row.get("value", "") or "").strip()
    if val.lower().startswith("bearer "):
        val = val[7:].strip()
    return val

def _skill_secret_upsert(cfg: Dict[str, Any], alias: str, value: str, *, source: str = "skill_refresh") -> None:
    a = SecretStore.normalize_alias(str(alias or ""))
    v = str(value or "").strip()
    if not a or not v:
        return
    store = _secret_store(cfg)
    store.upsert_secret(alias=a, value=v, meta={"source": source, "dialog_key": "runtime"})

def _gmail_oauth_error_details(resp: httpx.Response) -> str:
    parts: List[str] = []
    try:
        ctype = str(resp.headers.get("content-type", "")).lower()
    except Exception:
        ctype = ""
    body_obj: Dict[str, Any] = {}
    if "application/json" in ctype:
        with contextlib.suppress(Exception):
            parsed = resp.json()
            if isinstance(parsed, dict):
                body_obj = parsed
    err = str(body_obj.get("error", "") or "").strip()
    err_desc = str(body_obj.get("error_description", "") or "").strip()
    err_sub = str(body_obj.get("error_subtype", "") or "").strip()
    if err:
        parts.append(f"oauth_error={err}")
    if err_desc:
        parts.append(f"description={err_desc}")
    if err_sub:
        parts.append(f"subtype={err_sub}")
    if not parts:
        txt = ""
        with contextlib.suppress(Exception):
            txt = str(resp.text or "").strip()
        if txt:
            one = " ".join(txt.split())
            parts.append(f"body={one[:260]}")
    return "; ".join(parts)

def _gmail_refresh_request(
    *,
    token_endpoint: str,
    payload: Dict[str, Any],
    use_basic_auth: bool,
) -> httpx.Response:
    req_payload = dict(payload)
    headers: Dict[str, str] = {}
    if use_basic_auth:
        cid = str(req_payload.pop("client_id", "") or "").strip()
        csec = str(req_payload.pop("client_secret", "") or "").strip()
        if cid and csec:
            raw = f"{cid}:{csec}".encode("utf-8")
            headers["Authorization"] = "Basic " + base64.b64encode(raw).decode("ascii")
    with httpx.Client(timeout=30, trust_env=False) as client:
        return client.post(token_endpoint, data=req_payload, headers=headers or None)

def _gmail_refresh_access_token(cfg: Dict[str, Any], handler: Dict[str, Any], skill_cfg: Dict[str, Any]) -> tuple[str, str]:
    token_endpoint = str(skill_cfg.get("token_endpoint", "") or handler.get("token_endpoint", "") or "https://oauth2.googleapis.com/token").strip()
    refresh_alias = str(skill_cfg.get("refresh_token_secret", "") or handler.get("refresh_token_secret", "gmail_refresh_token") or "gmail_refresh_token").strip()
    client_id_alias = str(skill_cfg.get("client_id_secret", "") or handler.get("client_id_secret", "gmail_client_id") or "gmail_client_id").strip()
    client_secret_alias = str(skill_cfg.get("client_secret_secret", "") or handler.get("client_secret_secret", "gmail_client_secret") or "gmail_client_secret").strip()
    access_alias = str(skill_cfg.get("token_secret", "") or handler.get("token_secret", "gmail_access_token") or "gmail_access_token").strip()

    refresh_token = _skill_secret_value(cfg, refresh_alias)
    client_id = _skill_secret_value(cfg, client_id_alias)
    client_secret = _skill_secret_value(cfg, client_secret_alias)
    if not refresh_token:
        return "", f"Refresh-Token fehlt (Secret-Alias: {refresh_alias})."
    if not client_id:
        return "", f"Client-ID fehlt (Secret-Alias: {client_id_alias})."
    if not client_secret:
        return "", f"Client-Secret fehlt (Secret-Alias: {client_secret_alias})."
    if not token_endpoint:
        return "", "Token-Endpoint fehlt."
    payload = {
        "grant_type": "refresh_token",
        "refresh_token": refresh_token,
        "client_id": client_id,
        "client_secret": client_secret,
    }
    with _gmail_refresh_lock:
        try:
            last_detail = ""
            for use_basic in (False, True):
                resp = _gmail_refresh_request(token_endpoint=token_endpoint, payload=payload, use_basic_auth=use_basic)
                if resp.status_code >= 400:
                    detail = _gmail_oauth_error_details(resp)
                    last_detail = detail
                    body_obj: Dict[str, Any] = {}
                    with contextlib.suppress(Exception):
                        parsed = resp.json()
                        if isinstance(parsed, dict):
                            body_obj = parsed
                    oauth_err = str(body_obj.get("error", "") or "").strip().lower()
                    # If the refresh token is invalid/revoked, surface a clear action to re-connect.
                    if oauth_err in {"invalid_grant", "invalid_request", "invalid_token"}:
                        return "", (
                            f"Token-Refresh fehlgeschlagen: {oauth_err}. "
                            "Bitte verbinde Gmail erneut unter /api/skills/gmail/connect/start und aktualisiere die gespeicherten Tokens."
                        )
                    retry_with_basic = (not use_basic) and resp.status_code in {400, 401} and oauth_err in {"invalid_client", "unauthorized_client"}
                    if retry_with_basic:
                        continue
                    continue
                obj = resp.json() if "application/json" in str(resp.headers.get("content-type", "")).lower() else {}
                access_token = str(obj.get("access_token", "") or "").strip()
                if not access_token:
                    return "", "Token-Refresh lieferte kein access_token."
                _skill_secret_upsert(cfg, access_alias, access_token, source="gmail_refresh")
                # Some OAuth providers rotate refresh tokens; persist if present.
                refresh_new = str(obj.get("refresh_token", "") or "").strip()
                if refresh_new:
                    _skill_secret_upsert(cfg, refresh_alias, refresh_new, source="gmail_refresh")
                return access_token, ""
            suffix = f" ({last_detail})" if last_detail else ""
            return "", f"Token-Refresh fehlgeschlagen: HTTP 401/400{suffix}"
        except Exception as exc:
            return "", f"Token-Refresh fehlgeschlagen: {exc}"

def _gmail_get_access_token(cfg: Dict[str, Any], handler: Dict[str, Any], skill_cfg: Dict[str, Any]) -> tuple[str, str]:
    access_alias = str(skill_cfg.get("token_secret", "") or handler.get("token_secret", "gmail_access_token") or "gmail_access_token").strip()
    token = _skill_secret_value(cfg, access_alias)
    if token:
        return token, ""
    return _gmail_refresh_access_token(cfg, handler, skill_cfg)

def _gmail_oauth_build_settings(cfg: Dict[str, Any], redirect_uri: str) -> tuple[Optional[Dict[str, Any]], str]:
    handler = _skill_handler_for_kind("gmail_send_email") or _skill_handler_for_kind("gmail_send_email_advanced") or {}
    if not isinstance(handler, dict) or not handler:
        return None, "Gmail-Skill nicht gefunden."
    skill_cfg = handler.get("skill_config", {}) if isinstance(handler.get("skill_config", {}), dict) else {}
    token_endpoint = str(skill_cfg.get("token_endpoint", "") or handler.get("token_endpoint", "") or "https://oauth2.googleapis.com/token").strip()
    auth_endpoint = str(skill_cfg.get("auth_endpoint", "") or handler.get("auth_endpoint", "") or "https://accounts.google.com/o/oauth2/v2/auth").strip()
    client_id_alias = str(skill_cfg.get("client_id_secret", "") or handler.get("client_id_secret", "gmail_client_id") or "gmail_client_id").strip()
    client_secret_alias = str(skill_cfg.get("client_secret_secret", "") or handler.get("client_secret_secret", "gmail_client_secret") or "gmail_client_secret").strip()
    access_alias = str(skill_cfg.get("token_secret", "") or handler.get("token_secret", "gmail_access_token") or "gmail_access_token").strip()
    refresh_alias = str(skill_cfg.get("refresh_token_secret", "") or handler.get("refresh_token_secret", "gmail_refresh_token") or "gmail_refresh_token").strip()
    client_id = _skill_secret_value(cfg, client_id_alias)
    client_secret = _skill_secret_value(cfg, client_secret_alias)
    if not client_id:
        return None, f"Client-ID fehlt (Secret-Alias: {client_id_alias})."
    if not client_secret:
        return None, f"Client-Secret fehlt (Secret-Alias: {client_secret_alias})."
    scopes_raw = skill_cfg.get("oauth_scopes", handler.get("oauth_scopes", []))
    scopes = [str(x).strip() for x in scopes_raw if str(x).strip()] if isinstance(scopes_raw, list) else []
    if not scopes:
        scopes = [
            "https://www.googleapis.com/auth/gmail.send",
            "https://www.googleapis.com/auth/gmail.readonly",
        ]
    settings = {
        "auth_endpoint": auth_endpoint,
        "token_endpoint": token_endpoint,
        "client_id": client_id,
        "client_secret": client_secret,
        "client_id_alias": client_id_alias,
        "client_secret_alias": client_secret_alias,
        "access_alias": access_alias,
        "refresh_alias": refresh_alias,
        "redirect_uri": str(redirect_uri or "").strip(),
        "scopes": scopes,
    }
    return settings, ""

def _gmail_oauth_start_state() -> str:
    state = uuid.uuid4().hex
    now = time.time()
    with _gmail_oauth_lock:
        # Keep small and short-lived in-memory state map.
        stale = [k for k, v in _gmail_oauth_states.items() if now - float(v.get("ts", 0.0) or 0.0) > 1800]
        for k in stale:
            _gmail_oauth_states.pop(k, None)
        _gmail_oauth_states[state] = {"ts": now}
    return state

def _gmail_oauth_consume_state(state: str) -> bool:
    s = str(state or "").strip()
    if not s:
        return False
    with _gmail_oauth_lock:
        payload = _gmail_oauth_states.pop(s, None)
    if not isinstance(payload, dict):
        return False
    try:
        age = time.time() - float(payload.get("ts", 0.0) or 0.0)
    except Exception:
        age = 99999.0
    return age <= 1800

def _webui_push_notification(text: str, *, source: str = "cron", platform: str = "webui", target: str = "webui") -> None:
    msg = str(text or "").strip()
    if not msg:
        return
    
    # Quiet Mode Filterung: Prüfe ob Nachricht unterdrückt werden soll
    cfg = _cfg()
    ui_cfg = cfg.get("ui", {}) if isinstance(cfg.get("ui", {}), dict) else {}
    quiet_mode = bool(ui_cfg.get("quiet_mode", False))
    show_thinking = bool(ui_cfg.get("show_thinking", False))
    show_actions = bool(ui_cfg.get("show_actions", False))
    
    # Wenn Quiet Mode aktiv ist, prüfe ob die Nachricht gefiltert werden soll
    if quiet_mode and source == "react_plan":
        # Im Quiet Mode: Thinking/Action-Nachrichten nur anzeigen wenn explizit aktiviert
        is_thinking = any(x in msg.lower() for x in ["denke", "analysiere", "überlege", "thinking"])
        is_action = any(x in msg.lower() for x in ["schritt", "step", "⏳", "✅", "❌", "läuft", "abgeschlossen", "fehlgeschlagen"])
        
        # Unterdrücke Thinking-Nachrichten wenn show_thinking=False
        if is_thinking and not show_thinking:
            return
        
        # Unterdrücke Action-Nachrichten wenn show_actions=False
        if is_action and not show_actions:
            return
    
    global _webui_notify_seq
    row = {
        "id": 0,
        "ts": datetime.now().isoformat(),
        "source": str(source or "cron"),
        "platform": str(platform or "webui"),
        "target": str(target or "webui"),
        "text": msg[:2000],
    }
    with _webui_notify_lock:
        _webui_notify_seq += 1
        row["id"] = int(_webui_notify_seq)
        _webui_notifications.append(row)
        if len(_webui_notifications) > 300:
            del _webui_notifications[:-300]

def _webui_list_notifications(after_id: int = 0, limit: int = 50) -> List[Dict[str, Any]]:
    try:
        aid = int(after_id or 0)
    except Exception:
        aid = 0
    lim = max(1, min(200, int(limit or 50)))
    with _webui_notify_lock:
        items = [dict(x) for x in _webui_notifications if int(x.get("id", 0) or 0) > aid]
    if len(items) > lim:
        items = items[-lim:]
    return items

def _run_skill_action(cfg: Dict[str, Any], action: Dict[str, Any]) -> Dict[str, Any]:
    kind = str(action.get("kind", "") or "").strip()
    handler = _skill_handler_for_kind(kind)
    if not isinstance(handler, dict):
        return {"ok": False, "reply": f"Skill-Handler nicht gefunden fuer: {kind}"}
    htype = str(handler.get("type", "") or "").strip().lower()
    skill_cfg = handler.get("skill_config", {}) if isinstance(handler.get("skill_config", {}), dict) else {}
    ctx: Dict[str, Any] = {}
    for k, v in skill_cfg.items():
        ctx[str(k)] = v
    for k, v in action.items():
        if k == "kind":
            continue
        ctx[str(k)] = v

    if htype == "http_json":
        method = str(handler.get("method", "POST") or "POST").upper()
        url = str(_skill_render_template(handler.get("url", ""), ctx) or "").strip()
        if not url:
            return {"ok": False, "reply": f"Skill {kind}: URL fehlt."}
        headers = _skill_render_template(handler.get("headers", {}), ctx)
        if not isinstance(headers, dict):
            headers = {}
        token_alias = str(skill_cfg.get("token_secret", "") or handler.get("token_secret", "") or "").strip()
        token_header_name = str(handler.get("token_header", "") or skill_cfg.get("token_header", "") or "Authorization").strip()
        if token_alias:
            token = _skill_secret_value(cfg, token_alias)
            if token:
                if token_header_name == "Authorization":
                    headers.setdefault("Authorization", f"Bearer {token}")
                else:
                    headers.setdefault(token_header_name, token)
        body = _skill_render_template(handler.get("body", {}), ctx)
        # Nicht aufgeloeste optionale Template-Vars entfernen (z.B. {{count}} wenn nicht uebergeben)
        if isinstance(body, dict):
            body = {k: v for k, v in body.items() if not (isinstance(v, str) and v.startswith("{{") and v.endswith("}}"))}
        timeout_sec = int(handler.get("timeout_sec", 30) or 30)
        try:
            with httpx.Client(timeout=max(5, min(120, timeout_sec)), trust_env=False) as client:
                if method in {"GET", "DELETE"}:
                    resp = client.request(method, url, headers=headers, params=body if isinstance(body, dict) else None)
                else:
                    resp = client.request(method, url, headers=headers, json=body if isinstance(body, (dict, list)) else {"payload": body})
                resp.raise_for_status()
                # Optionales response_path + result_fields fuer strukturierte Ausgabe
                response_path = str(handler.get("response_path", "") or "").strip()
                result_fields = handler.get("result_fields", [])
                result_limit = int(handler.get("result_limit", 5) or 5)
                if response_path or result_fields:
                    try:
                        import re as _re
                        data = resp.json()
                        # response_path: z.B. "web.results" -> data["web"]["results"]
                        node = data
                        if response_path:
                            for part in response_path.split("."):
                                node = node[part] if isinstance(node, dict) else node
                        items = node if isinstance(node, list) else [node]
                        lines = []
                        for idx, item in enumerate(items[:result_limit], 1):
                            if isinstance(item, dict) and result_fields:
                                parts = []
                                for f in result_fields:
                                    val = str(item.get(f, "") or "")
                                    val = _re.sub(r"<[^>]+>", "", val).strip()
                                    if val:
                                        parts.append(val)
                                lines.append(f"{idx}. " + " | ".join(parts))
                            else:
                                lines.append(f"{idx}. {str(item)[:200]}")
                        txt = "\n".join(lines) if lines else resp.text[:900]
                    except Exception:
                        txt = resp.text[:900]
                else:
                    txt = resp.text[:900]
                return {"ok": True, "reply": f"{kind}: HTTP {resp.status_code}\n{txt}"}
        except Exception as exc:
            return {"ok": False, "reply": f"{kind}: HTTP-Fehler: {exc}"}

    if htype in {"gmail_send", "gmail_send_advanced"}:
        token, token_err = _gmail_get_access_token(cfg, handler, skill_cfg)
        if not token:
            token_alias = str(skill_cfg.get("token_secret", "") or handler.get("token_secret", "gmail_access_token") or "gmail_access_token").strip()
            extra = f" {token_err}" if token_err else ""
            return {"ok": False, "reply": f"{kind}: Access-Token fehlt/ungueltig (Secret-Alias: {token_alias}).{extra}"}
        to = str(action.get("to", "") or "").strip()
        subject = str(action.get("subject", "") or "").strip()
        body = str(action.get("body", "") or "")
        html_body = str(action.get("html_body", "") or "")
        cc = str(action.get("cc", "") or "").strip()
        bcc = str(action.get("bcc", "") or "").strip()
        reply_to = str(action.get("reply_to", "") or "").strip()
        raw_attachments = action.get("attachments", [])
        attachments: List[str] = []
        if isinstance(raw_attachments, list):
            attachments = [str(x).strip() for x in raw_attachments if str(x).strip()]
        elif isinstance(raw_attachments, str) and raw_attachments.strip():
            txt = str(raw_attachments).strip()
            sep = "|" if "|" in txt else (";" if ";" in txt else ",")
            attachments = [x.strip() for x in txt.split(sep) if x.strip()]
        if not to or not subject:
            return {"ok": False, "reply": f"{kind}: to und subject sind erforderlich."}
        msg = EmailMessage()
        msg["To"] = to
        msg["Subject"] = subject
        if cc:
            msg["Cc"] = cc
        if bcc:
            msg["Bcc"] = bcc
        if reply_to:
            msg["Reply-To"] = reply_to
        text_body = str(body or "").strip()
        html_part = str(html_body or "").strip()
        if text_body:
            msg.set_content(text_body, subtype="plain", charset="utf-8")
            if html_part:
                msg.add_alternative(html_part, subtype="html", charset="utf-8")
        elif html_part:
            msg.set_content(" ", subtype="plain", charset="utf-8")
            msg.add_alternative(html_part, subtype="html", charset="utf-8")
        else:
            msg.set_content(" ", subtype="plain", charset="utf-8")
        total_size = 0
        if attachments:
            ws = _workspace_abs(cfg)
            for raw_path in attachments[:10]:
                p = Path(raw_path)
                fp = p.resolve() if p.is_absolute() else (ws / p).resolve()
                if not fp.exists() or not fp.is_file():
                    return {"ok": False, "reply": f"{kind}: Anhang nicht gefunden: {fp}"}
                size = int(fp.stat().st_size or 0)
                total_size += size
                if total_size > 20 * 1024 * 1024:
                    return {"ok": False, "reply": f"{kind}: Anhaenge zu gross (>20MB gesamt)."}
                data = fp.read_bytes()
                mt = mimetypes.guess_type(fp.name)[0] or "application/octet-stream"
                main_t, sub_t = (mt.split("/", 1) + ["octet-stream"])[:2]
                msg.add_attachment(data, maintype=main_t, subtype=sub_t, filename=fp.name)
        raw_b64 = base64.urlsafe_b64encode(msg.as_bytes()).decode("ascii").rstrip("=")
        user_id = str(handler.get("user_id", "me") or "me").strip()
        url = f"https://gmail.googleapis.com/gmail/v1/users/{user_id}/messages/send"
        payload = {"raw": raw_b64}
        thread_id = str(action.get("thread_id", "") or "").strip()
        if thread_id:
            payload["threadId"] = thread_id
        def _send_with_token(tok: str) -> httpx.Response:
            with httpx.Client(timeout=40, trust_env=False) as client:
                return client.post(url, headers={"Authorization": f"Bearer {tok}"}, json=payload)
        try:
            resp = _send_with_token(token)
            if resp.status_code == 401:
                fresh, refresh_err = _gmail_refresh_access_token(cfg, handler, skill_cfg)
                if fresh:
                    resp = _send_with_token(fresh)
                elif refresh_err:
                    return {"ok": False, "reply": f"{kind}: Gmail-Fehler: HTTP 401. {refresh_err}"}
            resp.raise_for_status()
            obj = resp.json() if "application/json" in str(resp.headers.get("content-type", "")).lower() else {}
            mid = str(obj.get("id", "") or "").strip()
            att_txt = f" | anhaenge={len(attachments)}" if attachments else ""
            return {"ok": True, "reply": f"{kind}: Mail gesendet (id={mid or '-'}) an {to}{att_txt}."}
        except Exception as exc:
            return {"ok": False, "reply": f"{kind}: Gmail-Fehler: {exc}"}

    def _gmail_extract_body(payload: Any) -> str:
        """Extract plain text body from Gmail message payload (handles multi-part).
        HTML parts are stripped to plain text before truncation so tracking numbers
        deep in large HTML emails are not cut off."""
        import re as _re
        import html as _html_mod

        def _strip_html(raw: str) -> str:
            cleaned = _re.sub(r'<(script|style)[^>]*>.*?</(script|style)>', '', raw, flags=_re.DOTALL | _re.IGNORECASE)
            cleaned = _re.sub(r'<[^>]+>', ' ', cleaned)
            cleaned = _html_mod.unescape(cleaned)
            cleaned = _re.sub(r'\s+', ' ', cleaned).strip()
            return cleaned

        def _decode_part(data: str, mime_type: str) -> str:
            try:
                raw = base64.urlsafe_b64decode(data + "==").decode("utf-8", errors="replace")
                if "html" in str(mime_type).lower():
                    return _strip_html(raw)[:15000]
                return raw[:15000]
            except Exception:
                return ""

        if not isinstance(payload, dict):
            return ""
        parts = payload.get("parts", [])
        if parts and isinstance(parts, list):
            # Multi-part: prefer text/plain, fallback to text/html
            for preferred in ("text/plain", "text/html"):
                for part in parts:
                    if not isinstance(part, dict):
                        continue
                    if str(part.get("mimeType", "") or "").lower() == preferred:
                        data = str((part.get("body", {}) or {}).get("data", "") or "").strip()
                        if data:
                            result = _decode_part(data, preferred)
                            if result:
                                return result
                    # Recurse into nested parts
                    nested = part.get("parts", [])
                    if nested:
                        sub = _gmail_extract_body(part)
                        if sub:
                            return sub
        else:
            mime_type = str(payload.get("mimeType", "") or "")
            data = str((payload.get("body", {}) or {}).get("data", "") or "").strip()
            if data:
                return _decode_part(data, mime_type)
        return ""

    if htype == "gmail_get":
        token, token_err = _gmail_get_access_token(cfg, handler, skill_cfg)
        if not token:
            token_alias = str(skill_cfg.get("token_secret", "") or handler.get("token_secret", "gmail_access_token") or "gmail_access_token").strip()
            extra = f" {token_err}" if token_err else ""
            return {"ok": False, "reply": f"{kind}: Access-Token fehlt/ungueltig (Secret-Alias: {token_alias}).{extra}"}
        user_id = str(handler.get("user_id", "me") or "me").strip()
        message_id = str(action.get("message_id", "") or "").strip()
        if not message_id:
            return {"ok": False, "reply": f"{kind}: message_id ist erforderlich."}
        def _get_with_token(tok: str) -> httpx.Response:
            with httpx.Client(timeout=40, trust_env=False) as client:
                return client.get(
                    f"https://gmail.googleapis.com/gmail/v1/users/{user_id}/messages/{message_id}",
                    headers={"Authorization": f"Bearer {tok}"},
                    params={"format": "full"},
                )
        try:
            resp = _get_with_token(token)
            if resp.status_code == 401:
                fresh, refresh_err = _gmail_refresh_access_token(cfg, handler, skill_cfg)
                if fresh:
                    token = fresh
                    resp = _get_with_token(fresh)
                elif refresh_err:
                    return {"ok": False, "reply": f"{kind}: Gmail-Fehler: HTTP 401. {refresh_err}"}
            resp.raise_for_status()
            jo = resp.json()
            payload_obj = jo.get("payload", {}) if isinstance(jo.get("payload", {}), dict) else {}
            headers_list = payload_obj.get("headers", []) if isinstance(payload_obj.get("headers", []), list) else []
            def _hval(name: str) -> str:
                for h in headers_list:
                    if isinstance(h, dict) and str(h.get("name", "") or "").strip().lower() == name.lower():
                        return str(h.get("value", "") or "").strip()
                return ""
            subj = _hval("Subject") or "(ohne Betreff)"
            from_v = _hval("From") or "-"
            date_v = _hval("Date") or "-"
            body_text = _gmail_extract_body(payload_obj)
            snippet = str(jo.get("snippet", "") or "").strip()
            reply_parts = [
                f"gmail_get_message: id={message_id}",
                f"Betreff: {subj}",
                f"Von: {from_v}",
                f"Datum: {date_v}",
            ]
            if body_text:
                reply_parts.append(f"Body:\n{body_text}")
            elif snippet:
                reply_parts.append(f"Snippet: {snippet[:500]}")
            else:
                reply_parts.append("(Kein lesbarer Body gefunden)")
            return {"ok": True, "reply": "\n".join(reply_parts)}
        except Exception as exc:
            return {"ok": False, "reply": f"{kind}: Gmail-Fehler: {exc}"}

    if htype == "gmail_list":
        token, token_err = _gmail_get_access_token(cfg, handler, skill_cfg)
        if not token:
            token_alias = str(skill_cfg.get("token_secret", "") or handler.get("token_secret", "gmail_access_token") or "gmail_access_token").strip()
            extra = f" {token_err}" if token_err else ""
            return {"ok": False, "reply": f"{kind}: Access-Token fehlt/ungueltig (Secret-Alias: {token_alias}).{extra}"}
        user_id = str(handler.get("user_id", "me") or "me").strip()
        q = str(action.get("query", "") or "").strip()
        include_body = bool(action.get("include_body", False))
        try:
            max_results = int(action.get("max_results", 5) or 5)
        except Exception:
            max_results = 5
        max_results = max(1, min(20, max_results))
        url = f"https://gmail.googleapis.com/gmail/v1/users/{user_id}/messages"
        params = {"maxResults": max_results}
        if q:
            params["q"] = q
        def _list_with_token(tok: str) -> httpx.Response:
            with httpx.Client(timeout=40, trust_env=False) as client:
                return client.get(url, headers={"Authorization": f"Bearer {tok}"}, params=params)
        try:
            resp = _list_with_token(token)
            if resp.status_code == 401:
                fresh, refresh_err = _gmail_refresh_access_token(cfg, handler, skill_cfg)
                if fresh:
                    resp = _list_with_token(fresh)
                    token = fresh
                elif refresh_err:
                    return {"ok": False, "reply": f"{kind}: Gmail-Fehler: HTTP 401. {refresh_err}"}
            resp.raise_for_status()
            obj = resp.json()
            msgs = obj.get("messages", []) if isinstance(obj.get("messages", []), list) else []
            ids = [str(x.get("id", "")).strip() for x in msgs if isinstance(x, dict)]
            ids = [x for x in ids if x][:max_results]
            if not ids:
                return {"ok": True, "reply": f"{kind}: 0 Nachricht(en)."}

            def _header_value(headers: Any, name: str) -> str:
                if not isinstance(headers, list):
                    return ""
                for h in headers:
                    if not isinstance(h, dict):
                        continue
                    hn = str(h.get("name", "") or "").strip().lower()
                    if hn == str(name).strip().lower():
                        return str(h.get("value", "") or "").strip()
                return ""

            lines = [f"{kind}: {len(ids)} Nachricht(en):"]
            with httpx.Client(timeout=40, trust_env=False) as client:
                for i, mid in enumerate(ids, start=1):
                    try:
                        _fmt = "full" if include_body else "metadata"
                        _params = {"format": _fmt}
                        if not include_body:
                            _params["metadataHeaders"] = ["From", "Subject", "Date"]
                        r_msg = client.get(
                            f"https://gmail.googleapis.com/gmail/v1/users/{user_id}/messages/{mid}",
                            headers={"Authorization": f"Bearer {token}"},
                            params=_params,
                        )
                        if r_msg.status_code == 401:
                            fresh, refresh_err = _gmail_refresh_access_token(cfg, handler, skill_cfg)
                            if fresh:
                                token = fresh
                                r_msg = client.get(
                                    f"https://gmail.googleapis.com/gmail/v1/users/{user_id}/messages/{mid}",
                                    headers={"Authorization": f"Bearer {token}"},
                                    params=_params,
                                )
                            elif refresh_err:
                                lines.append(f"{i}. id={mid} | Fehler: {refresh_err}")
                                continue
                        r_msg.raise_for_status()
                        jo = r_msg.json() if "application/json" in str(r_msg.headers.get("content-type", "")).lower() else {}
                        payload = jo.get("payload", {}) if isinstance(jo.get("payload", {}), dict) else {}
                        headers = payload.get("headers", []) if isinstance(payload.get("headers", []), list) else []
                        from_v = _header_value(headers, "From") or "-"
                        subj_v = _header_value(headers, "Subject") or "(ohne Betreff)"
                        date_v = _header_value(headers, "Date") or "-"
                        snippet = str(jo.get("snippet", "") or "").strip()
                        lines.append(f"{i}. {subj_v}")
                        lines.append(f"   von: {from_v}")
                        lines.append(f"   datum: {date_v}")
                        lines.append(f"   id: {mid}")
                        if include_body:
                            body_txt = _gmail_extract_body(payload)
                            if body_txt:
                                lines.append(f"   body: {body_txt[:800]}")
                            elif snippet:
                                lines.append(f"   snippet: {snippet[:220]}")
                        elif snippet:
                            lines.append(f"   snippet: {snippet[:220]}")
                    except Exception as ex_msg:
                        lines.append(f"{i}. id={mid} | Fehler beim Laden: {ex_msg}")
            return {"ok": True, "reply": "\n".join(lines)}
        except Exception as exc:
            return {"ok": False, "reply": f"{kind}: Gmail-Fehler: {exc}"}

    return {"ok": False, "reply": f"Skill-Handler-Typ nicht unterstuetzt: {htype}"}

def _looks_unsolved_reply(reply: str) -> bool:
    low_reply = str(reply or "").strip().lower()
    if not low_reply:
        return True
    partial_markers = [
        "0 gefunden",
        "(keine eintraege gefunden)",
        "(keine dateien gefunden)",
        "(keine ordner gefunden)",
        "keine gueltigen pfade fuer die aktion erkannt",
        "bitte dateipfad angeben",
        "konnte ich keine konkrete datei",
    ]
    if any(m in low_reply for m in partial_markers):
        return True
    return bool("keine " in low_reply and " gefunden" in low_reply)

def _run_llm_planned_action(
    cfg: Dict[str, Any],
    message: str,
    action: Dict[str, Any],
    note: str,
    *,
    dialog_key: str = "",
    pre_approved: bool = False,
) -> Dict[str, Any]:
    def _finalize_result(res: Dict[str, Any], act: Dict[str, Any], *, reflection: str = None, attempt: int = 1, max_attempts: int = 2) -> Dict[str, Any]:
        out = dict(res or {})
        low_reply = str(out.get("reply", "") or "").strip().lower()
        
        # Feedback-Loop: Wenn nicht erfolgreich, fügen wir eine Lern-Aufforderung hinzu
        if not bool(out.get("ok", False)):
            out["outcome"] = "failed"
            out["partial"] = False
            
            # Anweisungen für das LLM anhängen (global für alle Tool-Typen)
            error_instruction = (
                "\n\n[SYSTEM] Die Aktion ist fehlgeschlagen. Bitte analysiere die obige Fehlermeldung genau.\n"
                "- Falls ein Modul fehlt: Nutze 'install_python_packages'.\n"
                "- Falls ein Syntaxfehler vorliegt: Korrigiere den Code (achte auf Windows-Pfade!).\n"
                "- Falls Parameter falsch waren: Passe die Parameter an und versuche es erneut.\n"
                "- Nutze den kompletten Traceback für die Fehlerursache."
            )
            out["reply"] = str(out.get("reply", "")) + error_instruction
            
            try:
                tool_store.log("llm_action_failed", f"Kind={act.get('kind','')} | Attempt={attempt} | Reply={low_reply[:500]}")
            except Exception:
                pass
            # Self-reflection/retry logic
            if reflection and attempt < max_attempts:
                try:
                    tool_store.log("llm_action_reflection", f"Retrying with reflection: {reflection[:180]}")
                except Exception:
                    pass
                # Compose a new action/message for retry (simple version: append reflection to message)
                retry_action = dict(act)
                retry_message = f"{reflection}\n{out.get('reply','')}"
                retry_res = _run_llm_planned_action(cfg, retry_message, retry_action, note+"_reflection", dialog_key=dialog_key, pre_approved=pre_approved)
                retry_res["_reflection_attempt"] = True
                retry_res["_reflection_source"] = reflection
                return _finalize_result(retry_res, retry_action, reflection=None, attempt=attempt+1, max_attempts=max_attempts)
            return out
        # Treat "executed but not solved" as partial so orchestrator can recover.
        if _looks_unsolved_reply(low_reply):
            out["outcome"] = "partial"
            out["partial"] = True
            return out
        # Search/list actions with empty result should be partial.
        k = str((act or {}).get("kind", "") or "").strip().lower()
        if k in {"list_entries", "list_files", "list_dirs", "read_file", "script_exec"} and "keine " in low_reply and " gefunden" in low_reply:
            out["outcome"] = "partial"
            out["partial"] = True
            return out
        out["outcome"] = "success"
        out["partial"] = False
        return out

    cancelled = _cancelled_reply("vor Aktion")
    if cancelled:
        return cancelled
    action = _normalize_llm_action_paths(cfg, message, action if isinstance(action, dict) else {})
    # Dispatcher: Intent-Objekt entgegennehmen, Tool-Calls isoliert mit Timeout/Cancellation
    # --- GENERIC INTENT MAPPING (OpenClaw-Style) ---
    if isinstance(action, dict):
        act_type = str(action.get("action", "") or "").strip().lower()
        tool_name = str(action.get("tool_name", "") or "").strip().lower()
        # tool_call ohne tool_name → skip
        if act_type == "tool_call" and not tool_name:
            pass
        # admin_task → admin_task
        if act_type == "admin_task":
            action = dict(action)
            action["kind"] = "admin_task"
        # script_create → script_create
        if act_type == "script_create":
            action = dict(action)
            action["kind"] = "script_create"
        # conversation → conversation
        if act_type == "conversation":
            action = dict(action)
            action["kind"] = "conversation"
    kind = str(action.get("kind", "") or "").strip().lower()
    reflection = action.get("reflection") if isinstance(action, dict) else None
    # send_messenger_file muss hier direkt abgefangen werden, bevor es in
    # run_in_executor landet (dort geht dialog_key verloren).
    if kind == "send_messenger_file":
        file_path = str(action.get("path", action.get("file_path", "")) or "")
        caption = str(action.get("caption", "") or "")
        reply = _send_messenger_file(cfg, dialog_key, file_path, caption)
        tool_store.log("send_messenger_file", f"Ausgefuehrt (llm_action): {note}")
        ok = bool(reply and not any(reply.lower().startswith(p) for p in ("fehler", "unbekannt", "datei nicht")))
        return _finalize_result({"ok": ok, "reply": reply}, action, reflection=reflection)
    try:
        # Tool-Calls isoliert (async/subprocess) mit Timeout
        # Dynamische Timeouts aus Konfiguration laden
        tools_cfg = cfg.get("tools", {}) if isinstance(cfg.get("tools", {}), dict) else {}
        mcp_cfg = cfg.get("mcp", {}) if isinstance(cfg.get("mcp", {}), dict) else {}
        
        # Timeouts ausschließlich aus Konfiguration – kein LLM-Override möglich.
        # max_step_timeout_sec gilt für alle Tool-Calls; MCP hat eigenen konfigurierbaren Wert.
        step_timeout = int(tools_cfg.get("max_step_timeout_sec", 600))
        mcp_timeout = int(mcp_cfg.get("timeout", 180))

        # Welches Timeout nutzen wir für DIESE Aktion?
        current_timeout = step_timeout
        if kind.startswith("mcp_") or _is_cached_mcp_tool(kind):
            current_timeout = mcp_timeout

        # Script-Tools isoliert
        if kind in {"script_exec", "script_create", "script_validate", "install_python_packages", "run_downloaded_file"}:
            async def run_tool_async():
                loop = asyncio.get_event_loop()
                return await loop.run_in_executor(None, lambda: _run_action_with_policy(
                    cfg=cfg,
                    message=message,
                    action=action,
                    note=note,
                    deny_log="script_denied",
                    allowlist_for_remember=True,
                    dialog_key=dialog_key,
                    pre_approved=pre_approved,
                ))
            try:
                res = _run_coro_sync(asyncio.wait_for(run_tool_async(), timeout=current_timeout), timeout=current_timeout + 5)
            except asyncio.TimeoutError:
                tool_store.log("tool_timeout", f"Timeout bei Tool-Call: {kind} nach {current_timeout}s")
                return _finalize_result({"ok": False, "reply": f"Timeout bei Tool-Call: {kind} (> {current_timeout}s)"}, action, reflection=reflection)
            return _finalize_result(res, action, reflection=reflection)
        # Andere Tool-Calls ebenfalls isoliert
        if kind in {"shell_command", "mcp_refresh_tools", "mcp_register_server", "mcp_remove_server", "mcp_registry_search", "mcp_registry_prepare", "mcp_registry_install", "core_memory_update"} or kind.startswith("mcp_") or _is_cached_mcp_tool(kind):
            async def run_tool_async():
                loop = asyncio.get_event_loop()
                return await loop.run_in_executor(None, lambda: _run_action_with_policy(
                    cfg=cfg,
                    message=message,
                    action=action,
                    note=note,
                    deny_log="tool_denied",
                    allowlist_for_remember=False,
                    dialog_key=dialog_key,
                    pre_approved=pre_approved,
                ))
            try:
                res = _run_coro_sync(asyncio.wait_for(run_tool_async(), timeout=current_timeout), timeout=current_timeout + 5)
            except asyncio.TimeoutError:
                tool_store.log("tool_timeout", f"Timeout bei Tool-Call: {kind} nach {current_timeout}s")
                return _finalize_result({"ok": False, "reply": f"Timeout bei Tool-Call: {kind} (> {current_timeout}s)"}, action, reflection=reflection)
            return _finalize_result(res, action, reflection=reflection)
        # Skill-Handler isoliert
        if isinstance(_skill_handler_for_kind(kind), dict):
            tool_store.log(kind, f"Skill-Call gestartet: {kind}")
            async def run_skill_async():
                loop = asyncio.get_event_loop()
                return await loop.run_in_executor(None, lambda: _run_skill_action(cfg, action))
            try:
                res = _run_coro_sync(asyncio.wait_for(run_skill_async(), timeout=current_timeout), timeout=current_timeout + 5)
            except asyncio.TimeoutError:
                tool_store.log("tool_timeout", f"Timeout bei Skill-Call: {kind} nach {current_timeout}s")
                return _finalize_result({"ok": False, "reply": f"Timeout bei Skill-Call: {kind} (> {current_timeout}s)"}, action, reflection=reflection)
            ok_str = "OK" if (isinstance(res, dict) and res.get("ok")) else "FAILED"
            tool_store.log(kind, f"Skill-Call {ok_str}: {kind} | {str(res.get('reply',''))[:120] if isinstance(res,dict) else ''}")
            return _finalize_result(res, action, reflection=reflection)
        # Virtuelle Actions isoliert
        if kind in {"print_file", "list_printers", "cron_list", "cron_create", "cron_delete", "cron_pause", "cron_resume", "cron_test"}:
            async def run_virtual_async():
                loop = asyncio.get_event_loop()
                return await loop.run_in_executor(None, lambda: _run_virtual_action(cfg, message, action, note, dialog_key=dialog_key))
            try:
                res = _run_coro_sync(asyncio.wait_for(run_virtual_async(), timeout=current_timeout), timeout=current_timeout + 5)
            except asyncio.TimeoutError:
                tool_store.log("tool_timeout", f"Timeout bei Virtual-Call: {kind} nach {current_timeout}s")
                return _finalize_result({"ok": False, "reply": f"Timeout bei Virtual-Call: {kind} (> {current_timeout}s)"}, action, reflection=reflection)
            return _finalize_result(res, action, reflection=reflection)
        # Filesystem-Action isoliert
        async def run_fs_async():
            loop = asyncio.get_event_loop()
            return await loop.run_in_executor(None, lambda: _run_filesystem_action_with_policy(cfg, message, action, note))
        try:
            res = _run_coro_sync(asyncio.wait_for(run_fs_async(), timeout=current_timeout), timeout=current_timeout + 5)
        except asyncio.TimeoutError:
            tool_store.log("tool_timeout", f"Timeout bei Filesystem-Call: {kind} nach {current_timeout}s")
            return _finalize_result({"ok": False, "reply": f"Timeout bei Filesystem-Call: {kind} (> {current_timeout}s)"}, action, reflection=reflection)
        return _finalize_result(res, action, reflection=reflection)
    except Exception as exc:
        tool_store.log("dispatcher_error", f"Fehler im Dispatcher: {exc}")
        return _finalize_result({"ok": False, "reply": f"Fehler im Dispatcher: {exc}"}, action, reflection=reflection)

def _resolve_step_templates(value: Any, step_replies: List[str]) -> Any:
    if isinstance(value, str):
        out = str(value)
        for i, rep in enumerate(step_replies):
            r = str(rep or "")
            # Support both {{steps.N.reply}} and {{steps.N.result}}
            out = out.replace(f"{{{{steps.{i}.reply}}}}", r)
            out = out.replace(f"{{{{steps.{i}.result}}}}", r)
        return out
    if isinstance(value, list):
        return [_resolve_step_templates(x, step_replies) for x in value]
    if isinstance(value, dict):
        return {str(k): _resolve_step_templates(v, step_replies) for k, v in value.items()}
    return value

def _prepare_planned_action_for_step(action: Dict[str, Any], step_replies: List[str]) -> Dict[str, Any]:
    return _resolve_step_templates(dict(action or {}), step_replies) if isinstance(action, dict) else {}

def _path_filename_hint(path_value: str, fallback: str = "output.txt") -> str:
    raw = str(path_value or "").strip().rstrip("/\\")
    if not raw:
        return fallback
    name = Path(raw.replace("\\", "/")).name.strip()
    if not name:
        return fallback
    if "." in name and not name.endswith("."):
        return name
    return fallback

def _slug_token(text: str, fallback: str = "x", max_len: int = 48) -> str:
    raw = str(text or "").strip().lower()
    raw = re.sub(r"[^a-z0-9]+", "_", raw)
    raw = re.sub(r"_+", "_", raw).strip("_")
    if not raw:
        raw = fallback
    return raw[:max_len]

def _is_valid_windows_filename(name: str) -> bool:
    n = str(name or "").strip()
    if not n or n in {".", ".."}:
        return False
    if any(ch in n for ch in '<>:"/\\|?*'):
        return False
    if n.endswith(" ") or n.endswith("."):
        return False
    base = n.split(".", 1)[0].upper()
    reserved = {
        "CON", "PRN", "AUX", "NUL",
        "COM1", "COM2", "COM3", "COM4", "COM5", "COM6", "COM7", "COM8", "COM9",
        "LPT1", "LPT2", "LPT3", "LPT4", "LPT5", "LPT6", "LPT7", "LPT8", "LPT9",
    }
    if base in reserved:
        return False
    return True

def _generic_output_filename(message: str, *, intent: str = "save") -> str:
    low = str(message or "").lower()
    if _has_any(low, ["gmail", "mail", "email", "posteingang", "inbox"]):
        domain = "gmail"
    elif _has_any(low, ["web", "http", "https", "seite", "search", "suche"]):
        domain = "web"
    elif _has_any(low, ["datei", "ordner", "verzeichnis", "laufwerk", "pfad"]):
        domain = "filesystem"
    else:
        domain = "note"
    entities: List[str] = []
    m_last = re.search(r"(?:letzten|letzte|last)\s+(\d{1,3})", low, flags=re.IGNORECASE)
    if m_last:
        entities.append(f"last_{m_last.group(1)}")
    if _has_any(low, ["ungelesen", "unread"]):
        entities.append("unread")
    if _has_any(low, ["inbox", "posteingang"]):
        entities.append("inbox")
    ent = "_".join([_slug_token(x) for x in entities if str(x).strip()]) or "data"
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    return f"{_slug_token(domain)}_{_slug_token(intent)}_{_slug_token(ent)}_{stamp}.txt"

def _path_looks_like_directory(raw_path: str) -> bool:
    raw = str(raw_path or "").strip().replace("/", "\\")
    if not raw:
        return True
    if raw.endswith("\\"):
        return True
    if re.match(r"^[A-Za-z]:\\?$", raw):
        return True
    # UNC share roots or likely directory targets.
    if raw.startswith("\\\\"):
        parts = [p for p in raw.split("\\") if p]
        if len(parts) <= 2:
            return True
    p = Path(raw)
    with contextlib.suppress(Exception):
        if p.exists() and p.is_dir():
            return True
    return False

def _known_user_dirs(cfg: Dict[str, Any]) -> Dict[str, Path]:
    ws = _workspace_abs(cfg).resolve()
    userprofile = Path(str(os.environ.get("USERPROFILE", "") or "")).resolve() if str(os.environ.get("USERPROFILE", "") or "").strip() else Path()
    one_drive = Path(str(os.environ.get("OneDrive", "") or "")).resolve() if str(os.environ.get("OneDrive", "") or "").strip() else Path()

    def _pick(cands: List[Path], fallback: Path) -> Path:
        for c in cands:
            with contextlib.suppress(Exception):
                if str(c).strip() and c.exists():
                    return c.resolve()
        return fallback.resolve()

    desktop = _pick([userprofile / "Desktop", one_drive / "Desktop"], ws)
    documents = _pick([userprofile / "Documents", userprofile / "Dokumente", one_drive / "Documents", one_drive / "Dokumente"], ws / "documents")
    pictures = _pick([userprofile / "Pictures", userprofile / "Bilder", one_drive / "Pictures", one_drive / "Bilder"], ws / "pictures")
    downloads = _pick([userprofile / "Downloads", one_drive / "Downloads"], ws / "downloads")
    temp_dir = Path(tempfile.gettempdir()).resolve()
    return {
        "workspace": ws,
        "desktop": desktop,
        "documents": documents,
        "pictures": pictures,
        "downloads": downloads,
        "temp": temp_dir,
    }

def _map_llm_path_to_local(
    cfg: Dict[str, Any],
    message: str,
    raw_path: str,
    *,
    prefer_file_target: bool = True,
) -> str:
    raw = str(raw_path or "").strip().strip("`").strip("\"'")
    if not raw:
        return raw
    raw = raw.replace("\r", " ").replace("\n", " ").strip().rstrip(".,;")

    # Clip obvious command tails accidentally appended to a file path.
    m_tail = re.search(r"(?i)^(.+?\.[a-z0-9]{1,8})\s+(.+)$", raw)
    if m_tail:
        rest = str(m_tail.group(2) or "").strip()
        if rest and (
            rest.startswith("-")
            or rest.startswith("/")
            or bool(re.match(r"^[A-Z_][A-Z0-9_]*(?:\s|$)", rest))
            or (" --" in f" {rest}")
        ):
            raw = str(m_tail.group(1) or "").strip().rstrip(".,;")

    raw = raw.replace("/", "\\")
    sys_drive = str(os.environ.get("SystemDrive", "C:") or "C:").strip()
    if not re.match(r"^[A-Za-z]:$", sys_drive):
        sys_drive = "C:"
    # Treat single-leading backslash as Windows root-relative path.
    if re.match(r"^\\(?!\\)", raw):
        raw = f"{sys_drive}{raw}"
    # Repair malformed local-absolute paths that were turned into pseudo-UNC.
    if re.match(r"^\\\\(users|windows|programdata|program files(?: \(x86\))?)(\\|$)", raw, flags=re.IGNORECASE):
        raw = f"{sys_drive}\\{raw.lstrip('\\')}"

    generic_name = _generic_output_filename(message, intent="save")
    # Keep explicit Windows/UNC paths from model unchanged (A:..Z:, slash or backslash).
    if re.match(r"^[A-Za-z]:[\\/]", raw):
        fixed = raw.replace("/", "\\")
        if _path_looks_like_directory(fixed):
            return str((Path(fixed) / generic_name)) if prefer_file_target else fixed
        name = Path(fixed).name
        if not _is_valid_windows_filename(name):
            return str((Path(fixed).parent / generic_name)) if prefer_file_target else str(Path(fixed).parent)
        return fixed
    if raw.startswith("\\\\"):
        fixed = raw
        if _path_looks_like_directory(fixed):
            base = fixed.rstrip("\\/")
            return f"{base}\\{generic_name}" if prefer_file_target else base
        name = Path(fixed).name
        if not _is_valid_windows_filename(name):
            base = str(Path(fixed).parent)
            return f"{base}\\{generic_name}" if prefer_file_target else base
        return fixed

    dirs = _known_user_dirs(cfg)
    low_raw = raw.replace("\\", "/").strip().lower()
    low_msg = str(message or "").lower()
    fname = _path_filename_hint(raw, fallback=generic_name)
    if not _is_valid_windows_filename(fname):
        fname = generic_name

    # Explicit target in user message has highest precedence.
    unc_msg = _extract_unc_from_text(message)
    explicit_msg_path = _extract_any_path(message) or ""
    if unc_msg:
        base = str(unc_msg).rstrip("\\/")
        if "." in Path(base).name:
            return base
        return f"{base}\\{fname}" if prefer_file_target else base
    if explicit_msg_path and re.match(r"^[A-Za-z]:[\\/]", explicit_msg_path):
        p = Path(str(explicit_msg_path).replace("/", "\\"))
        if p.suffix:
            return str(p)
        return str((p / generic_name)) if prefer_file_target else str(p)
    drive_hint = _extract_drive_letter(message)
    if drive_hint and re.match(r"^[A-Za-z]:$", drive_hint):
        return f"{drive_hint}\\{fname}" if prefer_file_target else f"{drive_hint}\\"

    # Workspace aliases.
    if low_raw.startswith("workspace/") or low_raw.startswith("workspace\\") or low_raw == "workspace" or low_raw.startswith("/workspace/"):
        rel = raw.replace("\\", "/")
        rel = re.sub(r"^(?:/)?workspace(?:/)?", "", rel, flags=re.IGNORECASE).strip("/ ")
        if not rel:
            rel = generic_name if prefer_file_target else ""
        if not rel:
            return str(dirs["workspace"].resolve())
        return str((dirs["workspace"] / rel).resolve())
    # Desktop / documents / pictures / downloads / temp aliases from model path or message.
    alias_checks = [
        ("desktop", ["desktop"]),
        ("documents", ["documents", "dokumente", "dokument", "document"]),
        ("pictures", ["pictures", "bilder", "fotos", "images"]),
        ("downloads", ["downloads", "download"]),
        ("temp", ["/tmp", "tmp", "temp"]),
    ]
    for alias, needles in alias_checks:
        if any(n in low_raw for n in needles) or any(n in low_msg for n in needles):
            base = dirs[alias]
            # Preserve trailing relative part after alias where possible.
            rel = ""
            norm = raw.replace("\\", "/")
            for n in needles:
                pos = norm.lower().find(n.lower())
                if pos >= 0:
                    rel = norm[pos + len(n):].lstrip("/")
                    break
            if rel and Path(rel).suffix:
                cand_name = Path(rel).name
                if _is_valid_windows_filename(cand_name):
                    return str((base / rel).resolve())
                return str((base / generic_name).resolve()) if prefer_file_target else str(base.resolve())
            return str((base / fname).resolve()) if prefer_file_target else str(base.resolve())

    # Unix-like absolute path from model -> map by common anchors.
    if low_raw.startswith("/users/") or low_raw.startswith("/home/"):
        if "/desktop" in low_raw:
            return str((dirs["desktop"] / fname).resolve()) if prefer_file_target else str(dirs["desktop"].resolve())
        if "/document" in low_raw or "/dokument" in low_raw:
            return str((dirs["documents"] / fname).resolve()) if prefer_file_target else str(dirs["documents"].resolve())
        if "/picture" in low_raw or "/bilder" in low_raw or "/image" in low_raw:
            return str((dirs["pictures"] / fname).resolve()) if prefer_file_target else str(dirs["pictures"].resolve())
        if "/download" in low_raw:
            return str((dirs["downloads"] / fname).resolve()) if prefer_file_target else str(dirs["downloads"].resolve())
        return str((dirs["workspace"] / generic_name).resolve()) if prefer_file_target else str(dirs["workspace"].resolve())
    if low_raw.startswith("/tmp"):
        return str((dirs["temp"] / generic_name).resolve()) if prefer_file_target else str(dirs["temp"].resolve())

    # --- DEFAULT: Anchor relative paths to workspace ---
    # If it's a simple filename or relative path without anchor, put it in workspace.
    if not (raw.startswith("\\\\") or re.match(r"^[A-Za-z]:", raw)):
        try:
            p = Path(raw)
            if not p.is_absolute():
                return str((dirs["workspace"] / raw).resolve())
        except Exception:
            pass

    return raw

def _normalize_llm_action_paths(cfg: Dict[str, Any], message: str, action: Dict[str, Any]) -> Dict[str, Any]:
    out = dict(action or {})
    kind = str(out.get("kind", "") or "").strip().lower()
    file_target_kinds = {
        "write_file",
        "append_file",
        "write_json_file",
        "touch_file",
        "export_entries_to_file",
        "script_create",
        "script_exec",
        "script_validate",
        "run_downloaded_file",
        "create_zip_archive",
        "extract_zip_archive",
        "copy_file_chunked",
    }

    path_like_names = {
        "path",
        "out_path",
        "script_path",
        "file_path",
        "filepath",
        "directory_path",
        "dir_path",
        "folder_path",
        "root_path",
        "base_path",
        "target_path",
        "destination_path",
        "output_path",
        "pdf_path",
        "unc_path",
        "share",
        "src",
        "dst",
    }

    def _looks_path_key(name: str) -> bool:
        n = str(name or "").strip().lower()
        if not n:
            return False
        if n in path_like_names:
            return True
        if n.endswith("_path") or n.startswith("path_"):
            return True
        # Restricted set of segment matches to avoid false positives like 'root_cause'
        parts = {p for p in re.split(r"[^a-z0-9]+", n) if p}
        # Explicit full-word matches only for high-probability path keys
        if any(p in {"filepath", "directory", "unc", "share"} for p in parts):
            return True
        # Combined words that strongly indicate paths
        if ("file" in parts or "dir" in parts or "folder" in parts) and ("name" in parts or "path" in parts or "target" in parts or "src" in parts or "dst" in parts):
            return True
        return False

    def _prefer_file_target_for_key(name: str) -> bool:
        n = str(name or "").strip().lower()
        if n in {"directory_path", "dir_path", "folder_path", "root_path", "base_path", "directory", "dir", "folder", "share", "unc_path"}:
            return False
        if n.endswith("_dir") or n.endswith("_folder") or n.endswith("_directory"):
            return False
        return True

    for k, v in list(out.items()):
        if not isinstance(v, str):
            continue
        if not _looks_path_key(k):
            continue
        raw_val = str(v or "").strip()
        if not raw_val:
            continue
        # Extract/repair embedded path forms before mapping.
        extracted = _extract_any_path(raw_val)
        source_val = extracted if extracted else raw_val
        prefer_file_target = bool(kind in file_target_kinds or str(k).strip().lower() in {"out_path", "script_path"})
        if not _prefer_file_target_for_key(k):
            prefer_file_target = False
        out[k] = _map_llm_path_to_local(
            cfg,
            message,
            source_val,
            prefer_file_target=prefer_file_target,
        )

    # Normalize attachment path items as file targets.
    atts = out.get("attachments")
    if isinstance(atts, list):
        fixed_atts: List[Any] = []
        for item in atts:
            if isinstance(item, str) and str(item).strip():
                extracted = _extract_any_path(item)
                source_val = extracted if extracted else str(item)
                fixed_atts.append(
                    _map_llm_path_to_local(cfg, message, source_val, prefer_file_target=True)
                )
            else:
                fixed_atts.append(item)
        out["attachments"] = fixed_atts
    return out

def _is_answer_and_save_request(message: str) -> bool:
    lower = message.strip().lower()
    if not lower:
        return False
    # Explicit filesystem export/list commands must not be hijacked by answer+save flow.
    if re.search(
        r"\b(schreibe|liste|exportiere)\b.*\b(ordner|verzeichnisse|dateien|files)\b.*\b(in\s+eine\s+textdatei|als\s+textdatei)\b",
        lower,
        flags=re.IGNORECASE,
    ):
        return False
    non_save_task = _has_any(
        lower,
        [
            "screenshot",
            "bildschirmfoto",
            "screen shot",
            "foto machen",
            "bild machen",
            "mach ",
            "mache ",
            "erstelle script",
            "skript",
            "script",
            "ausfuehren",
            "ausführen",
            "run ",
            "execute ",
            "starte ",
            "start ",
            "schick mir",
            "sende mir",
            "send me",
            "anhaeng",
            "anhäng",
            "upload",
        ],
    )
    if non_save_task:
        return False
    save_verb = bool(re.search(r"\b(speicher|speichere|speichern|save)\b", lower))
    save_phrase = _has_any(lower, ["als textdatei", "in eine textdatei", "as text file", "als txt"])
    write_textfile_phrase = bool(
        re.search(r"\b(schreibe|write)\b.*\b(textdatei|text file)\b", lower, flags=re.IGNORECASE)
    )
    # Avoid false positives for status questions like "wo hast du das gespeichert?"
    if (not save_verb) and ("gespeichert" in lower) and (not save_phrase):
        return False
    save_hint = save_verb or save_phrase or write_textfile_phrase
    if not save_hint:
        return False
    # Avoid stealing explicit filesystem/script commands.
    explicit_tool = _has_any(
        lower,
        [
            "schreibe datei",
            "schreibe json",
            "json datei",
            "write file",
            "append",
            "haenge an",
            "anhaeng",
            "lies datei",
            "read file",
            "zeige dateien",
            "liste dateien",
            "list files",
            "benenne",
            "rename",
            "erstelle ordner",
            "create folder",
            "touch file",
            "kopier",
            "copy ",
            "verschieb",
            "move ",
            "loesch",
            "delete ",
            "python:",
            "powershell:",
            "pwsh:",
            "suche ",
            "such ",
            "finde ",
            "find ",
            "zeige inhalt",
            "inhalt von",
            "dateiliste",
            "liste mit",
            "anzahl",
            "wie viele",
            "count ",
            "laufwerk",
            "ordner",
            "verzeichnis",
            "pfad",
        ],
    )
    return not explicit_tool

def _wants_save_output(message: str) -> bool:
    low = str(message or "").strip().lower()
    if not low:
        return False
    has_save_verb = _has_any(low, ["speicher", "save", "schreib", "write"])
    has_file_hint = _has_any(low, ["datei", "txt", "textdatei", "text datei", "file", ".txt", ".md"])
    # Extra Prüfung für Pfade wie c:\xxx.txt
    has_path_with_ext = bool(re.search(r"[a-zA-Z]:\\[^.]+\.(txt|md)", low))
    return bool(has_save_verb and (has_file_hint or has_path_with_ext))

def _try_direct_execution(message: str, interpretation: Optional[Dict[str, Any]], cfg: Dict[str, Any], dialog_key: str = "") -> Optional[Dict[str, Any]]:
    """
    HYBRIDE LÖSUNG: Versucht direkte Execution bei klarem Intent.
    Returns result dict if direct execution was possible, None otherwise.
    """
    if not isinstance(interpretation, dict):
        return None
    
    intent = str(interpretation.get("intent", "") or "").strip().lower()
    confidence = float(interpretation.get("confidence", 0.0) or 0.0)
    entities = interpretation.get("entities", {}) if isinstance(interpretation.get("entities", {}), dict) else {}
    
    # Nur bei hoher Confidence und klarem Intent direkt ausführen
    MIN_CONFIDENCE = 0.8
    
    # 1. answer_and_save mit allen nötigen Infos
    if intent == "answer_and_save" and confidence >= MIN_CONFIDENCE:
        tool_store.log("hybrid_answer_and_save", f"intent={intent}, conf={confidence}, message={message[:100]}")
        result = _handle_answer_and_save_request(message, cfg)
        if result:
            tool_store.log("hybrid_answer_and_save_result", f"result_ok={result.get('ok')}")
            return result
    
    # 2. filesystem mit klarem pfad - erweiterte Operationen
    if intent == "filesystem" and confidence >= MIN_CONFIDENCE:
        path = str(entities.get("path", "") or "").strip()
        query = str(entities.get("query", "") or "").strip().lower()
        # Zusätzlich Originaltext prüfen, da LLM manchmal den Inhalt in "query" steckt
        msg_lower = message.lower()
        
        if path:
            # Bestimme Operation basierend auf Query oder Originaltext
            action = None
            
            # Lese-Operationen
            if any(w in query for w in ["lesen", "read", "inhalt", "zeige", "show", "cat", "type"]) or \
               any(w in msg_lower for w in ["lesen", "lese ", " lese", "read "]):
                action = {"kind": "read_file", "path": path}
            
            # Schreibe Operationen
            elif any(w in query for w in ["schreibe", "write", "erstelle", "create"]) or \
                 any(w in msg_lower for w in ["schreibe", "schreiben", "write ", "erstelle "]):
                # content aus entities.content, fallback: entities.query (LLM steckt Inhalt manchmal dort)
                content = str(entities.get("content", "") or "").strip()
                if not content and query and not any(w in query for w in ["schreibe", "write", "erstelle", "lese", "create"]):
                    # query enthält den Inhalt (kein Befehlsverb) → als content nutzen
                    content = str(entities.get("query", "") or "").strip()
                if content:
                    action = {"kind": "write_file", "path": path, "content": content}
            
            # Löschen
            elif any(w in query for w in ["loesch", "lösch", "delete", "remove", "entfern"]) or \
                 any(w in msg_lower for w in ["loesch", "lösch", "delete ", "entfern"]):
                action = {"kind": "delete_path", "path": path}
            
            # Liste Verzeichnis
            elif any(w in query for w in ["liste", "list", "dir", "inhalt"]) or \
                 any(w in msg_lower for w in ["liste ", "list ", " dir "]):
                action = {"kind": "list_entries", "path": path}
            
            # Existiert?
            elif any(w in query for w in ["existiert", "exists", "gibt es"]):
                action = {"kind": "exists_entries", "path": path}
            
            # Kein Fallback mehr: unbekannte Operationen (copy/move/rename/etc.)
            # an _handle_filesystem_request / _llm_plan_action weitergeben
            
            if action:
                try:
                    tool_name, reply = _execute_action(action)
                    if tool_name:
                        return {"ok": True, "reply": reply}
                except Exception as e:
                    tool_store.log("try_direct_exec_error", str(e))
                    return None  # Fallback zu _llm_plan_action
    
    # 3. cron mit allen infos
    if intent == "cron" and confidence >= MIN_CONFIDENCE:
        action = _cron_parse_natural_create(message)
        if action:
            result = _cron_create_from_action(action)
            if result:
                return {"ok": True, "reply": str(result.get("reply", "Cron-Job erstellt."))}
    
    # 4. clear_context
    if intent == "clear_context" and confidence >= MIN_CONFIDENCE:
        # Direkt löschen
        dk = str(dialog_key or "").strip()
        if dk:
            with _session_lock:
                if dk in _session_history:
                    del _session_history[dk]
        return {"ok": True, "reply": "Kontext gelöscht."}
    
    # 5. help - ruft die strukturierte Befehlsübersicht auf
    if intent == "help" and confidence >= MIN_CONFIDENCE:
        return {"ok": True, "reply": _commands_overview()}
    
    return None

def _channel_tag(dialog_key: str) -> str:
    """Gibt einen kurzen Kanal-Tag zurück: 'tg', 'dc', 'webui' oder ''."""
    k = str(dialog_key or "").lower()
    if k.startswith("telegram:"):
        return "tg"
    if k.startswith("discord:"):
        return "dc"
    if k.startswith("webui") or k == "webui:na":
        return "webui"
    return ""

def _derive_save_filename(query: str, channel_tag: str = "") -> str:
    terms = _query_terms(query)
    stem = "_".join(terms[:4]).strip("_")
    if not stem:
        stem = f"antwort_{int(time.time())}"
    tag_suffix = f"_{channel_tag}" if channel_tag else ""
    return f"{stem[:80]}{tag_suffix}.txt"

def _extract_requested_save_path(message: str) -> Optional[str]:
    quoted = re.findall(r'"([^"]+)"', message)
    for q in quoted:
        t = q.strip()
        if t.lower().endswith(".txt") or t.lower().endswith(".md"):
            return t
        if re.match(r"^[A-Za-z]:\\?$", t):
            return t
        if "/" in t or "\\" in t:
            return t
    m = re.search(
        r"(?:unter|in|to)\s+([A-Za-z]:\\?|[A-Za-z]:[\\\/][^\s]+|[^\s]+(?:\.txt|\.md)|[^\s]*[\\/][^\s]+)",
        message,
        flags=re.IGNORECASE,
    )
    if m:
        return m.group(1).strip()
    # Fallback: when rewrites phrase the target as "im Ordner C:\... als Textdatei",
    # pick the first explicit absolute/UNC path in the message.
    with contextlib.suppress(Exception):
        any_path = _extract_any_path(message)
        if any_path:
            return str(any_path).strip()
    return None

def _extract_query_without_save(message: str) -> str:
    cleaned = message.strip()
    patterns = [
        r"(?:\s+und\s+|\s+)?(?:kannst\s+du\s+)?(?:es|das|diese[sn]?|den\s+text)?\s*(?:als\s+textdatei|als\s+txt|in\s+eine?\s+datei)\s+speicher[nst]*.*$",
        r"(?:\s+und\s+|\s+)?(?:bitte\s+)?(?:such(?:e|en)\s+.*?\s+)?speicher(?:e|n)?\s+.*$",
        r"(?:\s+und\s+|\s+)?(?:bitte\s+)?(?:schreibe|write)\s+.*(?:als\s+textdatei|als\s+txt|in\s+eine?\s+textdatei|in\s+eine?\s+datei|as\s+text\s+file).*$",
        r"(?:\s+und\s+|\s+)?(?:bitte\s+)?(?:save)\s+.*$",
    ]
    for p in patterns:
        cleaned = re.sub(p, "", cleaned, flags=re.IGNORECASE).strip()
    if cleaned:
        return cleaned
    return message.strip()

def _save_text_to_requested_target(
    cfg: Dict[str, Any],
    *,
    original_message: str,
    query_for_name: str,
    text_content: str,
    dialog_key: str = "",
) -> Dict[str, Any]:
    _ctag = _channel_tag(dialog_key)
    def _workspace_fallback_target(current: Path, reason: str) -> Tuple[Path, str]:
        ws = _workspace_abs(cfg).resolve()
        name = current.name.strip() if str(current.name or "").strip() else _derive_save_filename(query_for_name, _ctag)
        if not _is_valid_windows_filename(name):
            name = _derive_save_filename(query_for_name, _ctag)
        if "." not in name:
            name = f"{name}.txt"
        fb = (ws / name).resolve()
        msg = (
            f"Hinweis: Zielpfad wurde auf Workspace umgeleitet ({reason}).\n"
            f"Neues Ziel: {fb}"
        )
        return fb, msg

    content = str(text_content or "").strip()
    if not content:
        return {"ok": False, "reply": "Kein Textinhalt zum Speichern vorhanden."}
    workspace = _workspace_abs(cfg)
    raw_msg = str(original_message or "")
    requested = _extract_requested_save_path(raw_msg)
    if requested:
        req = requested.strip()
        req_drive = re.match(r"^([A-Za-z]):\\?$", req)
        is_file = req.lower().endswith(".txt") or req.lower().endswith(".md")
        if req_drive:
            base_dir = Path(f"{req_drive.group(1)}:\\")
            target = (base_dir / _derive_save_filename(query_for_name, _ctag)).resolve()
        else:
            p = Path(req)
            if p.is_absolute():
                if is_file:
                    target = p.resolve()
                else:
                    target = (p / _derive_save_filename(query_for_name, _ctag)).resolve()
            else:
                req_norm = str(req).replace("\\", "/").lstrip("./")
                ws_rel = str(cfg.get("workspace", "data/workspace")).replace("\\", "/").strip("/")
                if req_norm == ws_rel or req_norm.startswith(ws_rel + "/"):
                    base = (ROOT_DIR / Path(req_norm)).resolve()
                else:
                    base = (workspace / p).resolve()
                if is_file:
                    target = base
                else:
                    target = (base / _derive_save_filename(query_for_name, _ctag)).resolve()
    else:
        target = (workspace / _derive_save_filename(query_for_name, _ctag)).resolve()

    fallback_prefix = ""
    with contextlib.suppress(Exception):
        raw_req = str(requested or "").strip()
        if raw_req:
            p_req = Path(raw_req)
            if p_req.is_absolute() or raw_req.startswith("\\\\"):
                parent = target if _path_looks_like_directory(str(target)) else target.parent
                try:
                    if str(parent) and (not parent.exists()):
                        # Try mkdir first, fall back to workspace redirect
                        try:
                            parent.mkdir(parents=True, exist_ok=True)
                        except Exception:
                            target, fb_msg = _workspace_fallback_target(target, "Zielpfad existiert nicht")
                            fallback_prefix = fb_msg
                except Exception:
                    target, fb_msg = _workspace_fallback_target(target, "Pfadprüfung fehlgeschlagen")
                    fallback_prefix = fb_msg

    allowed, path_msg = validate_risky_paths(cfg, ROOT_DIR, [str(target)])
    if not allowed:
        target_fb, fb_msg = _workspace_fallback_target(target, "Pfadregel/Berechtigung")
        allowed_fb, path_msg_fb = validate_risky_paths(cfg, ROOT_DIR, [str(target_fb)])
        if not allowed_fb:
            return {"ok": False, "reply": path_msg}
        target = target_fb
        fallback_prefix = (fallback_prefix + "\n" + fb_msg).strip()

    try:
        with contextlib.suppress(Exception):
            target.parent.mkdir(parents=True, exist_ok=True)
        action = {"kind": "write_file", "path": str(target), "content": content}
        _, save_reply = _execute_action(action)
        _persist_last_save_status(cfg, query=query_for_name, target_path=str(target), saved=True, error="")
        if str(dialog_key or "").strip():
            with contextlib.suppress(Exception):
                _set_session_last_artifact(str(dialog_key), Path(target))
        final_reply = f"Gespeichert unter: {target}\n{save_reply}"
        if fallback_prefix:
            final_reply = f"{fallback_prefix}\n{final_reply}"
        return {"ok": True, "reply": final_reply, "target_path": str(target)}
    except Exception as exc:
        with contextlib.suppress(Exception):
            target_fb, fb_msg = _workspace_fallback_target(target, f"Schreibfehler: {exc}")
            if str(target_fb) != str(target):
                with contextlib.suppress(Exception):
                    target_fb.parent.mkdir(parents=True, exist_ok=True)
                _, save_reply = _execute_action({"kind": "write_file", "path": str(target_fb), "content": content})
                _persist_last_save_status(cfg, query=query_for_name, target_path=str(target_fb), saved=True, error="")
                final_reply = f"{fb_msg}\nGespeichert unter: {target_fb}\n{save_reply}"
                return {"ok": True, "reply": final_reply, "target_path": str(target_fb)}
        tool_store.log("fs_action_error", str(exc))
        _persist_last_save_status(cfg, query=query_for_name, target_path=str(target), saved=False, error=str(exc))
        return {"ok": False, "reply": f"Speichern fehlgeschlagen: {exc}\nGeplanter Zielpfad: {target}", "target_path": str(target)}

def _is_likely_followup_to_previous(message: str, previous_answer: str) -> bool:
    """Prüft ob die Message ein Follow-up auf die vorherige Antwort ist."""
    msg_lower = message.lower().strip()
    prev_lower = previous_answer.lower()
    
    # Pronomen und indirekte Referenzen
    followup_indicators = [
        "die", "das", "es", "diese", "diesen", "der", "die antwort", 
        "das ergebnis", "das resultat", "den inhalt", "die liste",
        "das was", "alles was", "alles dort", "das verzeichnis",
        "die datei", "die dateien", "den ordner", "die ordner",
    ]
    
    if any(indicator in msg_lower for indicator in followup_indicators):
        # Prüfe ob die vorherige Antwort relevant ist (Liste, Text, etc.)
        if len(previous_answer) > 50:
            return True
    
    # Check for explicit reference patterns
    reference_patterns = [
        r"^speicher\s+(die|das|es|diese|diesen)",
        r"^speichere\s+(die|das|es|diese|diesen)",
        r"^schreib\s+(die|das|es|diese|diesen)",
        r"^schreibe\s+(die|das|es|diese|diesen)",
        r"^hab\s+ich\s+(die|das|es)",
        r"^hast\s+du\s+(die|das|es)",
    ]
    
    for pattern in reference_patterns:
        if re.search(pattern, msg_lower):
            return True
            
    return False

def _handle_answer_and_save_with_context(message: str, cfg: Dict[str, Any], previous_content: str, dialog_key: str) -> Dict[str, Any]:
    """Behandelt answer_and_save mit vorherigem Kontext wenn kein Pfad angegeben wurde."""
    # Generiere einen Dateinamen basierend auf dem Kontext
    import hashlib
    
    # Erstelle einen kurzen Hash fuer den Dateinamen
    content_hash = hashlib.md5(previous_content[:500].encode()).hexdigest()[:8]
    
    # Versuche Topic aus dem Kontext zu extrahieren
    topic = ""
    lines = previous_content.split("\n")
    for line in lines[:5]:
        # Suche nach Ordnernamen oder aussagekraeftigen Woertern
        match = re.search(r'([A-Za-z0-9_-]+\\[A-Za-z0-9_-]+)', line)
        if match:
            topic = match.group(1).split("\\")[-1][:30]
            break
    
    if not topic:
        topic = f"output_{content_hash}"
    
    # Baue einen sinnvollen Dateinamen
    target_path = f"data/workspace/{topic}_{content_hash}.txt"
    
    save_res = _save_text_to_requested_target(
        cfg,
        original_message=message,
        query_for_name=topic,
        text_content=previous_content,
        dialog_key=dialog_key,
    )
    
    if bool(save_res.get("ok", False)):
        reply = f"{previous_content[:300]}...\n\n{str(save_res.get('reply', '') or '').strip()}"
        _persist_conversation(cfg, message, reply, 0.82)
        return {"ok": True, "reply": reply}
    else:
        return save_res

def _get_last_assistant_message(cfg: Dict[str, Any], dialog_key: str = "") -> str:
    """Holt die letzte Assistant-Nachricht aus der Session-History."""
    dk = dialog_key or str(_dialog_key_ctx.get("") or "").strip()
    if not dk:
        return ""
    with _session_lock:
        hist = list(_session_history.get(dk, deque()))
    for item in reversed(hist):
        role = str(item.get("role", "")).strip().lower()
        if role == "assistant":
            txt = str(item.get("text", "")).strip()
            if txt:
                return txt
    return ""

def _handle_answer_and_save_request(message: str, cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    tool_store.log("answer_and_save_start", f"message={message[:100]}")
    
    if not _is_answer_and_save_request(message):
        tool_store.log("answer_and_save", "not detected as save request")
        return None

    query = _extract_query_without_save(message)
    
    # Intelligente Follow-up Erkennung: Wenn keine klare Query, frage das LLM ob dies ein Follow-up ist
    if not query or len(query.strip()) < 3:
        dk = str(_dialog_key_ctx.get("") or "").strip()
        last_answer = _get_last_assistant_message(cfg, dk)
        if last_answer and _is_likely_followup_to_previous(message, last_answer):
            # Dies ist ein Follow-up - verwende die vorherige Antwort als Content
            tool_store.log("answer_and_save", "detected as follow-up via LLM, using previous answer")
            target_path = _extract_requested_save_path(message)
            if target_path:
                save_res = _save_text_to_requested_target(
                    cfg,
                    original_message=message,
                    query_for_name="",
                    text_content=last_answer,
                    dialog_key=dk,
                )
                if bool(save_res.get("ok", False)):
                    reply = f"{last_answer}\n\n{str(save_res.get('reply', '') or '').strip()}"
                    _persist_conversation(cfg, message, reply, 0.82)
                    return {"ok": True, "reply": reply}
            # Wenn kein Pfad angegeben, generiere einen
            return _handle_answer_and_save_with_context(message, cfg, last_answer, dk)

    if not query:
        # If the user only provided a filename/path as a follow-up, try to use the previous assistant reply as content.
        target_path = _extract_requested_save_path(message)
        if target_path:
            # Treat as pronoun-only query so the previous assistant message will be used.
            query = "das"
        else:
            tool_store.log("answer_and_save", "no query extracted")
            return None

    tool_store.log("answer_and_save", f"query={query[:100]}, path_extraction={message[:200]}")

    answer_text = ""
    
    # Prüfe ob die Query nur ein Pronomen ist ("das", "es", "diesen text")
    # In dem Fall hole den vorherigen Kontext
    low_query = query.lower().strip()
    is_pronoun_only = low_query in {"das", "es", "dies", "diesen", "diese", "der text", "die antwort", "das rezept", "die"} or low_query.startswith("das ") or low_query.startswith("es ") or low_query.startswith("die ")
    
    if is_pronoun_only:
        dk = str(_dialog_key_ctx.get("") or "").strip()
        last_answer = _get_last_assistant_message(cfg, dk)
        if last_answer:
            # Bereinige die vorherige Antwort von evtl. Tool-Ausgaben
            # Nehme nur den reinen Textteil
            lines = last_answer.split("\n")
            clean_lines = []
            for line in lines:
                # Überspringe Tool-Ausgaben und Pfade
                if re.match(r"^[A-Za-z]:\\|Tool:|```", line):
                    continue
                clean_lines.append(line)
            answer_text = "\n".join(clean_lines).strip()
            if answer_text:
                # Extrahiere den Zielpfad aus der aktuellen Nachricht
                target_path = _extract_requested_save_path(message)
                if target_path:
                    # Speichere direkt mit dem vorherigen Content
                    save_res = _save_text_to_requested_target(
                        cfg,
                        original_message=message,
                        query_for_name="",
                        text_content=answer_text,
                        dialog_key=dk,
                    )
                    if bool(save_res.get("ok", False)):
                        reply = f"{answer_text}\n\n{str(save_res.get('reply', '') or '').strip()}"
                        _persist_conversation(cfg, message, reply, 0.82)
                        return {"ok": True, "reply": reply}
                    else:
                        # Fallback: fahre normal fort
                        pass
                else:
                    # Kein Zielpfad gefunden, verwende normalen Flow
                    pass
        # Wenn kein Kontext gefunden, fahre normal fort
    factual_domain = _detect_factual_domain(query)
    if factual_domain == "us_presidents_list":
        answer_text = _build_us_presidents_list(cfg).strip()
    else:
        try:
            answer_text = _llm_answer_with_quality_gate(cfg, query).strip()
        except Exception:
            fallback = _answer_from_memory_or_web(cfg, query)
            answer_text = str(fallback or "").strip()

    low_answer = answer_text.lower()
    if _has_any(low_answer, ["darf ich", "soll ich", "bevor ich", "```python", "```powershell", "tool_code"]):
        try:
            router = LLMRouter(cfg)
            strict = (
                query
                + "\n\nGib nur die finale Nutzantwort als Fliesstext aus. "
                "Kein Codeblock, kein Plan, keine Rueckfrage, keine Sicherheits- oder Toolhinweise."
            )
            retry = router.chat(_build_llm_message(cfg, strict, turns=12))
            answer_text = sanitize_user_facing_reply(str(retry.text or "").strip())
        except Exception:
            pass
    if factual_domain or _needs_factual_web_verification(query):
        verified = _web_verified_answer(cfg, query, answer_text)
        if verified:
            answer_text = verified
    issue = _factual_answer_issue(factual_domain, query, answer_text)
    if issue:
        try:
            answer_text = _regenerate_factual_answer(cfg, query, factual_domain, answer_text, issue)
        except Exception:
            pass

    if not answer_text:
        tool_store.log("answer_and_save", "no answer text generated")
        return {"ok": False, "reply": "Ich konnte keine brauchbare Antwort erzeugen, daher nichts gespeichert."}

    tool_store.log("answer_and_save", f"saving to file, answer_len={len(answer_text)}")
    
    save_res = _save_text_to_requested_target(
        cfg,
        original_message=message,
        query_for_name=query,
        text_content=answer_text,
        dialog_key="",
    )
    try:
        if bool(save_res.get("ok", False)):
            reply = f"{answer_text}\n\n{str(save_res.get('reply', '') or '').strip()}"
        else:
            reply = f"{answer_text}\n\n{str(save_res.get('reply', '') or '').strip()}"
        _persist_conversation(cfg, message, reply, 0.82)
        return {"ok": True, "reply": reply}
    except Exception:
        return {"ok": False, "reply": str(save_res.get("reply", "") or "Speichern fehlgeschlagen.")}

