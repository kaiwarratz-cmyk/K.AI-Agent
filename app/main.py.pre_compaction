@app.get("/api/skills/gmail/connect/callback", name="api_skills_gmail_connect_callback")
def api_skills_gmail_connect_callback(
    request: Request,
    code: Optional[str] = None,
    state: Optional[str] = None,
    error: Optional[str] = None,
) -> HTMLResponse:
    cfg = _cfg()
    if str(error or "").strip():
        return HTMLResponse(
            content=(
                "<html><body><h3>Gmail-Verbindung fehlgeschlagen</h3>"
                f"<p>{str(error)}</p><p>Du kannst dieses Fenster schliessen.</p></body></html>"
            ),
            status_code=400,
        )
    if not _gmail_oauth_consume_state(str(state or "")):
        return HTMLResponse(
            content=(
                "<html><body><h3>Ungueltiger oder abgelaufener OAuth-Status</h3>"
                "<p>Bitte den Connect-Vorgang erneut starten.</p></body></html>"
            ),
            status_code=400,
        )
    if not str(code or "").strip():
        return HTMLResponse(
            content=(
                "<html><body><h3>Kein Authorization-Code erhalten</h3>"
                "<p>Bitte den Connect-Vorgang erneut starten.</p></body></html>"
            ),
            status_code=400,
        )
    redirect_uri = str(request.url_for("api_skills_gmail_connect_callback"))
    settings, err = _gmail_oauth_build_settings(cfg, redirect_uri)
    if not isinstance(settings, dict):
        return HTMLResponse(
            content=(
                "<html><body><h3>Gmail-Konfiguration fehlt</h3>"
                f"<p>{str(err or 'Client-ID/Secret fehlen.')}</p></body></html>"
            ),
            status_code=400,
        )
    token_endpoint = str(settings.get("token_endpoint", "") or "https://oauth2.googleapis.com/token")
    body = {
        "code": str(code or "").strip(),
        "client_id": str(settings.get("client_id", "") or ""),
        "client_secret": str(settings.get("client_secret", "") or ""),
        "redirect_uri": redirect_uri,
        "grant_type": "authorization_code",
    }
    try:
        with httpx.Client(timeout=30, trust_env=False) as client:
            resp = client.post(token_endpoint, data=body)
            resp.raise_for_status()
            obj = resp.json() if "application/json" in str(resp.headers.get("content-type", "")).lower() else {}
    except Exception as exc:
        tool_store.log("gmail_connect_error", str(exc))
        return HTMLResponse(
            content=(
                "<html><body><h3>Token-Austausch fehlgeschlagen</h3>"
                f"<p>{str(exc)}</p><p>Bitte OAuth-Client/Redirect-URI pruefen.</p></body></html>"
            ),
            status_code=400,
        )
    access_token = str(obj.get("access_token", "") or "").strip()
    refresh_token = str(obj.get("refresh_token", "") or "").strip()
    if not access_token:
        return HTMLResponse(
            content=(
                "<html><body><h3>Kein Access-Token erhalten</h3>"
                "<p>Bitte den Connect-Vorgang erneut starten.</p></body></html>"
            ),
            status_code=400,
        )
    _skill_secret_upsert(cfg, str(settings.get("access_alias", "gmail_access_token") or "gmail_access_token"), access_token, source="gmail_connect")
    if refresh_token:
        _skill_secret_upsert(cfg, str(settings.get("refresh_alias", "gmail_refresh_token") or "gmail_refresh_token"), refresh_token, source="gmail_connect")
    tool_store.log("gmail_connect", "oauth_success")
    refresh_txt = "gesetzt" if bool(refresh_token) else "nicht geliefert"
    return HTMLResponse(
        content=(
            "<html><body><h3>Gmail verbunden</h3>"
            "<p>Access-Token gespeichert.</p>"
            f"<p>Refresh-Token: {refresh_txt}.</p>"
            "<p>Du kannst dieses Fenster jetzt schliessen.</p></body></html>"
        ),
        status_code=200,
    )

