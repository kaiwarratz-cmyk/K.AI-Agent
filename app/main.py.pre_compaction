    if not t:
        return None
    if t in {"/selfimprove klein", "/self-improve klein", "selfimprove klein", "selbstverbesserung klein", "selbstverbesserung test klein"}:
        return "quick"
    if t in {
        "/selfimprove gross",
        "/selfimprove groß",
        "/self-improve gross",
        "selfimprove gross",
        "selbstverbesserung gross",
        "selbstverbesserung groß",
        "selbstverbesserung ausfuehrlich",
    }:
        return "deep"
    if t in {"/selfimprove diagnose", "/self-improve diagnose", "selfimprove diagnose"}:
        return "diagnose"
    if re.fullmatch(r"(?:/selfimprove|/self-improve|selfimprove)\s+reports(?:\s+\d{1,2})?", t):
        return "reports"
    return None

def _self_improve_cfg(cfg: Dict[str, Any]) -> Dict[str, Any]:
    raw = cfg.get("self_improve", {}) if isinstance(cfg.get("self_improve", {}), dict) else {}
    try:
        scan = int(raw.get("scan_interval_sec", 300))
    except Exception:
        scan = 300
    try:
        deep = int(raw.get("deep_check_interval_sec", 1800))
    except Exception:
        deep = 1800
    try:
        cooldown = int(raw.get("cooldown_sec", 900))
    except Exception:
        cooldown = 900
    return {
        "enabled": bool(raw.get("enabled", True)),
        "scan_interval_sec": max(30, min(3600, scan)),
        "deep_check_interval_sec": max(120, min(86400, deep)),
        "cooldown_sec": max(0, min(86400, cooldown)),
        "auto_execute": bool(raw.get("auto_execute", False)),
        "auto_analyze": bool(raw.get("auto_analyze", False)),
    }

def _self_improve_state_snapshot() -> Dict[str, Any]:
    with _self_improve_lock:
        return dict(_self_improve_state)

def _self_improve_update_state(**kwargs: Any) -> None:
    with _self_improve_lock:
        for k, v in kwargs.items():
            _self_improve_state[k] = v

def _self_improve_small_report(cfg: Dict[str, Any]) -> Dict[str, Any]:
    signals = _collect_improvement_signals()
    if signals:
        _persist_improvement_signals(cfg, signals)
    top = []
    for s in signals[:8]:
        msg = re.sub(r"\s+", " ", str(s.get("last_message", "") or "")).strip()
        top.append(
            {
                "key": str(s.get("key", "")),
                "severity": int(s.get("severity", 0)),
                "count": int(s.get("count", 0)),
                "last_message": (msg[:280] + ("..." if len(msg) > 280 else "")),
            }
        )
    report = {
        "ok": True,
        "type": "small",
        "generated_at": datetime.now().isoformat(),
        "signal_count": len(signals),
        "top_signals": top,
    }
    _self_improve_update_state(last_scan_at=report["generated_at"], last_small_report=report)
    return report

def _self_improve_report_path(report_type: str) -> Path:
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    reports_dir = (_workspace_abs(_cfg()) / "reports").resolve()
    reports_dir.mkdir(parents=True, exist_ok=True)
    safe_type = re.sub(r"[^a-z0-9_-]", "_", str(report_type or "report").lower())
    return (reports_dir / f"self_improve_{safe_type}_{stamp}.json").resolve()

def _self_improve_save_report(report: Dict[str, Any], report_type: str) -> str:
    p = _self_improve_report_path(report_type)
    with contextlib.suppress(Exception):
        p.write_text(json.dumps(report, ensure_ascii=False, indent=2), encoding="utf-8")
        return str(p)
    return ""

def _self_improve_report_to_text(report: Dict[str, Any], report_path: str = "") -> str:
    rtype = str(report.get("type", "?"))
    when = str(report.get("generated_at", "") or "")
    lines = [f"Self-Improve Report ({rtype})", f"Zeit: {_format_datetime_readable(when)}"]
    if report_path:
        lines.append(f"Datei: {report_path}")
        lines.append("Hinweis: Vollstaendige Details stehen in der Report-Datei.")
    if rtype == "small":
        lines.append(f"Signale gesamt: {int(report.get('signal_count', 0))}")
        for i, s in enumerate(report.get("top_signals", [])[:8], start=1):
            last = re.sub(r"\s+", " ", str(s.get("last_message", "") or "")).strip()
            lines.append(
                f"{i}. {s.get('key','')} | severity={s.get('severity',0)} | count={s.get('count',0)} | {last[:220]}{'...' if len(last) > 220 else ''}"
            )
    elif rtype == "deep":
        small = report.get("small_scan", {}) if isinstance(report.get("small_scan", {}), dict) else {}
        lines.append(f"Signale gesamt: {int(small.get('signal_count', 0))}")
        llm = report.get("llm_ping", {}) if isinstance(report.get("llm_ping", {}), dict) else {}
        lines.append(f"LLM Ping: {'OK' if bool(llm.get('ok')) else 'FEHLER'}")
        chain = report.get("llm_provider_chain", []) if isinstance(report.get("llm_provider_chain", []), list) else []
        if chain:
            lines.append("Provider-Chain: " + ", ".join(str(x) for x in chain[:8]))
        lines.append(f"errors.log Eintraege (Sample): {int(report.get('errors_log_entries_seen', 0))}")
        for i, s in enumerate(small.get("top_signals", [])[:6], start=1):
            last = re.sub(r"\s+", " ", str(s.get("last_message", "") or "")).strip()
            lines.append(
                f"{i}. {s.get('key','')} | severity={s.get('severity',0)} | count={s.get('count',0)} | {last[:220]}{'...' if len(last) > 220 else ''}"
            )
    return "\n".join(lines)

def _self_improve_reports_overview(limit: int = 10) -> str:
    n = max(1, min(30, int(limit)))
    reports_dir = (_workspace_abs(_cfg()) / "reports").resolve()
    if not reports_dir.exists():
        return "Self-Improve Reports: keine Dateien vorhanden."
    items: List[Path] = []
    with contextlib.suppress(Exception):
        items = sorted(reports_dir.glob("self_improve_*.json"), key=lambda p: p.stat().st_mtime, reverse=True)
    if not items:
        return "Self-Improve Reports: keine Dateien vorhanden."
    lines = [f"Self-Improve Reports (neueste {min(n, len(items))}/{len(items)}):"]
    for i, p in enumerate(items[:n], start=1):
        ts = _format_datetime_readable(datetime.fromtimestamp(p.stat().st_mtime, tz=timezone.utc).isoformat())
        lines.append(f"{i}. {p.name} | {ts}")
        lines.append(f"   {p}")
