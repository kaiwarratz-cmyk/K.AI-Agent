# Poison-patterns that indicate false "tool broken" beliefs stored in memory
_MEMORY_POISON_PATTERNS = [
    "cron_create.*defekt", "cron_create.*nicht.*m.glich", "cron_create.*gesperrt",
    "tool.*gesperrt.*defekt", "nicht.*m.glich.*cron", "defekt.*cron_create",
    "tool ist defekt", "tool ist gesperrt",
    # False workflow_success: write_file recorded as successful cron action
    r"workflow_success.*write_file.*cron", r"write_file.*intent:cron",
    r"context_key.*write_file.*cron", r"context_key.*cron.*write_file",
    # Impossibility beliefs
    r"erstellung.*cronjob.*nicht m.glich", r"cronjob.*derzeit.*nicht",
    r"unmöglichkeit.*cron", r"cron.*unmöglich",
]

def _auto_purge_poisoned_memory() -> int:
    """Auto-cleanup on startup: remove ChromaDB entries AND session state with false 'tool broken' beliefs."""
    import re
    removed = 0

    # 1. ChromaDB purge
    try:
        db_path = ROOT_DIR / "data" / "chroma_db" / "chroma.sqlite3"
        if db_path.exists():
            import sqlite3
            conn = sqlite3.connect(str(db_path))
            cur = conn.cursor()
            cur.execute("SELECT id, string_value FROM embedding_metadata WHERE string_value IS NOT NULL")
            rows = cur.fetchall()
            poison_ids = []
            for row_id, val in rows:
                if not val:
                    continue
                val_lower = val.lower()
                for pat in _MEMORY_POISON_PATTERNS:
                    if re.search(pat, val_lower):
                        poison_ids.append(row_id)
                        break
            if poison_ids:
                placeholders = ','.join(['?' for _ in poison_ids])
                cur.execute(f"DELETE FROM embedding_metadata WHERE id IN ({placeholders})", poison_ids)
                cur.execute(f"DELETE FROM embeddings WHERE id IN ({placeholders})", poison_ids)
                conn.commit()
                removed += len(poison_ids)
            conn.close()
    except Exception:
        pass

    # 2. Session state purge — clean poisoned entities/active_goal from all session JSON files
    _SIMPLE_POISON = ["defekt", "gesperrt", "nicht möglich", "nicht moeglich", "unmöglich"]
    def _is_poisoned(text: str) -> bool:
        t = str(text).lower()
        return any(p in t for p in _SIMPLE_POISON)

    sessions_dir = ROOT_DIR / "data" / "sessions"
    try:
        for sf in sessions_dir.glob("*.json"):
            try:
                data = json.loads(sf.read_text(encoding="utf-8"))
                if not isinstance(data, dict):
                    continue
                changed = False
                # Clean entities
                orig = data.get("entities", {})
                if isinstance(orig, dict):
                    clean = {k: v for k, v in orig.items() if not _is_poisoned(k) and not _is_poisoned(v)}
                    if len(clean) < len(orig):
                        data["entities"] = clean
                        removed += len(orig) - len(clean)
                        changed = True
                # Clean active_goal
                if _is_poisoned(data.get("active_goal", "")):
                    data["active_goal"] = "Kein aktives Ziel."
                    changed = True
                # Clean summary
                if _is_poisoned(data.get("summary", "")):
                    data["summary"] = ""
                    changed = True
                if changed:
                    sf.write_text(json.dumps(data, indent=2, ensure_ascii=False), encoding="utf-8")
            except Exception:
                pass
    except Exception:
        pass

    return removed


