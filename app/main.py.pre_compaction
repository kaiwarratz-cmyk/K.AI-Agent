def _normalize_web_query(message: str) -> str:
    raw = str(message or "").strip()
    if not raw:
        return ""
    query = raw
    query = re.sub(
        r"^\s*(?:suche|finde|recherchiere|recherche|search|look\s+up)\b",
        "",
        query,
        flags=re.IGNORECASE,
    )
    query = re.sub(r"\b(?:im\s+internet|im\s+web|online)\b", "", query, flags=re.IGNORECASE)
    query = re.sub(r"^\s*(?:nach|zu|about)\s+", "", query, flags=re.IGNORECASE)
    query = query.strip(" \t\r\n:;,.!?")
    return query or raw


def _strip_html_tags(text: str) -> str:
    cleaned = re.sub(r"<[^>]+>", " ", str(text or ""), flags=re.IGNORECASE)
    cleaned = html.unescape(cleaned)
    return re.sub(r"\s+", " ", cleaned).strip()


def _duckduckgo_search(cfg: Dict[str, Any], query: str, limit: int = 6) -> List[Dict[str, str]]:
    q = _normalize_web_query(query)
    if not q:
        return []
    web_cfg = cfg.get("web", {}) if isinstance(cfg.get("web", {}), dict) else {}
    configured_endpoint = str(
        web_cfg.get("ddg_endpoint", "https://html.duckduckgo.com/html/")
        or "https://html.duckduckgo.com/html/"
    ).strip()
    try:
        timeout_sec = float(web_cfg.get("timeout_sec", 12) or 12)
    except Exception:
        timeout_sec = 12.0
    timeout_sec = max(5.0, min(20.0, timeout_sec))
    max_hits = max(1, min(10, int(limit or 6)))
    endpoints = [configured_endpoint, "https://html.duckduckgo.com/html/"]
    dedup_endpoints: List[str] = []
    for ep in endpoints:
        if ep and ep not in dedup_endpoints:
            dedup_endpoints.append(ep)

    body = ""
    last_http_status = 0
    for endpoint in dedup_endpoints:
        try:
            with httpx.Client(
                timeout=timeout_sec,
                trust_env=False,
                follow_redirects=True,
                headers={
                    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
                    "Accept-Language": "de-DE,de;q=0.9,en;q=0.8",
                },
            ) as client:
                resp = client.post(endpoint, data={"q": q})
                last_http_status = int(resp.status_code)
                if 200 <= last_http_status < 300 and "result__a" in str(resp.text or ""):
                    body = str(resp.text or "")
                    break
        except Exception:
            continue
    if not body:
        tool_store.log("web_search_error", f"ddg_http_{last_http_status or 'request_failed'}")
        return []

    anchors = list(
        re.finditer(
            r'<a[^>]+class="[^"]*result__a[^"]*"[^>]+href="([^"]+)"[^>]*>(.*?)</a>',
            body,
            flags=re.IGNORECASE | re.DOTALL,
        )
    )
    snippets_raw = list(
        re.finditer(
            r'<(?:a|div)[^>]+class="[^"]*result__snippet[^"]*"[^>]*>(.*?)</(?:a|div)>',
            body,
            flags=re.IGNORECASE | re.DOTALL,
        )
    )
    snippets: List[str] = [_strip_html_tags(m.group(1) or "") for m in snippets_raw]

    results: List[Dict[str, str]] = []
    seen_urls: set[str] = set()
    for idx, match in enumerate(anchors):
        href_raw = html.unescape(str(match.group(1) or "").strip())
        href = href_raw
        if href.startswith("//"):
            href = "https:" + href
        elif href.startswith("/"):
            href = "https://duckduckgo.com" + href
        final_url = href
        if "duckduckgo.com/l/?" in href:
            try:
                parsed = urlparse(href)
                uddg = parse_qs(parsed.query).get("uddg", [""])[0]
                if uddg:
                    final_url = unquote(uddg)
            except Exception:
                pass
        if not str(final_url or "").lower().startswith(("http://", "https://")):
            continue
        if final_url in seen_urls:
            continue
        seen_urls.add(final_url)
        title = _strip_html_tags(match.group(2) or "") or "(ohne Titel)"
        try:
            domain = urlparse(final_url).netloc.lower()
        except Exception:
            domain = ""
        if domain.startswith("www."):
            domain = domain[4:]
        snippet = snippets[idx] if idx < len(snippets) else ""
        results.append(
            {
                "title": title,
                "url": final_url,
                "domain": domain,
                "snippet": snippet,
            }
        )
        if len(results) >= max_hits:
            break
    return results


def _register_web_sources(query: str, items: List[Dict[str, str]]) -> None:
    if not items:
        return
    ts = datetime.now().isoformat()
    for item in items:
