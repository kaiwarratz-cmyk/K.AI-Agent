            '- "zeige mir die datei c:\\\\temp\\\\x.txt" -> domain=tool_filesystem, intent=filesystem (path setzen), multi_step=no\n'
            '- "recherchiere aktuelle sicherheitsluecken in docker" -> domain=chat, intent=knowledge_or_web, multi_step=no\n'
            '- "mache einen screenshot und schicke ihn mir" -> domain=tool_script, intent=script, multi_step=yes\n'
            '- "welches modell nutzt du aktuell?" -> domain=chat, intent=chat, multi_step=no\n'
            '- "fasse zusammen und speichere als txt" -> domain=tool_answer_and_save, intent=answer_and_save, multi_step=yes\n'
            '- "lies die datei c:\\test.txt" -> domain=tool_filesystem, intent=filesystem, multi_step=no\n'
            '- "schreibe hallo welt in c:\\neu.txt" -> domain=tool_filesystem, intent=filesystem, multi_step=no\n'
            '- "suche nach X und erstelle bericht" -> domain=chat, intent=knowledge_or_web, multi_step=yes\n'
            '- "schreibe mir einen ESP32 blink sketch" -> domain=tool_script, intent=script, multi_step=no\n'
            '- "erstelle Arduino code fuer LED blinken" -> domain=tool_script, intent=script, multi_step=no\n'
            '- "schreibe Python script fuer X" -> domain=tool_script, intent=script, multi_step=no\n'
            "- Code-Generierung (Arduino, Python, C++, etc.) ist IMMER intent=script, multi_step=no – KEIN Web-Search nötig!\n"
            '- "loesche c:\\alt.txt" -> domain=tool_filesystem, intent=filesystem\n'
            '- "fuehre python script aus" -> domain=tool_script, intent=script\n'
            '- "erstelle cron job alle 5 minuten" -> domain=tool_cron, intent=cron\n\n'
            "- multi_step=true wenn die Anfrage MEHRERE unabhaengige Aktionen in verschiedenen Domains enthaelt\n"
            "  (z.B. erstelle Skript UND lege Cronjob an, Screenshot machen UND per Mail senden UND Cron einrichten).\n"
            "- multi_step=false fuer einfache Einzelaktionen, auch wenn komplex.\n\n"
            '- "erstelle ein python skript das screenshot macht und lege cron an alle 10 min" -> multi_step=true\n'
            '- "erstelle ein skript" -> multi_step=false\n\n'
        )
        ctx = _latest_conversation_text(cfg)
        if ctx:
            base_prompt += f"Letzter Gespraechskontext (Auszug): {ctx[:1200]}\n\n"
        caps_block = _capabilities_prompt_block()
        if caps_block:
            base_prompt += caps_block + "\n\n"
        base_prompt += f"Anfrage: {text_for_router}"
        allowed_intents = {
            "chat",
            "filesystem",
            "script",
            "cron",
            "knowledge_or_web",
            "answer_and_save",
            "memory_query",
            "help",
            "clear_context",
            "unknown",
        }
        allowed_script_types = {"python", "powershell", ""}

        def _coerce_bool(value: Any) -> bool:
            if isinstance(value, bool):
                return value
            s = str(value).strip().lower()
            return s in {"true", "1", "yes", "ja"}

        def _validate_schema(obj: Dict[str, Any]) -> tuple[bool, Optional[Dict[str, Any]], str]:
            if not isinstance(obj, dict):
                return False, None, "root_not_object"
            required = [
                "schema_version",
                "intent",
                "confidence",
                "needs_clarification",
                "clarification_question",
                "normalized_user_text",
                "entities",
            ]
            missing = [k for k in required if k not in obj]
            if missing:
                return False, None, f"missing_keys:{','.join(missing)}"
            schema_version = str(obj.get("schema_version", "") or "").strip().lower()
            if schema_version != "intent_schema_v1":
                return False, None, f"invalid_schema_version:{schema_version}"
            intent = str(obj.get("intent", "unknown") or "").strip().lower()
            if intent not in allowed_intents:
                return False, None, f"invalid_intent:{intent}"
            if intent not in set(allowed_intents_for_domain) and domain_name not in {"unknown", "chat"}:
                return False, None, f"intent_outside_domain:{intent}"
            try:
                conf = float(obj.get("confidence", 0.0) or 0.0)
            except Exception:
                return False, None, "confidence_not_float"
            conf = max(0.0, min(1.0, conf))
            needs = _coerce_bool(obj.get("needs_clarification", False))
            q = str(obj.get("clarification_question", "") or "").strip()[:240]
            norm = str(obj.get("normalized_user_text", "") or "").strip()[:400]
            entities_in = obj.get("entities", {})
            if not isinstance(entities_in, dict):
                return False, None, "entities_not_object"
            query = str(entities_in.get("query", "") or "").strip()[:500]
            path = str(entities_in.get("path", "") or "").strip()[:500]
            script_type = str(entities_in.get("script_type", "") or "").strip().lower()
            if script_type not in allowed_script_types:
                return False, None, f"invalid_script_type:{script_type}"
            multi_step_raw = str(obj.get("multi_step", "no") or "no").strip().lower()
            sanitized = {
                "schema_version": "intent_schema_v1",
                "intent": intent,
                "multi_step": "yes" if multi_step_raw == "yes" else "no",
                "confidence": conf,
                "needs_clarification": needs,
                "clarification_question": q,
                "normalized_user_text": norm,
                "entities": {
                    "query": query,
                    "path": path,
                    "script_type": script_type,
                },
            }
            # use normalized text as helper context for later debug/metrics only
            sanitized["domain"] = domain_name
            sanitized["domain_confidence"] = round(domain_conf, 4)
            # Post-validation normalization for known confusion pairs.
            msg_low = str(text or "").strip().lower()
            # Memory recall questions should not degrade to generic chat/unknown.
            if sanitized["intent"] in {"chat", "unknown"}:
                query_low = str(sanitized["entities"].get("query", "") or "").strip().lower()
                if _is_internal_memory_query(msg_low) or _is_internal_memory_query(query_low):
                    sanitized["intent"] = "memory_query"
                    sanitized["confidence"] = max(float(sanitized["confidence"]), 0.74)
                    sanitized["needs_clarification"] = False
                    sanitized["clarification_question"] = ""
            # Script-like requests should not degrade to unknown/chat.
            if sanitized["intent"] in {"chat", "unknown"}:
                script_words = _has_any(msg_low, ["script", "skript", "python", "powershell", "pwsh", "screenshot", "bildschirmfoto"])
                script_verbs = _has_any(msg_low, ["erstell", "schreib", "ausfuehr", "ausführ", "run", "execute", "starte", "start", "mach", "mache"])
                if script_words and script_verbs:
                    sanitized["intent"] = "script"
                    sanitized["confidence"] = max(float(sanitized["confidence"]), 0.74)
                    sanitized["needs_clarification"] = False
                    sanitized["clarification_question"] = ""
            if sanitized["intent"] in {"chat", "unknown"}:
                cron_words = _has_any(msg_low, ["erinnere mich", "remind me", "cron", "schedule", "alle ", "every ", "jede "])
                cron_time = _has_any(msg_low, ["minute", "minuten", "stunden", "uhr", "hour", "hours", "morgen", "today", "tomorrow"])
                if cron_words and cron_time:
                    sanitized["intent"] = "cron"
                    sanitized["confidence"] = max(float(sanitized["confidence"]), 0.76)
                    sanitized["needs_clarification"] = False
                    sanitized["clarification_question"] = ""
            # Generic knowledge prompts should not remain unknown.
            if sanitized["intent"] == "unknown":
                looks_chat = signals.is_question or _has_any(msg_low, ["erklaere", "erkläre", "rezept", "tipps", "was ist", "wer ist", "wie funktioniert", "gib mir"])
                if looks_chat and (not signals.explicit_tool_intent) and (not signals.is_approval_reply):
                    sanitized["intent"] = "chat"
                    sanitized["confidence"] = max(float(sanitized["confidence"]), 0.72)
                    sanitized["needs_clarification"] = False
                    sanitized["clarification_question"] = ""
            # Mixed research + save phrasing should map to answer_and_save.
            if sanitized["intent"] == "unknown":
                has_save = _has_any(msg_low, ["speicher", "save", "textdatei", ".txt"])
                has_research = _has_any(msg_low, ["suche", "recherchiere", "infos", "information", "zusammenfassen", "fasse"])
                if has_save and has_research:
                    sanitized["intent"] = "answer_and_save"
                    sanitized["confidence"] = max(float(sanitized["confidence"]), 0.72)
                    sanitized["needs_clarification"] = False
                    sanitized["clarification_question"] = ""
            if sanitized["intent"] == "memory_query":
                if _has_any(msg_low, ["welches modell", "welche quellen", "rezept", "erklaere", "erkläre", "was ist", "who is", "what is"]):
                    sanitized["intent"] = "chat"
                    sanitized["confidence"] = max(float(sanitized["confidence"]), 0.72)
            if sanitized["needs_clarification"] and not sanitized["clarification_question"]:
                return False, None, "clarification_question_required"
            # Intent-level abstain calibration.
            min_intent_conf = _intent_threshold(cfg, sanitized["intent"])
            if _llm_abstain_enabled(cfg) and sanitized["intent"] != "chat" and float(sanitized["confidence"]) < float(min_intent_conf):
                sanitized["intent"] = "unknown"
                sanitized["needs_clarification"] = True
                if not sanitized["clarification_question"]:
                    sanitized["clarification_question"] = "Ich bin mir noch unsicher. Kannst du die Aufgabe bitte konkretisieren?"
            return True, sanitized, ""

        last_err = ""
        for attempt in range(1, 4):
            prompt = base_prompt
            if attempt > 1:
                prompt += (
                    "\n\nWICHTIG: Vorherige Antwort war ungueltig ("
                    + last_err
                    + "). Gib jetzt NUR ein einzelnes valides JSON-Objekt exakt nach Schema aus. "
                    "Keine Markdown-Backticks, kein Zusatztext."
                )
            try:
                obj = router.chat_json(prompt=prompt, schema_name="intent_schema_v1", schema=intent_schema_v1)
            except Exception as exc:
                tool_store.log("intent_schema_native_error", f"attempt={attempt} err={exc}")
                raw = router.chat(prompt)
                obj = _extract_json_dict(str(raw.text or ""))
            if not isinstance(obj, dict):
                last_err = "json_parse_failed"
                tool_store.log("intent_schema_retry", f"attempt={attempt} err={last_err}")
                continue
            # Domain aus kombinierter Antwort extrahieren und Heuristiken anwenden
            _raw_domain = str(obj.get("domain", "unknown") or "").strip().lower()
            if _raw_domain in _valid_domains:
                domain_name = _raw_domain
            try:
                domain_conf = max(0.0, min(1.0, float(obj.get("domain_confidence", 0.0) or 0.0)))
            except Exception:
                domain_conf = 0.0
            low_text = text.lower()
            # Heuristic floors (identisch zum früheren zweistufigen Ansatz)
            if domain_name in {"unknown", "chat"} and domain_conf < 0.58:
                if signals.is_question and not signals.explicit_tool_intent and not signals.is_approval_reply:
                    domain_name = "chat"; domain_conf = max(domain_conf, 0.62)
                elif _has_any(low_text, ["zeige mir die datei", "sind da dateien enthalten", "welche ordner", "welche dateien"]):
                    domain_name = "tool_filesystem"; domain_conf = max(domain_conf, 0.64)
                elif _has_any(low_text, ["mache einen screenshot und schicke", "screenshot und schick", "schreib ein python skript"]):
                    domain_name = "tool_script"; domain_conf = max(domain_conf, 0.66)
                elif _has_any(low_text, ["erinnere mich", "remind me", "cron", "schedule", "alle ", "every ", "jede "]):
                    domain_name = "tool_cron"; domain_conf = max(domain_conf, 0.67)
            if not signals.explicit_tool_intent and not signals.is_approval_reply:
                if _has_any(low_text, ["gib mir", "erklaere", "erkläre", "rezept", "tipps", "kurz erklaeren", "kurz erklären"]):
                    domain_name = "chat"; domain_conf = max(domain_conf, 0.66)
                if _has_any(low_text, ["mache einen screenshot", "screenshot", "bildschirmfoto"]) and _has_any(low_text, ["schick", "sende", "send"]):
                    domain_name = "tool_script"; domain_conf = max(domain_conf, 0.68)
                if _has_any(low_text, ["speicher", "save", "textdatei", ".txt"]) and _has_any(low_text, ["suche", "recherchiere", "infos", "information"]):
                    domain_name = "tool_answer_and_save"; domain_conf = max(domain_conf, 0.68)
                if _has_any(low_text, ["erinnere mich", "remind me", "cron", "schedule", "alle ", "every ", "jede "]):
                    domain_name = "tool_cron"; domain_conf = max(domain_conf, 0.7)
            allowed_intents_for_domain = domain_to_intents.get(domain_name, ["unknown", "chat"])
            # Domain-Abstain: wenn Domain zu unsicher
            if _llm_abstain_enabled(cfg) and domain_conf < _domain_min_confidence(cfg):
                return {
                    "schema_version": "intent_schema_v1",
                    "intent": "unknown",
                    "confidence": domain_conf,
                    "needs_clarification": True,
                    "clarification_question": "Kannst du kurz praezisieren, was ich konkret tun soll?",
                    "normalized_user_text": text[:400],
                    "domain": domain_name,
                    "domain_confidence": round(domain_conf, 4),
                    "entities": {"query": "", "path": "", "script_type": ""},
                }
            ok, sanitized, err = _validate_schema(obj)
            if ok and sanitized is not None:
                return sanitized
            last_err = err or "schema_invalid"
            tool_store.log("intent_schema_retry", f"attempt={attempt} err={last_err}")
        tool_store.log("intent_schema_failed", last_err or "unknown")
        return None
    except Exception as exc:
        tool_store.log("intent_interpret_error", str(exc))
        return None

def _apply_interpretation(message: str, signals: ReasoningSignals, interpretation: Dict[str, Any]) -> tuple[str, ReasoningSignals]:
    text = message
    lower = message.lower()
    intent = str(interpretation.get("intent", "unknown"))
    conf = float(interpretation.get("confidence", 0.0) or 0.0)
    entities = interpretation.get("entities", {}) if isinstance(interpretation.get("entities", {}), dict) else {}

    is_approval = False
    explicit_tool = signals.explicit_tool_intent
    mixed_save = signals.mixed_answer_save_intent
    internal_memory = signals.internal_memory_query

    if conf >= 0.72:
        if intent == "filesystem":
            explicit_tool = True
            ent_path = str(entities.get("path", "") or "").strip()
            if ent_path and not _extract_any_path(text):
                text = f'{text} "{ent_path}"'
        elif intent == "script":
            explicit_tool = True
        elif intent == "answer_and_save":
            query = str(entities.get("query", "") or "").strip()
            path = str(entities.get("path", "") or "").strip()
            save_hint = _has_any(lower, ["speicher", "save", "textdatei", ".txt", "sicher"])
            if save_hint:
                if query:
                    if path:
                        text = f"{query} und speichere als Textdatei unter {path}"
                    else:
                        text = f"{query} und speichere als Textdatei"
                mixed_save = True
                explicit_tool = False
        elif intent == "memory_query":
            query_hint = str(entities.get("query", "") or "").strip()
            # Guardrail: only activate memory-only mode for real memory-recall requests.
            if _is_internal_memory_query(text) or _is_internal_memory_query(query_hint):
                internal_memory = True
        elif intent == "help":
            text = "/befehle"
        elif intent == "clear_context":
            # Guardrail: never rewrite explicit memory-delete commands to context-only.
            if not (_is_memory_delete_command(message) or _is_memory_delete_command(text)):
                text = "kontext loeschen"

    # Central argument binding layer (paths/query) to keep parsing robust.
    ent_path = str(entities.get("path", "") or "").strip()
    ent_query = str(entities.get("query", "") or "").strip()
    if intent in {"filesystem", "answer_and_save"} and ent_path and (not _extract_any_path(text)):
        text = f'{text} "{ent_path}"'

    new_signals = ReasoningSignals(
        is_question=signals.is_question,
        is_approval_reply=is_approval,
        explicit_tool_intent=explicit_tool,
        mixed_answer_save_intent=mixed_save,
        internal_memory_query=internal_memory,
    )
    return text, new_signals

def _action_policy_flags(action: Dict[str, Any]) -> tuple[bool, bool]:
    kind = str(action.get("kind", "") or "").strip().lower()
    risky_kinds = {
        "copy_path",
        "move_path",
        "delete_path",
        "bulk_delete_ext",
        "rename_path",
        "copy_all_files",
        "move_all_files",
    }
    admin_required_kinds = {
        "write_file",
        "append_file",
        "write_json_file",
        "touch_file",
        "make_dir",
        "run_downloaded_file",
    }
    return kind in risky_kinds, kind in admin_required_kinds


def _mcp_tool_names() -> List[str]:
    try:
        from app.mcp_tools import get_cached_mcp_tools
        names: List[str] = []
        for t in get_cached_mcp_tools():
            func = t.get("function", {}) if isinstance(t, dict) else {}
            name = str(func.get("name", "")).strip()
            if name:
                names.append(name)
        return names
    except Exception:
        return []

def _allowed_action_kinds_for_intent(intent: str) -> List[str]:
    i = str(intent or "").strip().lower()
    reg = _skills_snapshot()
    extra_map = reg.get("intent_kinds", {}) if isinstance(reg.get("intent_kinds", {}), dict) else {}
    extra = [str(x) for x in (extra_map.get(i, []) if isinstance(extra_map.get(i, []), list) else []) if str(x).strip()]
    cfg_now = _cfg()
    if _cli_core_enabled(cfg_now):
        core_allowed = _cli_core_allowed_action_kinds(i, cfg=cfg_now)
        # Keep skill-provided action kinds available in core mode.
        return list(dict.fromkeys([x for x in (core_allowed + extra) if str(x).strip()]))
    mcp_existing = _mcp_tool_names()
    direct_exec = ["shell_command", "send_messenger_file"]
    mcp_external = ["mcp_registry_search", "mcp_registry_prepare", "mcp_registry_install"]
    script_dynamic = ["script_create", "script_exec", "script_validate", "install_python_packages", "install_nodejs_packages"]
    if i in {"filesystem", "script", "cron", "answer_and_save"}:
        classic_fallback: List[str] = []
        if i == "filesystem":
            classic_fallback = ["list_entries", "read_file", "write_file"]
        elif i == "answer_and_save":
            classic_fallback = ["write_file", "read_file"]
        elif i == "cron":
            classic_fallback = ["cron_create", "cron_list", "cron_delete", "cron_pause", "cron_resume", "cron_test"]
        ordered = mcp_existing + direct_exec + mcp_external + script_dynamic + classic_fallback + extra
        return list(dict.fromkeys([x for x in ordered if str(x).strip()]))
    extra += mcp_existing
    extra += direct_exec + mcp_external
    if i == "knowledge_or_web":
        return ["script_exec", "script_create"] + extra
    if i == "script":
        return ["script_create", "script_exec", "script_validate", "install_python_packages", "install_nodejs_packages"] + extra
    if i == "cron":
        return ["cron_create", "cron_list", "cron_delete", "cron_pause", "cron_resume", "cron_test"] + extra
    if i == "filesystem":
        return [
            "read_file",
            "list_entries",
            "write_file",
            "script_exec",
            "script_create",
        ] + extra
    if i == "answer_and_save":
        # Keep this intent focused; large action catalogs reduce planner reliability.
        return [
            "write_file",
            "read_file",
            "script_exec",
            "script_create",
        ] + extra
    return list(dict.fromkeys(list(_action_schemas().keys()) + extra))

def _json_type_for_python(t: Any) -> str:
    if t in {bool}:
        return "boolean"
    if t in {int}:
        return "integer"
    if t in {float}:
        return "number"
    if t in {list}:
        return "array"
    if t in {dict}:
        return "object"
    return "string"

def _json_schema_for_python_type(t: Any) -> Dict[str, Any]:
    jt = _json_type_for_python(t)
    if jt == "array":
        return {"type": "array", "items": {"type": "string"}}
    if jt == "object":
        return {"type": "object", "additionalProperties": True}
    return {"type": jt}

