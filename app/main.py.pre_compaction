def _self_improve_recompute_schedule(cfg: Dict[str, Any], now: Optional[datetime] = None) -> None:
    si = _self_improve_cfg(cfg)
    base = now or datetime.now(timezone.utc)
    _self_improve_update_state(
        enabled=bool(si["enabled"]),
        scan_interval_sec=int(si["scan_interval_sec"]),
        deep_check_interval_sec=int(si["deep_check_interval_sec"]),
        cooldown_sec=int(si["cooldown_sec"]),
        auto_execute=bool(si["auto_execute"]),
        next_scan_at=(base + timedelta(seconds=int(si["scan_interval_sec"]))).isoformat(),
        next_deep_at=(base + timedelta(seconds=int(si["deep_check_interval_sec"]))).isoformat(),
    )

def _self_improve_worker_loop() -> None:
    # Lightweight monitoring only; no automatic diagnose script execution.
    while not _self_improve_stop_event.is_set():
        cfg = _cfg()
        si = _self_improve_cfg(cfg)
        now = datetime.now(timezone.utc)
        if not bool(si["enabled"]):
            _self_improve_update_state(
                enabled=False,
                scan_interval_sec=int(si["scan_interval_sec"]),
                deep_check_interval_sec=int(si["deep_check_interval_sec"]),
                cooldown_sec=int(si["cooldown_sec"]),
                auto_execute=bool(si["auto_execute"]),
            )
            _self_improve_stop_event.wait(2.0)
            continue
        snap = _self_improve_state_snapshot()
        next_scan = _cron_parse_run_at_iso(str(snap.get("next_scan_at", "") or ""))
        next_deep = _cron_parse_run_at_iso(str(snap.get("next_deep_at", "") or ""))
        if next_scan is None or next_deep is None:
            _self_improve_recompute_schedule(cfg, now=now)
            _self_improve_stop_event.wait(1.0)
            continue
        did_any = False
        if now >= next_scan:
            with contextlib.suppress(Exception):
                signals = _collect_improvement_signals()
                rep = _self_improve_small_report(cfg)
                signal_count = rep.get('signal_count', 0)
                # Nur loggen/speichern wenn Signale vorhanden
                if signal_count > 0:
                    p = _self_improve_save_report(rep, "small_auto")
                    tool_store.log("self_improve_scan", f"small signals={signal_count}")
                    if p:
                        tool_store.log("self_improve_report", f"small_auto -> {p}")
                # Auto-Analyse: wenn Signale vorhanden und konfiguriert
                if signals and bool(si.get("auto_analyze", False)):
                    try:
                        from app.trace_utils import start_thread_with_trace
                        start_thread_with_trace(_si_analyze_with_llm, signals, cfg, name="kaia-si-analyze", daemon=True)
                    except Exception:
                        threading.Thread(
                            target=_si_analyze_with_llm,
                            args=(signals, cfg),
                            name="kaia-si-analyze",
                            daemon=True,
                        ).start()
            _self_improve_update_state(next_scan_at=(now + timedelta(seconds=int(si["scan_interval_sec"]))).isoformat())
            did_any = True

        if now >= next_deep:
            cooldown = int(si["cooldown_sec"])
            last_deep = _cron_parse_run_at_iso(str(_self_improve_state_snapshot().get("last_deep_at", "") or ""))
            if (last_deep is None) or ((now - last_deep).total_seconds() >= cooldown):
                with contextlib.suppress(Exception):
                    rep = _self_improve_deep_report(cfg)
                    p = _self_improve_save_report(rep, "deep_auto")
                    tool_store.log(
                        "self_improve_scan",
                        f"deep signals={rep.get('small_scan', {}).get('signal_count', 0)} llm_ok={rep.get('llm_ping', {}).get('ok')}",
                    )
                    if p:
                        tool_store.log("self_improve_report", f"deep_auto -> {p}")
            _self_improve_update_state(next_deep_at=(now + timedelta(seconds=int(si["deep_check_interval_sec"]))).isoformat())
            did_any = True
        _self_improve_stop_event.wait(1.0 if did_any else 2.0)

def _self_improve_start_worker() -> None:
    global _self_improve_thread
    with _self_improve_lock:
        if _self_improve_thread is not None and _self_improve_thread.is_alive():
            return
        cfg = _cfg()
        _self_improve_recompute_schedule(cfg)
        _self_improve_stop_event.clear()
        _self_improve_thread = threading.Thread(target=_self_improve_worker_loop, name="kaia-self-improve-worker", daemon=True)
        _self_improve_thread.start()

def _self_improve_stop_worker() -> None:
    global _self_improve_thread
    _self_improve_stop_event.set()
    with _self_improve_lock:
        t = _self_improve_thread
        _self_improve_thread = None
    if t is not None and t.is_alive():
        with contextlib.suppress(Exception):
            t.join(timeout=2.0)

def _read_error_log_entries(limit: int = 300, max_age_hours: int = 72) -> List[Dict[str, Any]]:
    if not ERROR_LOG_FILE.exists():
        return []
    try:
        lines = ERROR_LOG_FILE.read_text(encoding="utf-8", errors="ignore").splitlines()
    except Exception:
        return []
    cutoff = (datetime.now(timezone.utc) - timedelta(hours=max_age_hours)).isoformat()
    out: List[Dict[str, Any]] = []
    for line in lines[-max(1, limit) :]:
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
            if isinstance(obj, dict):
                ts = str(obj.get("ts", ""))
                if ts and ts < cutoff:
                    continue
                out.append(obj)
        except Exception:
            continue
    return out

def _collect_improvement_signals() -> List[Dict[str, Any]]:
    counts: Dict[str, int] = {}
    last_msg: Dict[str, str] = {}
    severities: Dict[str, int] = {}

    def add_signal(key: str, msg: str, severity: int) -> None:
        counts[key] = counts.get(key, 0) + 1
        last_msg[key] = msg[:350]
        severities[key] = max(severities.get(key, 0), severity)

    # Persistent LLM/network errors
    for row in _read_error_log_entries(limit=350):
        kind = str(row.get("kind", "")).strip().lower()
        msg = str(row.get("message", "")).strip()
        if not kind:
            continue
        sev = 2
        if "stream" in kind or "http_status" in kind:
            sev = 3
        add_signal(f"llm:{kind}", msg or kind, sev)

    # Runtime tool errors in this process
    for event in tool_store.recent_events(limit=240):
        tool = str(event.get("tool", "")).strip().lower()
        note = str(event.get("note", "")).strip()
        if not tool:
            continue
        if "error" in tool:
            sev = 2
            if "script" in tool or "chat_error" in tool:
                sev = 3
            add_signal(f"tool:{tool}", note or tool, sev)
        if "timeout" in note.lower():
            add_signal("tool:timeout", note, 3)

    signals: List[Dict[str, Any]] = []
    for key, cnt in counts.items():
        signals.append(
            {
                "key": key,
                "count": cnt,
                "severity": severities.get(key, 1),
                "last_message": last_msg.get(key, ""),
            }
        )
    signals.sort(key=lambda s: (int(s.get("severity", 0)), int(s.get("count", 0))), reverse=True)
    return signals[:10]

def _persist_improvement_signals(cfg: Dict[str, Any], signals: List[Dict[str, Any]]) -> None:
    if not signals:
        return
    store = _memory_store(cfg)
    for s in signals[:10]:
        key = f"{s.get('key','')}:{s.get('last_message','')[:80].lower()}"
        # WICHTIG: Interne System-Signale MÜSSEN in eine separate Collection,
        # damit sie NIEMALS beim semantischen Recall als Nutzerfakten zurückgegeben werden!
        store.upsert_memory(
            "system_signals",  # FIX: war "important" → führte zu Prompt-Kontamination
            key,
            {
                "field": "improvement_signal",
                "value": str(s.get("key", "")),
                "count": int(s.get("count", 0)),
                "severity": int(s.get("severity", 1)),
                "last_message": str(s.get("last_message", ""))[:350],
            },
            confidence=0.86,
        )

