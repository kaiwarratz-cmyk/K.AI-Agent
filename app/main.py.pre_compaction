def _handle_drive_status_query(message: str, cfg: Dict[str, Any], dialog_key: str) -> Optional[Dict[str, Any]]:
    lower = str(message or "").strip().lower()
    if not lower:
        return None
    asks_status = (
        _has_any(lower, ["ist verbunden", "hat es funktioniert", "verbunden?", "gemappt", "gemountet"])
        and _has_any(lower, ["laufwerk", "freigabe", "verbunden", "gemappt", "gemountet", "funktioniert"])
    )
    if not asks_status:
        return None
    net = _get_session_network_ctx(dialog_key)
    drive = _extract_drive_letter(net.get("drive", "")) or _get_session_last_drive(dialog_key) or _latest_conversation_drive(cfg, dialog_key=dialog_key)
    unc = str(net.get("unc", "") or "").strip()
    if not drive:
        return {"ok": True, "reply": "Ich habe in diesem Kontext noch kein Laufwerk gemerkt."}
    try:
        exists = Path(f"{drive}\\").exists()
    except Exception:
        exists = False
    if exists:
        if unc:
            return {"ok": True, "reply": f"Ja, {drive} ist verbunden ({unc})."}
        return {"ok": True, "reply": f"Ja, {drive} ist verbunden."}
    if unc:
        return {"ok": True, "reply": f"Nein, {drive} ist aktuell nicht verbunden ({unc})."}
    return {"ok": True, "reply": f"Nein, {drive} ist aktuell nicht verbunden."}

def _handle_drive_letter_query(message: str, dialog_key: str) -> Optional[Dict[str, Any]]:
    lower = str(message or "").strip().lower()
    if not lower:
        return None
    asks_letter = bool(
        re.search(r"(mit\s+welchem\s+buchstaben|welcher\s+buchstabe|welches\s+laufwerk|welcher\s+laufwerksbuchstabe)", lower)
    )
    if not asks_letter:
        return None
    net = _get_session_network_ctx(dialog_key)
    unc = str(net.get("unc", "") or "").strip()
    remembered = _extract_drive_letter(net.get("drive", "")) or _get_session_last_drive(dialog_key)
    if not unc:
        assistant_text = _latest_session_assistant_text(dialog_key)
        unc = _extract_unc_from_text(assistant_text)
        if unc:
            _set_session_network_ctx(dialog_key, unc=unc, drive=str(remembered or ""), awaiting_drive=False)
    if unc:
        mapped = _lookup_mapped_drive_for_unc(unc)
        if mapped:
            _set_session_last_drive(dialog_key, mapped)
            _set_session_network_ctx(dialog_key, unc=unc, drive=mapped, awaiting_drive=False)
            return {"ok": True, "reply": f"Die Freigabe ist als Laufwerk {mapped} verbunden."}
    if remembered:
        return {"ok": True, "reply": f"Zuletzt wurde {remembered} verwendet."}
    return {"ok": True, "reply": "Ich habe aktuell keinen zugeordneten Laufwerksbuchstaben im Kontext."}

def _normalize_network_map_request(message: str) -> str:
    raw = str(message or "").strip()
    if not raw:
        return raw
    low = raw.lower()
    if _has_any(low, ["subst", "lokal als laufwerk", "ordner als laufwerk", "lokales laufwerk"]):
        return raw
    unc = _extract_any_path(raw)
    if not unc or not str(unc).startswith("\\\\"):
        return raw
    drive = _extract_drive_letter(raw)
    map_like = bool(re.search(r"\b(map\w*|mapp\w*|mount\w*|verbin\w*)\b", low))
    network_obj = _has_any(low, ["laufwerk", "netzlaufwerk", "freigabe", "netzwerkfreigabe", "network share", "drive"])
    if map_like and network_obj:
        if drive:
            return f'verbinde die freigabe als laufwerk "{unc}" als laufwerk {drive}'
        return f'verbinde die freigabe als laufwerk "{unc}"'
    return raw

def _is_network_map_or_unmap_message(message: str) -> bool:
    raw = str(message or "").strip()
    if not raw:
        return False
    low = raw.lower()
    if _has_any(low, ["subst", "lokal als laufwerk", "ordner als laufwerk", "lokales laufwerk"]):
        return False
    if not _has_any(low, ["laufwerk", "netzlaufwerk", "freigabe", "netzwerkfreigabe", "drive"]):
