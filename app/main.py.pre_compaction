    def _persist_response_async(stage_name: str, reply_value: str, skip_persist: bool) -> None:
        if skip_persist:
            return
        session_turns = 20
        session_turns = max(2, min(20, session_turns))
        msg_snapshot = str(raw_user_input)
        reply_snapshot = str(reply_value or "")
        steps_snapshot = list(_runtime_steps or [])
        interp_snapshot = dict(_runtime_interp) if isinstance(_runtime_interp, dict) else {}
        dialog_snapshot = str(dialog_key or "")
        source_snapshot = str(source or "")
        trace_snapshot = str(tid or "")

        def _worker() -> None:
            # Automatischer Trigger für Memory-Konsolidierung (alle 30 Interaktionen)
            global _interaction_counter
            do_consolidate = False
            with _interaction_lock:
                _interaction_counter += 1
                if _interaction_counter >= 30:
                    do_consolidate = True
                    _interaction_counter = 0
            
            if do_consolidate:
                try:
                    _ms = _memory_store(cfg)
                    _mc = MemoryConsolidator(cfg, _ms)
                    _res = _mc.consolidate_all()
                    tool_store.log("memory_consolidation_auto", f"Interaktion 30 erreicht: {_res}")
                except Exception as _ce:
                    tool_store.log("memory_consolidation_error", f"Auto-Konsolidierung fehlgeschlagen: {_ce}")

            # Nicht blockieren: wenn Persistenz bereits laeuft, diesen Turn ueberspringen.
            if not _memory_persist_lock.acquire(blocking=False):
                with contextlib.suppress(Exception):
                    tool_store.log("memory_persist_skip", f"busy trace={trace_snapshot} stage={stage_name}")
                return
            try:
                with contextlib.suppress(Exception):
                    if dialog_snapshot:
                        _update_session_history(cfg, dialog_snapshot, msg_snapshot, reply_snapshot, session_turns)
                    _persist_episode_memory(
                        cfg,
                        trace_id=trace_snapshot,
                        dialog_key=dialog_snapshot,
                        source=source_snapshot,
                        user_msg=msg_snapshot,
                        stage=stage_name,
                        reply=reply_snapshot,
                        steps=steps_snapshot,
                        interpretation=interp_snapshot,
                    )
            except Exception as exc:
                with contextlib.suppress(Exception):
                    tool_store.log("memory_persist_error", str(exc)[:220])
            finally:
                with contextlib.suppress(Exception):
                    _memory_persist_lock.release()

        try:
            from app.trace_utils import start_thread_with_trace
            start_thread_with_trace(_worker, name=f"KAI-memory-persist-{trace_snapshot[:8]}", daemon=True)
        except Exception:
            threading.Thread(
                target=_worker,
                daemon=True,
                name=f"KAI-memory-persist-{trace_snapshot[:8]}",
            ).start()
    
    try:
        _plan_path: Optional[str] = None
        _plan_id: Optional[str] = None

        def _ret(resp: Dict[str, Any], stage: str, extra: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
            resp_local = dict(resp or {})
            reply_text = str(resp_local.get("reply", "") or "")
            def _append_failure_summary_if_missing() -> None:
                nonlocal reply_text, resp_local
                if bool(resp_local.get("ok", False)):
                    return
                if "Versucht:" in reply_text or "Versuche:" in reply_text:
                    return
                attempted_steps: List[str] = []
                steps_from_resp = resp_local.get("steps", None)
                if isinstance(steps_from_resp, list):
                    attempted_steps = [str(x).strip() for x in steps_from_resp if str(x).strip()][:10]
                if not attempted_steps:
                    attempted_steps = [str(x).strip() for x in (_runtime_steps or []) if str(x).strip()][:10]
                intent_txt = str(_runtime_interp.get("intent", "") or "").strip() if isinstance(_runtime_interp, dict) else ""
                step_txt = ", ".join(attempted_steps) if attempted_steps else "(keine protokollierten Schritte)"
                suffix = (
                    "\n\n---\n"
                    "<details>\n"
                    "<summary><b>Technische Details zum Ablauf (Fehlgeschlagen)</b></summary>\n\n"
                    f"- **Stage:** `{stage}`\n"
                    f"- **Intent:** `{intent_txt or 'unbekannt'}`\n"
                    f"- **Schritte:** {step_txt}\n"
                    "</details>"
                )
                reply_text = (reply_text.rstrip() + suffix).strip()
                resp_local["reply"] = reply_text
            # Strict completion gate: successful operational stages must be verified as solved.
            # If output looks unresolved, run one autonomous recovery pass before final response.
            strict_cfg = cfg.get("react", {}) if isinstance(cfg.get("react", {}), dict) else {}
            strict_verify = bool(strict_cfg.get("strict_verify", True))
            operational_stage = stage in {
                "filesystem",
                "script_exec",
                "llm_action_ok",
                "react_loop_ok",
                "react_plan_ok",
                "react_loop_auto_recovery",
                "cli_core_react_loop_ok",
                "cli_core_react_loop_partial",
            }
            unresolved = False
            # Initialisierung hier verhindert UnboundLocalError wenn Code-Pfad
            # den solved_val-is-True-Zweig nicht durchläuft (z.B. solved_val=None)
            _explicit_file_request = False
            _file_actually_sent = False
            # Messenger-Guard früh setzen — wird in Recovery-Checks benötigt (auch wenn LLM-Check scheitert)
            _is_messenger_dialog = bool(
                dialog_key and ":" in dialog_key
                and dialog_key.split(":")[0] in {"telegram", "discord", "dc"}
            )
            if strict_verify and operational_stage and bool(resp_local.get("ok", False)):
                # Deterministic gate first: controller-owned status beats LLM wording.
                det_outcome = str(resp_local.get("outcome", "") or "").strip().lower()
                det_partial = bool(resp_local.get("partial", False)) or det_outcome == "partial"
                det_failed = det_outcome == "failed"
                if det_outcome == "success":
                    unresolved = False
                elif det_failed:
                    resp_local["ok"] = False
                    unresolved = False
                elif det_partial:
                    unresolved = True
                else:
                    # Deterministischer Pre-Check: zähle echte erfolgreiche Schritte.
                    # Wenn genug Schritte ok=True haben UND die Antwort substanziell ist
                    # UND keine Fehler-Keywords → direkt als gelöst werten, kein LLM-Check nötig.
                    _steps_list_pre = resp_local.get("steps") or []
                    _success_steps = sum(1 for _s in _steps_list_pre if isinstance(_s, dict) and bool(_s.get("ok")))
                    _fail_keywords = {"fehler", "error", "exception", "traceback", "fehlgeschlagen", "nicht gefunden", "not found"}
                    _reply_lower = reply_text.lower()
                    _reply_has_error = any(kw in _reply_lower for kw in _fail_keywords)
                    _reply_substantive = len(reply_text.strip()) > 80
                    if _success_steps >= 2 and _reply_substantive and not _reply_has_error:
                        # Genug echte Arbeit geleistet + positive Antwort → gelöst ohne LLM-Check
                        chk = {"solved": True, "confidence": 0.85, "reason": "deterministic_step_check", "next_action_hint": ""}
                    else:
                        # Secondary semantic check by LLM only when deterministic state is inconclusive.
                        # Originalnachricht ohne Memory-Injection übergeben, damit der Self-Check
                        # die echte Nutzeranfrage bewertet (nicht die injizierte Erinnerung).
                        _check_message = message
                        if "\n\nAktuelle User-Nachricht: " in message:
                            _check_message = message.split("\n\nAktuelle User-Nachricht: ", 1)[1]
                            if "\n\nCRITICAL KNOWLEDGE" in _check_message:
                                _check_message = _check_message.split("\n\nCRITICAL KNOWLEDGE", 1)[0]
                        try:
                            chk = _llm_self_check_solved(cfg, _check_message, reply_text, steps=resp_local.get("steps"))
                        except Exception:
                            chk = {"solved": None, "confidence": 0.0}
                    solved_val = chk.get("solved", None)
                    try:
                        chk_conf = float(chk.get("confidence", 0.0) or 0.0)
                    except Exception:
                        chk_conf = 0.0
                    if solved_val is False:
                        unresolved = True
                    elif solved_val is True and chk_conf >= 0.4:
                        unresolved = False
                        # Sekundär-Check: Dateiversand-Fokus
                        # Verhindert, dass Agent behauptet "Hier ist das Dokument", aber keins schickt.
                        # Urteil kommt direkt vom LLM-Self-Check (kein Keyword-Matching).
                        _explicit_file_request = bool(chk.get("file_delivery_expected", False))
                        
                        # Dateiversand-Check nur relevant wenn User über Messenger (Telegram/Discord) schreibt.
                        # Im WebUI ist Datei schreiben korrekt — kein send_messenger_file nötig.
                        _is_messenger_dialog = dialog_key and ":" in dialog_key and dialog_key.split(":")[0] in {"telegram", "discord", "dc"}
                        if _explicit_file_request and _is_messenger_dialog:
                            _steps_list = resp_local.get("steps") or []
                            _file_actually_sent = any(
                                isinstance(_s, dict)
                                and _s.get("kind") == "send_messenger_file"
                                and bool(_s.get("ok"))
                                for _s in _steps_list
                            )
                            if not _file_actually_sent:
                                # Wenn der Nutzer "als Datei" will, aber nur Text kommt -> unresolved.
                                unresolved = True
                    elif solved_val is True and chk_conf < 0.4:
                        # Sonderfall: LLM sagt "gelöst" aber nur mit schwacher Konfidenz (< 0.4).
                        # Bei Reply mit echten Tool-Ergebnissen (Schritte vorhanden) → gelöst.
                        # Verhindert Recovery-Loop-Fehlzündungen bei einfachen Aufgaben.
                        _steps_list = resp_local.get("steps") or []
                        if _steps_list:
                            unresolved = False  # Echte Schritte = echte Arbeit = gelöst
                        else:
                            unresolved = True
                    else:
                        # Inconclusive (solved_val=None/False und confidence=0): unresolved.
                        unresolved = True
                _audit_event(
                    "strict_verify_check",
                    {
                        "stage": stage,
                        "det_outcome": det_outcome,
                        "det_partial": det_partial,
                        "det_failed": det_failed,
                        "unresolved": unresolved,
                        "llm_solved": (solved_val if "solved_val" in locals() else None),
                        "llm_confidence": (chk_conf if "chk_conf" in locals() else 0.0),
                    },
                )
            # Guard: Wenn der Agent bereits erfolgreich eine Datei via send_messenger_file
            # gesendet hat, Recovery-Loop unterdrücken – verhindert doppelten Versand.
            if unresolved and resp_local.get("steps"):
                _file_sent_ok = any(
                    isinstance(_s, dict)
                    and _s.get("kind") == "send_messenger_file"
                    and bool(_s.get("ok"))
                    for _s in (resp_local.get("steps") or [])
                )
                if _file_sent_ok:
                    unresolved = False
                    _audit_event(
                        "strict_verify_file_guard",
                        {"note": "send_messenger_file bereits ok – Recovery übersprungen"},
                    )
            # Guard: Recovery bei 0 Tool-Calls unterdrücken (konversationell oder reines LLM-Wissen).
            # Wenn der erste Loop keine Tools aufgerufen hat, würde die Recovery nur eine
            # "Ich werde ... tun"-Ankündigung produzieren ohne echte Arbeit — schlimmer als Original.
            if unresolved and not (resp_local.get("steps") or []):
                unresolved = False
                _audit_event(
                    "strict_verify_no_steps_guard",
                    {"note": "0 Tool-Calls im ersten Versuch – Recovery übersprungen, Original-Antwort beibehalten"},
                )
            # Guard: Recovery-Loop blockieren wenn Agent absichtlich auf Nutzer-Input wartet
            if unresolved:
                try:
                    from app.task_state import get_task_state_manager as _get_tsm
                    _dstate = str((_get_tsm().get_state(dialog_key) or {}).get("dialogue_state", "") or "")
                    if _dstate == "awaiting_input":
                        unresolved = False
                        _audit_event("strict_verify_awaiting_guard",
                                     {"note": "AWAITING_INPUT – Recovery-Loop unterdrückt"})
                except Exception:
                    pass
            if (
                strict_verify
                and operational_stage
                and bool(resp_local.get("ok", False))
                and unresolved
                and not bool(_strict_verify_guard.get("running", False))
            ):
                try:
                    _strict_verify_guard["running"] = True
                    # Sofort sichtbares Feedback: User weiß dass der Agent noch arbeitet.
                    # Verhindert die stille Lücke zwischen Loop-Ende und Recovery-Start.
                    if dialog_key:
                        try:
                            _react_push_status("🔍 Analysiere Ergebnisse, suche weiter...", cfg, dialog_key)
                        except Exception:
                            pass
                    # Recovery-Loop bekommt das volle Iterationsbudget des Nutzers.
                    # Kein recovery_ratio-Cap – der Nutzer steuert das Limit ausschließlich via WebUI.
                    rec_max_iter = max(3, int(max_iterations or strict_cfg.get("max_iterations", 50) or 50))
                    # Recovery-Nachricht: LLM erhält klaren Hinweis was noch fehlt
                    _rec_hint = ""
                    if _explicit_file_request and not _file_actually_sent and _is_messenger_dialog:
                        _rec_hint = (
                            "\n\n[SYSTEM-KORREKTUR] Du hast im vorherigen Versuch BEHAUPTET eine Datei gesendet zu haben, "
                            "aber send_messenger_file wurde NIE aufgerufen! Das ist eine Halluzination. "
                            "🚨 Du MUSST jetzt sofort send_messenger_file aufrufen — die Datei existiert bereits im workspace. "
                            "Suche sie mit fs_find_files oder nutze den bekannten Pfad direkt. KEIN Erstellen mehr, NUR senden!"
                        )
                    else:
                        # Allgemeiner Recovery-Hint: Schritte aus dem ersten Versuch mitgeben,
                        # damit die LLM nicht von vorne beginnt sondern auf dem Ergebnis aufbaut.
                        _prev_steps = resp_local.get("steps") or []
                        if _prev_steps:
                            _step_summary = []
                            for _ps in _prev_steps[:8]:
                                if isinstance(_ps, dict):
                                    _ps_kind = _ps.get("kind", "")
                                    _ps_ok = _ps.get("ok", False)
                                    _ps_result = str(_ps.get("result") or _ps.get("reply") or "")[:200]
                                    _step_summary.append(f"- {_ps_kind} (ok={_ps_ok}): {_ps_result}")
                            if _step_summary:
                                # Prüfe ob Schritte große gespeicherte Dateien erzeugt haben
                                _saved_files = []
                                for _ps in _prev_steps:
                                    if isinstance(_ps, dict):
                                        _r = str(_ps.get("result") or _ps.get("reply") or "")
                                        import re as _re_hint
                                        _fm = _re_hint.search(r'gespeichert[:\s]+([A-Za-z]:[^\s\n,]+|data/[^\s\n,]+)', _r)
                                        if _fm:
                                            _saved_files.append(_fm.group(1))
                                _file_hint = ""
                                if _saved_files:
                                    _file_hint = (
                                        "\n🔑 WICHTIG: Folgende Dateien wurden gespeichert weil die Ausgabe zu groß war. "
                                        "Lese sie mit fs_read_file um den Inhalt zu verarbeiten:\n"
                                        + "\n".join(f"  - {f}" for f in _saved_files)
                                        + "\n"
                                    )
                                _rec_hint = (
                                    "\n\n[KONTEXT AUS VORHERIGEM VERSUCH] Folgende Schritte wurden bereits ausgeführt:\n"
                                    + "\n".join(_step_summary)
                                    + _file_hint
                                    + "\n\nDie Aufgabe ist NOCH NICHT abgeschlossen. "
                                    "Führe NUR die fehlenden Schritte durch. "
                                    "Verwende bereits heruntergeladene/gespeicherte Dateien statt neu zu suchen. "
                                    "Wenn ein Tool 'Output zu groß, gespeichert unter X' meldet → lese X mit fs_read_file. "
                                    "WICHTIG: Behalte denselben technischen Ansatz wie im vorherigen Versuch bei. "
                                    "Python-Module via sys_python_exec + sys.executable installieren/ausführen, "
                                    "NICHT via sys_shell_command 'python -m ...' (falsches Python)."
                                )
                    rec = _execute_react_loop(
                        message=message + _rec_hint if _rec_hint else message,
                        cfg=cfg,
                        dialog_key=dialog_key,
                        max_iterations=rec_max_iter,
                        trace_id=tid,
                        reset_plan=False,  # Plan aus dem ersten Loop NICHT überschreiben!
                        images=images or None,
                    )
                    if isinstance(rec, dict) and str(rec.get("reply", "")).strip():
                        _rec_reply = str(rec.get("reply", "") or "").strip()
                        # Guard: Recovery-Antwort "Abgeschlossen." (oder trivial kurz) nicht übernehmen.
                        # Das ist das Symptom wenn das LLM keine echte Antwort hat (z.B. Output in Datei
                        # gespeichert aber nicht gelesen). Original-Antwort ist besser als leere Hülle.
                        _TRIVIAL_REPLIES = {"abgeschlossen.", "abgeschlossen", "erledigt.", "erledigt", "done.", "done"}
                        if _rec_reply.lower() in _TRIVIAL_REPLIES or len(_rec_reply) < 20:
                            _audit_event("strict_verify_trivial_recovery_guard",
                                         {"note": f"Recovery-Antwort trivial ({repr(_rec_reply[:40])}) — Original beibehalten"})
                        else:
                            resp_local = dict(rec)
                            stage = "strict_verify_recovery"
                        reply_text = str(resp_local.get("reply", "") or "")
                        # Post-Recovery-Check: Wurde die Datei JETZT wirklich gesendet?
                        # Nur relevant für Messenger-Dialoge (Telegram/Discord) — WebUI braucht keinen Versand.
                        if _explicit_file_request and not _file_actually_sent and _is_messenger_dialog:
                            _rec_steps = resp_local.get("steps") or []
                            _file_sent_in_recovery = any(
                                isinstance(_s, dict)
                                and _s.get("kind") == "send_messenger_file"
                                and bool(_s.get("ok"))
                                for _s in _rec_steps
                            )
                            if not _file_sent_in_recovery:
                                # Recovery hat Datei auch nicht gesendet → Fehler zurückmelden
                                resp_local["ok"] = False
                                resp_local["reply"] = (
                                    "⚠️ Fehler: Die Datei konnte nicht versendet werden. "
                                    "Bitte versuche es erneut oder weise mich explizit an."
                                )
                                stage = "strict_verify_failed"
                                reply_text = resp_local["reply"]
                    else:
                        resp_local["ok"] = False
                        resp_local["reply"] = "Aufgabe nicht abgeschlossen; automatischer Recovery-Versuch blieb ohne verwertbares Ergebnis."
                        stage = "strict_verify_failed"
                        reply_text = str(resp_local.get("reply", "") or "")
                except Exception as _strict_exc:
                    resp_local["ok"] = False
                    resp_local["reply"] = f"Aufgabe nicht abgeschlossen; Recovery-Fehler: {_strict_exc}"
                    stage = "strict_verify_error"
                    reply_text = str(resp_local.get("reply", "") or "")
                finally:
                    _strict_verify_guard["running"] = False
            if not reply_text.strip():
                if bool(resp_local.get("ok", False)):
                    if stage in {"llm", "llm_hard_fallback", "llm_direct", "hybrid_direct"}:
                        reply_text = "Die Anfrage wurde verarbeitet, aber es wurde keine Textantwort erzeugt. Bitte sende die letzte Anweisung erneut."
                    else:
                        reply_text = "Erledigt."
                else:
                    reply_text = "Aktion fehlgeschlagen ohne Fehlermeldung. Bitte erneut versuchen."
                resp_local["reply"] = reply_text
                _audit_event(
                    "empty_reply_fallback",
                    {
                        "stage": stage,
                        "source": source,
                        "dialog_key": dialog_key,
                        "ok": bool(resp_local.get("ok", False)),
                    },
                )
            _append_failure_summary_if_missing()
            payload = {
                "ok": bool(resp_local.get("ok", False)),
                "stage": stage,
                "reply_preview": str(resp_local.get("reply", ""))[:240],
                "source": source,
                "dialog_key": dialog_key,
            }
            if isinstance(extra, dict):
                payload.update(extra)
            _audit_event("response", payload)
            skip_persist = bool(
                stage == "memory_commands"
                and ("Gedächtnis gelöscht (alles):" in reply_text or "Gedaechtnis geloescht (alles):" in reply_text)
            )
            _persist_response_async(stage, str(resp_local.get("reply", "")), skip_persist)
            
            # Globales Gedaechtnis-Update triggern (asynchron)
            try:
                final_steps = list(resp_local.get("steps", []) or _runtime_steps or [])
                def _bg_summarize():
                    _summarize_and_update_session(cfg, message, final_steps, str(resp_local.get("reply", "")))
                threading.Thread(target=_bg_summarize, daemon=True, name=f"KAI-summary-{tid[:8]}").start()
            except Exception:
                pass

            # Plan nach completed verschieben wenn Aufgabe erfolgreich
            if _plan_path and bool(resp_local.get("ok", False)):
                try:
                    plan_p = Path(_plan_path)
                    _plan_p_parts = plan_p.parts
                    _plan_in_active = (
                        "plans" in _plan_p_parts
                        and "active" in _plan_p_parts
                        and _plan_p_parts.index("active") == _plan_p_parts.index("plans") + 1
                    ) or "plans/active/" in str(plan_p).replace("\\", "/")
                    if plan_p.exists() and _plan_in_active:
                        completed_dir = plan_p.parent.parent / "completed"
                        completed_dir.mkdir(parents=True, exist_ok=True)
                        completed_path = completed_dir / plan_p.name
                        plan_p.rename(completed_path)
                        tool_store.log("plan_moved_to_completed", f"Plan verschoben: {_plan_path} -> {completed_path}")
                        _audit_event("plan_completed", {"plan_path": str(completed_path)})
                except Exception as plan_move_err:
                    tool_store.log("plan_move_error", f"Plan-Verschiebung fehlgeschlagen: {plan_move_err}")

            # OPT-M5: Plan-Archive nur nach ReAct-Loop-Abschluss prüfen,
            # NICHT nach jeder einfachen LLM-Antwort.
            # Vorher: Glob + Read aller .md-Dateien bei JEDER Response!
            _react_stages = {
                "react_loop_ok", "react_plan_ok", "react_loop_partial",
                "cli_core_react_loop_ok", "strict_verify_recovery",
            }
            if stage in _react_stages:
                try:
                    _active_plans_dir = Path(workspace) / "plans" / "active"
                    if _active_plans_dir.exists():
                        for _llm_plan_file in list(_active_plans_dir.glob("*.md")):
                            try:
                                _plan_content_check = _llm_plan_file.read_text(encoding="utf-8", errors="replace")
                                _has_open_tasks = "- [ ]" in _plan_content_check
                                if _has_open_tasks:
                                    tool_store.log("plan_auto_archive_skipped", f"Plan hat offene Tasks, bleibt in active/: {_llm_plan_file.name}")
                                    continue
                                _llm_completed_dir = _llm_plan_file.parent.parent / "completed"
                                _llm_completed_dir.mkdir(parents=True, exist_ok=True)
                                _llm_completed_path = _llm_completed_dir / _llm_plan_file.name
                                _llm_plan_file.rename(_llm_completed_path)
                                tool_store.log("plan_auto_archived", f"LLM-Plan auto-archiviert: {_llm_plan_file.name}")
                                _audit_event("plan_auto_archived", {"plan": _llm_plan_file.name})
                            except Exception:
                                pass
                except Exception:
                    pass


            out = dict(resp_local)
            out["trace_id"] = tid
            return out

        cancelled = _cancelled_reply("vor Start")
        if cancelled:
            return _ret(cancelled, "cancelled")

        _audit_event("request", {"source": source, "dialog_key": dialog_key, "message": str(message)[:500]})
        # Normalize slash commands centrally so WebUI/API and Messenger behave identically.
        raw_msg = raw_user_input.strip()
        # State-driven follow-up: if previous turn requested a path and user now sends only a path,
        # merge it into the pending operational query.
        with contextlib.suppress(Exception):
            p_only = _extract_any_path(raw_msg)
            if p_only and str(p_only).strip() == raw_msg:
                pending_query = _consume_pending_path_request(dialog_key)
                if pending_query:
                    raw_msg = f'{pending_query} in "{p_only}"'
                    message = raw_msg # Update full message as well so LLM sees the follow-up
        if raw_msg.startswith("/"):
            mapped_cmd = _map_standalone_command(raw_msg)
            if mapped_cmd == "__status__":
                return _ret({"ok": True, "reply": _status_text(cfg)}, "status_cmd")
            if mapped_cmd and mapped_cmd != "__session_reset__":
                raw_msg = mapped_cmd
                message = mapped_cmd # Also override full message for the rest of pipeline
        # Must run before follow-up augmentation/rewrites.
        early_save_loc = _handle_last_save_location_query(raw_msg, cfg)
        if early_save_loc:
            return _ret(early_save_loc, "last_save_location")
        early_save_status = _handle_last_save_status_query(raw_msg, cfg)
        if early_save_status:
            return _ret(early_save_status, "last_save_status")
        cron_action = _cron_action_from_text(raw_msg)
        if isinstance(cron_action, dict):
            cron_res = _run_virtual_action(cfg, raw_msg, cron_action, note="cron_cmd", dialog_key=dialog_key)
            return _ret({"ok": bool(cron_res.get("ok", False)), "reply": str(cron_res.get("reply", ""))}, "cron")
        skill_cmd = _skill_commands(raw_msg)
        if isinstance(skill_cmd, dict):
            return _ret(skill_cmd, "skills_cmd")
        # Active memory/secret dialogs must be resolved before any LLM/tool routing.
        memory_cmd_early = _handle_memory_commands(raw_msg, cfg, dialog_key=dialog_key)
        if memory_cmd_early:
            return _ret(memory_cmd_early, "memory_commands")
        secret_cmd_early = _handle_secret_commands(raw_msg, cfg, dialog_key=dialog_key)
        if secret_cmd_early:
            return _ret(secret_cmd_early, "secret_store")
        # Explicit skill syntax should run on raw user text before any rewrite.
        if not _looks_like_cron_request_text(raw_msg):
            explicit_skill_action, explicit_skill_err = _parse_explicit_skill_action(raw_msg)
            if explicit_skill_err:
                return _ret({"ok": False, "reply": explicit_skill_err}, "skill_tool_clarify")
            if isinstance(explicit_skill_action, dict):
                result = _run_llm_planned_action(
                    cfg=cfg,
                    message=raw_msg,
                    action=explicit_skill_action,
                    note=f"explicit_skill_action_raw:{explicit_skill_action.get('kind', '')}",
                    dialog_key=dialog_key,
                )
                if isinstance(result, dict):
                    stage = "llm_action_ok" if bool(result.get("ok", False)) else "llm_action_error"
                    return _ret(result, stage)
        si_action = _self_improve_action_from_text(raw_msg)
        if si_action == "reports":
            m_lim = re.search(r"(?:/selfimprove|/self-improve|selfimprove)\s+reports\s+(\d{1,2})", str(raw_msg or "").lower())
            lim = int(m_lim.group(1)) if m_lim else 10
            txt = _self_improve_reports_overview(limit=lim)
            return _ret({"ok": True, "reply": txt}, "self_improve_reports")
        if si_action == "quick":
            rep = _self_improve_small_report(cfg)
            txt = _self_improve_report_to_text(rep)
            return _ret({"ok": True, "reply": txt}, "self_improve_quick")
        if si_action == "deep":
            rep = _self_improve_deep_report(cfg)
            txt = _self_improve_report_to_text(rep)
            return _ret({"ok": True, "reply": txt}, "self_improve_deep")
        if si_action == "diagnose":
            out = _handle_self_improve_request("Selbstverbesserung ausfuehren", cfg)
            if isinstance(out, dict):
                return _ret({"ok": bool(out.get("ok", False)), "reply": str(out.get("reply", ""))}, "self_improve_diagnose")

        if _cli_core_enabled(cfg) and (not _is_approval_answer(message)) and _looks_operational_request(message):
            core_cfg = _cli_core_cfg(cfg)
            core_message = _maybe_enrich_missing_operational_path(
                cfg=cfg,
                message=message,
                interpretation=None,
                signals=None,
                dialog_key=dialog_key,
            )
            rec = _execute_react_loop(
                message=core_message,
                cfg=cfg,
                dialog_key=dialog_key,
                max_iterations=int(core_cfg.get("max_iterations", 50)),
                images=images or None,
            )
            if dialog_key:
                try:
                    from app.dialogue_engine import on_react_loop_complete as _de_complete_core
                    _de_steps_core = rec.get("steps", []) if isinstance(rec.get("steps"), list) else []
                    _de_complete_core(dialog_key, rec.get("ok", False), str(rec.get("reply", "")), _de_steps_core)
                except Exception:
                    pass
            if bool(rec.get("ok", False)) and not bool(rec.get("partial", False)):
                return _ret(rec, "cli_core_react_loop_ok")
            return _ret(rec, "cli_core_react_loop_partial")

        # ── ReAct wird nach _build_task_state ausgeführt (LLM-first, siehe unten) ──

        routing_cfg = cfg.get("routing", {}) if isinstance(cfg.get("routing", {}), dict) else {}
        llm_first = bool(routing_cfg.get("llm_first", False))
        det_fallback = bool(routing_cfg.get("deterministic_fallback", False))
        heuristics_enabled = bool(routing_cfg.get("heuristics_enabled", False))
        allow_pre_filters = heuristics_enabled and ((not llm_first) or det_fallback)

        if allow_pre_filters:
            normalized_map = _normalize_network_map_request(message)
            # Compound-Nachrichten NICHT normalisieren – sie müssen vollständig
            # an den ReAct-Planner übergeben werden.
            if normalized_map != message and not _is_multi_step_request(message):
                message = normalized_map
                _audit_event("network_map_normalized", {"dialog_key": dialog_key, "mapped": message[:240]})
        subst_direct = bool(
            _has_any(str(message or "").lower(), ["subst"])
            and _has_any(str(message or "").lower(), ["laufwerk", "drive"])
        )
        if allow_pre_filters and subst_direct and not _is_approval_answer(message):
            direct_fs = _handle_filesystem_request(message, cfg, dialog_key=dialog_key)
            if direct_fs is not None:
                return _ret(direct_fs, "filesystem", {"forced_subst_direct": True})
        if not _is_approval_answer(message):
            # Seed network context from the current user message so reconnect
            # follow-ups ("verbinde es wieder") keep UNC + drive reliably.
            unc_msg_pre = _extract_unc_from_text(message)
            drive_msg_seed = _extract_drive_letter(message)
            msg_low_pre = str(message or "").lower()
            has_reconnect_hint = bool(
                _has_any(msg_low_pre, ["verbindung", "verbinde", "trenne", "disconnect", "unmap", "mount", "map"])
                and (unc_msg_pre or drive_msg_seed)
            )
            if _is_network_map_or_unmap_message(message) or has_reconnect_hint:
                if unc_msg_pre or drive_msg_seed:
                    _set_session_network_ctx(
                        dialog_key,
                        unc=str(unc_msg_pre or ""),
                        drive=str(drive_msg_seed or ""),
                        awaiting_drive=False,
                    )
                    _audit_event(
                        "network_ctx_seed",
                        {
                            "dialog_key": dialog_key,
                            "has_unc": bool(unc_msg_pre),
                            "has_drive": bool(drive_msg_seed),
                        },
                    )
            net_ctx_pre = _get_session_network_ctx(dialog_key)
            awaiting_drive_pre = str(net_ctx_pre.get("awaiting_drive", "0")) == "1"
            unc_ctx_pre = str(net_ctx_pre.get("unc", "") or "").strip()
            drive_msg_pre = _extract_drive_letter(message)
            if awaiting_drive_pre and unc_ctx_pre and drive_msg_pre:
                message = f'verbinde die freigabe als laufwerk "{unc_ctx_pre}" als laufwerk {drive_msg_pre}'
                _set_session_network_ctx(dialog_key, unc=unc_ctx_pre, drive=drive_msg_pre, awaiting_drive=False)
                _audit_event(
                    "network_followup_mapped_pre",
                    {"dialog_key": dialog_key, "mapped": message[:240]},
                )

        if heuristics_enabled and (not _is_approval_answer(message)):
            pre_augmented = _augment_followup_with_llm_first(message, cfg, dialog_key=dialog_key)
            if pre_augmented != message:
                _audit_event("followup_preaugmented", {"orig": str(message)[:220], "augmented": str(pre_augmented)[:220], "dialog_key": dialog_key})
                message = pre_augmented
        # OPT-M2: Zweites Enrichment nur wenn erstes nichts vergaendert hat.
        if not _enriched_once:
            with contextlib.suppress(Exception):
                message = _maybe_enrich_missing_operational_path(
                    cfg=cfg,
                    message=message,
                    interpretation=None,
                    signals=detect_signals(message),
                    dialog_key=dialog_key,
                )

        tool_message = str(original_message)  # immer Original-Nachricht, nie normalisiert/umgeschrieben
        state = _build_task_state(message, cfg, source=source, dialog_key=dialog_key)
        message = state.message_working
        signals = state.signals or detect_signals(message)
        interpretation = state.interpretation
        interp_intent = ""
        interp_conf = 0.0
        if isinstance(interpretation, dict):
            interp_intent = str(interpretation.get("intent", "") or "").strip().lower()
            try:
                interp_conf = float(interpretation.get("confidence", 0.0) or 0.0)
            except Exception:
                interp_conf = 0.0
        # OPT-M3: Dritter Enrichment-Aufruf + zweiter _build_task_state (LLM-Call)
        # nur wenn die Nachricht sich tatsaechlich veraendert hat.
        with contextlib.suppress(Exception):
            if not _enriched_once:
                enriched2 = _maybe_enrich_missing_operational_path(
                    cfg=cfg,
                    message=message,
                    interpretation=interpretation if isinstance(interpretation, dict) else None,
                    signals=signals,
                    dialog_key=dialog_key,
                )
                if enriched2 != message:
                    message = enriched2
                    # OPT-M3: Zweiter _build_task_state (LLM-Call!) nur bei echter Aenderung.
                    state = _build_task_state(message, cfg, source=source, dialog_key=dialog_key)
                    message = state.message_working
                    signals = state.signals or detect_signals(message)
                    interpretation = state.interpretation
                    interp_intent = ""
                    interp_conf = 0.0
                    if isinstance(interpretation, dict):
                        interp_intent = str(interpretation.get("intent", "") or "").strip().lower()
                        with contextlib.suppress(Exception):
                            interp_conf = float(interpretation.get("confidence", 0.0) or 0.0)




        # ── ReAct Multi-Step Loop ─────────────────────────────────────────────
        # Das LLM entscheidet ob multi_step=yes basierend auf der Aufgabenkomplexität.
        llm_says_multi_step = isinstance(interpretation, dict) and str(interpretation.get("multi_step", "no")).lower() == "yes"

        react_attempted = False
        if (
            not _is_approval_answer(message)
            and _memory_dialog_get(dialog_key) is None
            and _secret_dialog_get(dialog_key) is None
            and llm_says_multi_step
        ):
            _audit_event("react_trigger", {
                "dialog_key": dialog_key,
                "message": message[:200],
                "llm_multi_step": llm_says_multi_step,
            })
            react_attempted = True
            
            # Config-Flag: Plan-First oder Loop?
            react_cfg = cfg.get("react", {}) if isinstance(cfg.get("react", {}), dict) else {}
            use_loop = bool(react_cfg.get("use_loop", True))  # Default: Loop als Fallback
            plan_first = bool(react_cfg.get("plan_first", True))
            
            if plan_first:
                tool_store.log("react_mode", "Using plan-first ReAct planner")
                react_steps = _llm_plan_react(tool_message, cfg, dialog_key=dialog_key)
                if react_steps:
                    result = _execute_react_plan_with_retry(message, react_steps, cfg, dialog_key=dialog_key)
                    stage = "react_plan_ok" if result.get("ok") else "react_plan_partial"
                    # Bei erfolgreicher Ausführung: LLM-Zusammenfassung erstellen
                    if result.get("ok") and not result.get("stage"):
                        try:
                            summary_prompt = f"""Nutzeranfrage: {message}

Ausgeführte Schritte und Ergebnisse:
{result.get("reply", "")}

Erstelle eine prägnante, menschenlesbare Zusammenfassung der Ergebnisse für den Nutzer.
Beantworte die ursprüngliche Anfrage basierend auf den Tool-Ergebnissen.
Wenn Bilder gefunden wurden, erwähne die wichtigsten.
Wenn Informationen gesammelt wurden, fasse sie zusammen."""
                            
                            router = LLMRouter(cfg)
                            summary_result = router.chat(prompt=summary_prompt)
                            summary_text = summary_result.text if hasattr(summary_result, "text") else str(summary_result)
                            
                            if summary_text and len(summary_text.strip()) > 20:
                                # Zusammenfassung + Rohdaten
                                result["reply"] = summary_text + "\n\n---\n**Technische Details:**\n" + result.get("reply", "")
                        except Exception as exc:
                            tool_store.log("react_summary_error", f"Fehler bei LLM-Zusammenfassung: {exc}")
                    
                    _persist_conversation(cfg, message, str(result.get("reply", "")), 0.85)
                    return _ret(result, stage)

            if use_loop:
                # ── NEUER ECHTER REACT-LOOP ──
                tool_store.log("react_mode", "Using iterative ReAct loop")
                # Iterationen: Dialogue Engine hat Vorrang, sonst WebUI-Wert (max_iterations aus ui_cfg)
                _react_loop_kwargs = {"plan_path": _plan_path}
                if _dialogue_max_iter is not None and _dialogue_max_iter > 0:
                    _react_loop_kwargs["max_iterations"] = _dialogue_max_iter
                elif max_iterations:
                    _react_loop_kwargs["max_iterations"] = max_iterations
                result = _execute_react_loop(message, cfg, dialog_key=dialog_key, trace_id=tid, intent=interp_intent, images=images or None, **_react_loop_kwargs)
                stage = "react_loop_ok" if result.get("ok") else "react_loop_partial"
                # Update dialogue engine working memory after react loop completes
                if dialog_key:
                    try:
                        from app.dialogue_engine import on_react_loop_complete as _de_complete
                        _de_steps = result.get("steps", []) if isinstance(result.get("steps"), list) else []
                        _de_complete(dialog_key, result.get("ok", False), str(result.get("reply", "")), _de_steps)
                    except Exception:
                        pass
                _persist_conversation(cfg, message, str(result.get("reply", "")), 0.85)
                return _ret(result, stage)

            if not plan_first:
                # ── ALTER REACT-PLANER (Fallback) ──
                tool_store.log("react_mode", "Using classic ReAct planner")
                react_steps = _llm_plan_react(tool_message, cfg, dialog_key=dialog_key)
                if react_steps:
                    result = _execute_react_plan_with_retry(message, react_steps, cfg, dialog_key=dialog_key)
                    stage = "react_plan_ok" if result.get("ok") else "react_plan_partial"
                    # Bei erfolgreicher Ausführung: LLM-Zusammenfassung erstellen
                    if result.get("ok") and not result.get("stage"):
                        try:
                            summary_prompt = f"""Nutzeranfrage: {message}

Ausgeführte Schritte und Ergebnisse:
{result.get("reply", "")}

Erstelle eine prägnante, menschenlesbare Zusammenfassung der Ergebnisse für den Nutzer.
Beantworte die ursprüngliche Anfrage basierend auf den Tool-Ergebnissen.
Wenn Bilder gefunden wurden, erwähne die wichtigsten.
Wenn Informationen gesammelt wurden, fasse sie zusammen."""
                            
                            router = LLMRouter(cfg)
                            summary_result = router.chat(prompt=summary_prompt)
                            summary_text = summary_result.text if hasattr(summary_result, "text") else str(summary_result)
                            
                            if summary_text and len(summary_text.strip()) > 20:
                                # Zusammenfassung + Rohdaten
                                result["reply"] = summary_text + "\n\n---\n**Technische Details:**\n" + result.get("reply", "")
                        except Exception as exc:
                            tool_store.log("react_summary_error", f"Fehler bei LLM-Zusammenfassung: {exc}")
                    
                    _persist_conversation(cfg, message, str(result.get("reply", "")), 0.85)
                    return _ret(result, stage)
            # ReAct-Planner hat keine Steps geliefert → deterministischer Fallback
            _fallback_steps = decompose_compound_steps(tool_message)
            if _fallback_steps:
                _fb_result = _execute_compound_pipeline(_fallback_steps, cfg, dialog_key=dialog_key)
                return _ret(_fb_result, "filesystem", {"compound_pipeline_fallback": True})
        # ── Ende ReAct Planner ────────────────────────────────────────────────
        routing_cfg_local = cfg.get("routing", {}) if isinstance(cfg.get("routing", {}), dict) else {}
        routing_cfg = cfg.get("routing", {}) if isinstance(cfg.get("routing", {}), dict) else {}
        llm_first = bool(routing_cfg.get("llm_first", False))
        det_fallback = bool(routing_cfg.get("deterministic_fallback", False))
        try:
            fallback_threshold = float(routing_cfg.get("fallback_confidence_threshold", 0.55) or 0.55)
        except Exception:
            fallback_threshold = 0.55
        forced_intent = ""
        should_use_deterministic = not llm_first
        if llm_first and det_fallback:
            # Emergency fallback only when LLM did not choose a concrete action intent.
            llm_has_action_intent = interp_intent in {
                "filesystem",
                "script",
                "cron",
                "answer_and_save",
                "memory_query",
                "help",
                "clear_context",
            }
            if (not llm_has_action_intent) and _looks_operational_request(message, signals):
                llm_has_action_intent = True
            should_use_deterministic = (not llm_has_action_intent) and ((interp_intent in {"", "unknown", "chat"}) or (interp_conf < fallback_threshold))
        if should_use_deterministic:
            forced_intent = _deterministic_tool_intent(message, cfg)
            if not forced_intent and _looks_operational_request(message, signals):
                forced_intent = "filesystem"
        operational_mode = forced_intent in {"filesystem", "script", "cron"}
        _audit_event(
            "routing_decision",
            {
                "llm_first": llm_first,
                "deterministic_fallback": det_fallback,
                "fallback_threshold": fallback_threshold,
                "interp_intent": interp_intent,
                "interp_conf": interp_conf,
                "forced_intent": forced_intent,
                "operational_mode": operational_mode,
            },
        )
        if operational_mode:
            # Keep original user command text for deterministic tool execution,
            # but preserve path-enriched working text when it adds a missing path.
            if forced_intent == "filesystem":
                orig_has_path = bool(_extract_any_path(tool_message))
                working_has_path = bool(_extract_any_path(state.message_working))
                if (not orig_has_path) and working_has_path:
                    message = state.message_working
                else:
                    message = tool_message
            else:
                message = tool_message
            signals = detect_signals(message)
        if forced_intent:
            forced_steps: List[str] = []
            if forced_intent == "filesystem":
                forced_steps = ["filesystem", "llm"]
            elif forced_intent == "script":
                forced_steps = ["script_memory", "script_create", "script_exec", "filesystem", "llm"]
            elif forced_intent == "cron":
                forced_steps = ["filesystem", "llm"]
            if forced_steps:
                merged: List[str] = []
                for s in forced_steps + list(state.steps or []):
                    if s and s not in merged:
                        merged.append(s)
                state.steps = merged
        if allow_pre_filters and _is_network_map_or_unmap_message(message):
            merged: List[str] = []
            for s in ["filesystem", "llm"] + list(state.steps or []):
                if s and s not in merged:
                    merged.append(s)
            state.steps = merged
        if not _is_approval_answer(message):
            net_ctx = _get_session_network_ctx(dialog_key)
            awaiting_drive = str(net_ctx.get("awaiting_drive", "0")) == "1"
            unc_ctx = str(net_ctx.get("unc", "") or "").strip()
            drive_msg = _extract_drive_letter(message)
            if awaiting_drive and unc_ctx and drive_msg:
                message = f'verbinde die freigabe als laufwerk "{unc_ctx}" als laufwerk {drive_msg}'
                signals = detect_signals(message)
                _set_session_network_ctx(dialog_key, unc=unc_ctx, drive=drive_msg, awaiting_drive=False)
                _audit_event(
                    "network_followup_mapped",
                    {"dialog_key": dialog_key, "mapped": message[:240]},
                )
        _audit_event(
            "task_state",
            {
                "message_working": str(message)[:500],
                "steps": state.steps,
                "factual_domain": state.factual_domain,
                "needs_verification": state.needs_verification,
                "interpretation": interpretation or {},
            },
        )
        _runtime_interp = dict(interpretation) if isinstance(interpretation, dict) else {}
        _runtime_steps = list(state.steps or [])
        _runtime_action_intent_expected = bool(
            interp_intent in {"filesystem", "script", "cron", "answer_and_save"}
            and interp_conf >= _intent_threshold(cfg, interp_intent)
        )
        if (not _runtime_action_intent_expected) and _looks_operational_request(message, signals):
            _runtime_action_intent_expected = True
        # Save-path source selection:
        # prefer original user text, but if it has no explicit target path and the
        # follow-up/LLM rewrite added one, use the enriched message for save routing.
        save_target_message = raw_msg
        with contextlib.suppress(Exception):
            if not _extract_requested_save_path(str(save_target_message or "")):
                msg_with_path = str(message or "")
                if _extract_requested_save_path(msg_with_path):
                    save_target_message = msg_with_path
        if isinstance(interpretation, dict):
            _clarif_intent = str(interpretation.get("intent", "") or "").strip()
            # Fuer operative Intents nicht sofort mit Rueckfrage abbrechen.
            # Erst aktive Aufloesung versuchen (Memory/Facts, Netzlaufwerke, MCP/Dynamic/Filesystem-Tools).
            _entities = interpretation.get("entities", {}) if isinstance(interpretation.get("entities", {}), dict) else {}
            _ent_path = str(_entities.get("path", "") or "").strip()
            _skip_clarif = _clarif_intent in ("script", "multi_step", "filesystem")
            if _clarif_intent == "filesystem" and (not _ent_path):
                with contextlib.suppress(Exception):
                    _audit_event(
                        "clarification_deferred",
                        {"intent": "filesystem", "reason": "try_auto_resolution_first", "dialog_key": dialog_key},
                    )
            _msg_low = str(message or "").lower()
            _unknown_placeholder_followup = (
                _clarif_intent == "unknown"
                and bool(interpretation.get("needs_clarification", False))
                and (
                    _has_any(_msg_low, ["folgenden pfad", "diesen pfad", "den pfad", "nimm folgenden", "verwende den", "nutze den"])
                    or (
                        _has_any(_msg_low, ["folgenden", "diesen", "den"])
                        and not bool(_extract_any_path(message))
                    )
                )
            )
            if (
                (not _skip_clarif)
                and bool(interpretation.get("needs_clarification", False))
                and (
                    float(interpretation.get("confidence", 0.0) or 0.0) >= 0.72
                    or _unknown_placeholder_followup
                )
            ):
                q = str(interpretation.get("clarification_question", "") or "").strip()
                if q:
                    op_req = _looks_operational_request(message, signals)
                    if op_req:
                        # Operative Aufgaben nicht mit sofortiger Rueckfrage abbrechen:
                        # erst Auto-Aufloesung/Toolversuch erzwingen.
                        if not _extract_any_path(message):
                            mem_path = _memory_path_candidate(cfg, message, dialog_key=dialog_key)
                            if mem_path:
                                message = f'{message} in "{mem_path}"'
                            else:
                                _set_pending_path_request(dialog_key, str(message or ""))
                        _audit_event(
                            "clarification_suppressed",
                            {"intent": _clarif_intent, "reason": "operational_try_first", "dialog_key": dialog_key},
                        )
                        # Kein return -> normaler Tool/Loop-Pfad.
                        pass
                    else:
                    # Erst Gedächtnis prüfen – wenn relevante Einträge vorhanden, Rückfrage überspringen
                        _mem_hits: List[Dict[str, Any]] = []
                        with contextlib.suppress(Exception):
                            _mem_hits = _memory_store(cfg).search(message, limit=3, min_similarity=0.52)
                        if _mem_hits:
                            # Relevante Facts in die Nachricht einbetten damit der Handler sie nutzen kann
                            _mem_ctx = "\n".join(
                                f"[Gedächtnis: {h['content'][:200]}]"
                                for h in _mem_hits[:2]
                            )
                            message = f"{message}\n{_mem_ctx}"
                        else:
                            if _looks_operational_request(message) and (not _extract_any_path(message)):
                                mem_path = _memory_path_candidate(cfg, message, dialog_key=dialog_key)
                                if mem_path:
                                    message = f'{message} in "{mem_path}"'
                                    # Continue normal flow with enriched path, no clarification return.
                                else:
                                    _set_pending_path_request(dialog_key, str(message or ""))
                                    _set_pending_question(dialog_key, q)
                                    return _ret({"ok": True, "reply": q}, "clarification")
                            else:
                                _set_pending_question(dialog_key, q)
                                return _ret({"ok": True, "reply": q}, "clarification")

        mapped_drive_followup = _augment_session_drive_followup(message, cfg, dialog_key)
        if mapped_drive_followup != message:
            message = mapped_drive_followup
            state = _build_task_state(message, cfg, source=source, dialog_key=dialog_key)
            signals = state.signals or detect_signals(message)
            interpretation = state.interpretation

        drive_status = _handle_drive_status_query(message, cfg, dialog_key)
        if drive_status:
            return _ret(drive_status, "drive_status")
        drive_letter_info = _handle_drive_letter_query(message, dialog_key)
        if drive_letter_info:
            return _ret(drive_letter_info, "drive_letter_status")

        secret_cmd_early = _handle_secret_commands(message, cfg, dialog_key=dialog_key)
        if secret_cmd_early:
            return _ret(secret_cmd_early, "secret_store")

        # Context follow-up must run early to keep long conversation chains stable.
        eager_context_followup = _handle_context_followup_queries(message, cfg)
        if eager_context_followup:
            return _ret(eager_context_followup, "context_followup_eager")

        # Save follow-up status/location must be answered before tool routing
        # so phrases like "hast du das geschrieben?" are not re-routed as Gmail/file actions.
        save_loc_early = _handle_last_save_location_query(message, cfg)
        if save_loc_early:
            return _ret(save_loc_early, "last_save_location")
        save_status_early = _handle_last_save_status_query(message, cfg)
        if save_status_early:
            return _ret(save_status_early, "last_save_status")

        # LLM-first bridge for mixed Gmail+save intents:
        # if interpretation already says answer_and_save and the query is Gmail-list-like,
        # run Gmail tool first, then save exact tool output.
        if not forced_intent and isinstance(interpretation, dict):
            interp_now = str(interpretation.get("intent", "") or "").strip().lower()
            if interp_now == "answer_and_save":
                ents = interpretation.get("entities", {}) if isinstance(interpretation.get("entities", {}), dict) else {}
                q_hint = str(ents.get("query", "") or "").strip()
                gmail_probe = q_hint or str(message or "")
                gmail_action, gmail_err = _gmail_action_from_text(gmail_probe)
                if isinstance(gmail_action, dict) and str(gmail_action.get("kind", "")).strip().lower() == "gmail_list_messages":
                    g_res = _run_llm_planned_action(
                        cfg=cfg,
                        message=message,
                        action=gmail_action,
                        note="llm_first_answer_and_save_gmail",
                        dialog_key=dialog_key,
                    )
                    if isinstance(g_res, dict) and bool(g_res.get("ok", False)) and str(g_res.get("reply", "")).strip():
                        save_q = _extract_query_without_save(message) or q_hint or "gmail_mails"
                        s_res = _save_text_to_requested_target(
                            cfg,
                            original_message=save_target_message,
                            query_for_name=save_q,
                            text_content=str(g_res.get("reply", "")),
                            dialog_key=dialog_key,
                        )
                        if bool(s_res.get("ok", False)):
                            reply = str(g_res.get("reply", "")).rstrip() + "\n\n" + str(s_res.get("reply", "")).strip()
                            return _ret({"ok": True, "reply": reply}, "llm_action_ok")
                        return _ret({"ok": False, "reply": str(s_res.get("reply", "")).strip()}, "llm_action_error")
                elif gmail_err:
                    return _ret({"ok": False, "reply": gmail_err}, "skill_tool_clarify")

        is_approval = _is_approval_answer(message)
        has_pending = False
        skip_llm_action = is_approval and has_pending

        # Workspace-Listing vor LLM abfangen: "Liste Dateien/Ordner in data\workspace"
        _msg_low_ws = str(message or "").lower()
        _ws_list = bool(
            re.search(r"\b(liste\w*|auflisten|zeige\w*|zeig\w*)\b", _msg_low_ws)
            and _has_any(_msg_low_ws, ["workspace", "arbeitsverzeichnis", "data\\workspace", "data/workspace"])
        )
        if _ws_list and not skip_llm_action:
            _ws_result = _handle_filesystem_request(message, cfg, dialog_key=dialog_key)
            if isinstance(_ws_result, dict) and _ws_result.get("reply"):
                return _ret(_ws_result, "filesystem")

        # DIREKTE LLM-STEUERUNG: Wie ich (das LLM) direkt entscheide
        # Keine Intent-Zwischenschicht - das LLM entscheidet selbst was zu tun ist
        direct_result = None
        _skip_intents = {"script", "cron", "filesystem", "unknown", ""}
        skip_direct_llm = interpretation and str(interpretation.get("intent", "")).lower() in _skip_intents
        if not skip_llm_action and not skip_direct_llm:
            direct_result = _llm_direct_decide_and_act(cfg, message)
        if direct_result:
            return _ret(direct_result, "llm_direct")

        # HYBRIDE LÖSUNG: Direkte Execution bei klarem Intent
        # Prüfe zuerst ob wir direkt ausführen können (ohne Agentic-Overhead)
        if not skip_llm_action:
            _audit_event("hybrid_start", {"message": message[:100], "interpretation": str(interpretation)[:200] if interpretation else "None"})
            direct_result = _try_direct_execution(message, interpretation, cfg, dialog_key)
            _audit_event("hybrid_result", {"direct_result": str(direct_result)[:200] if direct_result else "None"})
            if direct_result:
                return _ret(direct_result, "hybrid_direct")
        
        # Prüfe immer auf answer_and_save (auch bei llm_first=True)
        if not skip_llm_action and not forced_intent and interp_intent != "script":
            if _wants_save_output(message) or _is_answer_and_save_request(message):
                eager_answer_save = _handle_answer_and_save_request(message, cfg)
                if eager_answer_save:
                    return _ret(eager_answer_save, "answer_and_save_eager")

        # LLM-first Tool-Call: if the model can produce a valid executable action,
        # execute it before deterministic handlers.
        single_step_enabled = bool(cfg.get("react", {}).get("single_step_enabled", True))
        if single_step_enabled and not skip_llm_action and not forced_intent:
            interp_for_plan = interpretation if isinstance(interpretation, dict) else None
            if interp_for_plan is None and llm_first:
                with contextlib.suppress(Exception):
                    interp_for_plan = _llm_interpret_message(cfg, message, signals if isinstance(signals, ReasoningSignals) else detect_signals(message))
            
            # Patch 18: Tool-Selection VOR Action-Generierung
            # LLM wählt explizit das beste Tool für die Anfrage
            selected_tool: Optional[str] = None
            if isinstance(interp_for_plan, dict):
                plan_intent = str(interp_for_plan.get("intent", "") or "").strip().lower()
                
                # Tool-Selection: no-op (Webtools entfernt)
            try:
                llm_plan_timeout_sec = int(routing_cfg_local.get("llm_action_plan_timeout_sec", 45) or 45)
            except Exception:
                llm_plan_timeout_sec = 45
            llm_plan_timeout_sec = max(5, min(180, llm_plan_timeout_sec))
            _to, _planned_out, _planned_err = _run_with_timeout(
                llm_plan_timeout_sec,
                lambda: _llm_plan_action(cfg, message, interp_for_plan),
            )
            if _to:
                _audit_event(
                    "llm_action_plan_timeout",
                    {"timeout_sec": llm_plan_timeout_sec, "message": str(message)[:220], "dialog_key": dialog_key},
                )
                planned = None
            elif _planned_err is not None:
                with contextlib.suppress(Exception):
                    tool_store.log("llm_action_plan_error", str(_planned_err)[:220])
                planned = None
            else:
                planned = _planned_out
            if isinstance(planned, dict):
                if bool(planned.get("needs_clarification", False)):
                    q = str(planned.get("clarification_question", "") or "").strip()
                    if q:
                        _set_pending_question(dialog_key, q)
                        return _ret({"ok": True, "reply": q}, "llm_action_clarify")
                planned_actions_raw = planned.get("actions")
                planned_actions = [dict(x) for x in planned_actions_raw if isinstance(x, dict)] if isinstance(planned_actions_raw, list) else []
                if not planned_actions:
                    one = planned.get("action")
                    if isinstance(one, dict):
                        planned_actions = [dict(one)]
                if planned_actions:
                    base_note = str(planned.get("note", "") or "").strip() or "LLM-Action-Plan"
                    step_replies: List[str] = []
                    step_results: List[Dict[str, Any]] = []
                    all_ok = True
                    failed_reason = ""
                    for idx, raw_action in enumerate(planned_actions, start=1):
                        resolved_action = _prepare_planned_action_for_step(raw_action, step_replies)
                        step_note = f"{base_note} [step {idx}/{len(planned_actions)}:{resolved_action.get('kind','')}]"
                        result = _run_llm_planned_action(
                            cfg=cfg,
                            message=message,
                            action=resolved_action,
                            note=step_note,
                            dialog_key=dialog_key,
                        )
                        if not isinstance(result, dict):
                            result = {"ok": False, "reply": "Leere Action-Antwort."}
                        step_results.append(result)
                        rep = str(result.get("reply", "") or "").strip()
                        step_replies.append(rep)
                        if bool(result.get("partial", False)):
                            all_ok = False
                            failed_reason = str(result.get("outcome", "partial"))
                            break
                        if not bool(result.get("ok", False)):
                            all_ok = False
                            failed_reason = str(result.get("outcome", "failed"))
                            break
                    # Always verify if the task is really solved, even when steps are technically "ok".
                    if all_ok and step_replies:
                        self_check = _llm_self_check_solved(cfg, message, "\n".join(step_replies[-3:]))
                        if not bool(self_check.get("solved", False)):
                            all_ok = False
                            failed_reason = "self_check_unsolved"
                            hint = str(self_check.get("next_action_hint", "") or "").strip()
                            if hint:
                                step_replies.append(f"Selbstpruefung: {hint}")
                            _audit_event(
                                "llm_self_check_unsolved",
                                {
                                    "reason": str(self_check.get("reason", "") or ""),
                                    "confidence": float(self_check.get("confidence", 0.0) or 0.0),
                                },
                            )
                    # Generic self-heal: if first attempt is failed/partial, try one alternative plan.
                    if (not all_ok) and planned_actions and (len(planned_actions) <= 6):
                        fail_text = str(step_replies[-1] if step_replies else "").strip()
                        recovery_prompt = (
                            f"{message}\n\n"
                            "Vorheriger Versuch war nicht ausreichend geloest.\n"
                            f"Grund: {failed_reason or 'failed_or_partial'}\n"
                            f"Letzte Observation: {fail_text[:600]}\n\n"
                            "Erzeuge jetzt einen ALTERNATIVEN Plan mit anderer Strategie. "
                            "Wenn Dateisuche/Filesystem nicht reicht: nutze zuerst bestehende MCP-Tools, "
                            "danach shell_command/shell_command/shell_command, dann MCP-Registry. "
                            "script_exec nur als spaeten Fallback; Laufzeit wird global ueber den Script-Timeout gesteuert."
                        )
                        _rto, _rplan_out, _rplan_err = _run_with_timeout(
                            llm_plan_timeout_sec,
                            lambda: _llm_plan_action(
                                cfg,
                                recovery_prompt,
                                interp_for_plan if isinstance(interp_for_plan, dict) else None,
                            ),
                        )
                        if _rto:
                            _audit_event(
                                "llm_action_recovery_plan_timeout",
                                {"timeout_sec": llm_plan_timeout_sec, "dialog_key": dialog_key},
                            )
                            recovery_plan = None
                        elif _rplan_err is not None:
                            with contextlib.suppress(Exception):
                                tool_store.log("llm_action_recovery_plan_error", str(_rplan_err)[:220])
                            recovery_plan = None
                        else:
                            recovery_plan = _rplan_out
                        recovery_actions_raw = recovery_plan.get("actions") if isinstance(recovery_plan, dict) else None
                        recovery_actions = [dict(x) for x in recovery_actions_raw if isinstance(x, dict)] if isinstance(recovery_actions_raw, list) else []
                        if not recovery_actions and isinstance(recovery_plan, dict) and isinstance(recovery_plan.get("action"), dict):
                            recovery_actions = [dict(recovery_plan.get("action"))]
                        if recovery_actions:
                            _audit_event("llm_action_recovery_start", {"count": len(recovery_actions), "reason": failed_reason or "failed_or_partial"})
                            rec_replies: List[str] = []
                            rec_results: List[Dict[str, Any]] = []
                            rec_ok = True
                            rec_note = str(recovery_plan.get("note", "") or "").strip() if isinstance(recovery_plan, dict) else ""
                            rec_note = rec_note or "LLM-Recovery-Plan"
                            for ridx, ract in enumerate(recovery_actions[:6], start=1):
                                rresolved = _prepare_planned_action_for_step(ract, rec_replies)
                                rstep_note = f"{rec_note} [step {ridx}/{len(recovery_actions)}:{rresolved.get('kind','')}]"
                                rres = _run_llm_planned_action(
                                    cfg=cfg,
                                    message=message,
                                    action=rresolved,
                                    note=rstep_note,
                                    dialog_key=dialog_key,
                                )
                                if not isinstance(rres, dict):
                                    rres = {"ok": False, "reply": "Leere Action-Antwort."}
                                rec_results.append(rres)
                                rrep = str(rres.get("reply", "") or "").strip()
                                rec_replies.append(rrep)
                                if bool(rres.get("partial", False)) or (not bool(rres.get("ok", False))):
                                    rec_ok = False
                                    break
                            if rec_results:
                                if len(rec_replies) == 1:
                                    rec_out = dict(rec_results[0])
                                    rec_out["reply"] = rec_replies[0]
                                    stage = "llm_action_ok" if bool(rec_out.get("ok", False)) and (not bool(rec_out.get("partial", False))) else "llm_action_error"
                                    return _ret(rec_out, stage, {"recovered": True})
                                rec_lines: List[str] = []
                                for i, rr in enumerate(rec_results, start=1):
                                    kk = str(recovery_actions[i - 1].get("kind", "") or "").strip() or "-"
                                    rp = str(rr.get("reply", "") or "").strip()
                                    state_txt = "ok" if bool(rr.get("ok", False)) and (not bool(rr.get("partial", False))) else "fehler"
                                    rec_lines.append(f"Recovery Schritt {i} ({kk}) | {state_txt}")
                                    if rp:
                                        rec_lines.append(rp)
                                stage = "llm_action_ok" if rec_ok else "llm_action_error"
                                return _ret({"ok": rec_ok, "reply": "\n".join(rec_lines)}, stage, {"recovered": True})
                    # Backward-compatible bridge: if single-step Gmail list on answer_and_save, persist output.
                    if (
                        all_ok
                        and len(planned_actions) == 1
                        and (_wants_save_output(message) or _is_answer_and_save_request(message) or interp_intent == "answer_and_save")
                        and str(planned_actions[0].get("kind", "")).strip().lower() == "gmail_list_messages"
                        and step_replies
                    ):
                        save_q = _extract_query_without_save(message) or "gmail_mails"
                        save_res = _save_text_to_requested_target(
                            cfg,
                            original_message=save_target_message,
                            query_for_name=save_q,
                            text_content=str(step_replies[0]),
                            dialog_key=dialog_key,
                        )
                        if bool(save_res.get("ok", False)):
                            step_replies[0] = str(step_replies[0]).rstrip() + "\n\n" + str(save_res.get("reply", "")).strip()
                        else:
                            all_ok = False
                            step_replies[0] = str(step_replies[0]).rstrip() + "\n\n" + str(save_res.get("reply", "")).strip()
                    if len(step_replies) == 1:
                        out = dict(step_results[0]) if step_results else {"ok": all_ok, "reply": step_replies[0] if step_replies else ""}
                        if step_replies:
                            out["reply"] = step_replies[0]
                        stage = "llm_action_ok" if bool(out.get("ok", False)) else "llm_action_error"
                        return _ret(out, stage)
                    lines: List[str] = []
                    for i, sr in enumerate(step_results, start=1):
                        k = str(planned_actions[i - 1].get("kind", "") or "").strip() or "-"
                        rp = str(sr.get("reply", "") or "").strip()
                        lines.append(f"Schritt {i} ({k}) | {'ok' if bool(sr.get('ok', False)) else 'fehler'}")
                        if rp:
                            lines.append(rp)
                    stage = "llm_action_ok" if all_ok else "llm_action_error"
                    return _ret({"ok": all_ok, "reply": "\n".join(lines)}, stage)

        # Deterministic Gmail fallback only when deterministic mode is active.
        has_direct_cron_cmd = isinstance(_cron_action_from_text(message), dict)
        if should_use_deterministic and (not _looks_like_cron_request_text(message)) and (not has_direct_cron_cmd):
            gmail_nl_action, gmail_nl_err = _gmail_action_from_text(message)
            if isinstance(gmail_nl_action, dict):
                result = _run_llm_planned_action(
                    cfg=cfg,
                    message=message,
                    action=gmail_nl_action,
                    note=f"gmail_nl_action:{gmail_nl_action.get('kind', '')}",
                    dialog_key=dialog_key,
                )
                if (
                    isinstance(result, dict)
                    and bool(result.get("ok", False))
                    and str(result.get("reply", "")).strip()
                    and (_wants_save_output(message) or _is_answer_and_save_request(message) or interp_intent == "answer_and_save")
                    and str(gmail_nl_action.get("kind", "")).strip().lower() == "gmail_list_messages"
                ):
                    save_q = _extract_query_without_save(message) or "gmail_mails"
                    save_res = _save_text_to_requested_target(
                        cfg,
                        original_message=save_target_message,
                        query_for_name=save_q,
                        text_content=str(result.get("reply", "")),
                        dialog_key=dialog_key,
                    )
                    if bool(save_res.get("ok", False)):
                        result = dict(result)
                        result["reply"] = str(result.get("reply", "")).rstrip() + "\n\n" + str(save_res.get("reply", "")).strip()
                    else:
                        result = dict(result)
                        result["ok"] = False
                        result["reply"] = str(result.get("reply", "")).rstrip() + "\n\n" + str(save_res.get("reply", "")).strip()
                if isinstance(result, dict):
                    stage = "llm_action_ok" if bool(result.get("ok", False)) else "llm_action_error"
                    return _ret(result, stage)
            if gmail_nl_err:
                return _ret({"ok": False, "reply": gmail_nl_err}, "skill_tool_clarify")

        # LLM-first mode: answer+save fallback only if no executable LLM action was produced.
        if (not forced_intent) and llm_first:
            eager_answer_save = _handle_answer_and_save_request(message, cfg)
            if eager_answer_save:
                return _ret(eager_answer_save, "answer_and_save_eager")

        steps = state.steps or build_plan(signals)
        if operational_mode:
            allowed_steps = {
                "help",
                "memory_commands",
                "clear_context",
                "personal_facts",
                "self_improve",
                "script_memory",
                "script_create",
                "script_exec",
                "filesystem",
            }
            steps = [s for s in steps if s in allowed_steps]
        for step in steps:
            if step == "help" and _is_help_command(message):
                return _ret({"ok": True, "reply": _commands_overview()}, "help")

            if step == "memory_commands":
                memory_cmd = _handle_memory_commands(message, cfg, dialog_key=dialog_key)
