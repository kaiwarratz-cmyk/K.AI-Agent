    allowed_kinds = _allowed_action_kinds_for_intent(intent)
    plan_action = _llm_plan_action(cfg, applied_message, interpretation if isinstance(interpretation, dict) else None)
    react_steps = _llm_plan_react(applied_message, cfg, dialog_key="simulate") or []
    return {
        "ok": True,
        "message": message,
        "applied_message": applied_message,
        "signals": {
            "is_question": bool(signals.is_question),
            "explicit_tool_intent": bool(signals.explicit_tool_intent),
