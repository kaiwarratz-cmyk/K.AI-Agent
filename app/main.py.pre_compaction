def _clear_conversation_context(cfg: Dict[str, Any], session_key: Optional[str] = None) -> Dict[str, int]:
    deleted_db = _memory_store(cfg).delete_kind("conversation")
    cleared_sessions = 0
    with _session_lock:
        if session_key:
            if session_key in _session_history:
                del _session_history[session_key]
            if session_key in _session_semantic_ctx:
                del _session_semantic_ctx[session_key]
                cleared_sessions = 1
        else:
            cleared_sessions = len(_session_history)
            _session_history.clear()
            _session_semantic_ctx.clear()
    with _session_artifact_lock:
        if session_key:
            _session_last_artifact.pop(session_key, None)
            _session_last_drive.pop(session_key, None)
        else:
            _session_last_artifact.clear()
            _session_last_drive.clear()
    if session_key:
        _clear_session_network_ctx(session_key)
        with contextlib.suppress(Exception):
            _memory_store(cfg).delete_key("session_summary", str(session_key))
    else:
        with _session_net_lock:
            _session_network_ctx.clear()
        with contextlib.suppress(Exception):
            _memory_store(cfg).delete_kind("session_summary")
    return {"deleted_db": int(deleted_db), "cleared_sessions": int(cleared_sessions)}

def _load_memory_on_start(cfg: Dict[str, Any], turns: int = 20) -> Dict[str, int]:
    items = _memory_store(cfg).search_by_kind(kind="conversation", limit=max(2, turns))
    loaded_pairs = 0
    q = deque(maxlen=max(2, turns * 2))
    for item in reversed(items):
        blob = _last_json_blob(str(item.get("content", "")))
        if not blob:
            continue
        user = str(blob.get("user", "")).strip()
        assistant = str(blob.get("assistant", "")).strip()
        if not user and not assistant:
            continue
        if user:
            q.append({"role": "user", "text": user[:700]})
        if assistant:
            q.append({"role": "assistant", "text": assistant[:700]})
        loaded_pairs += 1

    with _session_lock:
        _session_history["webui"] = q
    return {"conversation_pairs": loaded_pairs, "messages": len(q)}

