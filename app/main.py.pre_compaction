def _self_improve_deep_report(cfg: Dict[str, Any]) -> Dict[str, Any]:
    small = _self_improve_small_report(cfg)
    router = LLMRouter(cfg)
    llm_ping = router.ping()
    llm_chain: List[str] = []
    with contextlib.suppress(Exception):
        llm_chain = list(router._provider_chain())  # noqa: SLF001 - diagnostics
