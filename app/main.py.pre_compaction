@app.post("/api/chat")
def chat(req: ChatRequest) -> Dict[str, Any]:
    """
    Chat-Endpunkt mit Queue-System für Thread-Safety.
    """
    global _chat_queue
    cfg = _cfg()
    trace_id = _new_trace_id()
    
    dialog_key = req.dialog_key or "webui"
    source = req.source or "webui"
    
    if not _chat_queue:
        # Fallback falls Queue nicht initialisiert
        result = _chat_reply(req.message, cfg, dialog_key=dialog_key, source=source, trace_id=trace_id)
        # Wenn Telegram: Antwort aktiv senden
        if dialog_key.startswith("telegram:"):
            _send_telegram_reply(cfg, dialog_key, result.get("reply", ""))
        return result
    
    # Event für Ergebnis-Synchronisation
    result_event = threading.Event()
    result_container = {"data": None}
    
    def callback(result: Dict[str, Any]):
        result_container["data"] = result
        result_event.set()
    
    # SCHRITT 0: Semantischer Recall direkt am API-Eingang
    semantic_context = ""
    try:
        from app.chroma_memory import ChromaMemoryStore
        ms = _memory_store(cfg)
        facts = ms.search(req.message, limit=3, collection_name="important")
        if facts:
            semantic_context += "\n[ERINNERUNG AN NUTZERFAKTEN]:\n" + "\n".join([f"- {f.get('text','')}" for f in facts])
        
        # Erweitere die Nachricht um den gefundenen Kontext
        if semantic_context:
            req.message = semantic_context + "\n\nAktuelle User-Nachricht: " + req.message
            print(f"[DEBUG] API-Eingang: Kontext injiziert ({len(facts)} Fakten)")
    except Exception as e:
        print(f"[DEBUG] API-Recall Fehler: {e}")

    # Request in Queue einreihen (Bestehende Logik folgt...)
    request_id, started_event = _chat_queue.submit(
        message=req.message,
        cfg=cfg,
        result_callback=callback,
        source=source,
        dialog_key=dialog_key,
        trace_id=trace_id
    )
    
    # SCHRITT 1: Warten bis der Job aus der Queue gezogen wird (kein harter Timeout beim Warten)
    # Wir warten hier bis zu 2 Stunden, falls die Queue extrem voll ist.
    if not started_event.wait(timeout=7200):
        return {
            "ok": False,
            "reply": "Request wurde in der Warteschlange nicht rechtzeitig gestartet (Queue Timeout 2h).",
            "trace_id": trace_id
        }

    # SCHRITT 2: Der Job läuft jetzt! Jetzt gilt der eigentliche Plan-Timeout aus der WebUI/Config.
    react_cfg = cfg.get("react", {}) if isinstance(cfg.get("react", {}), dict) else {}
    # Wir geben dem Plan 60 Sekunden Puffer über sein Limit hinaus für Cleanup/Netzwerk
    plan_timeout = int(react_cfg.get("max_runtime_sec", 1800)) + 60

    # Auf Ergebnis warten
    if result_event.wait(timeout=plan_timeout):
        result = result_container["data"]
        # Wenn Telegram: Antwort aktiv senden
        if dialog_key.startswith("telegram:"):
            _send_telegram_reply(cfg, dialog_key, result.get("reply", ""))
        return result
    else:
        # Plan-Timeout erreicht
        cancelled = False
        with contextlib.suppress(Exception):
            cancelled = bool(_job_cancel(trace_id)) or cancelled
        with contextlib.suppress(Exception):
            cancelled = bool(_chat_queue.cancel_request(request_id)) or cancelled
        return {
            "ok": False,
            "reply": f"Plan-Timeout nach {plan_timeout}s erreicht - Job wurde abgebrochen.",
            "trace_id": trace_id,
            "cancelled": bool(cancelled),
        }

@app.post("/api/chat/stream")
async def chat_stream(req: ChatRequest) -> StreamingResponse:
    cfg = _cfg()
    trace_id = _new_trace_id()

    def format_sse(payload: Dict[str, Any]) -> str:
        return f"data: {json.dumps(payload, ensure_ascii=False)}\n\n"

    async def event_gen():
        yield format_sse({"type": "start", "trace_id": trace_id})
        try:
            # Stream-Endpoint nutzt KEINE Queue (würde async blockieren)
            result = await asyncio.to_thread(
                _chat_reply,
                req.message,
                cfg,
                "api:stream",
                "webui",
                trace_id,
            )
            
            text = str(result.get("reply", ""))
            if not bool(result.get("ok", True)):
                yield format_sse({"type": "error", "message": text or "Unbekannter Fehler."})
                return
            for i in range(0, len(text), 40):
                yield format_sse({"type": "chunk", "text": text[i : i + 40]})
            yield format_sse({"type": "done"})
        except Exception as exc:
            tool_store.log("chat_error", f"stream_unexpected: {exc}")
            _append_error_log("stream_unexpected_error", str(exc))
            yield format_sse({"type": "error", "message": f"Interner Fehler: {exc}"})

    return StreamingResponse(event_gen(), media_type="text/event-stream")

