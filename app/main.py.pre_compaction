def _memory_summary(cfg: Dict[str, Any]) -> str:
    store = _memory_store(cfg)
    counts = store.count_by_kind()
    if not counts:
        return "GedÃ¤chtnis ist leer."
    internal_kinds = {"episode", "session_summary", "lesson"}
    lines = ["GedÃ¤chtnisÃ¼bersicht:"]
    total = 0
    internal_total = 0
    for row in counts:
        kind = str(row.get("kind", ""))
        count = int(row.get("count", 0))
        if kind in internal_kinds:
            internal_total += count
            continue
        total += count
        lines.append(f"- {kind}: {count}")
    if total == 0:
        lines.append("- (keine nutzerrelevanten Eintraege)")
    lines.append(f"Gesamt (ohne interne Eintraege): {total}")
    if internal_total > 0:
        lines.append(f"Interne Eintraege (System): {internal_total}")
    recent = store.list_all(limit=6)
    if recent:
        lines.append("Zuletzt aktualisierte EintrÃ¤ge (ohne interne):")
        def _preview(kind: str, content: str) -> str:
            blob = _last_json_blob(str(content or ""))
            if not isinstance(blob, dict):
                raw = str(content or "").strip().replace("\n", " ")
                return raw[:90] + ("..." if len(raw) > 90 else "")
            k = str(kind or "").strip().lower()
            if k == "conversation":
                user = str(blob.get("user", "")).strip()
                if user:
                    return f"user: {user[:90]}" + ("..." if len(user) > 90 else "")
                assistant = str(blob.get("assistant", "")).strip()
                return f"assistant: {assistant[:90]}" + ("..." if len(assistant) > 90 else "")
            if k == "web":
                q = str(blob.get("query", "")).strip()
                p = str(blob.get("provider", "")).strip()
                if q and p:
                    return f"query: {q[:70]} | provider: {p}"
                if q:
                    return f"query: {q[:90]}" + ("..." if len(q) > 90 else "")
            if k == "script":
                path = str(blob.get("path", "")).strip()
                lang = str(blob.get("language", "")).strip()
                if path and lang:
                    return f"{lang}: {path[:80]}" + ("..." if len(path) > 80 else "")
                if path:
                    return f"path: {path[:90]}" + ("..." if len(path) > 90 else "")
            if k in {"profile", "important"}:
                field = str(blob.get("field", "")).strip()
                fact = str(blob.get("fact", "")).strip()
                if field and fact:
                    return f"{field}: {fact[:80]}" + ("..." if len(fact) > 80 else "")
                if fact:
                    return f"fact: {fact[:90]}" + ("..." if len(fact) > 90 else "")
            if k == "episode":
                stage = str(blob.get("stage", "")).strip()
                intent = str(blob.get("intent", "")).strip()
                status = str(blob.get("status", "")).strip()
                user = str(blob.get("user", "")).strip()
                meta = " | ".join([x for x in [stage, intent, status] if x])
                if user:
                    return (f"{meta} | {user[:60]}" if meta else user[:90]) + ("..." if len(user) > 90 else "")
                return meta[:90]
            if k == "lesson":
                sig = str(blob.get("signature", "")).strip()
                msg = str(blob.get("message", "")).strip()
                base = f"{sig}: {msg[:70]}" if sig else msg[:90]
                return base + ("..." if len(msg) > 90 else "")
            if k == "last_save":
                q = str(blob.get("query", "")).strip()
                target = str(blob.get("target_path", "")).strip()
                saved = bool(blob.get("saved", False))
                if q and target:
                    status = "ok" if saved else "fail"
                    return f"{status} | {q[:40]} -> {target[:40]}"
                if q:
                    return f"query: {q[:90]}" + ("..." if len(q) > 90 else "")
            # generic fallback
            keys = [str(x) for x in blob.keys()][:3]
            return "keys: " + ", ".join(keys) if keys else "-"
        shown = 0
        for item in recent:
            kind = str(item.get("kind", "?"))
            if kind in internal_kinds:
                continue
            updated = _format_datetime_readable(item.get("updated_at", ""))
            preview = _preview(kind, str(item.get("content", "")))
            lines.append(f"- {kind} | {updated} | {preview}")
            shown += 1
            if shown >= 6:
                break
    return "\n".join(lines)

def _memory_recent_details(cfg: Dict[str, Any], kind: Optional[str], limit: int) -> str:
    limit = max(1, min(20, int(limit)))
    items = _memory_store(cfg).search_by_kind(kind=kind, limit=limit)
    if not items:
        return "Keine passenden GedÃ¤chtnis-EintrÃ¤ge gefunden."
    lines = [f"Letzte EintrÃ¤ge ({'alle' if not kind else kind}, max {limit}):"]
    for i, item in enumerate(items, start=1):
        k = str(item.get("kind", ""))
        updated = _format_datetime_readable(item.get("updated_at", ""))
        blob = _last_json_blob(str(item.get("content", "")))
        preview = ""
        if isinstance(blob, dict):
            if k == "conversation":
                user = str(blob.get("user", "")).strip()
                assistant = str(blob.get("assistant", "")).strip()
                preview = f"user: {user[:140]} | assistant: {assistant[:140]}"
            elif k == "script":
                preview = f"path: {str(blob.get('path', ''))[:140]} | language: {blob.get('language', '')}"
            elif k == "web":
                preview = f"query: {str(blob.get('query', ''))[:160]}"
            else:
                preview = str(blob)[:200]
        else:
            preview = str(item.get("content", ""))[:200]
        lines.append(f"{i}. [{k}] {updated}")
        if preview:
            lines.append(f"   {preview}")
    return "\n".join(lines)

def _is_help_command(text: str) -> bool:
    t = text.strip().lower()
    if t in {"/befehle", "befehle", "/commands", "commands", "/help", "help", "hilfe", "/hilfe"}:
        return True
    # Weitere natürlichsprachliche Formulierungen
    keywords = ["was kannst du", "was kann ich", "zeige befehle", "alle befehle",
                "welche funktionen", "was hast du fuer", "capabilities", "uebersicht befehle",
                "kommandos", "was sind die moeglichkeiten"]
    return any(kw in t for kw in keywords)

def _is_cron_jobs_command(text: str) -> bool:
    t = str(text or "").strip().lower()
    t = re.sub(r"\s+", " ", t)
    if t.startswith("/"):
        t = t[1:].strip()
    return t in {"cron", "cron jobs", "cron job", "cron liste", "zeige cron jobs"}

def _skill_commands(message: str) -> Optional[Dict[str, Any]]:
    t = str(message or "").strip()
    low = t.lower()
    if not t:
        return None
    if low in {"/skills", "skills", "/skills list", "skills list"}:
        items = _skills_items_with_secret_status(_cfg())
        if not items:
            return {"ok": True, "reply": "Keine Skills gefunden (`skills/`)."}
        lines = [f"Skills ({len(items)}):"]
        for s in items:
            sid = str(s.get("id", "") or "")
            en = bool(s.get("enabled", False))
            name = str(s.get("name", sid) or sid)
            miss = s.get("missing_required", [])
            missing = [str(x) for x in miss if str(x).strip()] if isinstance(miss, list) else []
            if missing:
                lines.append(f"- {sid} | {'aktiv' if en else 'inaktiv'} | {name} | fehlende Secrets: {', '.join(missing)}")
            else:
                lines.append(f"- {sid} | {'aktiv' if en else 'inaktiv'} | {name}")
        return {"ok": True, "reply": "\n".join(lines)}
    m_sec = re.match(r"^/?skill\s+secrets\s+([a-zA-Z0-9._:-]+)\s*$", low, flags=re.IGNORECASE)
    if m_sec:
        sid = str(m_sec.group(1) or "").strip().lower()
        items = _skills_items_with_secret_status(_cfg())
        hit = None
        for x in items:
            if str(x.get("id", "") or "").strip().lower() == sid:
                hit = x
                break
        if not isinstance(hit, dict):
            return {"ok": False, "reply": f"Skill nicht gefunden: {sid}"}
        secrets = hit.get("secrets", [])
        sec_list = [x for x in secrets if isinstance(x, dict)] if isinstance(secrets, list) else []
        if not sec_list:
            return {"ok": True, "reply": f"Skill `{sid}` hat keine deklarierten Secrets."}
        lines = [f"Secrets fuer `{sid}`:"]
        for s in sec_list:
            alias = str(s.get("alias", "") or "").strip()
            req = bool(s.get("required", True))
            is_set = bool(s.get("is_set", False))
            lines.append(f"- {alias} | {'required' if req else 'optional'} | {'gesetzt' if is_set else 'fehlt'}")
        return {"ok": True, "reply": "\n".join(lines)}
    m_en = re.match(r"^/?skill\s+enable\s+([a-zA-Z0-9._:-]+)\s*$", low, flags=re.IGNORECASE)
    if m_en:
        sid = str(m_en.group(1) or "").strip()
        missing = _skill_missing_required_secrets(_cfg(), sid)
        if missing:
            return {
                "ok": False,
                "reply": f"Skill `{sid}` kann nicht aktiviert werden. Fehlende Pflicht-Secrets: {', '.join(missing)}. "
                f"Nutze Secret-Store oder `/skill secrets {sid}`.",
            }
        set_skill_enabled(SKILLS_STATE_FILE, sid, True)
        _skills_reload()
        return {"ok": True, "reply": f"Skill aktiviert: {sid}"}
    m_dis = re.match(r"^/?skill\s+disable\s+([a-zA-Z0-9._:-]+)\s*$", low, flags=re.IGNORECASE)
    if m_dis:
        sid = str(m_dis.group(1) or "").strip()
        set_skill_enabled(SKILLS_STATE_FILE, sid, False)
        _skills_reload()
        return {"ok": True, "reply": f"Skill deaktiviert: {sid}"}
    m_connect = re.match(r"^/?skill\s+connect\s+gmail\s*$", low, flags=re.IGNORECASE)
    if m_connect:
        cfg = _cfg()
        redirect_uri = "http://127.0.0.1:8000/api/skills/gmail/connect/callback"
        settings, err = _gmail_oauth_build_settings(cfg, redirect_uri)
        if not isinstance(settings, dict):
            return {"ok": False, "reply": err or "Gmail OAuth Konfiguration unvollstaendig."}
        state = _gmail_oauth_start_state()
        params = {
            "client_id": str(settings.get("client_id", "") or ""),
            "redirect_uri": redirect_uri,
            "response_type": "code",
            "scope": " ".join([str(x) for x in settings.get("scopes", []) if str(x).strip()]),
            "access_type": "offline",
            "prompt": "consent",
            "include_granted_scopes": "true",
            "state": state,
        }
        auth_endpoint = str(settings.get("auth_endpoint", "") or "https://accounts.google.com/o/oauth2/v2/auth")
        auth_url = f"{auth_endpoint}?{urlencode(params)}"
        return {
            "ok": True,
            "reply": (
                "Gmail Connect-Link:\n"
                f"{auth_url}\n\n"
                "Nach Freigabe werden Tokens automatisch ueber den Callback gespeichert."
            ),
        }
    if low in {"/skill reload", "skill reload"}:
        _skills_reload()
        return {"ok": True, "reply": "Skills neu geladen."}
    return None

