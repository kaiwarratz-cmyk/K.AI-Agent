                lines.append(f"session_summary: {summary_txt}")
            
            # Bei sehr kurzen Followups explizite Anweisung hinzufügen
            if short_followup:
                lines.append("WICHTIG: Die folgende Nutzeranfrage bezieht sich auf die vorherige Konversation. Analysiere den Kontext und führe die implizit gemeinte Aufgabe aus.")
            
            count = 0
            # Bei sehr kurzen Followups mehr History-Items einbeziehen
            max_items = max(6, dynamic_turns * 2) if short_followup else max(4, dynamic_turns * 2)
            
            for item in reversed(hist):
                role = str(item.get("role", "")).strip().lower()
                txt = str(item.get("text", "")).strip()
                if not txt or role not in {"user", "assistant"}:
                    continue
                # Relevanzfilter: bei normalen Anfragen nur thematisch passende History einbeziehen
                if not chain_followup and not short_followup and message_terms:
                    item_terms = set(_query_terms(txt))
                    # Filesystem-Kontext nur bei FS-Anfragen einbeziehen
                    if not fs_query_now and re.search(r"([a-z]:\\|\\\\)", txt.lower()):
                        continue
                    if not fs_query_now and _has_any(txt.lower(), ["datei", "dateien", "ordner", "verzeichnis", "laufwerk", "script", "skript"]):
                        continue
                    # Nur einbeziehen wenn Themen überlappen
                    if item_terms and len(message_terms.intersection(item_terms)) == 0:
                        continue
                lines.append(f"{role}: {txt[:20000]}")
                count += 1
                if count >= max_items:
                    break
            if count > 0:
                lines.append(f"user: {message}")
                message = "\n".join(lines)

    # Langzeit-Erinnerungen (ChromaDB) IMMER an den Anfang stellen
    if semantic_parts:
        message = "\n".join(semantic_parts) + "\n\n" + message
        
    return message


def _extract_any_path(text: str) -> Optional[str]:
    def _norm_unc_prefix(p: str) -> str:
        s = str(p or "")
        m = re.match(r"^[\\/]+", s)
        if not m:
            return s
        lead = str(m.group(0) or "")
        if len(lead) >= 2:
            s = "\\\\" + s[len(lead) :]
        return s

    def _is_plausible_path(token: str) -> bool:
        s = str(token or "").strip().strip("`").strip("\"'")
        if not s:
            return False
        low = s.lower()
        bad_markers = [
            "stdout:",
            "stderr:",
            "traceback",
            "windows-ip-konfiguration",
            "medienstatus",
            "adapter",
            " ip-routing",
            " no valid json",
        ]
        if any(m in low for m in bad_markers):
            return False
        if ("\n" in s) or ("\r" in s) or ("\t" in s) or ("\\n" in s) or ("\\r" in s):
            return False
        if re.match(r"^[A-Za-z]:([\\/]|$)", s):
            return True
        if re.match(r"^\\\\[^\\\r\n]+\\[^\\\r\n]+(?:\\[^\\\r\n]+)*\\?$", s):
            return True
        if s.startswith((".\\", "./", "..\\", "../")):
            return True
        if ("/" in s or "\\" in s) and not low.startswith(("http://", "https://")):
            return True
        return False

    def _clean_candidate(cand: str) -> str:
        s = str(cand or "").strip().strip("`").strip("\"'")
        if not s:
            return ""
        cut_markers = [
            " als laufwerk",
            " unter laufwerk",
            " mit laufwerk",
            " auf laufwerk",
            " bitte",
            " und ",
            "\n",
            "\r",
        ]
        low_s = s.lower()
        cut_at = len(s)
        for marker in cut_markers:
            pos = low_s.find(marker)
            if pos > 0:
                cut_at = min(cut_at, pos)
        s = s[:cut_at].strip().rstrip(".,;")

        # If a command-like tail was appended after a file path
        # (e.g. "...\\script.py CHAT_ID --text ..."), keep only the actual path.
        m_ext_tail = re.search(r"(?i)(\.[a-z0-9]{1,8})(\s+.+)$", s)
        if m_ext_tail:
            ext_end = int(m_ext_tail.end(1))
            prefix = s[:ext_end].strip().rstrip(".,;")
            rest = s[ext_end:].strip()
            rest_looks_like_cli = bool(
                rest
                and (
                    rest.startswith("--")
                    or rest.startswith("-")
                    or rest.startswith("/")
                    or bool(re.match(r"^[A-Z_][A-Z0-9_]*(?:\s|$)", rest))
                    or (" --" in f" {rest}")
                )
            )
            if rest_looks_like_cli and prefix:
                s = prefix
        # Also trim quoted/natural-language tails after a file extension
        # (e.g. '...\\file.pdf" gespeichert ...').
        m_ext_junk = re.search(r"(?i)^(.+?\.[a-z0-9]{1,8})([\"'`)\]}:;,.!? ]+.+)$", s)
        if m_ext_junk:
            prefix2 = str(m_ext_junk.group(1) or "").strip().rstrip(".,;")
            if prefix2:
                s = prefix2

        # Normalize common malformed Windows absolute paths:
        # - "\Users\..."  -> "C:\Users\..."
        # - "\\Users\..." -> "C:\Users\..."
        # while keeping real UNC shares intact.
        s = s.replace("/", "\\")
        sys_drive = str(os.environ.get("SystemDrive", "C:") or "C:").strip()
        if not re.match(r"^[A-Za-z]:$", sys_drive):
            sys_drive = "C:"
        if re.match(r"^\\(?!\\)", s):
            s = f"{sys_drive}{s}"
        if re.match(r"^\\\\(users|windows|programdata|program files(?: \(x86\))?)(\\|$)", s, flags=re.IGNORECASE):
            s = f"{sys_drive}\\{s.lstrip('\\')}"

        s = _norm_unc_prefix(s)
        if not _is_plausible_path(s):
            return ""
        if re.match(r"^[A-Za-z]:$", s):
            return s + "\\"
        return s

    quoted = re.findall(r'"([^"]+)"', text or "")
    for q in quoted:
        cand_q = _clean_candidate(q)
        if cand_q:
            return cand_q

    raw = str(text or "")
    m_drive = re.search(r"(?<![A-Za-z])([A-Za-z]:(?!//)(?:[\\/][^\s\"]*)?)", raw)
    if m_drive:
        p = _clean_candidate(str(m_drive.group(1) or "").replace("/", "\\"))
        if p:
            return p

    idx = raw.find("\\\\")
    if idx >= 0:
        tail = raw[idx:].strip()
        cand_unc = _clean_candidate(tail)
        if cand_unc.startswith("\\\\") and len(cand_unc) > 4:
            return cand_unc
    else:
        m_single_unc = re.search(r"\\[^\\\s]+\\[^\n\r]+", raw)
        if m_single_unc:
            cand_unc = _clean_candidate("\\" + str(m_single_unc.group(0) or ""))
            if cand_unc.startswith("\\\\") and len(cand_unc) > 4:
                return cand_unc

    m_rel = re.search(r"\b(?:unter|in|at|inside)\s+([.\w:\\/\-]+)", text or "", flags=re.IGNORECASE)
    if m_rel:
        cand = _clean_candidate(str(m_rel.group(1) or "").strip())
        if not cand:
            return None
        low = cand.lower()
        stopwords = {
            "deinem",
            "dein",
            "deiner",
            "deines",
            "meinem",
            "mein",
            "meiner",
            "my",
            "your",
            "workspace",
            "verzeichnis",
            "ordner",
            "directory",
            "folder",
        }
        if low in stopwords:
            return None
        # Relative path needs at least one strong path marker.
        if ("/" in cand) or ("\\" in cand) or cand.startswith(".") or re.match(r"^[A-Za-z]:", cand):
            return cand
        return None
    return None


def _workflow_context_key(message: str, action: Dict[str, Any]) -> str:
    low = str(message or "").lower()
    kind = str(action.get("kind", "") or "").strip().lower()
    tokens: List[str] = [kind or "unknown"]

    # Exact scope anchors (drive / UNC server/share) to avoid cross-scope reuse.
    scope_vals: List[str] = []
    for k in ("path", "src", "dst", "target", "script_path"):
        v = str(action.get(k, "") or "").strip()
        if v:
            scope_vals.append(v)
    if not scope_vals:
        p_from_msg = _extract_any_path(message)
        if p_from_msg:
            scope_vals.append(str(p_from_msg))
    for raw in scope_vals:
        s = str(raw).replace("/", "\\")
        m_drv = re.match(r"^([A-Za-z]:)\\?", s)
        if m_drv:
            tokens.append(f"drive:{m_drv.group(1).lower()}")
        if s.startswith("\\\\"):
            parts = [x for x in s.split("\\") if x]
            if parts:
                tokens.append(f"unc:{parts[0].lower()}")
            if len(parts) > 1:
                tokens.append(f"share:{parts[1].lower()}")

    # Intent hints.
    if _has_any(low, ["nas", "netzwerk", "freigabe", "laufwerk"]):
        tokens.append("intent:network_fs")
    elif _has_any(low, ["datei", "ordner", "verzeichnis"]):
        tokens.append("intent:filesystem")
    elif _has_any(low, ["cron", "zeitplan"]):
        tokens.append("intent:cron")

    return "|".join(dict.fromkeys(tokens))[:360]


def _save_workflow_success(cfg: Dict[str, Any], message: str, action: Dict[str, Any], reply_text: str = "") -> None:
    try:
        kind = str(action.get("kind", "") or "").strip().lower()
        if kind not in {"script_exec", "read_file", "write_file"}:
            return
        key = _workflow_context_key(message, action)
        if not key:
            return
        payload: Dict[str, Any] = {
            "field": "workflow_success",
            "context_key": key,
            "action_kind": kind,
            "sample_message": str(message or "")[:260],
            "action": dict(action),
            "updated_at": datetime.now().isoformat(),
            "last_success": str(reply_text or "")[:900],
        }
        _memory_store(cfg).upsert_memory("workflow_success", key, payload, confidence=0.9)
    except Exception as exc:
        tool_store.log("workflow_success_persist_error", str(exc))


def _is_safe_operational_path(cand: str) -> bool:
    s = str(cand or "").strip().strip("`").strip("\"'")
    if not s:
        return False
    low = s.lower()
    bad_markers = ["stdout:", "stderr:", "windows-ip-konfiguration", "medienstatus", "adapter", "ip-routing"]
    if any(b in low for b in bad_markers):
        return False
    if ("\n" in s) or ("\r" in s) or ("\\n" in s) or ("\\r" in s):
        return False
    if s.startswith("\\\\n") or s.startswith("\\\\r"):
        return False
    # Reject likely CLI tails accidentally glued to a file path,
    # e.g. "...\\send_telegram.py CHAT_ID --text".
    if re.search(
        r"(?i)\.[a-z0-9]{1,8}\s+(?:--|-|/[A-Za-z]|[A-Z_][A-Z0-9_]*(?:\s|$))",
        s,
    ):
        return False
    if re.match(r"^[A-Za-z]:\\", s):
        return True
    if re.match(r"^\\\\[^\\\r\n]+\\[^\\\r\n]+(?:\\[^\\\r\n]+)*\\?$", s):
        # Guard against malformed local paths missing drive letter that look like UNC:
        # \\Users\\name\\...  -> should be C:\\Users\\name\\...
        m_unc_host = re.match(r"^\\\\([^\\\r\n]+)\\", s)
        if m_unc_host:
            host = str(m_unc_host.group(1) or "").strip().lower()
            if host in {"users", "windows", "programdata", "program files", "program files (x86)"}:
                return False
        return True
    return False


def _looks_like_file_path(cand: str) -> bool:
    s = str(cand or "").strip().replace("/", "\\")
    if not s:
        return False
    tail = s.rstrip("\\").split("\\")[-1]
    # Heuristic: final segment with extension is likely a file.
    if "." in tail and not tail.endswith("."):
        return True
    return False


def _allowed_operational_path_for_request(
    msg: str,
    cand: str,
    *,
    require_existing_file: bool = True,
    require_existing_dir: bool = False,
) -> bool:
    low_msg = str(msg or "").lower()
    c = str(cand or "").strip().replace("/", "\\")
    if not _is_safe_operational_path(c):
        return False
    if _looks_like_file_path(c):
        if require_existing_file:
            try:
                p_file = Path(c)
                if not (p_file.exists() and p_file.is_file()):
                    return False
            except Exception:
                return False
    elif require_existing_dir:
        try:
            p_dir = Path(c)
            if p_dir.exists() and (not p_dir.is_dir()):
                return False
        except Exception:
            return False
    # For search/list tasks without explicit file-open/read intent, avoid injecting a file path.
    wants_search = _has_any(low_msg, ["suche", "finde", "durchsuche", "liste", "list"])
    wants_file_read = _has_any(low_msg, ["lies", "lese", "read", "oeffne", "öffne"])
    if wants_search and (not wants_file_read) and _looks_like_file_path(c):
        return False
    # If user explicitly names drive letters, do not inject a different drive.
    req_drives = re.findall(r"\b([A-Za-z]:)\\?", str(msg or ""))
    req_drives = [d.upper() for d in req_drives]
    if req_drives:
        m_c = re.match(r"^([A-Za-z]:)\\?", c)
        if not m_c:
            return False
        if m_c.group(1).upper() not in req_drives:
            return False
    # If this sounds like NAS/network search, avoid local C:/D: guesses.
    if _has_any(low_msg, ["nas", "netzwerk", "freigabe", "network share"]) and (not c.startswith("\\\\")):
        # mapped drive can still be valid if user asked for "laufwerk"
        if not _has_any(low_msg, ["laufwerk"]):
            return False
    # For NAS/network asks, prefer share-level paths over deep file paths.
    if _has_any(low_msg, ["nas", "netzwerk", "freigabe"]) and c.startswith("\\\\") and _looks_like_file_path(c):
        return False
    return True


def _session_path_candidate(cfg: Dict[str, Any], message: str, dialog_key: str = "") -> str:
    low = str(message or "").lower()
    prefer_unc = _has_any(low, ["nas", "netzwerk", "freigabe", "laufwerk", "network share"])
    candidates: List[str] = []
    key = str(dialog_key or "").strip()

    if key:
        with contextlib.suppress(Exception):
            art = _get_session_last_artifact(key)
            if art is not None:
                candidates.append(str(art))
        with contextlib.suppress(Exception):
            sem = _get_session_semantic_context(key)
            for sk in ("last_script", "last_path"):
                v = str(sem.get(sk, "") or "").strip()
                src = str(sem.get(f"{sk}_source", "") or "").strip()
                if v and src == "user":
                    candidates.append(v)
        with contextlib.suppress(Exception):
            hist_art = _artifact_from_recent_session_history(cfg, key)
            if hist_art is not None:
                candidates.append(str(hist_art))
    with contextlib.suppress(Exception):
        lp = _latest_conversation_path(cfg, dialog_key=dialog_key)
        if lp:
            candidates.append(str(lp))

    norm: List[str] = []
    seen: set[str] = set()
    for c in candidates:
        s = str(c or "").strip().strip("`")
        if not s:
            continue
        if not _allowed_operational_path_for_request(
            message,
            s,
            require_existing_file=True,
            require_existing_dir=False,
        ):
            continue
        k = s.lower()
        if k in seen:
            continue
        seen.add(k)
        norm.append(s)
    if not norm:
        return ""
    if prefer_unc:
        for c in norm:
            if c.startswith("\\\\"):
                return c
    return norm[0]


def _memory_path_candidate(cfg: Dict[str, Any], message: str, dialog_key: str = "") -> str:
    candidates: List[str] = []
    low = str(message or "").lower()
    prefer_unc = _has_any(low, ["nas", "netzwerk", "freigabe", "laufwerk", "network share"])

    # Session-local network context first.
    with contextlib.suppress(Exception):
        net = _get_session_network_ctx(dialog_key)
        unc = str(net.get("unc", "") or "").strip()
        if unc and _is_safe_operational_path(unc):
            candidates.append(unc)
        elif unc:
            # Remove poisoned session UNC context.
            _set_session_network_ctx(dialog_key, unc="", drive=str(net.get("drive", "") or ""), awaiting_drive=False)
        drv = str(net.get("drive", "") or "").strip()
        if drv and _is_safe_operational_path(drv if drv.endswith("\\") else f"{drv}\\"):
            candidates.append(drv if drv.endswith("\\") else f"{drv}\\")

    # Semantic/session history hints.
    with contextlib.suppress(Exception):
        sem = _get_session_semantic_context(dialog_key)
        last_path = str(sem.get("last_path", "") or "").strip()
        if last_path:
            candidates.append(last_path)
        last_script = str(sem.get("last_script", "") or "").strip()
        if last_script:
            candidates.append(last_script)
    with contextlib.suppress(Exception):
        lp = _latest_conversation_path(cfg, dialog_key=dialog_key)
        if lp:
            candidates.append(str(lp))

    # Structured memory only (no raw conversation blobs):
    # prefer durable facts/lessons over free-form chat context.
    with contextlib.suppress(Exception):
        store = _memory_store(cfg)
        for kind in ("important", "profile", "lesson", "workflow_success", "script", "last_save"):
            rows = store.search_by_kind(kind=kind, limit=40)
            for r in rows:
                txt = str(r.get("content", "") or "")
                p = _extract_any_path(txt)
                if p:
                    candidates.append(str(p))

    # Normalize, filter and dedupe.
    norm: List[str] = []
    seen: set[str] = set()
    for c in candidates:
        s = str(c or "").strip().strip("`")
        if not s:
            continue
        if not _allowed_operational_path_for_request(
            message,
            s,
            require_existing_file=True,
            require_existing_dir=False,
        ):
            continue
        key = s.lower()
        if key in seen:
            continue
        seen.add(key)
        norm.append(s)

    if not norm:
        return ""
    if prefer_unc:
        for c in norm:
            if c.startswith("\\\\"):
                return c
    return norm[0]


def _maybe_enrich_missing_operational_path(
    cfg: Dict[str, Any],
    message: str,
    interpretation: Optional[Dict[str, Any]],
    signals: Optional[ReasoningSignals],
    dialog_key: str = "",
) -> str:
    # BEST PRACTICE CLEANUP (Phase 1):
    # Das harte Anhängen von Pfaden per Regex ("in <pfad>") wurde deaktiviert.
    # Das LLM soll und kann Pfade via Tools oder eigenem Kontext herausfinden,
    # ohne dass der User-Prompt künstlich durch Regex manipuliert wird.
    return str(message or "")

    def _is_info_query(text_raw: str) -> bool:
        """Prüft ob es eine reine Info-Anfrage ist (keine Dateioperation)"""
        low_t = str(text_raw or "").lower()
        # Info-Verben
        info_verbs = ["welche", "zeige", "liste", "schaue", "prüfe", "check", "show", "list", "what"]
        # Info-Ziele (keine Dateien/Pfade)
        info_targets = ["tool", "tools", "befehl", "befehle", "command", "status", "fähigkeit", "capability", "mcp"]
        
        has_info_verb = any(verb in low_t for verb in info_verbs)
        has_info_target = any(target in low_t for target in info_targets)
        
        # Wenn es um Dateien/Pfade geht, ist es KEINE Info-Anfrage
        file_indicators = ["datei", "file", "ordner", "folder", "pfad", "path", "verzeichnis", "directory"]
        has_file_target = any(indicator in low_t for indicator in file_indicators)
        
        return bool(has_info_verb and has_info_target and not has_file_target)

    def _has_explicit_location_clause(text_raw: str) -> bool:
        # Respect user-provided location clauses (quoted or simple token),
        # so memory injection does not overwrite explicit relative paths like "in data".
        m = re.search(r"\b(?:in|unter|at|inside)\s+(.+)$", str(text_raw or ""), flags=re.IGNORECASE)
        if not m:
            return False
        tail = str(m.group(1) or "").strip()
        if not tail:
            return False
        if tail.startswith(("\"", "`")):
            return True
        first = re.split(r"[\s,;.!?]", tail, maxsplit=1)[0].strip().strip("\"'`")
        if not first:
            return False
        low = first.lower()
        generic = {
            "mein",
            "meinem",
            "meinen",
            "dein",
            "deinem",
            "deinen",
            "dem",
            "der",
            "den",
            "einem",
            "einer",
            "einen",
            "workspace",
            "ordner",
            "verzeichnis",
            "folder",
            "directory",
            "nas",
            "netzwerk",
            "freigabe",
            "laufwerk",
            "server",
        }
        if low in generic:
            return False
        return True

    raw = str(message or "").strip()
    if not raw:
        return raw
    # Slash commands must stay untouched (e.g. /session neu, /befehle).
    if raw.startswith("/"):
        return raw
    if _has_explicit_location_clause(raw):
        return raw
    # If user already gave a quoted target after a location preposition, do not inject memory path.
    if re.search(r"\b(?:in|unter|at|inside)\s+\"[^\"]+\"", raw, flags=re.IGNORECASE):
        return raw
    if _extract_any_path(raw):
        return raw
    if not _looks_operational_request(raw, signals):
        return raw
    # Web-Suchen brauchen KEINEN lokalen Pfad – "im Netz", "online", "im Internet", etc.
    _raw_lower = raw.lower()
    _web_phrases = ("im netz", "im internet", "im web", "online", "nur im netz",
                    "aus dem netz", "aus dem internet", "von einer website",
                    "von einer webseite", "from the web", "from internet")
    if any(p in _raw_lower for p in _web_phrases):
        return raw
    # Info-Anfragen (zeige/liste tools/befehle/status) brauchen KEINEN Pfad
    if _is_info_query(raw):
        return raw
    # Tool-Bauaufgaben sind meist konzeptionell; ein alter Datei-Pfad schadet hier.
    if _is_tool_construction_request(raw):
        return raw

    # Check if interpretation already has an explicit path entity.
    if isinstance(interpretation, dict):
        ents = interpretation.get("entities", {}) if isinstance(interpretation.get("entities", {}), dict) else {}
        ent_path = str(ents.get("path", "") or "").strip()
        if ent_path:
            return raw

    cand = _session_path_candidate(cfg, raw, dialog_key=dialog_key)
    if cand:
        prep = "unter" if str(cand).startswith("\\\\") else "in"
        enriched = f'{raw} {prep} "{cand}"'
        _audit_event("session_path_injected", {"dialog_key": dialog_key, "path": cand[:240], "orig": raw[:240]})
        return enriched

    cand = _memory_path_candidate(cfg, raw, dialog_key=dialog_key)
    if not cand:
        return raw
    prep = "unter" if str(cand).startswith("\\\\") else "in"
    enriched = f'{raw} {prep} "{cand}"'
    _audit_event("memory_path_injected", {"dialog_key": dialog_key, "path": cand[:240], "orig": raw[:240]})
    return enriched

def _conversation_dialog_key(blob: Dict[str, Any]) -> str:
    return str(blob.get("dialog_key", "") or "").strip()


def _conversation_blobs(cfg: Dict[str, Any], limit: int = 20, dialog_key: str = "") -> List[Dict[str, Any]]:
    target = str(dialog_key or "").strip() or str(_dialog_key_ctx.get("") or "").strip()
    items = _memory_store(cfg).search_by_kind(kind="conversation", limit=max(1, int(limit)))
    exact: List[Dict[str, Any]] = []
    fallback: List[Dict[str, Any]] = []
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not isinstance(blob, dict):
            continue
        b_key = _conversation_dialog_key(blob)
        if target:
            if b_key == target:
                exact.append(blob)
            elif not b_key:
                fallback.append(blob)
            else:
                # Foreign session: skip to avoid context leak.
                continue
        else:
            exact.append(blob)
    if target:
        return exact + fallback
    return exact


def _latest_user_message(cfg: Dict[str, Any], dialog_key: str = "") -> str:
    for blob in _conversation_blobs(cfg, limit=12, dialog_key=dialog_key):
        user = str(blob.get("user", "")).strip()
        if user:
            return user
    return ""


def _latest_assistant_message(cfg: Dict[str, Any], dialog_key: str = "") -> str:
    for blob in _conversation_blobs(cfg, limit=12, dialog_key=dialog_key):
        assistant = str(blob.get("assistant", "")).strip()
        if assistant:
            return assistant
    return ""


def _latest_conversation_path(cfg: Dict[str, Any], dialog_key: str = "") -> Optional[str]:
    def _looks_like_file(p: str) -> bool:
        tail = str(p or "").replace("/", "\\").rstrip("\\").split("\\")[-1]
        return bool("." in tail and not tail.endswith("."))

    for blob in _conversation_blobs(cfg, limit=16, dialog_key=dialog_key):
        user = str(blob.get("user", "")).strip()
        p_user = _extract_any_path(user)
        if p_user and _is_safe_operational_path(p_user):
            return p_user
    return None


def _latest_conversation_text(cfg: Dict[str, Any], dialog_key: str = "") -> str:
    blobs = _conversation_blobs(cfg, limit=1, dialog_key=dialog_key)
    if not blobs:
        return ""
    blob = blobs[0]
    user = str(blob.get("user", "")).strip()
    assistant = str(blob.get("assistant", "")).strip()
    return f"{user} {assistant}".strip().lower()

def _extract_drive_letter(text: str) -> str:
    matches = re.findall(r"(?<![A-Za-z0-9])([A-Za-z]:)(?:[\\/\s\"'.,;]|$)", str(text or ""), flags=re.IGNORECASE)
    if not matches:
        return ""
    return str(matches[-1] or "").upper()

def _latest_conversation_drive(cfg: Dict[str, Any], dialog_key: str = "") -> str:
    for blob in _conversation_blobs(cfg, limit=24, dialog_key=dialog_key):
        user = str(blob.get("user", "")).strip()
        assistant = str(blob.get("assistant", "")).strip()
        drive_a = _extract_drive_letter(assistant)
        if drive_a and _has_any(assistant.lower(), ["laufwerk", "verbunden", "netzlaufwerk", "gemount"]):
            return drive_a
        drive_u = _extract_drive_letter(user)
        if drive_u and _has_any(user.lower(), ["laufwerk", "verbinde", "map", "mapp", "mount"]):
            return drive_u
    return ""

def _infer_drive_from_reply(reply: str) -> str:
    txt = str(reply or "")
    low = txt.lower()
    if not _has_any(low, ["laufwerk", "verbunden", "netzlaufwerk", "gemount", "mapping"]):
        return ""
    return _extract_drive_letter(txt)

def _extract_unc_from_text(text: str) -> str:
    def _norm_unc_prefix(p: str) -> str:
        s = str(p or "")
        m = re.match(r"^[\\/]+", s)
        if not m:
            return s
        lead = str(m.group(0) or "")
        if len(lead) >= 2:
            s = "\\\\" + s[len(lead) :]
        return s

    def _is_valid_unc(cand: str) -> bool:
        s = _norm_unc_prefix(str(cand or "").strip().strip("`").strip("\"'"))
        if not s.startswith("\\\\"):
            return False
        low = s.lower()
        if any(m in low for m in ["stdout:", "stderr:", "traceback", "\\\\n", "\\\\r"]):
            return False
        if ("\n" in s) or ("\r" in s):
            return False
        return bool(re.match(r"^\\\\[^\\\r\n]+\\[^\\\r\n]+(?:\\[^\\\r\n]+)*\\?$", s))

    # Prefer unified path extraction first.
    direct = _extract_any_path(str(text or ""))
    if direct and str(direct).startswith("\\\\") and _is_valid_unc(str(direct)):
        return _norm_unc_prefix(str(direct))

    raw = str(text or "")
    m_tick = re.search(r"`(\\\\[^`]+)`", raw)
    if m_tick:
        cand = _norm_unc_prefix(str(m_tick.group(1) or "").strip())
        return cand if _is_valid_unc(cand) else ""
    m_unc = re.search(r"(\\\\[^\s\\]+\\[^\n\r`]+)", raw)
    if m_unc:
        cand = _norm_unc_prefix(str(m_unc.group(1) or "").strip().rstrip(".,;"))
        return cand if _is_valid_unc(cand) else ""
    m_single = re.search(r"(\\[^\\\s]+\\[^\n\r`]+)", raw)
    if not m_single:
        return ""
    cand = str(m_single.group(1) or "").strip().rstrip(".,;")
    if cand.startswith("\\\\"):
        cand = _norm_unc_prefix(cand)
    else:
        cand = _norm_unc_prefix(("\\" + cand).rstrip(".,;"))
    return cand if _is_valid_unc(cand) else ""

def _set_session_network_ctx(session_key: str, unc: str = "", drive: str = "", awaiting_drive: bool = False) -> None:
    key = str(session_key or "").strip()
    if not key:
        return
    with _session_net_lock:
        cur = dict(_session_network_ctx.get(key, {}) or {})
        if unc:
            cur["unc"] = str(unc).strip()
        if drive:
            d = _extract_drive_letter(drive)
            if d:
                cur["drive"] = d
        cur["awaiting_drive"] = "1" if awaiting_drive else "0"
        _session_network_ctx[key] = cur

def _get_session_network_ctx(session_key: str) -> Dict[str, str]:
    key = str(session_key or "").strip()
    if not key:
        return {}
    with _session_net_lock:
        return dict(_session_network_ctx.get(key, {}) or {})

def _clear_session_network_ctx(session_key: str) -> None:
    key = str(session_key or "").strip()
    if not key:
        return
    with _session_net_lock:
        _session_network_ctx.pop(key, None)

def _infer_network_dialog_state_from_reply(reply: str) -> Dict[str, str]:
    txt = str(reply or "")
    low = txt.lower()
    out: Dict[str, str] = {}
    unc = _extract_unc_from_text(txt)
    drive = _extract_drive_letter(txt)
    if unc:
        out["unc"] = unc
    if drive:
        out["drive"] = drive
    if _has_any(low, ["welchen laufwerksbuchstaben", "laufwerksbuchstaben soll ich", "welches laufwerk"]):
        out["awaiting_drive"] = "1"
    elif _has_any(low, ["netzlaufwerk verbunden", "als laufwerk verbunden", "wurde erfolgreich als laufwerk"]):
        out["awaiting_drive"] = "0"
    return out

def _find_recent_deadline_in_conversation(cfg: Dict[str, Any]) -> Optional[str]:
    items = _memory_store(cfg).search_by_kind(kind="conversation", limit=240)
    patterns = [
        r"deadline\s*[:=]\s*([0-9]{4}-[0-9]{2}-[0-9]{2})",
        r"deadline\s*[:=]\s*([0-9]{1,2}[.\-/][0-9]{1,2}[.\-/][0-9]{2,4})",
        r"faellig(?:keit)?\s*[:=]\s*([0-9]{4}-[0-9]{2}-[0-9]{2})",
    ]
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not isinstance(blob, dict):
            continue
        user = str(blob.get("user", "")).strip()
        assistant = str(blob.get("assistant", "")).strip()
        text = f"{user}\n{assistant}"
        for p in patterns:
            m = re.search(p, text, flags=re.IGNORECASE)
            if m:
                return m.group(1).strip()
    return None

