@app.post("/api/secrets/upsert")
def upsert_secret(payload: SecretUpsertRequest) -> Dict[str, Any]:
    cfg = _cfg()
    alias = SecretStore.normalize_alias(str(payload.alias or ""))
    value = str(payload.value or "").strip()
    if not value:
        raise HTTPException(status_code=400, detail="value darf nicht leer sein")
    if not alias:
        raise HTTPException(status_code=400, detail="alias darf nicht leer sein")
    store = _secret_store(cfg)
    existed = bool(store.has_alias(alias))
    if not bool(payload.confirm):
        return {
            "ok": False,
            "needs_confirmation": True,
            "action": "update" if existed else "create",
            "alias": alias,
            "message": (
                f"Bitte bestaetigen: Secret `{alias}` wird "
                + ("aktualisiert." if existed else "neu angelegt.")
            ),
        }
    confirm_alias = SecretStore.normalize_alias(str(payload.confirm_alias or ""))
    if confirm_alias != alias:
        raise HTTPException(status_code=400, detail="confirm_alias stimmt nicht mit alias ueberein")
    stored_alias = store.upsert_secret(
        alias=alias,
        value=value,
        meta={"source": "api", "dialog_key": "webui"},
    )
    fp = SecretStore.fingerprint(value)
    tool_store.log("secret_store", f"{'update' if existed else 'create'} alias={stored_alias} fingerprint={fp}")
    return {
        "ok": True,
        "updated": existed,
        "alias": stored_alias,
        "fingerprint": fp,
    }

