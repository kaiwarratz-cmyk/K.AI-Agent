def _cron_jobs_load() -> List[Dict[str, Any]]:
    with _cron_lock:
        try:
            if not CRON_JOBS_FILE.exists():
                return []
            payload = json.loads(CRON_JOBS_FILE.read_text(encoding="utf-8-sig", errors="ignore"))
            jobs = payload.get("jobs", payload) if isinstance(payload, dict) else payload
            if not isinstance(jobs, list):
                return []
            out: List[Dict[str, Any]] = []
            for raw in jobs:
                if isinstance(raw, dict):
                    item = dict(raw)
                    task = str(item.get("task", "") or "").strip()
                    query = str(item.get("query", "") or "").strip()
                    embedded = item.get("action", None)
                    if not isinstance(embedded, dict) or not embedded:
                        item["action"] = _cron_default_embedded_action(task=task, query=query)
                    out.append(item)
            return out
        except Exception:
            return []

def _cron_jobs_save(jobs: List[Dict[str, Any]]) -> None:
    with _cron_lock:
        CRON_JOBS_FILE.parent.mkdir(parents=True, exist_ok=True)
        payload = {"jobs": jobs, "updated_at": datetime.now().isoformat()}
        CRON_JOBS_FILE.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")

