def _load_capabilities() -> Dict[str, Any]:
    global _capabilities_cache
    base_cached: Dict[str, Any]
    with _capabilities_lock:
        if _capabilities_cache:
            base_cached = dict(_capabilities_cache)
        else:
            try:
                if CAPABILITIES_FILE.exists():
                    data = json.loads(CAPABILITIES_FILE.read_text(encoding="utf-8-sig", errors="ignore"))
                    if isinstance(data, dict):
                        _capabilities_cache = data
            except Exception:
                pass
            if not _capabilities_cache:
                _capabilities_cache = _default_capabilities()
            base_cached = dict(_capabilities_cache)
    # Always append runtime skill capabilities (optional, restart-safe).
    base = dict(base_cached)
    reg = _skills_snapshot()
    intents = base.get("intents", []) if isinstance(base.get("intents", []), list) else []
    tools = base.get("tools", []) if isinstance(base.get("tools", []), list) else []
    seen_intents = {str(x.get("id", "")).strip() for x in intents if isinstance(x, dict)}
    seen_tools = {str(x.get("id", "")).strip() for x in tools if isinstance(x, dict)}
    for it in reg.get("intents", []) if isinstance(reg.get("intents", []), list) else []:
        if not isinstance(it, dict):
            continue
        iid = str(it.get("id", "") or "").strip()
        if iid and iid not in seen_intents:
            intents.append({"id": iid, "description": str(it.get("description", "") or "").strip()})
            seen_intents.add(iid)
    for t in reg.get("tools", []) if isinstance(reg.get("tools", []), list) else []:
        if not isinstance(t, dict):
            continue
        tid = str(t.get("id", "") or "").strip()
        tint = str(t.get("intent", "") or "").strip()
        kind = str(t.get("kind", "") or "").strip()
        if tid and tid not in seen_tools:
            entry = {"id": tid, "intent": tint}
            if kind:
                entry["kind"] = kind
            tools.append(entry)
            seen_tools.add(tid)
    base["intents"] = intents
    base["tools"] = tools
    return base

def _capabilities_prompt_block() -> str:
    caps = _load_capabilities()
    intents = caps.get("intents", []) if isinstance(caps.get("intents", []), list) else []
    tools = caps.get("tools", []) if isinstance(caps.get("tools", []), list) else []
    intent_ids: List[str] = []
    for it in intents:
        if isinstance(it, dict):
            ii = str(it.get("id", "")).strip()
            if ii:
                intent_ids.append(ii)
    tool_lines: List[str] = []
    for t in tools:
        if not isinstance(t, dict):
            continue
        tid = str(t.get("id", "")).strip()
        tint = str(t.get("intent", "")).strip()
        tkind = str(t.get("kind", "")).strip()
        targs = t.get("args", []) if isinstance(t.get("args", []), list) else []
        args_txt = ", ".join(str(a) for a in targs[:8]) if targs else "-"
        if tid and tint:
            if tkind:
                tool_lines.append(f"- {tid} -> {tint} | kind: {tkind} | args: {args_txt}")
            else:
                tool_lines.append(f"- {tid} -> {tint} | args: {args_txt}")
    if not intent_ids and not tool_lines:
        return ""
    lines = ["Aktuelle Bot-Capabilities (verbindlich):"]
    if intent_ids:
        lines.append("Intents: " + ", ".join(intent_ids))
    lines.extend(tool_lines)
    lines.append("WICHTIG: Wenn du Scripte erstellst, die Dateien lesen, baue IMMER robuste Fehlerbehandlung (try-except) und eine Pruefung des Datenformats ein.")
    return "\n".join(lines)

@asynccontextmanager
async def lifespan(_: FastAPI):
    global _chat_queue
    cfg = _cfg()

    # CLI Logger
    from app.tool_engine import tool_store
    tool_store.log_fn = _cli_log_handler

    # Queue Initialisierung
    try:
        if _chat_queue is None:
            _chat_queue = ChatRequestQueue()
            _chat_queue.set_chat_reply_fn(_chat_reply)
            _chat_queue.start()
            print("[INIT] ChatRequestQueue started.")
    except Exception as exc:
        print(f"[ERROR] Queue: {exc}")

    # Job-Timeout Watchdog starten (unabhängig von API-Polls)
    global _watchdog_thread
    try:
        _watchdog_stop_event.clear()
        _watchdog_thread = threading.Thread(
            target=_watchdog_worker_loop,
            name="kaia-job-watchdog",
            daemon=True,
        )
        _watchdog_thread.start()
        print("[INIT] Job-Watchdog started (30s interval).")
    except Exception as exc:
        print(f"[ERROR] Watchdog: {exc}")
    # MCP Tools (Asynchron starten um Blockaden zu vermeiden)
    async def _mcp_startup_task():
        try:
            from app.mcp_tools import refresh_mcp_tools
            loop = asyncio.get_running_loop()
            await loop.run_in_executor(None, refresh_mcp_tools, cfg)
            print("[INIT] MCP Tools ready.")
        except Exception as exc:
            print(f"[ERROR] MCP Background Init: {exc}")

    asyncio.create_task(_mcp_startup_task())

    # Messenger & Execution Plane
    try:
        # Queue-Submit-Wrapper für Messenger
        def _messenger_queue_submit(message: str, **kwargs) -> str:
            """
            Wrapper: Messenger → Queue → _chat_reply
            Signatur: (message, result_callback=None, source=..., dialog_key=..., ...)
            """
            result_callback = kwargs.pop("result_callback", None)
            
            if _chat_queue:
                request_id, started_event = _chat_queue.submit(
                    message=message,
                    cfg=_cfg(),
                    result_callback=result_callback or (lambda r: None),
                    **kwargs
                )
                return f"queued:{request_id}"
            else:
                # Fallback wenn Queue nicht läuft
                result = _chat_reply(message, _cfg(), **kwargs)
                if result_callback:
                    result_callback(result)
                return str(result.get("reply", ""))
        
        messenger_runtime.start(cfg=cfg, reply_fn=_messenger_queue_submit, log_fn=lambda m: tool_store.log("messenger", m))
        if _execution_plane_enabled(cfg):
            execution_plane_runtime.ensure_started(cfg, log_fn=lambda m: tool_store.log("execution_plane", m))
    except Exception as exc:
        print(f"[ERROR] Runtime: {exc}")

    # Cron Worker starten
    try:
        _cron_start_worker()
        print("[INIT] Cron worker started.")
    except Exception as exc:
        print(f"[ERROR] Cron worker: {exc}")

    # Self-Improve Worker starten
    try:
        _self_improve_start_worker()
        print("[INIT] Self-improve worker started.")
    except Exception as exc:
        print(f"[ERROR] Self-improve worker: {exc}")

    yield

    # Shutdown
    messenger_runtime.stop()
    if _execution_plane_enabled(cfg):
        execution_plane_runtime.stop(cfg)
    _cron_stop_worker()
    _self_improve_stop_worker()
    _cli_anim_stop.set()
    _watchdog_stop_event.set()  # Job-Watchdog sauber beenden

