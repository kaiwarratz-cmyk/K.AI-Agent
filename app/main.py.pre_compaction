@app.post("/api/ui/config")
def set_ui_config(req: Dict[str, Any]) -> Dict[str, Any]:
    """Speichert UI-Optionen, React-Retry-Config und React-Loop-Config."""
    cfg = _cfg()
    
    # Update UI-Optionen
    if any(k in req for k in ["quiet_mode", "show_thinking", "show_actions"]):
        ui_cfg = cfg.get("ui", {}) if isinstance(cfg.get("ui", {}), dict) else {}
        if "quiet_mode" in req:
            ui_cfg["quiet_mode"] = bool(req["quiet_mode"])
        if "show_thinking" in req:
            ui_cfg["show_thinking"] = bool(req["show_thinking"])
        if "show_actions" in req:
            ui_cfg["show_actions"] = bool(req["show_actions"])
        cfg["ui"] = ui_cfg
    
    # Update React-Retry-Optionen
    if any(k in req for k in ["react_retry_enabled", "react_max_retries", "react_use_loop", "react_max_iterations", "llm_timeout_sec"]):
        react_cfg = cfg.get("react", {}) if isinstance(cfg.get("react", {}), dict) else {}
        if "react_retry_enabled" in req:
            react_cfg["retry_enabled"] = bool(req["react_retry_enabled"])
        if "react_max_retries" in req:
            react_cfg["max_retries"] = int(req["react_max_retries"])
        if "react_use_loop" in req:
            react_cfg["use_loop"] = bool(req["react_use_loop"])
        if "react_max_iterations" in req:
            react_cfg["max_iterations"] = int(req["react_max_iterations"])
        cfg["react"] = react_cfg
        
        # LLM Timeout in cli_core
        if "llm_timeout_sec" in req:
            core_cfg = cfg.get("cli_core", {}) if isinstance(cfg.get("cli_core", {}), dict) else {}
            core_cfg["llm_timeout_sec"] = int(req["llm_timeout_sec"])
            cfg["cli_core"] = core_cfg

        # NEU: Max Step Timeout in cli_core
        if "max_step_timeout_sec" in req:
            core_cfg = cfg.get("cli_core", {}) if isinstance(cfg.get("cli_core", {}), dict) else {}
            core_cfg["max_step_timeout_sec"] = int(req["max_step_timeout_sec"])
            cfg["cli_core"] = core_cfg

        # NEU: Execution Plane Request Timeout
        if "request_timeout_sec" in req:
            ep_cfg = cfg.get("execution_plane", {}) if isinstance(cfg.get("execution_plane", {}), dict) else {}
            ep_cfg["request_timeout_sec"] = int(req["request_timeout_sec"])
            cfg["execution_plane"] = ep_cfg

        save_config(cfg)    
    return {"ok": True, "message": "Einstellungen gespeichert"}

