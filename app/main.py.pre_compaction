                                            "```python\n"
                                            "import inspect\n"
                                            "print(dir(objekt))  # Alle verfügbaren Attributes/Methoden\n"
                                            "print(help(objekt))  # Dokumentation\n"
                                            "print(inspect.signature(objekt.methode))  # Exakte Signatur\n"
                                            "```\n"
                                        )
                                    elif "TypeError" in res_text:
                                        diagnostic_action = (
                                            "❌ TypeError: Falsche Argument-Typen oder -Anzahl.\n\n"
                                            "NÄCHSTER SCHRITT: Zeige die exakte Signatur:\n"
                                            "```python\n"
                                            "import inspect\n"
                                            "print(inspect.signature(funktion_oder_klasse))\n"
                                            "help(funktion_oder_klasse)  # Parameter & Typen\n"
                                            "```\n"
                                        )
                                    elif "SyntaxError" in res_text or "IndentationError" in res_text:
                                        diagnostic_action = (
                                            "❌ SyntaxError/IndentationError in deinem Code.\n\n"
                                            "NÄCHSTER SCHRITT: Der Code muss syntaktisch valide sein.\n"
                                            "Nutze Python-Linter lokal (`python -m py_compile datei.py`) oder verbessere die Syntax.\n"
                                        )
                                    else:
                                        diagnostic_action = (
                                            f"❌ {_exc_type}: {_exc_line}\n\n"
                                            "NÄCHSTER SCHRITT: Lies den KOMPLETTEN Traceback oben, nicht nur die letzte Zeile.\n"
                                            "Der echte Fehler steht meist weiter oben. Suche nach 'File' und 'line X'.\n"
                                        )

                                    history.append({"role": "user", "content": (
                                        f"[PROFESSIONAL-RECOVERY] Fehler #{_error_type_counts[_exc_type]}: {_exc_type}\n\n"
                                        f"{diagnostic_action}\n"
                                        "🚨 REGEL: Wiederhole NICHT blind denselben Code!\n"
                                        "Diagnose FIRST, dann adapting code. Kein 'raten'."
                                    )})

                                    # 🧠 PHASE 3: API-spezifische strukturierte Diagnose
                                    # Wenn unbekannte API-Fehler (TypeError, AttributeError auf APIs)
                                    if _error_type_counts[_exc_type] == 1 and _exc_type in {"TypeError", "AttributeError"}:
                                        # Erkennen ob es um API-Nutzung geht
                                        api_patterns = ["__init__", "Client", "API", "import ", "session", "async"]
                                        is_api_error = any(pattern in res_text for pattern in api_patterns)

                                        if is_api_error:
                                            # Extrahiere Klassennamen aus Fehler
                                            import re as _re_api
                                            class_match = _re_api.search(r"'([A-Za-z_]\w+)'\s+object", res_text)
                                            class_name = class_match.group(1) if class_match else "ApiClass"

                                            history.append({"role": "user", "content": (
                                                f"💡 API-DEBUGGING PROTOKOLL für '{class_name}':\n\n"
                                                "Folge DIESE Schritte systematisch (nicht blind variieren):\n\n"
                                                "SCHRITT 1: Inspiziere die Signatur\n"
                                                f"```python\n"
                                                f"import inspect\n"
                                                f"print('Signatur:', inspect.signature({class_name}.__init__))\n"
                                                f"print('Doku:', inspect.getdoc({class_name}.__init__))\n"
                                                f"print('Methoden:', [m for m in dir({class_name}) if not m.startswith('_')])\n"
                                                f"```\n\n"
                                                "SCHRITT 2: Dokumentation suchen\n"
                                                f"→ GitHub README für '{class_name}' oder offizielle API-Docs\n"
                                                "→ Kopiere EXAKTEN Beispielcode von dort\n\n"
                                                "SCHRITT 3: Beispiel testen\n"
                                                "→ Kopiere Code aus Docs GENAU wie dort\n"
                                                "→ Nutze print() zum Debuggen, nicht zum Raten\n\n"
                                                "SCHRITT 4: Speichern wenn erfolgreich\n"
                                                f"→ Wenn es funktioniert: mem_save_fact('api_{class_name.lower()}_correct_usage', 'was funktioniert hat')\n\n"
                                                "🚨 NICHT: Verschiedene Parameter blind versuchen\n"
                                                "✅ SONDERN: Verstehen → Kopieren → Debuggen → Speichern"
                                            )})

                                    # 🚨 FIX 1 COMPLETION: Error-Type Loop Abort bei >= 3 gleicher Exception
                                    if _error_type_counts[_exc_type] >= 3:
                                        _abort_msg = (
                                            f"🚫 ═══════════════════════════════════════════════════════════\n"
                                            f"ABORT: Error-Type Loop Detection (Fehler #{_error_type_counts[_exc_type]})\n"
                                            f"═══════════════════════════════════════════════════════════\n\n"
                                            f"Der Fehler '{_exc_type}' ist bereits {_error_type_counts[_exc_type]}× hintereinander aufgetreten.\n"
                                            f"Das ist ein Pattern → dieser Ansatz funktioniert NICHT.\n\n"
                                            f"MÖGLICHE URSACHEN:\n"
                                            f"• Falsche oder abgelaufene Credentials/API-Key\n"
                                            f"• API-Schnittstelle hat sich geändert\n"
                                            f"• Erforderliche Berechtigung nicht vorhanden\n"
                                            f"• Feature wird von der API nicht unterstützt\n"
                                            f"• System/Abhängigkeit ist kaputt\n\n"
                                            f"WHAT TO DO:\n"
                                            f"1. Erkläre dem Nutzer EHRLICH was nicht funktioniert\n"
                                            f"2. Erkläre WARUM (basierend auf Fehlern)\n"
                                            f"3. Setze done=True um den Job zu beenden\n"
                                            f"═══════════════════════════════════════════════════════════\n"
                                        )
                                        history.append({"role": "user", "content": _abort_msg})
                                        # AUCH im Log speichern damit es visible ist
                                        tool_store.log("main", f"ABORT_ERROR_LOOP: {_exc_type} (#{_error_type_counts[_exc_type]})")
                                        done = True

                        # Fix 2: Konsekutive Fehler-Schleife MIT Session-Reset (wie echte REPL-Systeme)
                        # "already satisfied" pip-install zählt NICHT als echter Fortschritt
                        _pip_already = (kind == "python_pip_install" and "already satisfied" in res_text.lower())
                        if ok and not _pip_already:
                            _consecutive_tool_failures = 0
                        else:
                            _consecutive_tool_failures += 1

                            # Session-Reset bei hartnäckigen Fehlern (nach 3 echten Versuchen)
                            if _consecutive_tool_failures >= 3:
                                try:
                                    from app.tools import python_exec as py_mod
                                    _tid = _trace_id_ctx.get() or ""
                                    if _tid:
                                        py_mod.cleanup_session(_tid)
                                        _reset_msg = (
                                            f"🔄 ═══════════════════════════════════════════════════════════\n"
                                            f"SYSTEM: Python Session zurückgesetzt\n"
                                            f"═══════════════════════════════════════════════════════════\n"
                                            f"Nach {_consecutive_tool_failures} aufeinanderfolgende Fehlern:\n"
                                            f"• Alte Python Session beendet\n"
                                            f"• Neue Session gestartet (sauberer State)\n"
                                            f"• Alle Variablen/Imports gelöscht\n\n"
                                            f"Du kannst jetzt einen NEUEN ANSATZ versuchen.\n"
                                            f"═══════════════════════════════════════════════════════════\n"
                                        )
                                        history.append({"role": "user", "content": _reset_msg})
                                        tool_store.log("main", f"SESSION_RESET: After {_consecutive_tool_failures} consecutive failures")
                                except Exception as _e:
                                    tool_store.log("main", f"Session reset failed: {_e}")

                            # Nach JEDEM Fehler: konkrete Diagnose-Anweisung (kein "radikal ändern")
                            if _consecutive_tool_failures == 1:
                                history.append({"role": "user", "content": (
                                    f"⚠️ WARNUNG (Fehler #{_consecutive_tool_failures}):\n"
                                    f"Tool '{kind}' ist fehlgeschlagen.\n\n"
                                    f"Ergebnis: {res_text[:500]}\n\n"
                                    "PROFESSIONELLE DIAGNOSE JETZT:\n"
                                    "1. Lies den KOMPLETTEN Traceback (oben, alle Zeilen)\n"
                                    "2. Identifiziere die Zeile mit 'File' die das Problem verursacht\n"
                                    "3. Fasse nicht Mut — nutze print() für Debugging bevor du retryest"
                                )})
                            elif _consecutive_tool_failures == 2:
                                history.append({"role": "user", "content": (
                                    f"🚨 KRITISCH (Fehler #{_consecutive_tool_failures}):\n"
                                    f"'{kind}' ist ZWEIMAL fehlgeschlagen. Der bisherige Ansatz funktioniert nicht.\n\n"
                                    "ERZWINGENDE DIAGNOSE jetzt:\n"
                                    "- Schreibe Code der den STATE ausdruckt (print(), dir(), type(), etc.)\n"
                                    "- Versuche NICHT die gleiche Operation nochmal\n"
                                    "- Rückgängigmachen + anderer Ansatz"
                                )})
                            elif _consecutive_tool_failures >= 3:
                                _abort_msg = (
                                    f"🚫 ═══════════════════════════════════════════════════════════\n"
                                    f"ABORT: Consecutive Failures (Fehler #{_consecutive_tool_failures})\n"
                                    f"═══════════════════════════════════════════════════════════\n\n"
                                    f"{_consecutive_tool_failures} aufeinanderfolgende Tool-Fehler.\n"
                                    f"Das System ist entweder überlastet oder fundamental kaputt.\n"
                                    f"Python Session wird zurückgesetzt.\n\n"
                                    f"WHAT TO DO:\n"
                                    f"1. Erkläre dem Nutzer EHRLICH was fehlgeschlagen ist\n"
                                    f"2. Erkläre WARUM es nicht weitergehen kann\n"
                                    f"3. Gib konkrete Alternativen oder nächste Schritte\n"
                                    f"4. Setze done=True um den Job zu beenden\n"
                                    f"═══════════════════════════════════════════════════════════\n"
                                )
                                history.append({"role": "user", "content": _abort_msg})
                                # AUCH im Log speichern damit es visible ist
                                tool_store.log("main", f"ABORT_CONSECUTIVE_FAILURES: {_consecutive_tool_failures} errors in a row")
                                done = True

                            tool_store.log("main", f"Error recovery nudge #{_consecutive_tool_failures} injected.")

                        _consecutive_local_only = 0  # echte Aktion → Zähler zurücksetzen
                        _real_action_count += 1      # echter Tool-Call gezählt
                        iteration += 1  # Nur echte Tool-Calls zählen gegen das Iterations-Limit
                        
                        # Phase 8: Quality Gate Tracking
                        if kind in {"fs_write_file", "fs_edit_replace", "fs_apply_patch", "fs_append"}:
                            _code_modified_in_job = True
                        if kind in {"sys_python_exec", "sys_cmd_exec", "terminal_background_run"}:
                            _test_executed_in_job = True

                        # 🚨 Wenn die Aktion selbst cancelled=True zurückgegeben hat → sofort stoppen
                        if res_dict.get("cancelled"):
                            _react_push_status("🛑 Job abgebrochen.", cfg, dialog_key)
                            _kill_all_subprocesses(trace_id)
                            _cleanup_subprocesses(trace_id)
                            return {"ok": False, "reply": res_text, "steps": all_steps_log, "cancelled": True}
                except Exception as e:
                    res_text, ok = f"CRITICAL ERROR: {e}", False

                # 🚨 CANCELLATION CHECK nach Tool-Ausführung
                # Wenn während des Tool-Calls abgebrochen wurde, sofort beenden
                if _job_is_cancelled(trace_id):
                    _react_push_status("🛑 Job abgebrochen (während Tool-Ausführung).", cfg, dialog_key)
                    _kill_all_subprocesses(trace_id)  # Kill any remaining subprocesses
                    _cleanup_subprocesses(trace_id)
                    return {"ok": False, "reply": "Job wurde während Tool-Ausführung abgebrochen.", "steps": all_steps_log, "cancelled": True}

                critique = validator.reflect_tool_result(kind, action, res_text, ok)
                if critique: res_text = f"{res_text}\n\n{critique}"

                # Tool-Output-Size-Cap – verhindert Context-Window-Overflow.
                # Unter cap-Schwelle: direkt zurückgeben.
                # Über cap-Schwelle: automatisch in Datei speichern und Pfad zurückgeben,
                # damit das LLM alle Ergebnisse via sys_python_exec/fs_grep verarbeiten kann.
                # Schwellwert ist in config.json unter tools.tool_output_cap_chars konfigurierbar.
                _MAX_TOOL_OUTPUT_CHARS = int(cfg.get("tools", {}).get("tool_output_cap_chars", 25_000) or 25_000)
                if len(res_text) > _MAX_TOOL_OUTPUT_CHARS:
                    # Verhindere Auto-Save-Loop: Wenn ein Tool eine bereits gespeicherte Datei
                    # aus tool_outputs/ liest und das Ergebnis wieder zu groß ist, nicht nochmal speichern.
                    _is_tool_output_read = (
                        kind in {"fs_read_file", "fs_read"}
                        and "tool_outputs" in str(action.get("path", "") or "")
                    )
                    if _is_tool_output_read:
                        # Direkt abschneiden mit klarer Anweisung – kein weiterer Auto-Save
                        _over = len(res_text) - _MAX_TOOL_OUTPUT_CHARS
                        res_text = (
                            res_text[:_MAX_TOOL_OUTPUT_CHARS]
                            + f"\n\n[WICHTIG: Ausgabe bei {_MAX_TOOL_OUTPUT_CHARS} Zeichen abgeschnitten "
                            f"({_over} weitere Zeichen). "
                            f"NICHT nochmal fs_read_file verwenden – nutze stattdessen "
                            f"sys_python_exec mit open(pfad, encoding='utf-8') oder fs_grep zum Filtern.]"
                        )
                    else:
                        try:
                            import datetime as _dt
                            _ts = _dt.datetime.now().strftime("%Y%m%d_%H%M%S")
                            _out_dir = ROOT_DIR / "data" / "workspace" / "tool_outputs"
                            _out_dir.mkdir(parents=True, exist_ok=True)
                            _out_file = _out_dir / f"{kind}_{_ts}.txt"
                            _out_file.write_text(res_text, encoding="utf-8")
                            _n_lines = res_text.count("\n") + 1
                            _preview = res_text[:800].rstrip()
                            # Pfad mit Forward-Slashes für Python (vermeidet \t-, \k-, \d-Escape-Sequenzen)
                            _safe_path = str(_out_file).replace("\\", "/")
                            # 🚨 REGISTRIERE die erstellte Datei
                            _register_file(trace_id, _safe_path, f"Tool-Output von {kind}")
                            res_text = (
                                f"Ausgabe zu gross fuer direkten Context "
                                f"({len(res_text):,} Zeichen, ~{_n_lines:,} Zeilen).\n"
                                f"Vollstaendige Ergebnisse gespeichert: {_safe_path}\n\n"
                                f"Vorschau (erste 800 Zeichen):\n{_preview}"
                            )
                        except Exception as _save_err:
                            _over = len(res_text) - _MAX_TOOL_OUTPUT_CHARS
                            res_text = (
                                res_text[:_MAX_TOOL_OUTPUT_CHARS]
                                + f"\n\n[... Ausgabe bei {_MAX_TOOL_OUTPUT_CHARS} Zeichen abgeschnitten"
                                f" – {_over} weitere Zeichen weggelassen (Speichern fehlgeschlagen: {_save_err}) ...]"
                            )

                status_symbol = "\u2705" if ok else "\u274C"
                # WICHTIG: Beobachtung/Ergebnis als NEUE Nachricht senden (ist_thought=False = Standard)
                obs_message = f"{status_symbol} {res_text[:120]}"
                _react_push_status(obs_message, cfg, dialog_key)  # is_thought=False (default)
                _cli_live_emit("observation", {"reply": res_text})

                all_steps_log.append({"iteration": iteration, "kind": kind, "action": action, "reply": res_text, "ok": ok})
                # _tool_id für natives Tool Calling (Anthropic/OpenAI benötigen ID-Tracking)
                history.append({
                    "role": "tool",
                    "tool": kind,
                    "content": res_text,
                    "_tool_id": str(action.get("_tool_id", "") or ""),
                })

                # Cycle 11: Self-Healing / Diagnostic Logic (Intervention & Reset)
                if not ok:
                    _consecutive_tool_failures += 1
                    
                    # Session-Reset bei persistenten Fehlern
                    if _consecutive_tool_failures >= 2:
                        try:
                            from app.tools import python_exec as py_mod
                            py_mod.kill_persistent_session(_trace_id_ctx.get("") or "")
                            tool_store.log("main", f"Restarting Python Session after {_consecutive_tool_failures} errors.")
                        except Exception: pass

                    if _consecutive_tool_failures >= 1:
                        history.append({
                            "role": "user", 
                            "content": (
                                f"🚨 GEBOT: STOPP & ANALYSE (Fehler #{_consecutive_tool_failures})\n"
                                f"Tool '{kind}' ist fehlgeschlagen.\n"
                                f"Message: {res_text[:300]}...\n\n"
                                "Du DARFST NICHT den identischen Aufruf wiederholen!\n"
                                "1. Nutze `sys_python_exec` für Diagnose (`print(sys.path)`, `print(dir())`).\n"
                                "2. Validiere deine Variablen.\n"
                                "3. ÄNDERE DEINE STRATEGIE RADIKAL. Raten ist verboten."
                            )
                        })
                        tool_store.log("main", f"Self-healing nudge (Native) injected.")
                else:
                    _consecutive_tool_failures = 0

                # Vision-Feedback: Wenn ein Bild an den Nutzer gesendet wurde, dem LLM das Bild zeigen,
                # damit es weiß was es gesendet hat (z.B. für Folgefragen zum Bildinhalt).
                if kind == "send_messenger_file" and ok:
                    _smf_path = str(action.get("path", action.get("file_path", "")) or "")
                    if _smf_path:
                        from pathlib import Path as _SmfPath
                        _smf_p = _SmfPath(_smf_path)
                        _SMF_IMG_EXTS = {".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp"}
                        if _smf_p.suffix.lower() in _SMF_IMG_EXTS:
                            try:
                                import base64 as _smf_b64, mimetypes as _smf_mt
                                if _smf_p.exists() and _smf_p.stat().st_size <= 3 * 1024 * 1024:
                                    _smf_mime = _smf_mt.guess_type(str(_smf_p))[0] or "image/jpeg"
                                    _smf_blob = _smf_b64.b64encode(_smf_p.read_bytes()).decode()
                                    history.append({
                                        "role": "user",
                                        "content": "[SYSTEM] Das folgende Bild wurde soeben an den Nutzer gesendet:",
                                        "_images": [{"media_type": _smf_mime, "data": _smf_blob, "filename": _smf_p.name}],
                                    })
                            except Exception:
                                pass

                # Followup nach Tool-Call prüfen: LLM soll sofort reagieren können
                _post_tool_followup = _chat_queue.pop_followup_for_dialog(dialog_key) if _chat_queue else None
                if _post_tool_followup:
                    _react_push_status("\U0001F4E5 Neue Nachricht empfangen...", cfg, dialog_key)
                    history.append({"role": "user", "content": f"[ZWISCHENNACHRICHT] {_post_tool_followup}"})

                # MCP-Katalog-Update: wenn neue Tools installiert/refreshed wurden → direkt injizieren
                if _mcp_catalog_dirty.is_set():
                    _mcp_catalog_dirty.clear()
                    with contextlib.suppress(Exception):
                        from app.mcp_tools import get_cached_mcp_tools
                        _new_mcp = get_cached_mcp_tools()
                        if _new_mcp:
                            _tool_lines = "\n".join(
                        f"  - {t.get('function', {}).get('name') or t.get('name', '?')}: {str((t.get('function', {}) or t).get('description',''))[:80]}"
                        for t in _new_mcp[:30]
                    )
                            history.append({"role": "system", "content":
                                f"[MCP-TOOLS AKTUALISIERT] {len(_new_mcp)} MCP-Tool(s) jetzt verfügbar:\n{_tool_lines}\n"
                                f"Diese Tools sind sofort direkt als Actions aufrufbar — benutze den Tool-Namen als 'kind' (z.B. kind='com_pulsemcp_servers_pulse_fetch__scrape'). KEIN mcp_call-Wrapper nötig!"
                            })
                
            except LLMRouterError as e:
                # LLM-Verbindungsfehler: Schritt NICHT zählen – das ist kein Task-Fehler.
                # llm_timeout_sec steuert nur den HTTP-Verbindungs-Timeout, nicht den Job-Ablauf.
                _llm_consecutive_errors += 1
                _react_push_status(
                    f"⚠️ LLM nicht erreichbar (Versuch {_llm_consecutive_errors}/3): {str(e)[:120]}",
                    cfg, dialog_key
                )
                _append_error_log("llm_connection_error", str(e))
                if _llm_consecutive_errors >= 3:
                    return {
                        "ok": False,
                        "reply": f"LLM nach {_llm_consecutive_errors} aufeinanderfolgenden Fehlern nicht erreichbar. Bitte Provider-Konfiguration prüfen.",
                        "steps": all_steps_log,
                    }
                time.sleep(3)
                # Iteration NICHT erhöhen – beim nächsten Durchlauf erneut versuchen
                continue
            except Exception as e:
                _react_push_status(f"\u274C System-Fehler: {e}", cfg, dialog_key)
                _critical_errors += 1
                if _critical_errors > 5: break  # Nur echte aufeinanderfolgende Crashes → Abbruch
    finally:
        _watchdog_active.clear()  # Watchdog-Thread stoppen
        typing_active = False
        _cli_anim_job_end()
        # Status-Message-Registries leeren – verhindert Leck bei Abbruch/Fehler/Max-Iter
        with _react_status_tg_lock:
            _react_action_msg.pop(dialog_key, None)
            _react_thought_msgs.pop(dialog_key, None)

    return {"ok": False, "reply": "Maximale Iterationen erreicht.", "steps": all_steps_log}

def _chat_reply(
    message: str,
    cfg: Dict[str, Any],
    source: str = "api",
    dialog_key: str = "api",
    trace_id: Optional[str] = None,
    platform: str = "unknown",
    chat_id: Optional[str] = None,
    user: Optional[str] = None,
    channel_id: Optional[str] = None,
    images: Optional[List[Dict[str, Any]]] = None,
    **_extra_kwargs,
) -> Dict[str, Any]:
    tid = str(trace_id or _new_trace_id())
    token = _trace_id_ctx.set(tid)
    token_dialog = _dialog_key_ctx.set(str(dialog_key or ""))
    _runtime_interp: Dict[str, Any] = {}
    _runtime_steps: List[str] = []
    _runtime_action_intent_expected = False
    _strict_verify_guard = {"running": False}
    # Universeller Job-Timeout – gilt für alle Quellen (Telegram, Discord, WebUI, API).
    # Einzige Quelle: execution_plane.request_timeout_sec (konfigurierbar im WebUI).
    max_runtime_sec = int(cfg.get("execution_plane", {}).get("request_timeout_sec", 1800) or 1800)
    max_runtime_sec = max(30, min(7200, max_runtime_sec))
    raw_user_input = str(message or "")
    # SCHRITT 0: Semantischer Recall direkt in _chat_reply (Worker-Ebene)
    _audit_event("chat_reply_start", {"trace_id": tid, "source": source, "dialog_key": dialog_key, "message_len": len(message)})
    semantic_context = ""
    try:
        import re as _re
        _poison_check = lambda t: any(_re.search(p, str(t).lower()) for p in _MEMORY_POISON_PATTERNS)
        _audit_event("semantic_recall_start", {"trace_id": tid})
        from app.chroma_memory import ChromaMemoryStore
        ms = _memory_store(cfg)
        # Mindest-Ähnlichkeit: Nur Fakten mit >= 65% Relevanz zum aktuellen Query
        # werden injiziert, um Kontext-Kontamination durch Fakten aus anderen
        # Themengebieten zu vermeiden.
        _RECALL_MIN_SIMILARITY = 0.65
        facts = ms.search(message, limit=3, collection_name="important", min_similarity=_RECALL_MIN_SIMILARITY)
        facts = [f for f in facts if not _poison_check(f.get('text', ''))]
        # Filtere improvement_signal-Fakten heraus – diese sind interne Signale,
        # keine Nutzerfakten, und sollten NICHT in den Kontext injiziert werden.
        facts = [f for f in facts if "improvement_signal" not in str(f.get('text', ''))]
        if facts:
            semantic_context += "\nVERIFIZIERTE NUTZERFAKTEN (nicht erneut prüfen):\n" + "\n".join([f"- {f.get('text','')}" for f in facts])

        workflows = ms.search(message, limit=2, collection_name="workflow_success", min_similarity=_RECALL_MIN_SIMILARITY)
        workflows = [w for w in workflows if not _poison_check(w.get('text', ''))]
        if workflows:
