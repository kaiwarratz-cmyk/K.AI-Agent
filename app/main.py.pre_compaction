@LocalActionDispatcher.register("mcp_registry_install")
def _h_mcp_reg_inst(kind, action):
    from app.mcp_registry import install_from_registry
    res = install_from_registry(_cfg(), str(action.get("source_id", "")), str(action.get("name", "")))
    if not res.get("ok"): return kind, str(res.get("message", "Install-Vorschlag fehlgeschlagen."))
    ser = res.get("proposal", {})
    # Warnung bei Browser-basierten Paketen (könnten Windows-Dialoge öffnen)
    _browser_warn = res.get("browser_warning", False)
    if _browser_warn:
        tool_store.log("mcp_browser_warning", f"Browser-basiertes Paket: {action.get('name','')}")
    reg_kind, reg_msg = _mcp_register_server(_cfg(), {"name": action.get("name"), "command": ser.get("command"), "args": ser.get("args", []), "env": ser.get("env", {}), "type": ser.get("type", "stdio")})
    # npm-Package vorab installieren damit npx -y nicht beim ersten Start lädt
    server_name = action.get("name", "")
    _npm_pkg = None
    _pkg_args = ser.get("args", [])
    if ser.get("command", "") == "npx" and isinstance(_pkg_args, list) and len(_pkg_args) >= 2:
        # args = ["-y", "@package/name@version"] oder ["-y", "package"]
        _npm_pkg = _pkg_args[1] if _pkg_args[0] == "-y" else _pkg_args[0]
    if _npm_pkg:
        try:
            import subprocess as _sp
            import shutil as _shutil
            # npm.cmd suchen: zuerst via shutil, dann Fallback auf bekannte Node-Pfade
            _npm_cmd = _shutil.which("npm") or _shutil.which("npm.cmd")
            if not _npm_cmd:
                for _candidate in [
                    r"C:\Program Files\nodejs\npm.cmd",
                    r"C:\Program Files\nodejs\npm",
                    r"C:\Program Files (x86)\nodejs\npm.cmd",
                ]:
                    if Path(_candidate).exists():
                        _npm_cmd = _candidate
                        break
            if _npm_cmd:
                tool_store.log("mcp_npm_prefetch", f"npm install -g {_npm_pkg}")
                # CREATE_NO_WINDOW verhindert Windows-Popup-Dialoge bei npm-Subprocessen
                _cflags = 0x08000000 if __import__("sys").platform == "win32" else 0  # CREATE_NO_WINDOW
                # Windows: npm.cmd darf nicht direkt mit shell=False ausgeführt werden → cmd.exe /c
                _npm_run_args = [_npm_cmd, "install", "-g", _npm_pkg]
                if __import__("sys").platform == "win32" and (
                    str(_npm_cmd).lower().endswith(".cmd") or str(_npm_cmd).lower().endswith(".bat")
                ):
                    _npm_run_args = ["cmd.exe", "/c"] + _npm_run_args
                _sp.run(_npm_run_args, capture_output=True, timeout=120, shell=False, creationflags=_cflags)
            else:
                tool_store.log("mcp_npm_prefetch_error", "npm nicht gefunden, überspringe Prefetch")
        except Exception as _npm_err:
            tool_store.log("mcp_npm_prefetch_error", str(_npm_err))

    # Sofort refreshen und prüfen ob der Server tatsächlich MCP-Tools liefert
    new_tool_names: list = []
    refresh_err = ""
    try:
        from app.mcp_tools import refresh_mcp_tools, get_cached_mcp_tools
        _, refresh_msg = refresh_mcp_tools(_cfg())
        tool_store.log("mcp_reg_inst_refresh", refresh_msg)
        # Prüfen welche Tools vom neuen Server kommen
        all_tools = get_cached_mcp_tools()
        safe_key = re.sub(r"[^a-zA-Z0-9_]", "_", server_name)
        new_tool_names = [
            t.get("function", {}).get("name", "") or t.get("name", "")
            for t in all_tools
            if (t.get("mcp_meta", {}) or {}).get("server", "") == server_name  # Original-Key
            or (t.get("mcp_meta", {}) or {}).get("server", "") == safe_key      # Safe-Key
            or safe_key in str(t.get("function", {}).get("name", ""))            # Tool-Name-Präfix
        ]
        new_tool_names = [n for n in new_tool_names if n]
        _mcp_catalog_dirty.set()
    except Exception as _re:
        refresh_err = str(_re)
        tool_store.log("mcp_reg_inst_refresh_error", refresh_err)

    if not new_tool_names:
        # Server liefert keine Tools → wahrscheinlich kein echter MCP-Server → wieder entfernen
        with contextlib.suppress(Exception):
            _mcp_remove_server(_cfg(), {"name": server_name})
        err_hint = f" (Fehler: {refresh_err})" if refresh_err else ""
        return reg_kind, (
            f"⚠️ '{server_name}' wurde registriert, aber beim Start wurden KEINE MCP-Tools gefunden{err_hint}. "
            "Das npm-Package ist wahrscheinlich kein MCP-Server (nur ein CLI-Tool). "
            "Server wurde wieder entfernt. Bitte ein anderes Suchergebnis waehlen!"
        )

    tools_info = ", ".join(new_tool_names[:10])
    return reg_kind, (
        f"✅ MCP-Server '{server_name}' erfolgreich installiert.\n"
        f"Verfügbare Tools: {tools_info}\n"
        f"Diese Tools sind jetzt direkt als Actions nutzbar — NICHT via CLI oder Python-Import!"
    )

