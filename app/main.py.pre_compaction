def _extract_path_candidates(text: str) -> List[str]:
    raw = str(text or "")
    out: List[str] = []
    quoted = re.findall(r'"([^"]+)"', raw)
    for q in quoted:
        qq = str(q or "").strip()
        if qq and ("\\" in qq or "/" in qq):
            out.append(qq)
    path_hits = re.findall(r"([A-Za-z]:\\[^\s\"']+)", raw)
    for p in path_hits:
        pp = str(p or "").strip().rstrip(".,;)")
        if pp:
            out.append(pp)
    seen = set()
    uniq: List[str] = []
    for p in out:
        pl = p.lower()
        if pl in seen:
            continue
        seen.add(pl)
        uniq.append(p)
    return uniq

def _gmail_action_from_text(message: str) -> tuple[Optional[Dict[str, Any]], Optional[str]]:
    text = str(message or "").strip()
    low = text.lower()
    if not text:
        return None, None
    if not _has_any(low, ["gmail", "email", "e-mail", "mail", "mails", "emails", "posteingang", "inbox"]):
        return None, None
    # list intent
    list_intent = _has_any(
        low,
        [
            "liste",
            "zeige",
            "list",
            "lies",
            "lese",
            "lesen",
            "checke",
            "pruef",
            "prüf",
            "unread",
            "ungelesen",
            "posteingang",
            "inbox",
            "mails",
            "emails",
        ],
    ) and not _has_any(
        low, ["sende", "schick", "send", "mail an", "verschicke"]
    )
    if list_intent:
        action: Dict[str, Any] = {"kind": "gmail_list_messages"}
        m_q = re.search(r"(?:query|suche|filter)\s*[:=]\s*(\"[^\"]+\"|'[^']+'|[^\n]+)$", text, flags=re.IGNORECASE)
        if m_q:
            q = str(m_q.group(1) or "").strip().strip('"').strip("'")
            if q:
                action["query"] = q
        elif _has_any(low, ["ungelesen", "unread"]):
            action["query"] = "is:unread"
        m_n = re.search(r"(?:max|limit|anzahl)\s*[:=]?\s*(\d{1,2})", low, flags=re.IGNORECASE)
        if m_n:
            with contextlib.suppress(Exception):
                action["max_results"] = max(1, min(20, int(m_n.group(1))))
        # Natural phrasing: "lese meine letzten 5 mails"
        m_last_n = re.search(r"(?:letzten|letzte|last)\s+(\d{1,2})\b", low, flags=re.IGNORECASE)
        if (not isinstance(action.get("max_results", None), int)) and m_last_n:
            with contextlib.suppress(Exception):
                action["max_results"] = max(1, min(20, int(m_last_n.group(1))))
        return action, None
    send_intent = _has_any(low, ["sende", "schick", "send", "mail an", "verschicke", "schicke"])
    if not send_intent:
        return None, None
    email_match = re.search(r"([A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,})", text)
    to = str(email_match.group(1) or "").strip() if email_match else ""
    subj = ""
    body = ""
    m_subj = re.search(
        r"(?:betreff|subject)\s*(?::|=)?\s*(\"[^\"]+\"|'[^']+'|.+?)(?=\s+(?:nachricht|text|body|inhalt)\b|[,;\n]|$)",
        text,
        flags=re.IGNORECASE,
    )
    if m_subj:
        subj = str(m_subj.group(1) or "").strip().strip('"').strip("'")
    m_body = re.search(r"(?:nachricht|text|body|inhalt)\s*(?::|=)?\s*(.+)$", text, flags=re.IGNORECASE)
    if m_body:
        body = str(m_body.group(1) or "").strip().strip('"').strip("'")
    has_attach_hint = _has_any(low, ["anhang", "anhaenge", "anhänge", "attachment", "attachments", "bild", "foto", "datei"])
    attachments = _extract_path_candidates(text) if has_attach_hint else []
    kind = "gmail_send_email_advanced" if attachments or _has_any(low, ["html"]) else "gmail_send_email"
    action = {"kind": kind}
    if to:
        action["to"] = to
    if subj:
        action["subject"] = subj
    if body:
        action["body"] = body
    if attachments:
        action["attachments"] = attachments
    required = ["to", "subject"]
    if kind == "gmail_send_email":
        required.append("body")
    missing = [k for k in required if not str(action.get(k, "") or "").strip()]
    if missing:
        return (
            None,
            f"Fuer `{kind}` fehlen Pflichtparameter: {', '.join(missing)}.\n"
            f"required: {', '.join(required)}\n"
            f"optional: " + ("thread_id" if kind == "gmail_send_email" else "body, html_body, attachments, cc, bcc, reply_to, thread_id"),
        )
    return action, None

def _intent_threshold(cfg: Dict[str, Any], intent: str) -> float:
    routing = cfg.get("routing", {}) if isinstance(cfg.get("routing", {}), dict) else {}
    per_intent = routing.get("intent_thresholds", {}) if isinstance(routing.get("intent_thresholds", {}), dict) else {}
    raw = per_intent.get(intent, _INTENT_DEFAULT_THRESHOLDS.get(intent, 0.62))
    try:
        return max(0.0, min(1.0, float(raw)))
    except Exception:
        return float(_INTENT_DEFAULT_THRESHOLDS.get(intent, 0.62))

def _domain_min_confidence(cfg: Dict[str, Any]) -> float:
    routing = cfg.get("routing", {}) if isinstance(cfg.get("routing", {}), dict) else {}
    raw = routing.get("domain_min_confidence", 0.58)
    try:
        return max(0.0, min(1.0, float(raw)))
    except Exception:
        return 0.58

def _llm_abstain_enabled(cfg: Dict[str, Any]) -> bool:
