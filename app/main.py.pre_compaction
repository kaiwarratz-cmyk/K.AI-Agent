def _cron_parse_run_at_iso(value: str) -> Optional[datetime]:
    raw = str(value or "").strip()
    if not raw:
        return None
    with contextlib.suppress(Exception):
        dt = datetime.fromisoformat(raw)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=datetime.now().astimezone().tzinfo)
        return dt.astimezone(timezone.utc)
    return None

def _cron_parse_schedule(schedule: str) -> tuple[Optional[int], Optional[datetime]]:
    s = str(schedule or "").strip().lower()
    if not s:
        return None, None
    
    # 1. Intervalle (every:10m oder every 10 minutes)
    m = re.fullmatch(r"every:?\s*(\d+)\s*([smhdtw]|sec|min|hour|day|week)s?", s)
    if m:
        amount = int(m.group(1))
        unit = str(m.group(2))[0]
        mult = {"s": 1, "m": 60, "h": 3600, "d": 86400, "t": 86400, "w": 604800}.get(unit, 60)
        return max(1, amount * mult), None
    
    # 2. Natürliche Sprache: "alle 5 Minuten", "jede Stunde", "every 10 minutes", etc.
    nl = re.search(r"(\d+)\s*(sekunde|second|minute|minuten|stunde|hour|stunden|tag|day|tage|days|woche|week)n?", s)
    if nl:
        amount = int(nl.group(1))
        unit_word = nl.group(2)
        unit_map = {
            "sekunde": 1, "second": 1,
            "minute": 60, "minuten": 60,
            "stunde": 3600, "hour": 3600, "stunden": 3600,
            "tag": 86400, "day": 86400, "tage": 86400, "days": 86400,
            "woche": 604800, "week": 604800,
        }
        mult = unit_map.get(unit_word, 60)
        return max(1, amount * mult), None
    # "jede Minute", "jede Stunde", "every hour", "every minute"
    single_nl = re.search(r"jede[rn]?\s+(minute|stunde|sekunde|tag|woche)|every\s+(minute|hour|second|day|week)", s)
    if single_nl:
        word = (single_nl.group(1) or single_nl.group(2) or "").strip()
        unit_map = {"minute": 60, "stunde": 3600, "hour": 3600, "sekunde": 1, "second": 1, "tag": 86400, "day": 86400, "woche": 604800, "week": 604800}
        return unit_map.get(word, 60), None

    # 3. Einmalige Verzögerung (in:5m oder in 5 minutes)
    m_in = re.fullmatch(r"in:?\s*(\d+)\s*([smhdtw]|sec|min|hour|day|week)s?", s)
    if m_in:
        amount = int(m_in.group(1))
        unit = str(m_in.group(2))[0]
        mult = {"s": 1, "m": 60, "h": 3600, "d": 86400, "t": 86400, "w": 604800}.get(unit, 60)
        dt = datetime.now(timezone.utc) + timedelta(seconds=amount * mult)
        return None, dt

    if s.startswith("at:"):
        dt = _cron_parse_run_at_iso(s[3:])
        return None, dt
    
    # 4. Standard cron expression (*/5 * * * * oder 0 */2 * * *)
    cron_raw = str(schedule or "").strip()
    if re.match(r'^[\d*/,\-]+(\s+[\d*/,\-]+){4,5}$', cron_raw.strip()):
        try:
            from croniter import croniter
            now_utc = datetime.now(timezone.utc)
            cron = croniter(cron_raw, now_utc)
            next_dt = cron.get_next(datetime)
            if next_dt.tzinfo is None:
                next_dt = next_dt.replace(tzinfo=timezone.utc)
            return None, next_dt
        except Exception:
            pass

    # Fallback für reines ISO Datum
    dt_iso = _cron_parse_run_at_iso(s)
    if dt_iso:
        return None, dt_iso

    return None, None

def _cron_next_run_utc(interval_sec: Optional[int], run_at: Optional[datetime]) -> Optional[str]:
    if isinstance(interval_sec, int) and interval_sec > 0:
        return (datetime.now(timezone.utc) + timedelta(seconds=int(interval_sec))).isoformat()
    if isinstance(run_at, datetime):
        return run_at.astimezone(timezone.utc).isoformat()
    return None

def _cron_job_from_action(action: Dict[str, Any]) -> Dict[str, Any]:
    now = datetime.now().isoformat()
    schedule = str(action.get("schedule", "") or "").strip()
    run_at_txt = str(action.get("run_at", "") or "").strip()
    interval_sec = action.get("interval_sec", None)
    parsed_interval: Optional[int] = None
    parsed_run_at: Optional[datetime] = None
    if isinstance(interval_sec, int) and not isinstance(interval_sec, bool) and int(interval_sec) > 0:
        parsed_interval = int(interval_sec)
    if schedule:
        si, sr = _cron_parse_schedule(schedule)
        if si:
            parsed_interval = si
        if sr:
            parsed_run_at = sr
    if run_at_txt:
        parsed_run_at = _cron_parse_run_at_iso(run_at_txt) or parsed_run_at
    job_id = f"cron-{uuid.uuid4().hex[:10]}"
    next_run = _cron_next_run_utc(parsed_interval, parsed_run_at)
    query_txt = str(action.get("query", "") or "").strip()
    embedded = dict(action.get("action", {})) if isinstance(action.get("action", {}), dict) else {}
    if not embedded:
        embedded = _cron_default_embedded_action(task=str(action.get("task", "") or ""), query=query_txt)
    platform_raw = str(action.get("platform", "") or "").strip().lower()
    platform = platform_raw if platform_raw in {"telegram", "discord", "webui"} else ""
    target = str(action.get("target", "") or "").strip()
    if platform and not target:
        remembered = _last_messenger_target(platform)
        if remembered:
            target = remembered
    if not platform:
        tg_target = _last_messenger_target("telegram")
        dc_target = _last_messenger_target("discord")
        if tg_target:
            platform = "telegram"
            target = tg_target
        elif dc_target:
            platform = "discord"
            target = dc_target
    return {
        "id": job_id,
        "task": str(action.get("task", "") or "").strip(),
        "schedule": schedule,
        "interval_sec": parsed_interval,
        "run_at": parsed_run_at.isoformat() if parsed_run_at else "",
        "next_run_at": str(next_run or ""),
        "query": query_txt,
        "action": embedded,
        "change_only": bool(action.get("change_only", False)),
        "last_observed_hash": str(action.get("last_observed_hash", "") or "").strip(),
        "last_observed_at": str(action.get("last_observed_at", "") or "").strip(),
        "dialog_key": str(action.get("dialog_key", "") or "").strip(),
        "platform": platform,
        "target": target,
        "enabled": True,
        "created_at": now,
        "updated_at": now,
        "last_run_at": "",
        "last_result": "",
    }

def _cron_jobs_overview(active_only: bool = False) -> str:
    jobs = _cron_jobs_load()
    if active_only:
        jobs = [j for j in jobs if bool(j.get("enabled", True))]
    if not jobs:
        return "Cron-Jobs: keine Eintraege vorhanden."
    lines = [f"Cron-Jobs ({'aktiv' if active_only else 'alle'}: {len(jobs)}):"]
    for i, raw in enumerate(jobs[:30], start=1):
        item = raw if isinstance(raw, dict) else {}
        job_id = str(item.get("id", f"job-{i}")).strip() or f"job-{i}"
        schedule = str(item.get("schedule", "") or "").strip() or "-"
        if item.get("interval_sec"):
            schedule = _format_interval_readable(item.get("interval_sec"))
        if item.get("run_at"):
            schedule = f"einmalig: {_format_datetime_readable(item.get('run_at'))}"
        task = str(item.get("task", item.get("action", item.get("prompt", "-")))).strip() or "-"
        enabled = bool(item.get("enabled", True))
        next_run = _format_datetime_readable(item.get("next_run_at", ""), fallback="")
        action_kind = ""
        if isinstance(item.get("action", {}), dict):
            action_kind = str(item.get("action", {}).get("kind", "") or "").strip()
        lines.append(f"{i}. {job_id} | {'aktiv' if enabled else 'pausiert'} | {schedule}")
        if bool(item.get("change_only", False)):
            lines.append("   modus: nur bei Aenderung melden")
        p = str(item.get("platform", "") or "").strip().lower()
        t = str(item.get("target", "") or "").strip()
        if p == "webui":
            lines.append("   zustellung: WebUI-Chat")
        elif not (p in {"telegram", "discord"} and t):
            lines.append("   zustellung: kein Messenger-Ziel hinterlegt")
        if action_kind:
            lines.append(f"   action: {action_kind}")
        if next_run:
            lines.append(f"   naechste Ausfuehrung: {next_run}")
        lines.append(f"   {task[:180]}")
    if len(jobs) > 30:
        lines.append(f"... weitere {len(jobs) - 30} Eintraege ausgeblendet.")
    return "\n".join(lines)

def _cron_create_from_action(action: Dict[str, Any]) -> Dict[str, Any]:
    job = _cron_job_from_action(action)
    
    # Schutz vor Debug-Files (success/field)
    embedded = job.get("action", {})
    if isinstance(embedded, dict) and embedded.get("kind") == "write_file":
        path = str(embedded.get("path", "")).strip().lower()
        if any(x in path for x in ["success", "field"]):
            return {"ok": False, "reply": "Fehler: 'write_file' auf Status-Dateien ist als Cron-Aktion nicht erlaubt. Bitte nutze eine funktionale Aktion (z.B. Smart Home Steuerung)."}

    if not str(job.get("task", "")).strip():
        return {"ok": False, "reply": "cron_create braucht task."}
    if not str(job.get("next_run_at", "")).strip():
        return {"ok": False, "reply": "Cron-Job braucht gueltige Zeitplanung (schedule/run_at/interval_sec)."}
    jobs = _cron_jobs_load()
    jobs.append(job)
    _cron_jobs_save(jobs)
    reply = f"Cron-Job angelegt: {job['id']} | naechste Ausfuehrung: {_format_datetime_readable(job['next_run_at'])} | task={job['task']}"
    p = str(job.get("platform", "")).strip().lower()
    t = str(job.get("target", "")).strip()
    has_delivery = (p in {"telegram", "discord"} and bool(t)) or (p == "webui")
    if not has_delivery:
        reply += "\nHinweis: Kein Messenger-Ziel gesetzt. Dieser Job wird ausgefuehrt, aber nicht aktiv in Telegram/Discord zugestellt."
    return {"ok": True, "reply": reply}

def _cron_update_job_state(job_id: str, enabled: Optional[bool]) -> Dict[str, Any]:
    jobs = _cron_jobs_load()
    jid = str(job_id or "").strip()
    if not jid:
        return {"ok": False, "reply": "job_id fehlt."}
    changed = False
    for job in jobs:
        if str(job.get("id", "")).strip() != jid:
            continue
        if enabled is not None:
            job["enabled"] = bool(enabled)
            if bool(enabled):
                interval = job.get("interval_sec", None)
                run_at = _cron_parse_run_at_iso(str(job.get("run_at", "") or ""))
                job["next_run_at"] = str(_cron_next_run_utc(int(interval) if isinstance(interval, int) else None, run_at) or "")
        job["updated_at"] = datetime.now().isoformat()
        changed = True
        break
    if not changed:
        return {"ok": False, "reply": f"Cron-Job nicht gefunden: {jid}"}
    _cron_jobs_save(jobs)
    if enabled is None:
        return {"ok": True, "reply": f"Cron-Job aktualisiert: {jid}"}
    return {"ok": True, "reply": f"Cron-Job {'fortgesetzt' if enabled else 'pausiert'}: {jid}"}

def _cron_delete_job(job_id: str) -> Dict[str, Any]:
    jobs = _cron_jobs_load()
    jid = str(job_id or "").strip()
    if not jid:
        return {"ok": False, "reply": "job_id fehlt."}
    kept = [j for j in jobs if str(j.get("id", "")).strip() != jid]
    if len(kept) == len(jobs):
        return {"ok": False, "reply": f"Cron-Job nicht gefunden: {jid}"}
    _cron_jobs_save(kept)
    return {"ok": True, "reply": f"Cron-Job geloescht: {jid}"}

def _cron_run_now(cfg: Dict[str, Any], job_id: str) -> Dict[str, Any]:
    jobs = _cron_jobs_load()
    jid = str(job_id or "").strip()
    if not jid:
        return {"ok": False, "reply": "job_id fehlt."}
    hit: Optional[Dict[str, Any]] = None
    for job in jobs:
        if str(job.get("id", "")).strip() == jid:
            hit = job
            break
    if not isinstance(hit, dict):
        return {"ok": False, "reply": f"Cron-Job nicht gefunden: {jid}"}
    now = datetime.now(timezone.utc)
    result = _cron_execute_job(cfg, hit)
    hit["last_run_at"] = now.isoformat()
    hit["last_result"] = str(result or "")[:500]
    hit["updated_at"] = now.isoformat()
    _cron_jobs_save(jobs)
    return {"ok": True, "reply": f"Cron-Job getestet: {jid}\nErgebnis: {hit['last_result']}"}

def _cron_jobs_items(active_only: bool = False) -> List[Dict[str, Any]]:
    jobs = _cron_jobs_load()
    if active_only:
        jobs = [j for j in jobs if bool(j.get("enabled", True))]
    out: List[Dict[str, Any]] = []
    for j in jobs:
        item = dict(j)
        item["id"] = str(item.get("id", "") or "").strip()
        item["task"] = str(item.get("task", "") or "").strip()
        item["enabled"] = bool(item.get("enabled", True))
        item["schedule"] = str(item.get("schedule", "") or "").strip()
        item["interval_sec"] = int(item.get("interval_sec", 0) or 0) if str(item.get("interval_sec", "")).strip() else 0
        item["run_at"] = str(item.get("run_at", "") or "").strip()
        item["next_run_at"] = str(item.get("next_run_at", "") or "").strip()
        item["updated_at"] = str(item.get("updated_at", "") or "").strip()
        item["last_run_at"] = str(item.get("last_run_at", "") or "").strip()
        item["last_result"] = str(item.get("last_result", "") or "").strip()
        item["action"] = dict(item.get("action", {})) if isinstance(item.get("action", {}), dict) else {}
        item["change_only"] = bool(item.get("change_only", False))
        item["last_observed_hash"] = str(item.get("last_observed_hash", "") or "").strip()
        item["last_observed_at"] = str(item.get("last_observed_at", "") or "").strip()
        out.append(item)
    out.sort(key=lambda x: str(x.get("next_run_at", "") or ""))
    return out

def _cron_deliver_message(cfg: Dict[str, Any], job: Dict[str, Any], text: str) -> str:
    msg = str(text or "").strip()
    if not msg:
        return "no_message"
    platform = str(job.get("platform", "") or "").strip().lower()
    target = str(job.get("target", "") or "").strip()
    if platform and not target:
        remembered = _last_messenger_target(platform)
        if remembered:
            target = remembered
            job["target"] = remembered
    if not platform:
        tg_target = _last_messenger_target("telegram")
        dc_target = _last_messenger_target("discord")
        if tg_target:
            platform = "telegram"
            target = tg_target
        elif dc_target:
            platform = "discord"
            target = dc_target
        if platform:
            job["platform"] = platform
            job["target"] = target
    if not platform:
        return "no_platform"
    if not target:
        if platform == "webui":
            target = "webui"
            job["target"] = target
        else:
            return "no_target"
    try:
        if platform == "telegram":
            tg = cfg.get("messenger", {}).get("telegram", {}) if isinstance(cfg.get("messenger", {}).get("telegram", {}), dict) else {}
            token = str(tg.get("token", "") or "").strip()
            if not token:
                return "telegram_token_missing"
            url = f"https://api.telegram.org/bot{token}/sendMessage"
            with httpx.Client(timeout=20, trust_env=False) as client:
                r = client.post(url, json={"chat_id": target, "text": msg})
                r.raise_for_status()
            return "ok:telegram"
        if platform == "discord":
            dc = cfg.get("messenger", {}).get("discord", {}) if isinstance(cfg.get("messenger", {}).get("discord", {}), dict) else {}
            token = str(dc.get("token", "") or "").strip()
            if not token:
                return "discord_token_missing"
            channel_id = target or str(dc.get("channel_id", "") or "").strip()
            if not channel_id:
                return "discord_channel_missing"
            headers = {"Authorization": f"Bot {token}", "Content-Type": "application/json"}
            with httpx.Client(timeout=20, trust_env=False) as client:
                r = client.post(f"https://discord.com/api/v10/channels/{channel_id}/messages", headers=headers, json={"content": msg})
                r.raise_for_status()
            return "ok:discord"
        if platform == "webui":
            _webui_push_notification(msg, source="cron", platform="webui", target=target or "webui")
            return "ok:webui"
        return f"unsupported_platform:{platform}"
    except Exception as exc:
        return f"delivery_error:{exc}"

def _cron_notify_decision(job: Dict[str, Any], observed_payload: str) -> tuple[bool, str]:
    change_only = bool(job.get("change_only", False))
    payload = str(observed_payload or "")
    digest = _text_digest(payload)
    prev = str(job.get("last_observed_hash", "") or "").strip()
    now = datetime.now().isoformat()
    job["last_observed_hash"] = digest
    job["last_observed_at"] = now
    if not change_only:
        return True, "always"
    if not prev:
        return False, "baseline_set"
    if prev == digest:
        return False, "unchanged"
    return True, "changed"

def _cron_execute_job(cfg: Dict[str, Any], job: Dict[str, Any]) -> str:
    embedded = job.get("action", None)
    if isinstance(embedded, dict) and embedded:
        kind = str(embedded.get("kind", "") or "").strip().lower()
        if kind == "screenshot_email":
            import subprocess as _sp, tempfile as _tf, os as _os
            ts = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")
            ss_path = str(Path(_tf.gettempdir()) / f"cron_ss_{ts}.png")
            ss_escaped = ss_path.replace("\\", "\\\\")
            ps_ss = (
                "Add-Type -AssemblyName System.Windows.Forms; "
                "Add-Type -AssemblyName System.Drawing; "
                "Add-Type -TypeDefinition 'using System.Runtime.InteropServices; public class DpiH { [DllImport(\"user32.dll\")] public static extern bool SetProcessDPIAware(); }'; "
                "[DpiH]::SetProcessDPIAware() | Out-Null; "
                "$bounds=[System.Windows.Forms.SystemInformation]::VirtualScreen; "
                "$bmp=New-Object System.Drawing.Bitmap($bounds.Width,$bounds.Height); "
                "$g=[System.Drawing.Graphics]::FromImage($bmp); "
                "$g.CopyFromScreen($bounds.Location,[System.Drawing.Point]::Empty,$bounds.Size); "
                f"$bmp.Save('{ss_escaped}',[System.Drawing.Imaging.ImageFormat]::Png); "
                "$g.Dispose(); $bmp.Dispose();"
            )
            try:
                _sp.run(["pwsh", "-NoProfile", "-Command", ps_ss], timeout=30, capture_output=True)
            except Exception:
                with contextlib.suppress(Exception):
                    _sp.run(["powershell", "-NoProfile", "-Command", ps_ss], timeout=30, capture_output=True)
            attachments = [ss_path] if _os.path.exists(ss_path) else []
            email_action = {
                "kind": "gmail_send_email_advanced",
                "to": str(embedded.get("to", "") or ""),
                "subject": str(embedded.get("subject", "") or "Screenshot"),
                "body": str(embedded.get("body", "") or "Automatischer Screenshot."),
                "attachments": attachments,
            }
            res = _run_skill_action(cfg, email_action)
            ok = bool(res.get("ok", False))
            reply = str(res.get("reply", "") or "").strip() or ("E-Mail gesendet." if ok else "E-Mail fehlgeschlagen.")
            do_notify, policy = _cron_notify_decision(job, reply)
            if not do_notify:
                return f"action:screenshot_email ok={ok} notify=skipped({policy}) reply={reply[:220]}"
            status = _cron_deliver_message(cfg, job, reply)
            return f"action:screenshot_email ok={ok} notify={status} policy={policy} reply={reply[:220]}"
        if kind == "cron_notify":
            msg = str(embedded.get("message", "") or "").strip() or str(job.get("task", "") or "").strip() or "Erinnerung."
            do_notify, policy = _cron_notify_decision(job, msg)
            if not do_notify:
                return f"action:cron_notify ok=True notify=skipped({policy}) reply={msg[:220]}"
            status = _cron_deliver_message(cfg, job, msg)
            return f"action:cron_notify ok=True notify={status} policy={policy} reply={msg[:220]}"
        if kind == "react_plan":
            try:
                steps = list(embedded.get("steps", []))
                task_msg = str(job.get("task", "") or f"Cron-Job {job.get('id', '?')}")
                res = _execute_react_plan_with_retry(
                    message=task_msg,
                    steps=steps,
                    cfg=cfg,
                    dialog_key=str(job.get("dialog_key", "") or ""),
                    approved=True,
                )
                ok = bool(res.get("ok", False))
                reply = str(res.get("reply", "") or "").strip()
                if not reply:
                    reply = "Ausfuehrung abgeschlossen." if ok else "Ausfuehrung fehlgeschlagen."
                notify_text = f"Cron-Job {job.get('id', '?')}: {reply[:700]}"
                do_notify, policy = _cron_notify_decision(job, notify_text)
                if not do_notify:
                    return f"action:react_plan ok={ok} notify=skipped({policy}) reply={reply[:220]}"
                status = _cron_deliver_message(cfg, job, notify_text)
                return f"action:react_plan ok={ok} notify={status} policy={policy} reply={reply[:220]}"
            except Exception as exc:
                status = _cron_deliver_message(cfg, job, f"Cron-Job {job.get('id', '?')} Fehler: {exc}")
                return f"action:react_plan error={exc} notify={status}"
        if kind and not kind.startswith("cron_"):
            # Schutz vor Fehl-Aktionen (z.B. Debug-Logs statt funktionaler Aktion)
            if kind == "write_file":
                p = str(embedded.get("path", "")).lower()
                if any(x in p for x in ["success", "field"]):
                    # Diese Aktion ist Schrott -> Fallback auf ReAct mit der Text-Beschreibung (task)
                    tool_store.log("cron_fix", f"Fehlerhafte write_file-Aktion in Job {job.get('id')} abgefangen. Nutze Task-Fallback.")
                    task_msg = str(job.get("task", "") or f"Cron-Job {job.get('id', '?')}")
                    try:
                        res = _execute_react_plan_with_retry(
                            message=task_msg, steps=[], cfg=cfg,
                            dialog_key=str(job.get("dialog_key", "") or ""), approved=True
                        )
                        ok = bool(res.get("ok", False))
                        reply = str(res.get("reply", "") or "").strip()
                        status = _cron_deliver_message(cfg, job, f"Korrektur-Lauf: {reply[:700]}")
                        return f"action:fallback_react ok={ok} notify={status} reply={reply[:220]}"
                    except Exception as e:
                        return f"action:fallback_react error={e}"

            try:
                res = _run_llm_planned_action(
                    cfg=cfg,
                    message=f"Cron-Job Aktion ({job.get('id', '?')}): {kind}",
                    action=dict(embedded),
                    note=f"cron_embedded_action:{job.get('id', '?')}",
                    dialog_key=str(job.get("dialog_key", "") or ""),
                    pre_approved=True,  # Cron-Jobs laufen unbeaufsichtigt – keine erneute Freigabe
                )
                ok = bool(res.get("ok", False))
                reply = str(res.get("reply", "") or "").strip()
                if not reply:
                    reply = "Ausfuehrung abgeschlossen." if ok else "Ausfuehrung fehlgeschlagen."
                notify_text = f"Cron-Job {job.get('id', '?')} ({kind}): {reply[:700]}"
                do_notify, policy = _cron_notify_decision(job, notify_text)
                if not do_notify:
                    return f"action:{kind} ok={ok} notify=skipped({policy}) reply={reply[:220]}"
                status = _cron_deliver_message(cfg, job, notify_text)
                return f"action:{kind} ok={ok} notify={status} policy={policy} reply={reply[:220]}"
            except Exception as exc:
                status = _cron_deliver_message(cfg, job, f"Cron-Job {job.get('id', '?')} ({kind}) Fehler: {exc}")
                return f"action:{kind} error={exc} notify={status}"
    task = str(job.get("task", "") or "").strip()
    query = str(job.get("query", "") or "").strip()
    # Reminder/default task
    reminder_text = task or query
    reminder = f"Erinnerung: {reminder_text}" if reminder_text else "Erinnerung."
    do_notify, policy = _cron_notify_decision(job, reminder)
    if not do_notify:
        return f"reminder: {task} | notify=skipped({policy})"
    status = _cron_deliver_message(cfg, job, reminder)
    return f"reminder: {task} | notify={status} policy={policy}"

def _cron_tick_once(cfg: Dict[str, Any]) -> None:
    jobs = _cron_jobs_load()
    if not jobs:
        return
    now = datetime.now(timezone.utc)
    to_keep = []
    changed = False
    for job in jobs:
        if not bool(job.get("enabled", True)):
            to_keep.append(job)
            continue
            
        due_at = _cron_parse_run_at_iso(str(job.get("next_run_at", "") or ""))
        if due_at is None or due_at > now:
            to_keep.append(job)
            continue
            
        # Job ist fällig
        result = _cron_execute_job(cfg, job)
        job["last_run_at"] = now.isoformat()
        job["last_result"] = result[:500]
        
        interval = job.get("interval_sec", None)
        schedule_expr = str(job.get("schedule", "") or "").strip()
        # Reschedule: interval_sec (classic), or cron expression (*/5 * * * *)
        if isinstance(interval, int) and int(interval) > 0:
            job["next_run_at"] = (now + timedelta(seconds=int(interval))).isoformat()
            job["updated_at"] = now.isoformat()
            to_keep.append(job)
        elif schedule_expr and re.match(r'^[\d*/,\-]+(\s+[\d*/,\-]+){4,5}$', schedule_expr.strip()):
            try:
                from croniter import croniter
                cron = croniter(schedule_expr, now)
                next_dt = cron.get_next(datetime)
                if next_dt.tzinfo is None:
                    next_dt = next_dt.replace(tzinfo=timezone.utc)
                job["next_run_at"] = next_dt.isoformat()
                job["updated_at"] = now.isoformat()
                to_keep.append(job)
            except Exception:
                tool_store.log("cron_job_finished", f"Cron-Expression ungueltig, Job entfernt: {job.get('id', '?')}")
        else:
            # Einmaliger Job -> NICHT zu to_keep hinzufügen (löschen)
            tool_store.log("cron_job_finished", f"Einmaliger Job erledigt und entfernt: {job.get('id', '?')}")
            
        changed = True
        tool_store.log("cron_job_run", f"{job.get('id', '?')}: {result[:240]}")
        
    if changed:
        _cron_jobs_save(to_keep)

def _cron_worker_loop() -> None:
    while not _cron_stop_event.is_set():
        try:
            _cron_tick_once(_cfg())
        except Exception as exc:
            tool_store.log("cron_worker_error", str(exc))
        _cron_stop_event.wait(3.0)

def _cron_start_worker() -> None:
    global _cron_thread
    with _cron_lock:
        if _cron_thread is not None and _cron_thread.is_alive():
            return
        _cron_stop_event.clear()
        try:
            from app.trace_utils import start_thread_with_trace
            _cron_thread = start_thread_with_trace(_cron_worker_loop, name="kaia-cron-worker", daemon=True)
        except Exception:
            _cron_thread = threading.Thread(target=_cron_worker_loop, name="kaia-cron-worker", daemon=True)
            _cron_thread.start()

def _cron_stop_worker() -> None:
    global _cron_thread
    _cron_stop_event.set()
    with _cron_lock:
        t = _cron_thread
        _cron_thread = None
    if t is not None and t.is_alive():
        with contextlib.suppress(Exception):
            t.join(timeout=2.0)

def _cron_local_dt_to_utc_iso(local_dt: datetime) -> str:
    dt = local_dt
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=datetime.now().astimezone().tzinfo)
    return dt.astimezone(timezone.utc).isoformat()

def _cron_parse_natural_create(text: str) -> Optional[Dict[str, Any]]:
    raw = str(text or "").strip()
    low = raw.lower()
    if not raw:
        return None
    change_only = _has_any(
        low,
        [
            "nur bei aender",
            "nur bei änder",
            "wenn sich",
            "sobald sich",
            "falls sich",
            "nur wenn neu",
            "only if changed",
            "on change",
        ],
    )

    # Pattern: "erstelle einen cronjob alle 10 minuten und nutze ..."
    m_generic_every = re.search(
        r"(?:erstelle|anlegen|lege\s+an|create|add)\b.*?\bcron(?:\s*job)?\b.*?(?:in\s+)?(?:alle|every)\s+(\d{1,4})\s*(sekunden|sek|s|minuten|min|m|stunden|h|tage|d|seconds?|minutes?|hours?|days?)\b(?:\s*(?:und\s+|mit\s+task\s*[:=]\s*|task\s*[:=]\s*|fuer\s+|für\s+|:)\s*(.+))?$",
        raw,
        flags=re.IGNORECASE,
    )
    if m_generic_every:
        n = int(m_generic_every.group(1))
        u = str(m_generic_every.group(2) or "").lower()
        mult = 1
        if u.startswith("m"):
            mult = 60
        elif u.startswith("h"):
            mult = 3600
        elif u.startswith("t") or u.startswith("d"):
            mult = 86400
        task_tail = str(m_generic_every.group(3) or "").strip()
        task = task_tail if task_tail else "geplanter cron job"
        return {
            "kind": "cron_create",
            "task": task,
            "interval_sec": max(1, n * mult),
            "change_only": bool(change_only),
        }

    # Pattern: "schalte X in 5 minuten aus" oder "erinnere mich in 2 minuten an..."
    m_in_once = re.search(
        r"(?:schalte|erinnere\s+mich|mach|fÃ¼hre|fuehre|execute)\b.*?\b(?:in\s+)(\d{1,4})\s*(sekunden|sek|s|minuten|min|m|stunden|h|tage|d|seconds?|minutes?|hours?|days?)\b(?:\s+(?:aus|an|auf|ab|an\s+)?(?:\s+(.+))?)?$",
        raw,
        flags=re.IGNORECASE,
    )
    if m_in_once:
        n = int(m_in_once.group(1))
        u = str(m_in_once.group(2) or "").lower()[0]
        mult = {"s": 1, "m": 60, "h": 3600, "t": 86400, "d": 86400}.get(u, 60)
        task = str(m_in_once.group(3) or "").strip()
        if not task: task = raw # Fallback auf ganzen Text
        return {
            "kind": "cron_create",
            "task": task,
            "schedule": f"in:{n}{u}",
            "change_only": bool(change_only),
        }

    # Pattern: "erinnere mich (in) alle 2 minuten an mein ...".
    m_every_reminder = re.search(
        r"erinnere\s+mich\s+(?:in\s+)?(?:alle|every)\s+(\d{1,4})\s*(sekunden|sek|s|minuten|min|m|stunden|h|tage|d|seconds?|minutes?|hours?|days?)\s+an\s+(.+)$",
        low,
        flags=re.IGNORECASE,
    )
    if m_every_reminder:
        n = int(m_every_reminder.group(1))
        u = str(m_every_reminder.group(2) or "").lower()
        mult = 1
        if u.startswith("m"):
            mult = 60
        elif u.startswith("h"):
            mult = 3600
        elif u.startswith("t") or u.startswith("d"):
            mult = 86400
        task = str(m_every_reminder.group(3) or "").strip()
        if task:
            return {
                "kind": "cron_create",
                "task": task,
                "interval_sec": max(1, n * mult),
                "change_only": bool(change_only),
            }

    # Pattern: "erinnere mich morgen um 08:00 an mein meeting"
    m_tomorrow = re.search(
        r"erinnere\s+mich\s+morgen(?:\s+frueh|\s+früh|\s+abend|\s+vormittag|\s+nachmittag)?\s+um\s+(\d{1,2}):(\d{2})\s*(?:uhr)?\s+an\s+(.+)$",
        low,
        flags=re.IGNORECASE,
    )
    if m_tomorrow:
        hh = int(m_tomorrow.group(1))
        mm = int(m_tomorrow.group(2))
        task = str(m_tomorrow.group(3) or "").strip()
        now_local = datetime.now().astimezone()
        target_local = (now_local + timedelta(days=1)).replace(hour=hh, minute=mm, second=0, microsecond=0)
        return {"kind": "cron_create", "task": task, "run_at": _cron_local_dt_to_utc_iso(target_local), "change_only": bool(change_only)}

    # Pattern: "erinnere mich um 08:00 an ..."
    m_time = re.search(
        r"erinnere\s+mich\s+um\s+(\d{1,2}):(\d{2})\s*(?:uhr)?\s+an\s+(.+)$",
        low,
        flags=re.IGNORECASE,
    )
    if m_time:
        hh = int(m_time.group(1))
        mm = int(m_time.group(2))
        task = str(m_time.group(3) or "").strip()
        now_local = datetime.now().astimezone()
        target_local = now_local.replace(hour=hh, minute=mm, second=0, microsecond=0)
        if target_local <= now_local:
            target_local = target_local + timedelta(days=1)
        return {"kind": "cron_create", "task": task, "run_at": _cron_local_dt_to_utc_iso(target_local), "change_only": bool(change_only)}
    return None

def _cron_action_from_text(text: str) -> Optional[Dict[str, Any]]:
    t = str(text or "").strip()
    low = t.lower()
    if not t:
        return None
    # Slash commands
    if low in {"/cron", "/cron jobs", "cron", "cron jobs", "cron liste", "/cron list"}:
        return {"kind": "cron_list"}
    if low in {"/cron active", "/cron aktive", "cron active", "cron aktive"}:
        return {"kind": "cron_list", "active_only": True}
    m_del = re.match(r"^/?cron\s+(?:delete|del|loeschen|löschen|remove)\s+([a-zA-Z0-9._:-]+)\s*$", low, flags=re.IGNORECASE)
    if m_del:
        return {"kind": "cron_delete", "job_id": str(m_del.group(1) or "").strip()}
    m_pause = re.match(r"^/?cron\s+(?:pause|stop)\s+([a-zA-Z0-9._:-]+)\s*$", low, flags=re.IGNORECASE)
    if m_pause:
        return {"kind": "cron_pause", "job_id": str(m_pause.group(1) or "").strip()}
    m_resume = re.match(r"^/?cron\s+(?:resume|start)\s+([a-zA-Z0-9._:-]+)\s*$", low, flags=re.IGNORECASE)
    if m_resume:
        return {"kind": "cron_resume", "job_id": str(m_resume.group(1) or "").strip()}
    m_test = re.match(r"^/?cron\s+(?:test|run|jetzt|now)\s+([a-zA-Z0-9._:-]+)\s*$", low, flags=re.IGNORECASE)
    if m_test:
        return {"kind": "cron_test", "job_id": str(m_test.group(1) or "").strip()}
    parsed = _cron_parse_natural_create(t)
    if parsed:
        return parsed
    return None
