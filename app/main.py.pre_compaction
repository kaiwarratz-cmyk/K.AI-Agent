            if required and not is_set:
                missing_required.append(alias)
            req.append(
                {
                    "alias": alias,
                    "label": label,
                    "description": desc,
                    "required": required,
                    "is_set": is_set,
                    "is_active": bool(active_alias and alias == active_alias),
                }
            )
        item["secrets"] = req
        item["missing_required"] = missing_required
        item["can_enable"] = len(missing_required) == 0
        item["active_token_alias"] = active_alias
    return items

def _skill_missing_required_secrets(cfg: Dict[str, Any], skill_id: str) -> List[str]:
    sid = str(skill_id or "").strip().lower()
    if not sid:
        return []
    for item in _skills_items_with_secret_status(cfg):
        if str(item.get("id", "") or "").strip().lower() == sid:
            miss = item.get("missing_required", [])
            return [str(x) for x in miss if str(x).strip()] if isinstance(miss, list) else []
    return []

def _action_schemas() -> Dict[str, Dict[str, Any]]:
    merged = dict(_ACTION_SCHEMAS)
    reg = _skills_snapshot()
    extra = reg.get("action_schemas", {}) if isinstance(reg.get("action_schemas", {}), dict) else {}
    for k, v in extra.items():
        if isinstance(v, dict):
            merged[str(k)] = dict(v)
    # MCP tools (cached)
    try:
        from app.mcp_tools import mcp_tools_as_action_schemas
        merged.update(mcp_tools_as_action_schemas())
    except Exception:
        pass
    return merged

def _skill_handler_for_kind(kind: str) -> Optional[Dict[str, Any]]:
    reg = _skills_snapshot()
    handlers = reg.get("handlers", {}) if isinstance(reg.get("handlers", {}), dict) else {}
    h = handlers.get(str(kind or "").strip(), None)
