            if step == "script_exec":
                script_result = _handle_script_request(message, cfg, source=source, dialog_key=dialog_key)
                if script_result:
                    return _ret(script_result, "script_exec")

            if step == "filesystem":
                fs_result = _handle_filesystem_request(message, cfg, dialog_key=dialog_key)
                if fs_result:
                    return _ret(fs_result, "filesystem")

            if step == "answer_and_save" and not operational_mode:
                answer_save_result = _handle_answer_and_save_request(message, cfg)
                if answer_save_result:
                    return _ret(answer_save_result, "answer_and_save")

            if step == "memory_only_qa":
                memory_only = _answer_from_memory_only(cfg, message)
                if memory_only:
                    _persist_conversation(cfg, message, memory_only, 0.76)
                    return _ret({"ok": True, "reply": memory_only}, "memory_only_qa")
                # Safety fallback in case memory-only routing had no concrete hit.
                knowledge_reply = _answer_from_memory_or_web(cfg, message)
                if knowledge_reply:
                    _persist_conversation(cfg, message, knowledge_reply, 0.74)
                    return _ret({"ok": True, "reply": knowledge_reply}, "memory_only_qa_fallback")

            if step == "knowledge_or_web" and not operational_mode:
                if _runtime_action_intent_expected:
                    continue
                # Prevent hallucinated "found files" answers when request is actually
                # an operational/filesystem search but intent fell back to unknown.
                _low_msg = str(message or "").lower()
                _unknown_intent = str(interp_intent or "").strip().lower() == "unknown"
                _looks_operational_search = (not _is_explicit_web_query(message)) and _has_any(
                    _low_msg,
                    [
                        "suche",
                        "finde",
                        "durchsuche",
                        "netzwerk",
                        "nas",
                        "laufwerk",
                        "freigabe",
                        "datei",
                        "dateien",
                        "ordner",
                        "verzeichnis",
                    ],
                )
                if _unknown_intent and _looks_operational_search and (not _runtime_action_intent_expected):
                    clarif = ""
                    if isinstance(_runtime_interp, dict):
                        clarif = str(_runtime_interp.get("clarification_question", "") or "").strip()
                    clarif = clarif or "Bitte nenne den genauen Pfad (z. B. \\\\Server\\Freigabe oder Laufwerk), dann suche ich dort."
                    if _looks_operational_request(message) and (not _extract_any_path(message)):
                        mem_path = _memory_path_candidate(cfg, message, dialog_key=dialog_key)
                        if mem_path:
                            message = f'{message} in "{mem_path}"'
                            continue
                        _set_pending_path_request(dialog_key, str(message or ""))
                    return _ret({"ok": True, "reply": clarif}, "unknown_operational_clarify")
                knowledge_reply = _answer_from_memory_or_web(cfg, message)
                if knowledge_reply:
                    _persist_conversation(cfg, message, knowledge_reply, 0.76)
                    return _ret({"ok": True, "reply": knowledge_reply}, "knowledge_or_web")

            if step == "llm" and not operational_mode:
                _low_msg = str(message or "").lower()
                _unknown_intent = str(interp_intent or "").strip().lower() == "unknown"
                _looks_operational_search = (not _is_explicit_web_query(message)) and _has_any(
                    _low_msg,
                    [
                        "suche",
                        "finde",
                        "durchsuche",
                        "netzwerk",
                        "nas",
                        "laufwerk",
                        "freigabe",
                        "datei",
                        "dateien",
                        "ordner",
                        "verzeichnis",
                    ],
                )
                if _unknown_intent and _looks_operational_search and (not _runtime_action_intent_expected):
                    clarif = ""
                    if isinstance(_runtime_interp, dict):
                        clarif = str(_runtime_interp.get("clarification_question", "") or "").strip()
                    clarif = clarif or "Bitte nenne den genauen Pfad (z. B. \\\\Server\\Freigabe oder Laufwerk), dann suche ich dort."
                    if _looks_operational_request(message) and (not _extract_any_path(message)):
                        mem_path = _memory_path_candidate(cfg, message, dialog_key=dialog_key)
                        if mem_path:
                            message = f'{message} in "{mem_path}"'
                            continue
                        _set_pending_path_request(dialog_key, str(message or ""))
                    return _ret({"ok": True, "reply": clarif}, "unknown_operational_clarify")
                if _runtime_action_intent_expected:
                    # Autonomous recovery: before asking the user, run one focused ReAct pass.
                    try:
                        react_cfg = cfg.get("react", {}) if isinstance(cfg.get("react", {}), dict) else {}
                        rec_max_iter = int(react_cfg.get("max_iterations", 50) or 50)
                        rec_max_iter = max(1, min(100, rec_max_iter))
                        rec = _execute_react_loop(
                            message=message,
                            cfg=cfg,
                            dialog_key=dialog_key,
                            max_iterations=rec_max_iter,
                        )
                    except Exception as exc:
                        rec = {"ok": False, "reply": f"Autonomer Recovery-Loop fehlgeschlagen: {exc}"}
                    if isinstance(rec, dict) and str(rec.get("reply", "")).strip():
                        # Do not jump to clarification if we already have a concrete observation.
                        if bool(rec.get("ok", False)) and not bool(rec.get("partial", False)):
                            return _ret(rec, "react_loop_auto_recovery")
                        return _ret(rec, "react_loop_auto_recovery_partial")
                    _record_intent_feedback(
                        message=message,
                        trace_id=tid,
                        interpretation=_runtime_interp,
                        stage="toolcall_binding_clarify",
                        reason="action_intent_without_executable_parameters_after_recovery",
                    )
                    if _looks_operational_request(message) and (not _extract_any_path(message)):
                        mem_path = _memory_path_candidate(cfg, message, dialog_key=dialog_key)
                        if mem_path:
                            message = f'{message} in "{mem_path}"'
                            # retry one compact recovery instead of immediate clarify
                            try:
                                react_cfg = cfg.get("react", {}) if isinstance(cfg.get("react", {}), dict) else {}
                                rec_max_iter = int(react_cfg.get("max_iterations", 50) or 50)
                                rec_max_iter = max(1, min(100, rec_max_iter))
                                rec2 = _execute_react_loop(message=message, cfg=cfg, dialog_key=dialog_key, max_iterations=min(5, rec_max_iter))
                                if isinstance(rec2, dict) and str(rec2.get("reply", "")).strip():
                                    if bool(rec2.get("ok", False)) and not bool(rec2.get("partial", False)):
                                        return _ret(rec2, "react_loop_auto_recovery")
                                    return _ret(rec2, "react_loop_auto_recovery_partial")
                            except Exception:
                                pass
                        _set_pending_path_request(dialog_key, str(message or ""))
                    return _ret(
                        {
                            "ok": True,
                            "reply": "Ich konnte es nicht vollstaendig autonom loesen. Bitte nenne einen Zielpfad (z. B. \\\\Server\\Freigabe oder Laufwerk) oder bestaetige die gewuenschte Aktion genauer.",
                        },
                        "toolcall_binding_clarify",
                    )
                try:
                    llm_answer_timeout_sec = int(routing_cfg_local.get("llm_answer_timeout_sec", 60) or 60)
                except Exception:
                    llm_answer_timeout_sec = 60
                llm_answer_timeout_sec = max(5, min(300, llm_answer_timeout_sec))
                # Wenn Bilder vorhanden: React-Loop verwenden (unterstützt Vision-Blöcke)
                if images:
                    _img_result = _execute_react_loop(
                        message=message,
                        cfg=cfg,
                        dialog_key=dialog_key,
                        trace_id=tid,
                        intent=interp_intent,
                        images=images,
                        max_iterations=5,
                    )
                    return _ret(_img_result, "react_loop_vision")

                try:
                    _ato, _aout, _aerr = _run_with_timeout(
                        llm_answer_timeout_sec,
                        lambda: _llm_answer_with_quality_gate(cfg, message),
                    )
                    if _ato:
                        _audit_event(
                            "llm_answer_timeout",
                            {"timeout_sec": llm_answer_timeout_sec, "dialog_key": dialog_key, "message": str(message)[:220]},
                        )
                        return _ret(
                            {
                                "ok": False,
                                "reply": f"LLM-Timeout (> {llm_answer_timeout_sec}s). Bitte Anfrage erneut senden oder konkreter formulieren.",
                            },
                            "llm_timeout",
                        )
                    if _aerr is not None:
                        raise _aerr
                    reply = str(_aout or "")
                    tool_store.log("chat", "Antwort via LLM erzeugt")
                except LLMRouterError as exc:
                    tool_store.log("chat_error", str(exc))
                    _append_error_log("chat_error", str(exc))
                    return _ret({"ok": False, "reply": f"LLM Fehler: {exc}"}, "llm_error")
                except Exception as exc:
                    tool_store.log("chat_error", f"unexpected: {exc}")
                    _append_error_log("chat_unexpected_error", str(exc))
                    return _ret({"ok": False, "reply": f"Interner Fehler: {exc}"}, "llm_unexpected_error")
                skill_clarify = _skill_execution_clarification_message(message)
                if skill_clarify and _reply_looks_like_action_promise(reply):
                    return _ret({"ok": False, "reply": skill_clarify}, "skill_tool_clarify")
                _persist_conversation(cfg, message, reply, 0.7)
                return _ret({"ok": True, "reply": reply}, "llm")

        if operational_mode:
            _record_intent_feedback(
                message=message,
                trace_id=tid,
                interpretation=_runtime_interp,
                stage="tool_only_no_match",
                reason="operational_mode_no_action_matched",
            )
            return _ret(
                {
                    "ok": False,
                    "reply": "Keine gueltige Tool-Aktion erkannt oder ausfuehrbar. Bitte nenne Zielpfad/Dateiname/Parameter konkreter.",
                },
                "tool_only_no_match",
            )
        # Last-resort fallback to avoid dead-end responses when routing/classification
        # did not match any deterministic handler.
        try:
            llm_answer_timeout_sec = int(routing_cfg_local.get("llm_answer_timeout_sec", 60) or 60)
        except Exception:
            llm_answer_timeout_sec = 60
        llm_answer_timeout_sec = max(5, min(300, llm_answer_timeout_sec))
        try:
            _ato, _aout, _aerr = _run_with_timeout(
                llm_answer_timeout_sec,
                lambda: _llm_answer_with_quality_gate(cfg, message),
            )
            if _ato:
                _audit_event(
                    "llm_answer_timeout",
                    {"timeout_sec": llm_answer_timeout_sec, "dialog_key": dialog_key, "message": str(message)[:220]},
                )
                return _ret(
                    {
                        "ok": False,
                        "reply": f"LLM-Timeout (> {llm_answer_timeout_sec}s). Bitte Anfrage erneut senden oder konkreter formulieren.",
                    },
                    "llm_timeout",
                )
            if _aerr is not None:
                raise _aerr
            reply = str(_aout or "")
            if str(reply or "").strip():
                skill_clarify = _skill_execution_clarification_message(message)
                if skill_clarify and _reply_looks_like_action_promise(reply):
                    return _ret({"ok": False, "reply": skill_clarify}, "skill_tool_clarify")
                _persist_conversation(cfg, message, reply, 0.66)
                return _ret({"ok": True, "reply": reply}, "llm_hard_fallback")
        except Exception as exc:
            tool_store.log("chat_error", f"hard_fallback_failed: {exc}")
            _append_error_log("chat_hard_fallback_failed", str(exc))
        _record_intent_feedback(
            message=message,
            trace_id=tid,
            interpretation=_runtime_interp,
            stage="no_handler",
            reason="no_route_and_no_llm_fallback",
        )
        return _ret({"ok": False, "reply": "Keine passende Verarbeitung gefunden."}, "no_handler")
    finally:
        with _active_jobs_lock:
            _active_jobs.pop(tid, None)
            _cancelled_jobs.discard(tid)
        _cli_anim_job_end()
        _dialog_key_ctx.reset(token_dialog)
        _trace_id_ctx.reset(token)

def _messenger_reply(message: str, meta: Optional[Dict[str, Any]] = None, **kwargs) -> str:
    def _out(val: str) -> str:
        return _normalize_messenger_out_text(str(val or ""))

    # Alle Metadaten mergen (unterstützt positionale und keyword Argumente)
    meta_merged = dict(meta or {})
    meta_merged.update(kwargs)

    cfg = _cfg()
    normalized = _normalize_messenger_message(message, meta_merged)
    text = normalized.raw_text
    if not text:
        return _out("Leere Nachricht.")
    platform = normalized.platform
    user = normalized.sender_label
    allowed, reason = _messenger_inbound_allowed(cfg, str(platform), meta_merged)
    if not allowed:
        tool_store.log("messenger_denied", f"{platform}/{user}: {reason}")
        return ""
    platform_cfg = _get_platform_cfg(cfg, str(platform))
    session_key = normalized.session_key
    pending_exists = False
    is_approval = _is_approval_answer(text)
    memory_dialog_active = (_memory_dialog_get(session_key) is not None) or (_secret_dialog_get(session_key) is not None)
    help_cmd = _is_help_command(text)

    standalone = _map_standalone_command(text)
    if standalone == "__status__":
        return _out(_status_text(cfg))
    if isinstance(standalone, str) and standalone:
        effective_text = standalone
    else:
        effective_text = ""

    if is_approval or memory_dialog_active or help_cmd:
        # While an action is awaiting confirmation, allow quick yes/no replies
        # from messenger without forcing command prefixes.
        effective_text = text
    elif not effective_text:
        if str(platform) == "discord":
            prefix = str(platform_cfg.get("command_prefix", "/botname") or "/botname")
            require_prefix_in_channel = bool(platform_cfg.get("require_prefix", True))
            # Discord rule:
            # - DMs: always process
            # - Guild channels: configurable via require_prefix
            effective_text = text if normalized.is_dm else _extract_prefixed_text(
                text, prefix=prefix, require_prefix=require_prefix_in_channel
            )
        else:
            require_prefix = bool(platform_cfg.get("require_prefix", False))
            prefix = str(platform_cfg.get("command_prefix", "/ownbot") or "/ownbot")
            effective_text = _extract_prefixed_text(text, prefix=prefix, require_prefix=require_prefix)
    if not effective_text:
        return ""
    _remember_last_messenger_target(str(platform), str(normalized.chat_id or ""))

    low_effective = str(effective_text or "").strip().lower()
    if _session_reset_is_pending(session_key):
        if low_effective in {"ja", "j", "yes", "ok", "okay"}:
            _session_reset_clear_pending(session_key)
            stats = _clear_conversation_context(cfg, session_key=session_key)
            msg = f"Session wurde neu gestartet: {stats['deleted_db']} Memory-Eintraege, {stats['cleared_sessions']} Session(s) geloescht."
            tool_store.log("context_clear", f"messenger {platform}/{user}: {msg}")
            return _out(msg)
        if low_effective in {"nein", "n", "no", "abbrechen", "cancel"}:
            _session_reset_clear_pending(session_key)
            return _out("Session-Neustart abgebrochen.")
        return _out("Session-Neustart offen. Bitte antworte mit: ja | nein")

    if standalone == "__session_reset__" or low_effective in {
        "session neu",
        "session reset",
        "session loeschen",
        "session löschen",
        "session clear",
        "neue session",
        "sitzung neu",
    }:
        _session_reset_set_pending(session_key)
        return _out("Soll ich die aktuelle Session wirklich neu starten? Antworte mit: ja | nein")

    session_enabled = bool(cfg.get("messenger", {}).get("session_memory_enabled", True))
    if _is_clear_conversation_command(effective_text):
        stats = _clear_conversation_context(cfg, session_key=session_key)
        msg = f"Kontext geloescht: {stats['deleted_db']} Memory-Eintraege, {stats['cleared_sessions']} Session(s)."
        tool_store.log("context_clear", f"messenger {platform}/{user}: {msg}")
        return _out(msg)
    cron_action = _cron_action_from_text(effective_text)
    if isinstance(cron_action, dict):
        cron_action.setdefault("dialog_key", session_key)
        cron_action.setdefault("platform", str(platform))
        cron_action.setdefault("target", str(normalized.chat_id or ""))
        res = _run_virtual_action(cfg, effective_text, cron_action, note="cron_messenger", dialog_key=session_key)
        return _out(str(res.get("reply", "")))

    # Important: keep messenger input semantically clean for routing/intent detection.
    # Context is persisted separately via memory/session store and should not be prepended
    # into the live user message.
    prompt = effective_text

    stop_cmd = effective_text.strip().lower()
    if stop_cmd in {"stop", "script stop", "stop script"}:
        stopped = _request_script_stop(reason=f"messenger:{platform}/{user}")
        return _out("Script-Stop angefordert." if stopped else "Kein laufendes Script gefunden.")

    tool_store.log("messenger_in", f"{platform}/{user}: {effective_text[:140]}")
    trace_id = str(meta_merged.get("trace_id", "") or _new_trace_id())
    timeout_raw = meta_merged.get("reply_timeout_sec", cfg.get("messenger", {}).get("reply_timeout_sec", 600))
    try:
        timeout_sec = max(10, min(3600, int(timeout_raw or 600)))
    except Exception:
        timeout_sec = 600
    # Watchdog logic removed for better performance and robustness.
    # --- Request in die Queue stellen (Stabilisiert) ---
    trace_id = trace_id or _new_trace_id()
    
    # --- Typing Indikator Loop (Background) ---
    _typing_stop = threading.Event()
    def _typing_loop():
        while not _typing_stop.is_set():
            try:
                _send_messenger_typing(cfg, session_key, platform)
            except Exception:
                pass
            # Warte 4s, breche sofort ab wenn Event gesetzt
            if _typing_stop.wait(4):
                break

    # Starte Loop in robustem Thread (keine Abhängigkeit von unvollständigen Utilities)
    threading.Thread(target=_typing_loop, daemon=True, name=f"KAI-typing-{platform}-{trace_id[:8]}").start()

    def _on_finish(res: Dict[str, Any]):
        """Callback wenn der Hintergrundjob fertig ist."""
        _typing_stop.set()
        reply = str(res.get("reply", ""))
        
        # Falls ein Worker einen eigenen Callback übergeben hat (z.B. TelegramWorker)
        worker_cb = meta_merged.get("result_callback")
        if worker_cb:
            try:
                worker_cb(res)
                return # Worker übernimmt Versand
            except Exception as e:
                tool_store.log("messenger_cb_error", str(e))

        if reply and platform == "telegram":
            _send_telegram_reply(cfg, session_key, reply)

    # In die Queue stellen
    _chat_queue.submit(
        prompt, 
        cfg, 
        result_callback=_on_finish,
        source=f"messenger:{platform}", 
        dialog_key=session_key, 
        trace_id=trace_id
    )
    
    # WICHTIG: Wir geben einen leeren String zurück, damit keine störende Nachricht im Messenger erscheint.
    # Das Gateway muss so konfiguriert sein, dass es leere Antworten toleriert.
    return ""

def _script_owner_for_path(cfg: Dict[str, Any], path: Path) -> str:
    p_norm = str(path.resolve()).lower()
    items = _memory_store(cfg).search_by_kind(kind="script", limit=80)
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not blob:
            continue
        b_path = str(blob.get("path", "")).lower()
        if b_path == p_norm:
            return str(blob.get("created_by_role", "user")).lower()
    return "user"

def _extract_script_request(message: str, cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    text = message.strip()
    if not text:
        return None
    timeout_sec = int(cfg.get("security", {}).get("script_timeout", 180) or 180)
    timeout_sec = max(60, min(1800, timeout_sec))
    lower = text.lower()
    no_validation = _has_any(
        lower,
        [
            "ohne validierung",
            "nicht validieren",
            "skip validation",
            "ohne syntaxcheck",
            "no validation",
        ],
    )
    run_file_intent = _has_any(lower, ["ausfuehren", "ausführen", "fuehre", "führe", "run", "execute", "starte", "start"]) and _has_any(
        lower, ["script", ".py", ".ps1"]
    )
    if run_file_intent:
        quoted = re.findall(r'"([^"]+)"', text)
        path_candidate = next((q for q in quoted if q.lower().endswith(".py") or q.lower().endswith(".ps1")), "")
        if not path_candidate:
            inline_path = re.search(r"([A-Za-z]:\\[^\s\"]+\.(?:py|ps1)|[./\\\w-]+\.(?:py|ps1))", text, flags=re.IGNORECASE)
            if inline_path:
                path_candidate = inline_path.group(1)
        if path_candidate:
            p = Path(path_candidate)
            abs_path = p.resolve() if p.is_absolute() else (_workspace_abs(cfg) / p).resolve()
            if abs_path.exists() and abs_path.is_file():
                code = abs_path.read_text(encoding="utf-8", errors="ignore")
                script_type = "python" if abs_path.suffix.lower() == ".py" else "powershell"
                return {
                    "script_type": script_type,
                    "script": code,
                    "script_path": str(abs_path),
                    "script_owner_role": _script_owner_for_path(cfg, abs_path),
                    "timeout_sec": timeout_sec,
                    "validate_before_run": not no_validation,
                }

    fence = re.search(r"```(powershell|pwsh|python)\s*\n([\s\S]*?)```", text, flags=re.IGNORECASE)
    if fence:
        lang = fence.group(1).lower()
        script = fence.group(2).strip()
        if not script:
            return None
        script_type = "powershell" if lang in {"powershell", "pwsh"} else "python"
        return {
            "script_type": script_type,
            "script": script,
            "timeout_sec": timeout_sec,
            "validate_before_run": not no_validation,
        }

    for prefix, script_type in [
        ("powershell:", "powershell"),
        ("pwsh:", "powershell"),
        ("python:", "python"),
        ("py:", "python"),
    ]:
        if lower.startswith(prefix):
            script = text[len(prefix) :].strip()
            if script:
                return {
                    "script_type": script_type,
                    "script": script,
                    "timeout_sec": timeout_sec,
                    "validate_before_run": not no_validation,
                }
    return None

def _extract_script_creation_request(message: str, cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    text = message.strip()
    if not text:
        return None
    lower = text.lower()
    no_validation = _has_any(
        lower,
        [
            "ohne validierung",
            "nicht validieren",
            "skip validation",
            "ohne syntaxcheck",
            "no validation",
        ],
    )
    explicit_no_script = _has_any(
        lower,
        [
            "kein script",
            "keine scripts",
            "kein skript",
            "keine skripte",
            "ohne script",
            "ohne skript",
            "kein script erstellen",
            "kein skript erstellen",
            "nur erklaeren",
            "nur erklären",
            "nur textantwort",
            "nur antworten",
        ],
    )
    if explicit_no_script:
        return None
    
    # Handle single-word script type responses (e.g., "python" or "powershell" as answer to clarification question)
    if lower in ("python", "powershell", "pwsh", ".py", ".ps1"):
        return {"language": lower.lstrip(".").replace("ps1", "powershell").replace("pwsh", "powershell").replace("py", "python") if lower.startswith(".") else lower, "target": "", "request_text": "", "explicit_script_request": True, "no_auto_run": False}
    
    create_words = [
        "erstelle",
        "erzeuge",
        "schreibe",
        "schreib",
        "create",
        "generate",
        "erweitere dich",
        "self extend",
        "automatisiere",
        "python",
        "powershell",
        "pwsh",
    ]
    script_words = [
        "script",
        "skript",
        "python",
        "powershell",
        "pwsh",
        ".py",
        ".ps1",
        "tool",
        "screenshottool",
        "screenshot",
        "bildschirmfoto",
        "screen shot",
    ]
    has_fence = bool(re.search(r"```(?:powershell|pwsh|python)?[ \t]*\n?[\s\S]*?```", text, flags=re.IGNORECASE))
    implicit_task_intent = _has_any(
        lower,
        [
            "mache ein screenshot",
            "mach ein screenshot",
            "take a screenshot",
            "erstelle ein screenshot",
            "create a screenshot",
            "automation fuer screenshot",
            "automation für screenshot",
            "automatisierung fuer screenshot",
            "automatisierung für screenshot",
            "screenshot automation",
        ],
    )
    if not implicit_task_intent:
        implicit_task_intent = bool(
            re.search(
                r"\b(mach\w*|mache\w*|erstelle\w*|create\w*|take\w*|capture\w*|nimm\w*|nehme\w*|fertige\w*|anfertige\w*|erzeug\w*)\b[\s\S]{0,80}\b(screenshot|bildschirmfoto|screen\s*shot)\b",
                lower,
                flags=re.IGNORECASE,
            )
            or re.search(
                r"\b(screenshot|bildschirmfoto|screen\s*shot)\b[\s\S]{0,80}\b(mach\w*|mache\w*|erstelle\w*|create\w*|take\w*|capture\w*|nimm\w*|nehme\w*|fertige\w*|anfertige\w*|erzeug\w*)\b",
                lower,
                flags=re.IGNORECASE,
            )
        )
    if not implicit_task_intent:
        implicit_task_intent = bool(
            re.search(
                r"(automation|automatisier\w*|automatisierung|tool)\b.*\b(screenshot|bildschirmfoto|screen\s*shot)",
                lower,
                flags=re.IGNORECASE,
            )
        )
    explicit_script_request = _has_any(lower, create_words) and (_has_any(lower, script_words) or has_fence)
    creation_intent = explicit_script_request or implicit_task_intent
    if not creation_intent:
        return None

    def choose_language_auto(text_lower: str) -> str:
        if _has_any(text_lower, ["powershell", "pwsh", ".ps1"]):
            return "powershell"
        if _has_any(text_lower, ["python", ".py"]):
            return "python"
        python_hints = [
            "screenshot",
            "api",
            "json",
            "csv",
            "regex",
            "web",
            "http",
            "scrape",
            "ki",
            "llm",
            "daten",
            "analyse",
            "image",
            "pdf",
        ]
        powershell_hints = [
            "registry",
            "dienst",
            "service",
            "eventlog",
            "ad ",
            "active directory",
            "windows feature",
            "iis",
            "firewall",
            "get-process",
            "set-itemproperty",
            "winget",
            "msi",
            ".exe",
        ]
        py_score = sum(1 for h in python_hints if h in text_lower)
        ps_score = sum(1 for h in powershell_hints if h in text_lower)
        if ps_score > py_score:
            return "powershell"
        return "python"

    language = choose_language_auto(lower)
    fence = re.search(r"```(powershell|pwsh|python)?[ \t]*\n?([\s\S]*?)```", text, flags=re.IGNORECASE)
    code = None
    if fence:
        lang = (fence.group(1) or "").lower().strip()
        if lang in {"powershell", "pwsh"}:
            language = "powershell"
        elif lang == "python":
            language = "python"
        elif not lang:
            body = (fence.group(2) or "").lower()
            if re.search(r"\bdef\b|\bimport\b|\bprint\(", body):
                language = "python"
            elif re.search(r"\bget-|set-|new-item|remove-item|write-host|\$[a-z_]", body):
                language = "powershell"
        code = (fence.group(2) or "").strip() or None

    quoted = re.findall(r'"([^"]+)"', text)
    path_candidate = next((q for q in quoted if q.lower().endswith(".py") or q.lower().endswith(".ps1")), "")
    if not path_candidate:
        inline_path = re.search(r"([A-Za-z]:\\[^\s\"]+\.(?:py|ps1)|[./\\\w-]+\.(?:py|ps1))", text, flags=re.IGNORECASE)
        if inline_path:
            path_candidate = inline_path.group(1)

    workspace = _workspace_abs(cfg)
    scripts_dir = (workspace / "scripts").resolve()
    scripts_dir.mkdir(parents=True, exist_ok=True)
    if path_candidate:
        p = Path(path_candidate)
        target = p.resolve() if p.is_absolute() else (workspace / p).resolve()
    else:
        ts = int(time.time())
        ext = ".py" if language == "python" else ".ps1"
        target = (scripts_dir / f"auto_{language}_{ts}{ext}").resolve()

    if target.suffix.lower() not in {".py", ".ps1"}:
        return {"invalid": True, "reason": "Nur .py oder .ps1 sind fuer Script-Erstellung erlaubt."}

    run_after_create = _has_any(lower, ["ausfuehren", "ausfÃ¼hren", "execute", "run", "starte", "start"])
    no_auto_run = _has_any(
        lower,
        [
            "nur erstellen",
            "nicht ausfuehren",
            "nicht ausführen",
            "ohne ausfuehren",
            "ohne ausführen",
            "don't run",
            "do not run",
            "only create",
        ],
    )
    return {
        "language": language,
        "target": str(target),
        "code": code,
        "request_text": text,
        "validate_before_run": not no_validation,
        "run_after_create": run_after_create,
        "no_auto_run": no_auto_run,
        "explicit_script_request": bool(explicit_script_request),
        "implicit_task_intent": bool(implicit_task_intent),
    }

def _extract_code_from_llm(text: str, language: str = "") -> str:
    # Robust extraction for fenced code, even when the model returns
    # ```python import ...``` (no newline after language).
    blocks = re.findall(r"```(?:\s*([A-Za-z0-9_+\-]+))?[ \t]*\n?([\s\S]*?)```", text, flags=re.IGNORECASE)
    wanted = "python" if language == "python" else "powershell"
    if blocks:
        preferred: list[str] = []
        fallback: list[str] = []
        for lang, body in blocks:
            code = (body or "").strip()
            if not code:
                continue
            l = (lang or "").strip().lower()
            if wanted == "python" and l == "python":
                preferred.append(code)
            elif wanted == "powershell" and l in {"powershell", "pwsh"}:
                preferred.append(code)
            else:
                fallback.append(code)
        pick = preferred[0] if preferred else (fallback[0] if fallback else "")
        if pick:
            return pick.strip()

    # Fallback heuristics: cut obvious explanation sections.
    cut_markers = [
        "\n**erklÃ¤rung",
        "\n**erklaerung",
        "\n**wie man es benutzt",
        "\n**wichtige hinweise",
        "\n###",
    ]
    lower = text.lower()
    cut_pos = len(text)
    for marker in cut_markers:
        i = lower.find(marker)
        if i >= 0:
            cut_pos = min(cut_pos, i)
    trimmed = text[:cut_pos].strip()
    return trimmed

def _find_existing_script_for_request(cfg: Dict[str, Any], language: str, request_text: str) -> Optional[Dict[str, Any]]:
    req_terms = set(_query_terms(request_text))
    if not req_terms:
        return None
    items = _memory_store(cfg).search_by_kind(kind="script", limit=80)  # 160 → 80
    best_blob: Optional[Dict[str, Any]] = None
    best_score = 0.0
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not isinstance(blob, dict):
            continue
        b_lang = str(blob.get("language", "")).strip().lower()
        if b_lang and b_lang != str(language).lower():
            continue
        path = Path(str(blob.get("path", "") or ""))
        if not path.exists() or not path.is_file():
            continue
        req_old = str(blob.get("request", "") or "")
        terms_old = set(_query_terms(req_old))
        if not terms_old:
            continue
        overlap = len(req_terms.intersection(terms_old))
        if overlap <= 0:
            continue
        denom = float(max(1, len(req_terms)))
        score = overlap / denom
        if score > best_score:
            best_score = score
            best_blob = blob
    if best_blob and best_score >= 0.2:
        out = dict(best_blob)
        out["_match_score"] = round(best_score, 3)
        return out
    return None

def _extract_explicit_request_constraints(text: str) -> Dict[str, List[str]]:
    raw = str(text or "")
    low = raw.lower()
    quoted = [q.strip().lower() for q in re.findall(r'"([^"]+)"', raw) if q.strip()]
    filenames = [
        m.group(1).strip().lower()
        for m in re.finditer(r"\b([A-Za-z0-9._-]+\.(?:py|ps1|png|jpg|jpeg|bmp|gif|webp|pdf|json|csv|txt|md|zip))\b", raw, flags=re.IGNORECASE)
    ]
    paths = [
        p.strip().lower()
        for p in re.findall(r"([A-Za-z]:\\[^\s\"']+|[./\\][^\s\"']+)", raw)
        if p and ("/" in p or "\\" in p)
    ]
    numbers = [n.strip() for n in re.findall(r"\b\d+(?:[.,]\d+)?\b", low)]
    return {
        "quoted": list(dict.fromkeys(quoted)),
        "filenames": list(dict.fromkeys(filenames)),
        "paths": list(dict.fromkeys(paths)),
        "numbers": list(dict.fromkeys(numbers)),
    }

def _script_reuse_matches_constraints(request_text: str, existing_request: str, existing_code: str) -> bool:
    c = _extract_explicit_request_constraints(request_text)
    haystack = f"{str(existing_request or '').lower()}\n{str(existing_code or '').lower()}"

    for q in c.get("quoted", []):
        if q and q not in haystack:
            return False
    for fn in c.get("filenames", []):
        if fn and fn not in haystack:
            return False
    for p in c.get("paths", []):
        if p and p not in haystack:
            return False
    # Numeric constraints are only strong when parameter context likely exists.
    # We keep this conservative to avoid over-blocking useful reuse.
    if re.search(r"\b(timeout|sekund|minute|minuten|stunde|stunden|anzahl|count|max|limit|groesse|größe|width|height)\b", request_text, flags=re.IGNORECASE):
        for n in c.get("numbers", []):
            if n and n not in haystack:
                return False
    return True

def _llm_script_reuse_compatible(
    cfg: Dict[str, Any],
    language: str,
    request_text: str,
    existing_request: str,
    existing_code: str,
) -> bool:
    req = str(request_text or "").strip()
    old_req = str(existing_request or "").strip()
    code = str(existing_code or "").strip()
    if not req or not old_req or not code:
        return False
    try:
        router = LLMRouter(cfg)
        schema: Dict[str, Any] = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "compatible": {"type": "boolean"},
                "confidence": {"type": "number"},
                "reason": {"type": "string"},
            },
            "required": ["compatible", "confidence", "reason"],
        }
        prompt = (
            "Pruefe, ob ein vorhandenes Script fuer eine neue Anfrage ohne Verhaltensabweichung wiederverwendet werden kann.\n"
            "Antworte nur als JSON.\n"
            'Schema: {"compatible":true|false,"confidence":0..1,"reason":"..."}\n'
            "Regeln:\n"
            "- compatible=true nur wenn Input, Ziel, Datei-/Pfad-/Output-Erwartung und Nebenwirkungen inhaltlich passen.\n"
            "- Bei Zweifel false.\n"
            f"Script-Sprache: {language}\n"
            f"Neue Anfrage: {req}\n"
            f"Alte Anfrage: {old_req}\n"
            "Bestehender Script-Code (Auszug):\n"
            f"{code[:4500]}"
        )
        try:
            obj = router.chat_json(prompt=prompt, schema_name="script_reuse_compat_v1", schema=schema)
        except Exception:
            raw = router.chat(prompt)
            obj = _extract_json_dict(str(raw.text or ""))
        if not isinstance(obj, dict):
            return False
        compatible = bool(obj.get("compatible", False))
        try:
            conf = float(obj.get("confidence", 0.0) or 0.0)
        except Exception:
            conf = 0.0
        if not compatible:
            return False
        return conf >= 0.64
    except Exception as exc:
        tool_store.log("script_reuse_llm_check_error", str(exc))
        return False

def _generate_script_code(cfg: Dict[str, Any], language: str, request_text: str) -> str:
    router = LLMRouter(cfg)
    lang_label = "Python" if language == "python" else "PowerShell"
    prompt = (
        f"Erzeuge ein einzelnes {lang_label}-Skript fuer folgende Anforderung.\n"
        "Gib NUR lauffaehigen Code in EINEM Markdown-Codeblock zurueck, ohne Erklaertext.\n\n"
        f"Anforderung:\n{request_text}"
    )
    result = router.chat(_with_persona_prompt(prompt, include_agent_rules=True))
    return _extract_code_from_llm(result.text, language=language)

def _extract_requested_screenshot_filename(message: str) -> str:
    text = str(message or "").strip()
    if not text:
        return "screenshot.png"
    image_exts = (".png", ".jpg", ".jpeg", ".bmp", ".gif", ".webp")
    quoted = re.findall(r'"([^"]+)"', text)
    for q in quoted:
        cand = Path(q.strip()).name
        if cand.lower().endswith(image_exts):
            safe = re.sub(r'[<>:"/\\|?*\x00-\x1F]+', "_", cand).strip(" .")
            return safe or "screenshot.png"
    m = re.search(r"\b([A-Za-z0-9._-]+\.(?:png|jpg|jpeg|bmp|gif|webp))\b", text, flags=re.IGNORECASE)
    if m:
        cand = Path(m.group(1)).name
        safe = re.sub(r'[<>:"/\\|?*\x00-\x1F]+', "_", cand).strip(" .")
        return safe or "screenshot.png"
    return "screenshot.png"

def _builtin_screenshot_python_script(filename: str = "screenshot.png") -> str:
    # Dependency-free screenshot via PowerShell/.NET to avoid Pillow/pyautogui blockers.
    target_name = _extract_requested_screenshot_filename(filename)
    return (
        "import subprocess\n"
        "import sys\n\n"
        "ps_script = r'''\n"
        "Add-Type -AssemblyName System.Windows.Forms\n"
        "Add-Type -AssemblyName System.Drawing\n"
        "Add-Type -TypeDefinition 'using System.Runtime.InteropServices; public class DpiH { [DllImport(\"user32.dll\")] public static extern bool SetProcessDPIAware(); }'\n"
        "[DpiH]::SetProcessDPIAware() | Out-Null\n"
        "$bounds = [System.Windows.Forms.SystemInformation]::VirtualScreen\n"
        "$bmp = New-Object System.Drawing.Bitmap $bounds.Width, $bounds.Height\n"
        "$gfx = [System.Drawing.Graphics]::FromImage($bmp)\n"
        "$gfx.CopyFromScreen($bounds.Location, [System.Drawing.Point]::Empty, $bounds.Size)\n"
        f"$bmp.Save('{target_name}', [System.Drawing.Imaging.ImageFormat]::Png)\n"
        "$gfx.Dispose()\n"
        "$bmp.Dispose()\n"
        f"Write-Output 'Screenshot wurde als {target_name} gespeichert.'\n"
        "'''\n\n"
        "proc = subprocess.run(\n"
        "    ['powershell', '-NoProfile', '-Command', ps_script],\n"
        "    capture_output=True,\n"
        "    text=True,\n"
        "    shell=False,\n"
        ")\n"
        "if proc.stdout:\n"
        "    print(proc.stdout.strip())\n"
        "if proc.stderr:\n"
        "    print(proc.stderr.strip())\n"
        "sys.exit(int(proc.returncode))\n"
    )

def _handle_script_creation_request(message: str, cfg: Dict[str, Any], dialog_key: str = "") -> Optional[Dict[str, Any]]:
    req = _extract_script_creation_request(message, cfg)
    if not req:
        return None
    if req.get("invalid"):
        return {"ok": False, "reply": str(req.get("reason", "Ungueltige Script-Anfrage."))}

    target = Path(str(req["target"])).resolve()
    workspace = _workspace_abs(cfg)
    if not _is_within(workspace, target):
        return {"ok": False, "reply": f"Script-Dateien duerfen nur im Workspace erstellt werden: {workspace}"}

    request_text = str(req.get("request_text", "") or "")
    lower_req = request_text.lower()
    screenshot_request = bool(req.get("implicit_task_intent", False)) and _has_any(
        lower_req, ["screenshot", "bildschirmfoto", "screen shot"]
    )
    requested_shot_name = _extract_requested_screenshot_filename(request_text)
    explicit_shot_name = requested_shot_name.lower() != "screenshot.png"
    wants_force_new = _has_any(lower_req, ["neu erstellen", "neues script", "erneut", "nochmal neu", "from scratch"])
    existing = None if wants_force_new else _find_existing_script_for_request(cfg, str(req["language"]), request_text)
    if existing:
        existing_path = Path(str(existing.get("path", "") or ""))
        existing_code = str(existing.get("code", "") or "").strip()
        existing_request_text = str(existing.get("request", "") or "")
        if screenshot_request and explicit_shot_name and requested_shot_name.lower() not in existing_code.lower():
            existing = None
        elif not _script_reuse_matches_constraints(request_text, existing_request_text, existing_code):
            existing = None
        elif not _llm_script_reuse_compatible(
            cfg=cfg,
            language=str(req["language"]),
            request_text=request_text,
            existing_request=existing_request_text,
            existing_code=existing_code,
        ):
            existing = None
        if existing and existing_path.exists() and existing_path.is_file() and existing_code:
            script_action = {
                "kind": "script_exec",
                "script_type": str(req["language"]),
                "script": existing_code,
                "script_path": str(existing_path),
                "script_owner_role": str(existing.get("created_by_role", "user")).lower(),
                "timeout_sec": 180,
                "source": "script_reuse",
                "validate_before_run": bool(req.get("validate_before_run", True)),
            }
            mode = str(cfg.get("security", {}).get("execution_mode", "unrestricted")).lower()
            wants_execution = (
                not bool(req.get("no_auto_run", False))
                and (
                    bool(req.get("run_after_create", False))
                    or bool(req.get("explicit_script_request", False))
                    or bool(req.get("implicit_task_intent", False))
                )
            )
            base_reply = (
                f"Passendes bestehendes Script gefunden: `{existing_path.name}` (`{existing_path}`). "
                f"Ich verwende es wieder (Match={existing.get('_match_score', '?')})."
            )
            if not wants_execution:
                reply = base_reply
            elif mode == "deny":
                reply = base_reply + "\nAusfuehrung ist im Modus 'deny' deaktiviert."
            else:
                run_result = _run_action_with_policy(
                    cfg=cfg,
                    message=message,
                    action=script_action,
                    note=f"Script-Ausfuehrung (reuse: {existing_path.name}, timeout=180s)",
                    deny_log="script_denied",
                    allowlist_for_remember=True,
                )
                reply = base_reply + "\n\n" + str(run_result.get("reply", ""))
            _persist_conversation(cfg, message, reply, 0.84)
            return {"ok": True, "reply": reply}

    code = str(req.get("code") or "").strip()
    if not code:
        req_text_lower = str(req.get("request_text", "")).lower()
        if bool(req.get("implicit_task_intent", False)) and _has_any(
            req_text_lower, ["screenshot", "bildschirmfoto", "screen shot"]
        ):
            code = _builtin_screenshot_python_script(str(req.get("request_text", "")))
        else:
            try:
                code = _generate_script_code(cfg, str(req["language"]), str(req["request_text"]))
            except LLMRouterError as exc:
                tool_store.log("script_create_error", str(exc))
                return {"ok": False, "reply": f"Script-Erstellung fehlgeschlagen: {exc}"}
    if not code:
        return {"ok": False, "reply": "Kein Script-Code erzeugt."}

    validate_before_run = bool(req.get("validate_before_run", True))
    if validate_before_run:
        try:
            _, validate_reply = _execute_action(
                {
                    "kind": "script_validate",
                    "script_type": str(req["language"]),
                    "script": code,
                    "script_path": str(target),
                }
            )
            tool_store.log("script_validate", validate_reply)
        except Exception as exc:
            fail = f"Script-Validierung fehlgeschlagen: {exc}"
            _persist_conversation(cfg, message, fail, 0.78)
            return {"ok": False, "reply": fail}
    try:
        _, create_reply = _execute_action(
            {
                "kind": "script_create",
                "script_type": str(req["language"]),
                "script": code,
                "script_path": str(target),
                "request_text": str(req["request_text"]),
                "overwrite": True,
                "validate_before_run": validate_before_run,
                "origin": "user_requested",
            }
        )
        tool_store.log("script_create", create_reply)
    except Exception as exc:
        fail = f"Script-Erstellung fehlgeschlagen: {exc}"
        _persist_conversation(cfg, message, fail, 0.78)
        return {"ok": False, "reply": fail}
    _persist_script_memory(cfg, target, str(req["language"]), str(req["request_text"]), code)
    script_action = {
        "kind": "script_exec",
        "script_type": str(req["language"]),
        "script": code,
        "script_path": str(target),
        "script_owner_role": str(cfg.get("security", {}).get("active_role", "user")).lower(),
        "timeout_sec": 180,
        "source": "script_create",
        "validate_before_run": validate_before_run,
    }
    mode = str(cfg.get("security", {}).get("execution_mode", "unrestricted")).lower()
    wants_execution = (
        not bool(req.get("no_auto_run", False))
        and (
            bool(req.get("run_after_create", False))
            or bool(req.get("explicit_script_request", False))
            or bool(req.get("implicit_task_intent", False))
        )
    )
    if not wants_execution:
        reply = f"Script `{target.name}` wurde in `{target}` erstellt."
    elif mode == "deny":
        reply = (
            f"Script `{target.name}` wurde in `{target}` erstellt.\n"
            "Ausfuehrung ist im Modus 'deny' deaktiviert."
        )
    else:
        run_result = _run_action_with_policy(
            cfg=cfg,
            message=message,
            action=script_action,
            note=f"Script-Ausfuehrung (neu erstellt: {target.name}, timeout=180s)",
            deny_log="script_denied",
            allowlist_for_remember=True,
        )
        run_reply = str(run_result.get("reply", ""))
        reply = f"Script `{target.name}` wurde in `{target}` erstellt.\n\n{run_reply}"
    tool_store.log("script_create", f"{req['language']} -> {target}")
    _persist_conversation(cfg, message, reply, 0.82)
    return {"ok": True, "reply": reply}

def _script_exec_reply_ok(reply: str) -> bool:
    """Gibt False zurück wenn die Script-Ausgabe auf Fehler oder Timeout hindeutet (returncode != 0)."""
    m = re.search(r"returncode=(-?\d+)", reply)
    if m:
        return int(m.group(1)) == 0
    return True  # kein returncode im Reply → kein Script-Result, ok annehmen


def _tool_reply_looks_error(reply: str) -> bool:
    text = str(reply or "").strip()
    if not text:
        return False
    low = text.lower()
    m = re.search(r"returncode=(-?\d+)", low)
    if m:
        try:
            if int(m.group(1)) != 0:
                return True
        except Exception:
            pass
    error_markers = [
        "mcp tool fehler",
        "error executing tool",
        "traceback (most recent call last)",
        "permissionerror",
        "filenotfounderror",
        "tool timeout",
        "status=python_runtime_error",
        "script fehlgeschlagen",
        "aktion fehlgeschlagen",
        "zugriff verweigert",
    ]
    return _has_any(low, error_markers)

def _format_script_result(result: Dict[str, Any]) -> str:
    rc = int(result.get("returncode", -1))
    stdout = str(result.get("stdout", "") or "").strip()
    stderr = str(result.get("stderr", "") or "").strip()

    def _python_error_summary(err_text: str) -> Optional[Dict[str, str]]:
        if not err_text:
            return None
        lines = [ln.rstrip() for ln in err_text.splitlines() if ln.strip()]
        if not lines:
            return None
        type_name = ""
        message = ""
        for ln in reversed(lines):
            m = re.match(r"^([A-Za-z_][\w.]*(?:Error|Exception|Interrupt|Exit))(?::\s*(.*))?$", ln.strip())
            if m:
                type_name = m.group(1)
                message = (m.group(2) or "").strip()
                break
        if not type_name:
            return None
        location = ""
        for ln in reversed(lines):
            m = re.search(r"File\s+\"([^\"]+)\",\s+line\s+(\d+)(?:,\s+in\s+([^\n]+))?", ln)
            if m:
                file_name = Path(m.group(1)).name
                line_no = m.group(2)
                func = (m.group(3) or "").strip()
                location = f"{file_name}:{line_no}" + (f" ({func})" if func else "")
                break
        error_text = f"{type_name}: {message}" if message else type_name
        out: Dict[str, str] = {"error": error_text}
        if location:
            out["location"] = location
        return out

    py_summary = _python_error_summary(stderr) if rc != 0 else None
    if py_summary:
        parts = ["status=python_runtime_error", f"returncode={rc}", f"fehler: {py_summary['error']}"]
        loc = py_summary.get("location", "")
        if loc:
            parts.append(f"ort: {loc}")
        if stdout:
            parts.append(f"stdout (gekuerzt):\n{stdout[:700]}")
        parts.append("details: siehe tool-log")
        return "\n\n".join(parts)

    stdout_short = stdout[:2200]
    stderr_short = stderr[:1200]
    parts = [f"returncode={rc}"]
    if stdout_short:
        parts.append(f"stdout:\n{stdout_short}")
    if stderr_short:
        parts.append(f"stderr:\n{stderr_short}")
    if not stdout_short and not stderr_short:
        parts.append("(keine Ausgabe)")
    return "\n\n".join(parts)

def _execute_script_validate_action(action: Dict[str, Any]) -> tuple[str, str]:
    script_type = str(action.get("script_type", "")).strip().lower()
    script = str(action.get("script", ""))
    script_path = str(action.get("script_path", "") or "").strip()
    if not script.strip():
        raise ValueError("Leerer Script-Inhalt.")
    if script_type not in {"python", "powershell"}:
        raise ValueError("Unbekannter script_type fuer Validierung.")
    if script_type == "python":
        try:
            ast.parse(script)
        except SyntaxError as exc:
            loc = f"Zeile {getattr(exc, 'lineno', '?')}, Spalte {getattr(exc, 'offset', '?')}"
            raise ValueError(f"Python-Syntaxfehler ({loc}): {exc.msg}") from exc
        label = script_path if script_path else "(inline)"
        return "script_validate", f"Script-Validierung OK (python): {label}"
    tmp_path: Optional[Path] = None
    try:
        with tempfile.NamedTemporaryFile("w", suffix=".ps1", delete=False, encoding="utf-8") as f:
            f.write(script)
            tmp_path = Path(f.name)
        safe = str(tmp_path).replace("'", "''")
        ps_cmd = (
            "$tokens=$null; $errors=$null; "
            f"[System.Management.Automation.Language.Parser]::ParseFile('{safe}', [ref]$tokens, [ref]$errors) | Out-Null; "
            "if ($errors -and $errors.Count -gt 0) { "
            "$errors | Select-Object -First 3 | ForEach-Object { "
            "Write-Output ($_.Message + ' @ Zeile ' + $_.Extent.StartLineNumber) "
            "}; exit 1 }"
        )
        proc = subprocess.run(
            ["powershell", "-NoProfile", "-NonInteractive", "-Command", ps_cmd],
            capture_output=True,
            text=True,
            timeout=45,
            shell=False,
        )
        if int(proc.returncode) != 0:
            msg = (proc.stdout or proc.stderr or "").strip()
            raise ValueError(f"PowerShell-Syntaxfehler: {msg or 'Parser meldet Fehler.'}")
    finally:
        if tmp_path is not None:
            with contextlib.suppress(Exception):
                tmp_path.unlink(missing_ok=True)
    label = script_path if script_path else "(inline)"
    return "script_validate", f"Script-Validierung OK (powershell): {label}"

def _extract_script_description(code: str, script_type: str) -> str:
    """Extrahiert ersten Kommentar oder Docstring aus Script-Code."""
    lines = [l.rstrip() for l in (code or "").splitlines() if l.strip()]
    if script_type == "python":
        for line in lines[:10]:
            if line.startswith("#"):
                return line.lstrip("#").strip()
        # Docstring
        if lines and (lines[0].startswith('"""') or lines[0].startswith("'''")):
            return lines[0].strip('"\' ').strip()
    else:  # powershell
        for line in lines[:10]:
            if line.startswith("#"):
                return line.lstrip("#").strip()
    return ""

def _register_script(script_path: Path, script_type: str, code: str, action: Dict[str, Any]) -> None:
    """Trägt erstelltes Script in data/script_registry.json ein."""
    try:
        registry_path = ROOT_DIR / "data" / "script_registry.json"
        registry_path.parent.mkdir(parents=True, exist_ok=True)
        entries: list = []
        if registry_path.exists():
            with contextlib.suppress(Exception):
                entries = json.loads(registry_path.read_text(encoding="utf-8"))
        if not isinstance(entries, list):
            entries = []
        name = script_path.name
        # Duplikate aktualisieren statt doppelt eintragen
        entries = [e for e in entries if str(e.get("path", "")) != str(script_path)]
        # Origin: aus Action falls gesetzt, sonst anhand Name ableiten
        origin = str(action.get("origin", "") or "")
        if not origin:
            if "self_improve" in name or name.startswith("auto_"):
                origin = "bot_created"
            else:
                origin = "user_requested"
        description = _extract_script_description(code, script_type)
        action_hash = ""
        entries.append({
            "path": str(script_path),
            "name": name,
            "type": script_type,
            "created_at": datetime.now().isoformat(),
            "origin": origin,
            "description": description,
            "action_hash": action_hash,
        })
        registry_path.write_text(json.dumps(entries, ensure_ascii=False, indent=2), encoding="utf-8")
        # Allowlist-Meta: Name auf echten Dateinamen aktualisieren
        with contextlib.suppress(Exception):
            meta_path = Path("data/allowlist_meta.json")
            if meta_path.exists() and action_hash in set():
                meta = json.loads(meta_path.read_text(encoding="utf-8"))
                if action_hash in meta:
                    meta[action_hash]["name"] = name
                    meta_path.write_text(json.dumps(meta, ensure_ascii=False, indent=2), encoding="utf-8")
    except Exception:
        pass  # Registry-Fehler soll Script-Erstellung nie blockieren

def _execute_script_create_action(action: Dict[str, Any]) -> tuple[str, str]:
    script_type = str(action.get("script_type", "")).strip().lower()
    script = str(action.get("script", ""))
    script = _repair_script_if_needed(script) if script_type == "python" else script
    script_path = Path(str(action.get("script_path", "") or "")).resolve()
    overwrite = bool(action.get("overwrite", True))
    if script_type not in {"python", "powershell"}:
        raise ValueError("Unbekannter script_type fuer Script-Erstellung.")
    if script_path.suffix.lower() not in {".py", ".ps1"}:
        raise ValueError("Nur .py oder .ps1 sind fuer Script-Dateien erlaubt.")
    if script_path.exists() and (not overwrite):
        raise ValueError(f"Script-Datei existiert bereits: {script_path}")
    script_path.parent.mkdir(parents=True, exist_ok=True)
    script_path.write_text(script, encoding="utf-8")
    _register_script(script_path, script_type, script, action)
    with contextlib.suppress(Exception):
        req_text = str(action.get("request_text", action.get("message", action.get("task", ""))))
        _persist_script_memory(_cfg(), script_path, script_type, req_text, script)
    return "script_create", f"Script-Datei geschrieben: {script_path}"

def _execute_script_action(action: Dict[str, Any]) -> tuple[str, str]:
    script_type = str(action.get("script_type", "")).lower()
    script = str(action.get("script", ""))
    if script_type == "python":
        script = _repair_script_if_needed(script)
    
    # Script-Timeout: ausschließlich aus der WebUI-Konfiguration (max_step_timeout_sec).
    # Das LLM setzt keinen Timeout – alle Zeitlimits werden zentral über das WebUI gesteuert.
    cfg = _cfg()
    _hard_limit = int(cfg.get("tools", {}).get("max_step_timeout_sec", 600) or 600)
    timeout_sec = max(30, _hard_limit)
    source = str(action.get("source", "api"))
    started_at = time.time()
    tmp_path = None
    run_cwd: Path
    script_path_raw = str(action.get("script_path", "") or "").strip()
    explicit_script_path = bool(script_path_raw)

    # Allow path-only execution: load script content from file when script is empty.
    if (not script.strip()) and script_path_raw:
        with contextlib.suppress(Exception):
            script = Path(script_path_raw).read_text(encoding="utf-8-sig", errors="ignore")

    # Script in workspace/scripts/ persistieren falls kein Pfad vorgegeben
    auto_saved_script_path = False
    if not script_path_raw and script:
        with contextlib.suppress(Exception):
            ws = _workspace_abs(_cfg())
            scripts_dir = (ws / "scripts").resolve()
            scripts_dir.mkdir(parents=True, exist_ok=True)
            ts = int(time.time())
            ext = ".py" if script_type == "python" else ".ps1"
            fname = f"auto_{script_type}_{ts}{ext}"
            saved_path = scripts_dir / fname
            saved_path.write_text(script, encoding="utf-8")
            script_path_raw = str(saved_path)
            auto_saved_script_path = True
            action = dict(action)
            action["script_path"] = script_path_raw

    if script_path_raw and explicit_script_path and (not auto_saved_script_path):
        try:
            run_cwd = Path(script_path_raw).resolve().parent
        except Exception:
            run_cwd = ROOT_DIR.resolve()  # K.AI Root als Fallback (verhindert doppelte data/workspace/-Pfade)
    else:
        run_cwd = ROOT_DIR.resolve()  # K.AI Root (konsistent mit sys_shell_command + sys_python_exec)
    with contextlib.suppress(Exception):
        run_cwd.mkdir(parents=True, exist_ok=True)
    # UTF-8 Umgebungsvariablen fuer stabilere Konsole unter Windows
    env = os.environ.copy()
    env["PYTHONIOENCODING"] = "utf-8"
    env["PYTHONUTF8"] = "1"

    import base64 as _b64
    if script_type == "powershell":
        # EncodedCommand (UTF-16-LE Base64) verhindert Fehler bei Pipes,
        # $-Variablen, Anführungszeichen und mehrzeiligen Skripten.
        _ps_prefix = (
            "$ErrorActionPreference = 'Continue'; "
            "$ProgressPreference = 'SilentlyContinue'; "
            "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; "
        )
        _ps_full = _ps_prefix + script
        _ps_enc = _b64.b64encode(_ps_full.encode("utf-16-le")).decode("ascii")
        cmd = ["powershell", "-NoProfile", "-NonInteractive",
               "-ExecutionPolicy", "Bypass", "-EncodedCommand", _ps_enc]
    elif script_type == "python":
        with tempfile.NamedTemporaryFile("w", suffix=".py", delete=False, encoding="utf-8") as f:
            f.write(script)
            tmp_path = Path(f.name)
        # Venv-Python bevorzugen damit installierte Pakete verfügbar sind
        _venv_py = (ROOT_DIR / ".venv" / "Scripts" / "python.exe").resolve()
        _py_exe = str(_venv_py) if _venv_py.exists() else "python"
        # EncodedCommand vermeidet Probleme mit Leerzeichen und Sonderzeichen im Pfad
        _ps_cmd = f"& '{_py_exe}' '{str(tmp_path)}'"
        _ps_enc = _b64.b64encode(_ps_cmd.encode("utf-16-le")).decode("ascii")
        cmd = ["powershell", "-NoProfile", "-NonInteractive", "-EncodedCommand", _ps_enc]
    else:
        raise ValueError("Unbekannter script_type")

    # Script in Registry eintragen (auch wenn nicht persistiert via script_create)
    if script_path_raw and script:
        with contextlib.suppress(Exception):
            _register_script(Path(script_path_raw), script_type, script, action)

    _script_stop_event.clear()
    proc: Optional[subprocess.Popen[str]] = None
    try:
        proc = subprocess.Popen(
            cmd, 
            stdout=subprocess.PIPE, 
            stderr=subprocess.PIPE, 
            text=True, 
            encoding='utf-8',
            errors='replace',
            cwd=str(run_cwd),
            env=env # HIER: UTF-8 Umgebung setzen
        )
        with _script_lock:
            global _script_proc
            _script_proc = proc
            _script_active.clear()
            _script_active.update(
                {
                    "running": True,
                    "script_type": script_type,
                    "source": source,
                    "timeout_sec": timeout_sec,
                    "started_at": time.time(),
                }
            )
        def _force_kill_proc(p):
            """Prozessbaum via taskkill /F /T killen – robust auch bei Network-I/O-Hang."""
            try:
                subprocess.run(
                    ["taskkill", "/F", "/T", "/PID", str(p.pid)],
                    capture_output=True, timeout=8
                )
            except Exception:
                with contextlib.suppress(Exception):
                    p.kill()
            try:
                p.wait(timeout=5)
            except Exception:
                pass

        out_chunks: List[str] = []
        err_chunks: List[str] = []
        stream_q: "queue.Queue[Tuple[str, str]]" = queue.Queue()

        def _reader_loop(stream_name: str, pipe: Any) -> None:
            if pipe is None:
                return
            try:
                while True:
                    chunk = pipe.readline()
                    if chunk == "":
                        break
                    stream_q.put((stream_name, str(chunk)))
            except Exception:
                pass
            finally:
                with contextlib.suppress(Exception):
                    pipe.close()

        def _drain_stream_queue() -> None:
            while True:
                try:
                    stream_name, chunk = stream_q.get_nowait()
                except queue.Empty:
                    break
                if stream_name == "stderr":
                    err_chunks.append(chunk)
                else:
                    out_chunks.append(chunk)
                # CR-basierte Progress-Ausgaben ebenfalls als Zeilen behandeln.
                for part in str(chunk).replace("\r", "\n").split("\n"):
                    line = str(part or "").strip()
                    if not line:
                        continue
                    _emit_script_stream(script_type, stream_name, line, source, timeout_sec)

        stdout_thread = threading.Thread(
            target=_reader_loop,
            args=("stdout", proc.stdout),
            daemon=True,
            name=f"script-{script_type}-stdout",
        )
        stderr_thread = threading.Thread(
            target=_reader_loop,
            args=("stderr", proc.stderr),
            daemon=True,
            name=f"script-{script_type}-stderr",
        )
        stdout_thread.start()
        stderr_thread.start()

        while proc.poll() is None:
            _drain_stream_queue()
            if _script_stop_event.is_set():
                _force_kill_proc(proc)
                with contextlib.suppress(Exception):
                    stdout_thread.join(timeout=1.5)
                with contextlib.suppress(Exception):
                    stderr_thread.join(timeout=1.5)
                _drain_stream_queue()
                result = {"returncode": -9, "stdout": "".join(out_chunks), "stderr": "".join(err_chunks), "stopped": True}
                _push_script_history(
                    {
                        "when": time.time(),
                        "script_type": script_type,
                        "source": source,
                        "timeout_sec": timeout_sec,
                        "status": "stopped",
                        "duration_sec": round(time.time() - started_at, 2),
                    }
                )
                return (f"{script_type}_exec", _format_script_result(result))
            if time.time() - started_at > timeout_sec:
                _force_kill_proc(proc)
                with contextlib.suppress(Exception):
                    stdout_thread.join(timeout=1.5)
                with contextlib.suppress(Exception):
                    stderr_thread.join(timeout=1.5)
                _drain_stream_queue()
                result = {"returncode": -124, "stdout": "".join(out_chunks), "stderr": "".join(err_chunks), "timeout": True}
                _push_script_history(
                    {
                        "when": time.time(),
                        "script_type": script_type,
                        "source": source,
                        "timeout_sec": timeout_sec,
                        "status": "timeout",
                        "duration_sec": round(time.time() - started_at, 2),
                    }
                )
                return (f"{script_type}_exec", _format_script_result(result))
            time.sleep(0.2)
        with contextlib.suppress(Exception):
            stdout_thread.join(timeout=2.0)
        with contextlib.suppress(Exception):
            stderr_thread.join(timeout=2.0)
        _drain_stream_queue()
        rc = int(proc.returncode if proc.returncode is not None else -1)
        status = "ok" if rc == 0 else "error"
        result = {"returncode": rc, "stdout": "".join(out_chunks), "stderr": "".join(err_chunks)}
        _push_script_history(
            {
                "when": time.time(),
                "script_type": script_type,
                "source": source,
                "timeout_sec": timeout_sec,
                "status": status,
                "duration_sec": round(time.time() - started_at, 2),
            }
        )
        return (f"{script_type}_exec", _format_script_result(result))
    finally:
        with _script_lock:
            _script_active.clear()
            _script_active.update({"running": False})
            _script_proc = None
        _script_stop_event.clear()
        if tmp_path and tmp_path.exists():
            with contextlib.suppress(Exception):
                tmp_path.unlink()
        if proc and proc.poll() is None:
            with contextlib.suppress(Exception):
                proc.kill()
    raise ValueError("Unbekannter script_type")

def _execute_install_python_packages_action(action: Dict[str, Any]) -> tuple[str, str]:
    # Package-Mapping: Import-Name → pip-Package-Name
    PACKAGE_MAPPING = {
        "win32api": "pywin32",
        "win32com": "pywin32",
        "win32con": "pywin32",
        "win32file": "pywin32",
        "win32gui": "pywin32",
        "win32process": "pywin32",
        "win32security": "pywin32",
        "pywintypes": "pywin32",
        "PIL": "Pillow",
        "cv2": "opencv-python",
        "sklearn": "scikit-learn",
    }

    pkgs_raw = action.get("packages", [])
    if not isinstance(pkgs_raw, list):
        raise ValueError("packages muss eine Liste sein")

    # Mappe Package-Namen
    packages = []
    for p in pkgs_raw:
        pkg = str(p).strip()
        if pkg:
            # Prüfe ob Mapping existiert
            mapped = PACKAGE_MAPPING.get(pkg, pkg)
            # Vermeide Duplikate
            if mapped not in packages:
                packages.append(mapped)

    if not packages:
        raise ValueError("Keine Python-Pakete angegeben")

    # PRE-FLIGHT-CHECK: Welche Pakete sind schon installiert?
    try:
        pip_list_proc = subprocess.run(
            [sys.executable, "-m", "pip", "list", "--disable-pip-version-check"],
            capture_output=True, text=True, timeout=15
        )
        if pip_list_proc.returncode == 0:
            installed_names = set()
            for line in pip_list_proc.stdout.strip().split('\n')[2:]:  # Skip header
                parts = line.split()
                if parts:
                    installed_names.add(parts[0].lower())

            # Filtere nur die Pakete die NICHT installiert sind
            packages_to_install = []
            for pkg in packages:
                if pkg.lower() not in installed_names:
                    packages_to_install.append(pkg)

            if not packages_to_install:
                # Alle Pakete sind schon installiert!
                return ("python_pip_install",
                        f"returncode=0\n\nAlle Pakete schon installiert: {', '.join(packages)}\n\n"
                        f"stdout:\nRequirement already satisfied: {', '.join(packages)}")

            packages = packages_to_install  # Nur fehlende installieren
    except Exception:
        pass  # Bei Fehler: normal installieren
    base_flags = ["--disable-pip-version-check", "--retries", "1", "--timeout", "20"]
    cmd = [sys.executable, "-m", "pip", "install", *base_flags, *packages]
    install_timeout = 60
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=install_timeout, shell=False)
    except subprocess.TimeoutExpired as exc:
        out = str(exc.stdout or "").strip()
        err = str(exc.stderr or "").strip()
        parts = [
            "returncode=-124",
            f"Pakete installiert: {', '.join(packages)}",
            f"pip install timeout ({install_timeout}s) - Vorgang wurde abgebrochen.",
        ]
        if out:
            parts.append(f"stdout:\n{out[:1800]}")
        if err:
            parts.append(f"stderr:\n{err[:1200]}")
        raise RuntimeError("\n\n".join(parts))
    stdout = (proc.stdout or "").strip()
    stderr = (proc.stderr or "").strip()
    rc = int(proc.returncode)
    fallback_used = False
    fallback_note = ""
    if rc != 0:
        retry_env = os.environ.copy()
        removed: List[str] = []
        for k in [
            "PIP_NO_INDEX",
            "PIP_FIND_LINKS",
            "HTTP_PROXY",
            "HTTPS_PROXY",
            "ALL_PROXY",
            "http_proxy",
            "https_proxy",
            "all_proxy",
            "GIT_HTTP_PROXY",
            "GIT_HTTPS_PROXY",
        ]:
            if k in retry_env:
                retry_env.pop(k, None)
                removed.append(k)
        retry_env["PIP_INDEX_URL"] = "https://pypi.org/simple"
        retry_cmd = [
            sys.executable,
            "-m",
            "pip",
            "install",
            "--index-url",
            "https://pypi.org/simple",
            *base_flags,
            *packages,
        ]
        try:
            proc2 = subprocess.run(
                retry_cmd, capture_output=True, text=True, timeout=install_timeout, shell=False, env=retry_env
            )
        except subprocess.TimeoutExpired as exc:
            out = str(exc.stdout or "").strip()
            err = str(exc.stderr or "").strip()
            parts = [
                "returncode=-124",
                f"Pakete installiert: {', '.join(packages)}",
                f"pip retry timeout ({install_timeout}s) - Vorgang wurde abgebrochen.",
            ]
            if out:
                parts.append(f"stdout:\n{out[:1800]}")
            if err:
                parts.append(f"stderr:\n{err[:1200]}")
            raise RuntimeError("\n\n".join(parts))
        rc2 = int(proc2.returncode)
        if rc2 == 0:
            proc = proc2
            stdout = (proc2.stdout or "").strip()
            stderr = (proc2.stderr or "").strip()
            rc = rc2
            fallback_used = True
            fallback_note = "Retry mit bereinigter pip-Umgebung + pypi.org erfolgreich."
        else:
            # keep first failure output, but make blockers visible
            if removed:
                fallback_note = (
                    "Hinweis: Retry mit bereinigter pip-Umgebung versucht (entfernt: "
                    + ", ".join(sorted(removed))
                    + "), blieb aber erfolglos."
                )
    reply = [f"returncode={rc}", f"Pakete installiert: {', '.join(packages)}"]
    if fallback_used and fallback_note:
        reply.append(fallback_note)
    elif fallback_note:
        reply.append(fallback_note)
    if stdout:
        reply.append(f"stdout:\n{stdout[:2200]}")
    if stderr:
        reply.append(f"stderr:\n{stderr[:1400]}")
    # 🧠 PROAKTIVES GEDÄCHTNIS: Erfolgreiche Installationen dauerhaft merken (mit Version!)
    if rc == 0 and packages:
        try:
            from app.context_manager import ContextManager
            import re
            _cm = ContextManager()

            # Extrahiere Versionen aus stdout
            _versions = {}
            for line in (stdout or "").split("\n"):
                # Format: "Successfully installed package-1.2.3"
                _match = re.search(r'(\S+?)-(\d+\.\d+[\.\d]*)', line)
                if _match:
                    _pkg_name = _match.group(1).lower().replace('-', '_')
                    _version = _match.group(2)
                    _versions[_pkg_name] = _version

            # Speichere Facts (mit Version wenn gefunden, sonst nur "installed")
            for _p in packages:
                _p_clean = _p.lower().replace('-', '_')
                _p_key = f"pkg_{_p_clean}_installed"
                _p_version = _versions.get(_p_clean, "installed")
                _cm.save_fact(_p_key, _p_version)
        except Exception:
            pass
            
    return ("python_pip_install", "\n\n".join(reply))

def _execute_install_nodejs_packages_action(action: Dict[str, Any]) -> tuple[str, str]:
    """Install Node.js packages via npm."""
    pkgs_raw = action.get("packages", [])
    if not isinstance(pkgs_raw, list):
        raise ValueError("packages muss eine Liste sein")
    packages = [str(p).strip() for p in pkgs_raw if str(p).strip()]
    if not packages:
        raise ValueError("Keine Node.js-Pakete angegeben")
    
    # Check if npm is available
    try:
        npm_check = subprocess.run(["npm", "--version"], capture_output=True, text=True, timeout=5, shell=False)
        if npm_check.returncode != 0:
            raise RuntimeError("npm ist nicht installiert oder nicht im PATH verfügbar.")
    except (subprocess.TimeoutExpired, FileNotFoundError):
        raise RuntimeError("npm ist nicht installiert oder nicht im PATH verfügbar.")
    
    # Install packages
    cmd = ["npm", "install", "--no-save", *packages]
    install_timeout = 120
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=install_timeout, shell=False)
    except subprocess.TimeoutExpired as exc:
        out = str(exc.stdout or "").strip()
        err = str(exc.stderr or "").strip()
        parts = [
            "returncode=-124",
            f"Pakete installiert: {', '.join(packages)}",
            f"npm install timeout ({install_timeout}s) - Vorgang wurde abgebrochen.",
        ]
        if out:
            parts.append(f"stdout:\n{out[:1800]}")
        if err:
            parts.append(f"stderr:\n{err[:1200]}")
        raise RuntimeError("\n\n".join(parts))
    
    stdout = (proc.stdout or "").strip()
    stderr = (proc.stderr or "").strip()
    rc = int(proc.returncode)
    reply = [f"returncode={rc}", f"Pakete installiert: {', '.join(packages)}"]
    if stdout:
        reply.append(f"stdout:\n{stdout[:2200]}")
    if stderr:
        reply.append(f"stderr:\n{stderr[:1400]}")
    if rc != 0:
        raise RuntimeError("\n\n".join(reply))
    return ("nodejs_npm_install", "\n\n".join(reply))

def _execute_downloaded_file_action(action: Dict[str, Any]) -> tuple[str, str]:
    path = Path(str(action.get("path", ""))).resolve()
    if not path.exists() or not path.is_file():
        raise FileNotFoundError(f"Datei nicht gefunden: {path}")
    suffix = path.suffix.lower()
    if suffix not in {".exe", ".msi", ".cmd", ".bat", ".ps1"}:
        raise ValueError(f"Dateityp nicht erlaubt fuer direkte Ausfuehrung: {suffix or '(ohne Endung)'}")

    if suffix == ".msi":
        cmd = ["msiexec", "/i", str(path), "/qn"]
    elif suffix == ".ps1":
        cmd = ["powershell", "-NoProfile", "-NonInteractive", "-ExecutionPolicy", "Bypass", "-File", str(path)]
    elif suffix in {".bat", ".cmd"}:
        cmd = ["cmd", "/c", str(path)]
    else:
        cmd = [str(path)]

    proc = subprocess.run(cmd, capture_output=True, text=True, timeout=900, shell=False)
    stdout = (proc.stdout or "").strip()
    stderr = (proc.stderr or "").strip()
    parts = [f"returncode={int(proc.returncode)}", f"Datei ausgefuehrt: {path}"]
    if stdout:
        parts.append(f"stdout:\n{stdout[:2200]}")
    if stderr:
        parts.append(f"stderr:\n{stderr[:1200]}")
    return "run_downloaded_file", "\n\n".join(parts)

def _lookup_mapped_drive_for_unc(unc_root: str) -> str:
    want = str(unc_root or "").strip().lower().replace("/", "\\")
    if not want:
        return ""
    try:
        proc = subprocess.run(
            ["cmd", "/c", "net", "use"],
            capture_output=True,
            text=True,
            encoding="utf-8",
            errors="ignore",
            timeout=20,
            shell=False,
        )
        txt = f"{proc.stdout or ''}\n{proc.stderr or ''}"
    except Exception:
        return ""
    for line in txt.splitlines():
        s = line.strip()
        if not s:
            continue
        m = re.search(r"\b([A-Z]:)\b", s, flags=re.IGNORECASE)
        if not m:
            continue
        drv = str(m.group(1) or "").upper()
        low = s.lower().replace("/", "\\")
        if want in low:
            return drv
    return ""

# ---------------------------------------------------------------------------
# Compound Pipeline Executor
# Executes a list of dependency-aware steps parsed by decompose_compound_steps().
# Context flows between steps: e.g. mapped drive_letter is available to search_files.
# Steps with unsatisfied requires[] are skipped with a clear reason.
# ---------------------------------------------------------------------------

def _execute_compound_pipeline(steps: list[dict], cfg: dict, dialog_key: str = "") -> dict:
    """Execute an ordered, dependency-aware list of pipeline steps.

    Context dict is passed between steps:
      search_files → provides: search_results, search_path
      send_result  → provides: output_file  (requires: search_results)
    """
    from app.tools.filesystem import list_entries, write_file as fs_write_file

    context: dict = {}
    reply_parts: list[str] = []

    for step in steps:
        kind = step.get("kind", "generic")

        # --- dependency check ---
        missing = [r for r in step.get("requires", []) if r not in context]
        if missing:
            reply_parts.append(
                f"[{kind}] übersprungen – fehlende Voraussetzung: {', '.join(missing)}"
            )
            continue

        # --- search_files ---
        if kind == "search_files":
            drive_ref = str(step.get("drive_ref") or context.get("drive_letter") or "").strip()
            folder = str(step.get("folder") or "").strip()
            ext = str(step.get("ext") or "").strip() or None
            keyword = str(step.get("keyword") or "").strip() or None

            # Build search base path; resolve subfolder case-insensitively
            base = Path(drive_ref + "\\") if drive_ref else Path(".")
            if folder:
                try:
                    matched = next(
                        (c for c in base.iterdir() if c.is_dir() and c.name.lower() == folder.lower()),
                        None,
                    )
                    base = matched if matched else base / folder
                except Exception:
                    base = base / folder

            try:
                items = list_entries(str(base), want="files", recursive=True, ext=ext, max_items=3000)
                if keyword:
                    kw = keyword.lower()
                    items = [i for i in items if kw in Path(i).name.lower()]
                context["search_results"] = items
                context["search_path"] = str(base)
                context["search_keyword"] = keyword or ""
                context["search_ext"] = ext or ""
                count = len(items)
                kw_info = f" mit '{keyword}' im Namen" if keyword else ""
                ext_info = f" ({ext})" if ext else ""
                if count:
                    reply_parts.append(f"{count} Datei(en){ext_info}{kw_info} in {base} gefunden.")
                else:
                    reply_parts.append(f"Keine Dateien{ext_info}{kw_info} in {base} gefunden.")
            except Exception as exc:
                reply_parts.append(f"Suche fehlgeschlagen: {exc}")

        # --- send_result ---
        elif kind == "send_result":
            results: list = context.get("search_results", [])
            if not results:
                reply_parts.append("Keine Suchergebnisse vorhanden.")
                continue
            fmt = str(step.get("format") or "txt")
            ws = _workspace_abs(cfg)
            kw = context.get("search_keyword") or "suchergebnisse"
            fname = f"{kw.replace(' ', '_')}_suche.txt"
            out_path = ws / fname
            content_txt = "\n".join(results)
            try:
                fs_write_file(str(out_path), content_txt)
                context["output_file"] = str(out_path)
                reply_parts.append(f"Suchergebnisse gespeichert unter `{out_path}`")
            except Exception as exc:
                reply_parts.append(f"Datei speichern fehlgeschlagen: {exc}")

        # --- generic fallback ---
        else:
            result = _handle_filesystem_request(step.get("text", ""), cfg, dialog_key)
            if result and result.get("reply"):
                reply_parts.append(str(result["reply"]))

    return {"ok": True, "reply": "\n\n".join(r for r in reply_parts if r)}

def _effective_catalog_from_config(cfg: Dict[str, Any]) -> Dict[str, Any]:
    by_id: Dict[str, Dict[str, Any]] = {}
    cfg_providers = cfg.get("providers", {}) if isinstance(cfg.get("providers", {}), dict) else {}
    for pid, p in cfg_providers.items():
        if not isinstance(p, dict):
            continue
        pid_s = str(pid).strip()
        if not pid_s:
            continue
        if not _provider_enabled(p):
            continue
        current = by_id.get(
            pid_s,
            {
                "id": pid_s,
                "name": pid_s,
                "type": str(p.get("type", "")),
                "models": [],
                "api_key_set": False,
                "api_key_required": True,
            },
        )
        current["type"] = str(p.get("type", current.get("type", "")))
        current["base_url"] = p.get("base_url")
        current["api_key_alias"] = p.get("api_key_alias")
        requires_key = _provider_requires_api_key(p)
        current["api_key_required"] = requires_key
        
        # Check if key is set: either directly in config OR in secrets.db via alias
        has_key = bool(str(p.get("api_key", "") or "").strip())
        if not has_key and p.get("api_key_alias"):
            try:
                store = _secret_store(cfg)
                val = store.get_alias(p["api_key_alias"])
                if val: has_key = True
            except Exception: pass
            
        current["api_key_set"] = (not requires_key) or has_key
        cfg_models = p.get("models", []) if isinstance(p.get("models", []), list) else []
        models = [str(m).strip() for m in cfg_models if str(m).strip()]
        if not models:
            default_model = str(p.get("default_model", "")).strip()
            if default_model:
                models = [default_model]
        if models:
            # keep stable order, unique
            uniq: List[str] = []
            seen: set[str] = set()
            for m in models:
                k = m.lower()
                if k in seen:
                    continue
                seen.add(k)
                uniq.append(m)
            current["models"] = uniq
        by_id[pid_s] = current
    return {"providers": list(by_id.values())}

def _should_try_network_map_fallback(exc_text: str) -> bool:
    low = str(exc_text or "").lower()
    return any(x in low for x in ["zugriff verweigert", "access denied", "unauthorized", "pfad nicht gefunden", "network path"])

from app.utils.shell_executor import _run_powershell, _run_python, _run_cmd, _run_shell_universal
class LocalActionDispatcher:
    _handlers = {}
    
    @classmethod
    def register(cls, *kinds):
        def decorator(func):
            for k in kinds:
                cls._handlers[k] = func
            return func
        return decorator

    @classmethod
    def dispatch(cls, action) -> tuple[str, str]:
        if "directory" in action and "path" not in action: action["path"] = action.pop("directory")
        if "file" in action and "path" not in action: action["path"] = action.pop("file")
        if "text" in action and "content" not in action: action["content"] = action.pop("content", action.pop("text", ""))
        if "body" in action and "content" not in action: action["content"] = action.pop("body")
        if "cmd" in action and "command" not in action: action["command"] = action.pop("cmd")
        
        kind = str(action.get("kind", "filesystem")).strip()
        
        if "param" in action:
            spec = _action_schemas().get(kind, {})
            req_keys = list(spec.get("required", {}).keys())
            if len(req_keys) == 1 and req_keys[0] not in action:
                action[req_keys[0]] = action.pop("param")
                
        if kind == "dynamic_tool_create":
            return kind, "FEHLER: dynamic_tool_create ist deaktiviert. Nutze 'sys_python_exec'." 
            
        alias_map = {"gmail_send": "gmail_send_email", "gmail_send_advanced": "gmail_send_email_advanced", "gmail_list": "gmail_list_messages"}
        if kind in alias_map:
            kind = alias_map[kind]
            action["kind"] = kind

        ok, err = _validate_action_schema(action)
        if not ok:
            raise ValueError(f"Action-Schema ungueltig: {err}")

        # Dispatch via dict
        handler = cls._handlers.get(kind)
        if handler:
            return handler(kind, action)
            
        # Fallbacks for dynamic grouped tools
        if kind.startswith("mcp_") or _is_cached_mcp_tool(kind):
            return _execute_mcp_tool(_cfg(), kind, action)
            
        if kind.startswith(("fs_", "net_", "git_", "mem_", "sys_")):
            return cls._handle_dynamic_structured(kind, action)

        try:
            return execute_filesystem_action(action)
        except Exception:
            raise

    @classmethod
    def _handle_dynamic_structured(cls, kind: str, action) -> tuple[str, str]:
        try:
            import os
            from app.config import ROOT_DIR
            from app.utils.shell_executor import _run_shell_universal
            cwd = str((ROOT_DIR / "data" / "workspace").resolve())
            os.makedirs(cwd, exist_ok=True)

            if kind == "fs_find_files":
                # 🚨 FIXED: PowerShell -Filter unterstützt NUR einfache Wildcard-Pattern!
                # NICHT: *.mp3;*.flac (Semikolon funktioniert nicht!)
                # STATTDESSEN: -Include für mehrere Pattern
                _p   = str(action.get("path", ".")).replace("'", "''")
                _pat = str(action.get("pattern", "*")).replace("'", "''")
                _rec = "-Recurse" if action.get("recursive", True) else ""

                # 🚨 FIX: Wenn Pattern mit Semikolon, nutze -Include statt -Filter
                if ";" in _pat or "," in _pat:
                    # Pattern wie *.mp3;*.flac → -Include *.mp3, *.flac
                    _includes = _pat.replace(";", ",").strip()
                    _ps_script = (
                        f"$items = @(Get-ChildItem -Path '{_p}' -Include {_includes} {_rec} -File"
                        f" -ErrorAction SilentlyContinue | Select-Object -ExpandProperty FullName)\n"
                    )
                else:
                    # Einfaches Pattern: *.mp3 oder *dubstep*
                    _ps_script = (
                        f"$items = @(Get-ChildItem -Path '{_p}' -Filter '{_pat}' {_rec} -File"
                        f" -ErrorAction SilentlyContinue | Select-Object -ExpandProperty FullName)\n"
                    )

                _ps_script += (
                    f"if ($items.Count -eq 0) {{\n"
                    f"  'Found 0 files:'\n"
                    f"  'PFAD: {_p}'\n"
                    f"  'PATTERN: {_pat}'\n"
                    f"}} else {{\n"
                    f"  'Found ' + $items.Count + ' files:'\n"
                    f"  $items\n"
                    f"}}"
                )
                _ps_timeout = int((_cfg() or {}).get("cli_core", {}).get("max_step_timeout_sec", 600) or 600)
                _, res = _run_shell_universal(_ps_script, timeout=max(30, _ps_timeout), kind="shell_command", cwd=cwd)
                return kind, res

            if kind == "sys_shell_command":
                action["kind"] = "shell_command"
                return cls.dispatch(action)

            # Interne Felder die nicht an Tool-Funktionen weitergegeben werden dürfen
            _INTERNAL_KEYS = {"kind", "_tool_id"}
            # Modul-Mapping
            import importlib
            mod_map = {
                "fs_apply_patch": "diff_engine", 
                "fs_code_outline": "code_scanner", 
                "fs_search_symbol": "code_scanner",
                "fs_find_usages": "code_scanner",
                "fs_index_workspace": "code_rag",
                "fs_search_codebase": "code_rag",
                "fs_": "filesystem", 
                "net_": "network", 
                "git_": "git", 
                "mem_": "memory", 
                "web_": "web_toolkit", 
                "terminal_": "terminal"
            }
            for prefix, mod_name in mod_map.items():
                if kind.startswith(prefix):
                    mod = importlib.import_module(f"app.tools.{mod_name}")
                    if hasattr(mod, kind):
                        func = getattr(mod, kind)
                        _kwargs = {k: v for k, v in action.items() if k not in _INTERNAL_KEYS}
                        _max_tool_timeout = int((_cfg() or {}).get("cli_core", {}).get("max_step_timeout_sec", 600) or 600)
                        import concurrent.futures as _cf
                        with _cf.ThreadPoolExecutor(max_workers=1) as _ex:
                            _fut = _ex.submit(func, **_kwargs)
                            try:
                                res = _fut.result(timeout=_max_tool_timeout)
                                if kind.startswith("terminal_") and isinstance(res, dict):
                                    parts = []
                                    if res.get("process_id"): parts.append(f"PROCESS_ID: {res['process_id']}")
                                    if res.get("status"): parts.append(f"STATUS: {res['status']}")
                                    if res.get("output"): parts.append(f"OUTPUT:\n{res.get('output', '').strip()}")
                                    if res.get("message"): parts.append(f"MESSAGE: {res['message']}")
                                    if res.get("error"): parts.append(f"ERROR: {res['error']}")
                                    if not parts: return kind, str(res)
                                    return kind, "\n".join(parts)
                                return kind, str(res)
                            except _cf.TimeoutError:
                                return kind, (
                                    f"TIMEOUT: {kind} wurde nach {_max_tool_timeout}s abgebrochen. "
                                    f"Der Suchpfad oder die Operation war zu groß — Pfad eingrenzen."
                                )

            if kind == "sys_cmd_exec":
                # background=True: Prozess detached starten, sofort zurück (GUI-Apps, Dienste)
                if action.get("background"):
                    import subprocess as _sp, time as _time
                    _bg_cmd = str(action.get("command", ""))
                    _bg_p = _sp.Popen(
                        _bg_cmd, shell=True,
                        creationflags=_sp.DETACHED_PROCESS | _sp.CREATE_NEW_PROCESS_GROUP,
                        stdout=_sp.DEVNULL, stderr=_sp.DEVNULL,
                        close_fds=True,
                    )
                    _time.sleep(1.5)
                    if _bg_p.poll() is None:
                        return kind, f"Prozess gestartet und läuft (background/detached), PID={_bg_p.pid}. ✓"
                    else:
                        return kind, (
                            f"⚠️ Prozess sofort beendet (returncode={_bg_p.returncode}, PID={_bg_p.pid}). "
                            f"Mögliche Ursachen: Port bereits belegt, Befehl nicht gefunden, fehlende Rechte. "
                            f"Tipp: Erst ohne background=True mit kurzem timeout ausführen um Fehlerausgabe zu sehen."
                        )
                from app.tools import cmd as cmd_mod
                # Timeout: LLM-Wert durch Config-Wert cappen (WebUI: Timeouts > Max. Tool-Timeout)
                _max_timeout = int((_cfg() or {}).get("cli_core", {}).get("max_step_timeout_sec", 600) or 600)
                _llm_timeout = action.get("timeout", _max_timeout)
                _safe_timeout = min(int(_llm_timeout or _max_timeout), _max_timeout)
                # Nur bekannte Parameter weitergeben — unbekannte (z.B. timeout_sec statt timeout)
                # führen sonst zu TypeError. Unbekannte sofort melden statt still scheitern.
                _known_cmd_keys = _INTERNAL_KEYS | {"command", "timeout", "background"}
                _unknown_cmd = [k for k in action if k not in _known_cmd_keys]
                _call_args = {"command": str(action.get("command", "")), "timeout": _safe_timeout}
                res = cmd_mod.run_cmd(**_call_args)
                _cmd_result = f"CMD_STDOUT: {res.get('stdout')}\nCMD_STDERR: {res.get('stderr')}\nEXIT_CODE: {res.get('returncode')}"
                if _unknown_cmd:
                    _cmd_result += f"\n\n⚠️ Unbekannte Parameter ignoriert: {_unknown_cmd}. Erlaubt: command, timeout, background."
                if res.get("returncode") == -124:
                    _cmd_result += (
                        "\n\n⚠️ TIMEOUT: Der Befehl wurde nach dem Zeitlimit abgebrochen. "
                        "Falls es ein Dauerprozess ist (Server, Dienst, GUI-App), "
                        "beim nächsten Aufruf background=True setzen — "
                        "dann startet er detached ohne zu blockieren."
                    )
                return kind, _cmd_result
            if kind == "sys_python_exec":
                from app.tools import python_exec as py_mod
                _py_kwargs = {k: v for k, v in action.items() if k not in _INTERNAL_KEYS}
                # trace_id übergeben → persistente Session pro Job (Variablen bleiben erhalten)
                # Priorität: action-Feld (Execution Plane) > ContextVar (direkter ReAct-Loop)
                try:
                    _py_kwargs["trace_id"] = _py_kwargs.get("trace_id") or _trace_id_ctx.get("") or ""
                except Exception:
                    pass
                res = py_mod.run_python(**_py_kwargs)
                _py_exe = res.get("python_exe", "unbekannt")
                _py_rc = int(res.get("returncode") or 0)
                _py_stdout = str(res.get("stdout") or "").strip()
                _py_stderr = str(res.get("stderr") or "").strip()

                # Smart Icon Logic: nicht nur auf returncode prüfen
                _py_icon = "✅"  # default success
                if _py_rc != 0:
                    # returncode != 0 = irgendein Fehler. Aber war der Code teilweise erfolgreich?
                    _success_keywords = ["success", "found", "completed", "done", "erfolgreich", "gefunden", "abgeschlossen"]
                    _has_success_output = any(kw in _py_stdout.lower() for kw in _success_keywords)

                    if _py_stdout and _has_success_output and _py_stderr:
                        _py_icon = "⚠️"  # Partial success: stdout hat erfolgs-signale aber stderr hat auch fehler
                    else:
                        _py_icon = "❌"  # Complete failure

                _py_parts = [f"{_py_icon} PYTHON ({_py_exe}):", f"returncode={_py_rc}"]
                if _py_stdout:
                    _py_parts.append(f"stdout:\n{_py_stdout}")
                if _py_stderr:
                    _py_parts.append(f"stderr:\n{_py_stderr}")
                if not _py_stdout and not _py_stderr:
                    _py_parts.append("(keine Ausgabe)")
                return kind, "\n\n".join(_py_parts)
            if kind == "sys_screenshot":
                from app.tools.screenshot import sys_screenshot as _ss
                res = _ss(**{k: v for k, v in action.items() if k not in _INTERNAL_KEYS})
                if res.get("ok"):
                    return kind, f"Screenshot gespeichert: {res['path']} ({res['width']}x{res['height']} px, {res['size_kb']} KB, Methode: {res['method']})"
                return kind, f"Screenshot fehlgeschlagen: {res.get('error')}"

        except Exception as e:
            return kind, f"ERROR executing structured tool {kind}: {e}"
        return kind, f"Tool {kind} nicht im Dynamik-Mapping gefunden."


