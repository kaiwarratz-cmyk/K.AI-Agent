@app.get("/api/mcp/tools")
def api_mcp_tools() -> Dict[str, Any]:
    from app.mcp_tools import get_cached_mcp_tools, mcp_available, LOCAL_SERVER_NAME
    ok, msg = mcp_available()
    if not ok:
        return {"ok": False, "count": 0, "items": [], "message": msg}
    tools = []
    for t in get_cached_mcp_tools():
        if not isinstance(t, dict):
            continue
        func = t.get("function", {}) if isinstance(t.get("function", {}), dict) else {}
        name = str(func.get("name", "")).strip()
        if not name:
            continue
        meta = t.get("mcp_meta", {}) if isinstance(t.get("mcp_meta", {}), dict) else {}
        tools.append(
            {
                "name": name,
                "description": str(func.get("description", "")).strip(),
                "server": meta.get("server"),
                "original_name": meta.get("original_name"),
                "is_dynamic": False,
                "created_by_role": None,
            }
        )
    return {"ok": True, "count": len(tools), "items": tools}


