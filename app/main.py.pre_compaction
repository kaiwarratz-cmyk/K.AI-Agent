def _detect_factual_domain(query: str) -> str:
    q = (query or "").strip().lower()
    if not q:
        return ""
    if re.search(r"(liste|alle).*(amerikanisch\w*\s+pr[aä]sident\w*|us[-\s]*pr[aä]sident\w*|u\.s\.\s*president\w*)", q):
        return "us_presidents_list"
    if re.search(r"\b(liste\s+aller|vollst[aä]ndige\s+liste|complete\s+list)\b", q):
        return "generic_factual_list"
    if _needs_factual_web_verification(q):
        return "time_sensitive_fact"
    return ""

def _answer_has_list_structure(answer_text: str, min_items: int = 8) -> bool:
    if not answer_text:
        return False
    numbered = re.findall(r"(^|\n)\s*\d+[.)]\s+", answer_text)
    bullets = re.findall(r"(^|\n)\s*[-*]\s+\S+", answer_text)
    return len(numbered) >= min_items or len(bullets) >= min_items

def _factual_answer_issue(domain: str, query: str, answer_text: str) -> str:
    q = (query or "").lower()
    a = (answer_text or "").strip()
    low = a.lower()
    if not a:
        return "empty"
    meta_markers = [
        "ich habe bereits",
        "in der vorherigen konversation",
        "bereits bereitgestellt",
        "benötigen sie weitere informationen",
        "benoetigen sie weitere informationen",
        "hier ist der link",
        "wikipedia.org/wiki",
    ]
    if _has_any(low, meta_markers):
        return "meta_or_reference"
    if domain in {"generic_factual_list", "us_presidents_list"} and not _answer_has_list_structure(a, min_items=8):
        return "list_structure_missing"
    if domain == "us_presidents_list":
        numbered = re.findall(r"(^|\n)\s*\d+[.)]\s+", a)
        if len(numbered) < 46:
            return "us_presidents_too_short"
    if domain == "time_sensitive_fact":
        has_date = bool(re.search(r"\b\d{4}-\d{2}-\d{2}\b", a)) or ("stand " in low)
        if not has_date:
            return "missing_as_of_date"
    if "liste" in q and ("http://" in low or "https://" in low) and not _answer_has_list_structure(a, min_items=5):
        return "url_only"
    return ""

def _regenerate_factual_answer(cfg: Dict[str, Any], query: str, domain: str, draft: str, issue: str) -> str:
    if domain == "us_presidents_list":
        return _build_us_presidents_list(cfg)
    verified = _web_verified_answer(cfg, query, draft)
    if verified:
        if not _factual_answer_issue(domain, query, verified):
            return verified
    router = LLMRouter(cfg)
    extra = []
    if domain in {"generic_factual_list", "us_presidents_list"}:
        extra.append("Gib eine klar nummerierte Liste aus.")
    if domain == "time_sensitive_fact":
        extra.append("Nenne explizit den Stand als Datum (YYYY-MM-DD).")
    extra_rules = "\n- ".join(extra)
    prompt = (
        "Erzeuge eine korrekte Endantwort zur Anfrage.\n"
        "Regeln:\n"
        "- Keine Meta-Texte, keine Rueckfragen.\n"
        "- Kein Verweis auf vorherige Konversation.\n"
        "- Keine reine URL statt Inhalt.\n"
        + (f"- {extra_rules}\n" if extra_rules else "")
        + f"Aktueller Fehler in Vorantwort: {issue}\n\n"
        + f"Anfrage: {query}\n"
        + f"Vorantwort: {draft[:1600]}"
    )
    res = router.chat(_build_llm_message(cfg, prompt, turns=10))
    return sanitize_user_facing_reply(str(res.text or "").strip())

def _answer_from_memory_only(cfg: Dict[str, Any], message: str) -> Optional[str]:
    if not _is_internal_memory_query(message):
        return None
    topic = _extract_knowledge_topic(message)
    hits = _memory_hits_for_query(cfg, topic, limit=6)
    if not hits:
        return "Dazu habe ich im Gedaechtnis aktuell nichts Konkretes gespeichert."
    return _format_memory_hits_response(topic, hits) or None

def _handle_runtime_meta_query(message: str, cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    lower = str(message or "").strip().lower()
    if not lower:
        return None
    asks_model = bool(
        re.search(r"\b(welches|welchen|which|what)\b.*\b(modell|model)\b", lower)
        and _has_any(lower, ["nutzt", "verwend", "aktiv", "gerade", "aktuell", "current", "using"])
    )
    asks_provider = bool(
        re.search(r"\b(welcher|welchen|which|what)\b.*\b(provider)\b", lower)
        and _has_any(lower, ["nutzt", "verwend", "aktiv", "gerade", "aktuell", "current", "using"])
    )
    if not (asks_model or asks_provider):
        return None
    llm = cfg.get("llm", {})
    provider = str(llm.get("active_provider_id", "") or "?")
    model = str(llm.get("active_model", "") or "?")
    return {
        "ok": True,
        "reply": f"Aktuell aktiv:\n- Provider: `{provider}`\n- Modell: `{model}`",
    }

def _llm_answer_with_quality_gate(cfg: Dict[str, Any], message: str) -> str:
    def _looks_like_false_capability_refusal(user_msg: str, llm_reply: str) -> bool:
        u = (user_msg or "").lower()
        r = (llm_reply or "").lower()
        if not r:
            return False
        refusal = _has_any(
            r,
            [
                "nicht in der lage",
                "bin nicht in der lage",
                "ich kann keine",
                "ich bin darauf ausgelegt",
                "nur dateisystem",
                "dateisystemverwaltung",
            ],
        )
        if not refusal:
            return False
        # If the user explicitly asked for filesystem/script actions, refusal may be valid.
        if detect_signals(user_msg).explicit_tool_intent:
            return False
        if _has_any(u, ["datei", "ordner", "filesystem", "pfad", "script", "python:", "powershell:"]):
            return False
        return True

    router = LLMRouter(cfg)
    llm_message = _build_llm_message(cfg, message, turns=20)
    result = router.chat(llm_message)
    reply = str(result.text or "").strip()
    signals = detect_signals(message)
    if reply_looks_like_internal_plan(reply):
        strict_prompts = [
            message + "\n\nAntworte direkt fuer Endnutzer. Kein Plan, keine Tool-Schritte, kein Codeblock.",
            message
            + "\n\nWICHTIG: Gib ausschliesslich die finale Antwort aus. "
            "Keine Mehrdeutigkeitsanalyse, keine internen Regeln, keine Zwischenschritte.",
        ]
        for strict_prompt in strict_prompts:
            retry = router.chat(_build_llm_message(cfg, strict_prompt, turns=20))
            reply = str(retry.text or "").strip()
            if not reply_looks_like_internal_plan(reply):
                break
    if not signals.explicit_tool_intent:
        reply = sanitize_user_facing_reply(reply)
        if _has_any(
            reply.lower(),
            [
                "okay, ich soll",
                "ich werde versuchen",
                "darf ich",
                "soll ich",
                "bevor ich",
                "```python",
                "```powershell",
            ],
        ):
            direct_prompt = (
                message
                + "\n\nAntworte direkt und hilfreich fuer Endnutzer. "
                "Keine Meta-Erklaerung ueber interne Tools oder Vorgehen."
            )
            retry = router.chat(_build_llm_message(cfg, direct_prompt, turns=12))
            reply = sanitize_user_facing_reply(str(retry.text or "").strip())
        if _looks_like_false_capability_refusal(message, reply):
            corrective = (
                message
                + "\n\nWICHTIG: Du bist ein allgemeiner Assistent und darfst normale Wissensfragen beantworten. "
                "Antworte direkt hilfreich fuer Endnutzer. Kein Hinweis, dass du nur Dateisystemaufgaben kannst."
            )
            retry = router.chat(_build_llm_message(cfg, corrective, turns=12))
            reply = sanitize_user_facing_reply(str(retry.text or "").strip())
    else:
        reply = sanitize_user_facing_reply(reply)
    if _needs_factual_web_verification(message):
        verified = _web_verified_answer(cfg, message, reply)
        if verified:
            reply = verified
    return reply

def _extract_json_dict(text: str) -> Optional[Dict[str, Any]]:
    """
    Extrahiert das erste JSON-Objekt aus einem Text.
    Extrem robust gegen Markdown, Text-Rauschen und unsaubere Formatierung.
    """
    raw = (text or "").strip()
    if not raw: return None
    
    # 1. Direkter Versuch
    try:
        obj = json.loads(raw)
        if isinstance(obj, dict): return obj
    except Exception: pass

    # 2. Markdown Blöcke (```json ... ```)
    fences = re.findall(r"```(?:json)?\s*([\s\S]*?)```", raw, flags=re.IGNORECASE)
    for inner in fences:
        inner = inner.strip()
        try:
            obj = json.loads(inner)
            if isinstance(obj, dict): return obj
        except Exception: pass
        
        # JSONDecoder Brute-Force innerhalb des Blocks
        try:
            dec = json.JSONDecoder()
            for i, ch in enumerate(inner):
                if ch == '{':
                    try:
                        obj, _ = dec.raw_decode(inner[i:])
                        if isinstance(obj, dict): return obj
                    except Exception: continue
        except Exception: pass

    # 3. Aggressiver Brute-Force Fallback im gesamten Text
    try:
        dec = json.JSONDecoder()
        for i, ch in enumerate(raw):
            if ch == '{':
                try:
                    obj, _ = dec.raw_decode(raw[i:])
                    if isinstance(obj, dict): return obj
                except Exception: continue
    except Exception: pass

    return None

def _is_hybrid_tool_intent_candidate(message: str) -> bool:
    lower = (message or "").lower()
    if not lower:
        return False
    soft_phrases = [
        "ich haette gerne",
        "ich hätte gerne",
        "koenntest du",
        "könntest du",
        "wuerdest du",
        "würdest du",
        "kannst du bitte",
        "waere es moeglich",
        "wäre es möglich",
    ]
    tool_hints = [
        "datei",
        "ordner",
        "verzeichnis",
        "pfad",
        "skript",
        "script",
        ".txt",
        ".json",
        ".py",
        ".ps1",
        "speicher",
        "lese",
        "lies",
        "inhalt",
        "kopier",
        "verschieb",
        "loesch",
        "lösch",
        "umbenenn",
        "mkdir",
        "touch",
    ]
    return _has_any(lower, soft_phrases) and _has_any(lower, tool_hints)

def _hybrid_promote_tool_intent(cfg: Dict[str, Any], message: str, signals: ReasoningSignals) -> ReasoningSignals:
    if signals.explicit_tool_intent:
        return signals
    if not _is_hybrid_tool_intent_candidate(message):
        return signals
    try:
        router = LLMRouter(cfg)
        prompt = (
            "Klassifiziere die Nutzeranfrage fuer Tool-Routing. "
            "Antworte NUR als JSON ohne Erklaerung.\n"
            'Schema: {"is_tool_intent": true|false, "kind": "filesystem|script|none", "confidence": 0..1}\n'
            "Regeln: true nur bei klarer Datei-/Ordner-/Script-Aktion.\n\n"
            f"Anfrage: {message}"
        )
        result = router.chat(prompt)
        obj = _extract_json_dict(str(result.text or ""))
        if not isinstance(obj, dict):
            return signals
        is_tool = bool(obj.get("is_tool_intent", False))
        kind = str(obj.get("kind", "none")).lower()
        try:
            conf = float(obj.get("confidence", 0.0) or 0.0)
        except Exception:
            conf = 0.0
        if is_tool and kind in {"filesystem", "script"} and conf >= 0.72:
            tool_store.log("intent_hybrid", f"promoted tool intent (kind={kind}, conf={conf:.2f})")
            return ReasoningSignals(
                is_question=signals.is_question,
                is_approval_reply=signals.is_approval_reply,
                explicit_tool_intent=True,
                mixed_answer_save_intent=signals.mixed_answer_save_intent,
                internal_memory_query=signals.internal_memory_query,
            )
    except Exception as exc:
        tool_store.log("intent_hybrid_error", str(exc))
    return signals

