def _handle_context_followup_queries(message: str, cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    lower = (message or "").strip().lower()
    if not lower:
        return None
    short = len(lower.split()) <= 8
    asks_project_name = bool(
        re.search(r"(projektname|project name|projekt\s+heisst|projekt\s+heißt)", lower, flags=re.IGNORECASE)
    ) or ("projekt" in lower and ("wie heisst" in lower or "wie heißt" in lower or "name" in lower))
    if short and asks_project_name:
        p_name = _profile_get_field(cfg, "project_name") or _important_get_field(cfg, "project_name") or _find_recent_project_name_in_conversation(cfg)
        if p_name:
            return {"ok": True, "reply": f"Der Projektname aus dem Kontext ist: {p_name}"}

    asks_deadline = "deadline" in lower or "faellig" in lower or "fällig" in lower
    if short and asks_deadline:
        dl = _profile_get_field(cfg, "deadline") or _important_get_field(cfg, "deadline") or _find_recent_deadline_in_conversation(cfg)
        if dl:
            return {"ok": True, "reply": f"Die Deadline aus dem letzten Kontext ist: {dl}"}
    return None

def _handle_last_save_location_query(message: str, cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    lower = (message or "").strip().lower()
    if not lower:
        return None
    asks_save_location = bool(
        re.search(r"(wo\s+hast\s+du\s+das\s+gespeichert|where\s+did\s+you\s+save)", lower)
    )
    if not asks_save_location:
        return None
    last_status = _latest_last_save_status(cfg)
    if isinstance(last_status, dict):
        target = str(last_status.get("target_path", "")).strip()
        saved = bool(last_status.get("saved", False))
        err = str(last_status.get("error", "")).strip()
        if target and saved:
            return {"ok": True, "reply": f"Gespeichert unter: {target}"}
        if target and (not saved):
            if err:
                return {
                    "ok": True,
                    "reply": f"Noch nicht gespeichert. Der letzte Speicher-Versuch ist fehlgeschlagen ({err}). Zielpfad war: {target}",
                }
            return {"ok": True, "reply": f"Noch nicht gespeichert. Der letzte Speicher-Versuch ist fehlgeschlagen. Zielpfad war: {target}"}
        if saved:
            return {"ok": True, "reply": "Der letzte Speicher-Versuch war erfolgreich, aber ohne protokollierten Zielpfad."}
        return {"ok": True, "reply": "Der letzte Speicher-Versuch war nicht erfolgreich."}

    items = _memory_store(cfg).search_by_kind(kind="conversation", limit=30)
    last_ok: Optional[str] = None
    last_fail: Optional[str] = None
    for item in items:
        blob = _last_json_blob(str(item.get("content", "")))
        if not isinstance(blob, dict):
            continue
        assistant = str(blob.get("assistant", "")).strip()
        if not assistant:
            continue
        m_fail = re.search(r"Speichern fehlgeschlagen:.*?Geplanter Zielpfad:\s*(.+)", assistant, flags=re.IGNORECASE | re.DOTALL)
        if m_fail:
            if last_fail is None:
                last_fail = m_fail.group(1).strip()
            continue
        m_ok = re.search(r"Gespeichert unter:\s*(.+)", assistant, flags=re.IGNORECASE)
        if m_ok and last_ok is None:
            last_ok = m_ok.group(1).strip()
    if last_fail:
        return {"ok": True, "reply": f"Noch nicht gespeichert. Der letzte Speicher-Versuch ist fehlgeschlagen. Zielpfad war: {last_fail}"}
    if last_ok:
        return {"ok": True, "reply": f"Gespeichert unter: {last_ok}"}
    return {"ok": True, "reply": "Ich habe in diesem Verlauf noch keinen Speicherpfad protokolliert."}

def _handle_last_save_status_query(message: str, cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    lower = (message or "").strip().lower()
    if not lower:
        return None
    asks_found = bool(
        re.search(
            r"(hast\s+du\s+.*(gefunden|geschrieben|gespeichert)|did\s+you\s+(find|save|write))",
            lower,
        )
    )
    if not asks_found:
        return None
    last_status = _latest_last_save_status(cfg)
    if not isinstance(last_status, dict):
        return None
    query = str(last_status.get("query", "")).strip()
    target = str(last_status.get("target_path", "")).strip()
    saved = bool(last_status.get("saved", False))
    err = str(last_status.get("error", "")).strip()
    if saved:
        if target:
            return {"ok": True, "reply": f"Ja, ich habe es gefunden und gespeichert unter: {target}"}
        return {"ok": True, "reply": "Ja, ich habe es gefunden und gespeichert."}
    if target:
        msg = f"Ja, ich habe es gefunden, aber das Speichern ist fehlgeschlagen. Zielpfad war: {target}"
        if err:
            msg += f" (Fehler: {err})"
        return {"ok": True, "reply": msg}
    if query:
        return {"ok": True, "reply": f"Ja, ich habe '{query}' gefunden, aber noch nicht gespeichert."}
    return {"ok": True, "reply": "Ja, ich habe es gefunden, aber noch nicht gespeichert."}


def _looks_like_short_followup(message: str) -> bool:
    """Grob-Filter: True = könnte ein Follow-up sein → LLM-Rewrite prüfen.
    False = Nachricht ist eindeutig eigenständig → LLM-Rewrite überspringen (spart ~7s)."""
    raw = str(message or "").strip()
    if not raw:
        return False
    if _is_greeting_message(raw):
        return False
    if _is_help_command(raw) or _is_clear_conversation_command(raw):
        return False
    # Eigenständige Nachricht: expliziter Windows-Pfad/Laufwerk + genug Wörter
    word_count = len(raw.split())
    has_explicit_path = bool(re.search(r"[A-Za-z]:\\|\\\\[A-Za-z]|[A-Za-z]:/", raw))
    if has_explicit_path and word_count >= 5:
        return False  # Hat konkreten Pfad → kein Rewrite nötig
    # Sehr lange Nachrichten sind fast immer eigenständige Anweisungen
    if word_count >= 18:
        return False
    # Kurze Nachricht ohne Pronomen/Referenz-Signale → auch kein typisches Follow-up
    followup_signals = re.search(
        r"\b(es|das|dort|da|die|den|dem|der|darin|dazu|damit|dafür|dafuer|darauf|"
        r"nochmal|nochmals|weiter|anschließend|anschliessend|besprochen|vorhin|"
        r"diesen|dieses|diesem|jene[rns]?)\b",
        raw, re.IGNORECASE
    )
    if word_count >= 10 and not followup_signals:
        return False  # Langer Satz ohne Follow-up-Signale → eigenständig
    return True

def _llm_rewrite_followup_with_context(message: str, cfg: Dict[str, Any], dialog_key: str = "") -> str:
    raw = str(message or "").strip()
    if not raw or (not _looks_like_short_followup(raw)):
        return ""
    try:
        prev_user = ""
        prev_assistant = ""
        key = str(dialog_key or "").strip()
        if not key:
            key = str(_dialog_key_ctx.get("") or "").strip()
        if key:
            with _session_lock:
                hist = list(_session_history.get(key, deque()))
            for item in reversed(hist):
                role = str(item.get("role", "")).strip().lower()
                txt = str(item.get("text", "")).strip()
                if (not prev_assistant) and role == "assistant" and txt:
                    prev_assistant = txt
                if (not prev_user) and role == "user" and txt:
                    prev_user = txt
                if prev_user and prev_assistant:
                    break
        if not prev_user:
            prev_user = _latest_user_message(cfg, dialog_key=dialog_key)
        if not prev_assistant:
            prev_assistant = _latest_assistant_message(cfg, dialog_key=dialog_key)
        if not prev_user and not prev_assistant:
            return ""

        # Rewrite nur wenn letzter Bot-Output Filesystem-Kontext hatte.
        # Bei normaler LLM-Konversation hat das LLM den Chat-Verlauf sowieso.
        _fs_signals = (
            r"[A-Za-z]:\\"          # Windows-Pfad
            r"|\\\\[A-Za-z]"        # UNC-Pfad
            r"|\b[Dd]atei(?:en)?\b"
            r"|\b[Oo]rdner\b"
            r"|\b[Vv]erzeichnis\b"
            r"|\bgefunden\b"
            r"|\bkopiert\b"
            r"|\bverschoben\b"
            r"|\bgeloescht\b"
            r"|\berstellt\b"
            r"|\b\d+\s+(?:Datei|Ordner)"
        )
        has_fs_context = bool(re.search(_fs_signals, prev_assistant))
        if not has_fs_context:
            return ""

        sem_ctx = _get_session_semantic_context(dialog_key)
        sem_path = str(sem_ctx.get("last_path", "") or "").strip()
        sem_topic = str(sem_ctx.get("last_topic", "") or "").strip()
        sem_drive = str(sem_ctx.get("last_drive", "") or "").strip()

        router = LLMRouter(cfg)
        schema: Dict[str, Any] = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "rewrite": {"type": "string"},
                "confidence": {"type": "number"},
            },
            "required": ["rewrite", "confidence"],
        }
        prompt = (
            "Forme eine kurze Folgefrage in eine vollstaendige eigenstaendige Nutzeranweisung um. "
            "Nutze nur den gegebenen Kontext. Keine neuen Fakten erfinden. "
            "Antworte nur als JSON.\n"
            'Schema: {"rewrite":"...", "confidence":0..1}\n'
            "Regeln:\n"
            "- Wenn Folgefrage sich auf Dateien/Ordner bezieht, uebernimm den letzten passenden Pfad.\n"
            "- Wenn Kontext unklar ist, gib rewrite leer und confidence niedrig.\n"
            "- Keine Erklaerung, kein Zusatztext.\n"
            f"Follow-up: {raw}\n"
            f"Letzte User-Nachricht: {prev_user[:400]}\n"
            f"Letzte Assistant-Nachricht: {prev_assistant[:400]}\n"
            f"Session-Kontext: path={sem_path}, topic={sem_topic}, drive={sem_drive}\n"
        )
        try:
            obj = router.chat_json(prompt=prompt, schema_name="followup_rewrite_v1", schema=schema)
        except Exception:
            raw_out = router.chat(prompt)
            obj = _extract_json_dict(str(raw_out.text or ""))
        if not isinstance(obj, dict):
            return ""
        rewrite = str(obj.get("rewrite", "") or "").strip()
        try:
            conf = float(obj.get("confidence", 0.0) or 0.0)
        except Exception:
            conf = 0.0
        if conf < 0.62 or not rewrite:
            return ""
        if rewrite.strip().lower() == raw.lower():
            return ""
        return rewrite[:500]
    except Exception:
        return ""

def _augment_followup_with_llm_first(message: str, cfg: Dict[str, Any], dialog_key: str = "") -> str:
    m = str(message or "").strip()
    m_low = m.lower()
    if m.startswith("/"):
        return m
    if _memory_dialog_get(dialog_key) is not None:
        return m
    if _secret_dialog_get(dialog_key) is not None:
        return m
    if (
        _is_help_command(m)
        or _is_clear_conversation_command(m)
        or _is_memory_show_command(m)
        or _is_memory_delete_command(m)
        or bool(re.search(r"(?:zeige|show)\s+gedaechtnis\s+(?:letzte|recent)\s+eintraege", m_low))
        or bool(re.search(r"(?:letzte|recent)\s+gedaechtnis(?:\s+eintraege)?", m_low))
    ):
        return m
    if _is_greeting_message(str(message or "")):
        return str(message or "")
    if _is_approval_answer(str(message or "")):
        if _memory_dialog_get(dialog_key) is not None:
            return str(message or "")
        if _secret_dialog_get(dialog_key) is not None:
            return str(message or "")
    routing = cfg.get("routing", {}) if isinstance(cfg.get("routing", {}), dict) else {}
    llm_followup_enabled = bool(routing.get("llm_followup_rewrite_enabled", False))
    if llm_followup_enabled:
        try:
            llm_followup_timeout_sec = float(routing.get("llm_followup_timeout_sec", 8.0) or 8.0)
        except Exception:
            llm_followup_timeout_sec = 8.0
        llm_followup_timeout_sec = max(1.0, min(30.0, llm_followup_timeout_sec))
        _rq: "queue.Queue[str]" = queue.Queue(maxsize=1)

        def _rw_worker() -> None:
            out = ""
            with contextlib.suppress(Exception):
                out = str(_llm_rewrite_followup_with_context(message, cfg, dialog_key=dialog_key) or "")
            with contextlib.suppress(Exception):
                _rq.put(out, timeout=0.05)

        try:
            from app.trace_utils import start_thread_with_trace
            start_thread_with_trace(_rw_worker, name="KAI-followup-rewrite", daemon=True)
        except Exception:
            threading.Thread(
                target=_rw_worker,
                daemon=True,
                name="KAI-followup-rewrite",
            ).start()
        rewritten = ""
        try:
            rewritten = str(_rq.get(timeout=llm_followup_timeout_sec) or "")
        except queue.Empty:
            _audit_event(
                "followup_llm_rewrite_timeout",
                {
                    "dialog_key": dialog_key,
                    "timeout_sec": llm_followup_timeout_sec,
                    "orig": str(message)[:220],
                },
            )
        if rewritten:
            _audit_event("followup_llm_rewrite", {"orig": str(message)[:220], "rewritten": rewritten[:220], "dialog_key": dialog_key})
            return rewritten
    return _augment_followup_with_recent_context(message, cfg, dialog_key=dialog_key)

def _augment_followup_with_recent_context(message: str, cfg: Dict[str, Any], dialog_key: str = "") -> str:
    raw = (message or "").strip()
    if not raw:
        return raw
    lower = raw.lower()
    explicit_path = _extract_any_path(raw)

    workspace = _workspace_abs(cfg)
    if (not explicit_path) and _has_any(
        lower,
        [
            "dein verzeichnis",
            "deinem verzeichnis",
            "dein workspace",
            "im workspace",
            "aktuelles verzeichnis",
            "in deinem verzeichnis",
        ],
    ):
        if _has_any(lower, ["welche dateien", "zeige dateien", "dateien", "files"]):
            return f'zeige dateien in "{workspace}"'
        if _has_any(lower, ["welche ordner", "zeige ordner", "ordner", "folder", "directories", "verzeichnisse"]):
            return f'zeige ordner in "{workspace}"'

    prev_user = ""
    prev_assistant = ""
    key = str(dialog_key or "").strip()
    if not key:
        key = str(_dialog_key_ctx.get("") or "").strip()
    if key:
        with _session_lock:
            hist = list(_session_history.get(key, deque()))
        for item in reversed(hist):
            role = str(item.get("role", "")).strip().lower()
            txt = str(item.get("text", "")).strip()
            if (not prev_assistant) and role == "assistant" and txt:
                prev_assistant = txt
            if (not prev_user) and role == "user" and txt:
                prev_user = txt
            if prev_user and prev_assistant:
                break
    if not prev_user:
        prev_user = _latest_user_message(cfg, dialog_key=dialog_key)
    if not prev_assistant:
        prev_assistant = _latest_assistant_message(cfg, dialog_key=dialog_key)
    if not prev_user and not prev_assistant:
        return raw
    # Important safety rule:
    # for destructive follow-ups like "loesche es" we only trust an explicit
    # path from the last user message, never a broad memory fallback.
    prev_assistant_path = _extract_any_path(prev_assistant)
    prev_user_path = _extract_any_path(prev_user)
    sem_ctx = _get_session_semantic_context(dialog_key)
    sem_last_path = str(sem_ctx.get("last_path", "") or "").strip()
    sem_last_topic = str(sem_ctx.get("last_topic", "") or "").strip()
    sem_list_pref = str(sem_ctx.get("list_pref", "") or "").strip().lower()
    prev_path = sem_last_path or prev_user_path or prev_assistant_path or _latest_conversation_path(cfg, dialog_key=dialog_key)
    prev_lower = prev_user.lower()
    ctx_lower = _latest_conversation_text(cfg, dialog_key=dialog_key)
    prev_ass_lower = prev_assistant.lower()

    if explicit_path:
        # Path-only follow-up after a NAS/search request: expand to full operational request
        # instead of generic clarification.
        if str(explicit_path).startswith("\\\\"):
            prev_was_search = _has_any(prev_lower, ["suche", "such", "finde", "find "]) and _has_any(
                prev_lower,
                ["nas", "netzwerk", "freigabe", "laufwerk", "lied", "lieder", "mp3", "datei", "dateien"],
            )
            prev_asked_path = _has_any(
                prev_ass_lower,
                ["wie lautet der pfad", "unter welchem pfad", "genauen pfad", "netzwerkpfad", "unc-pfad"],
            )
            if prev_was_search or prev_asked_path:
                base = str(prev_user or "").strip() or "Suche auf meinem NAS nach Dateien"
                return f'{base} in "{explicit_path}"'
            asked_unc_for_mapping = _has_any(
                prev_ass_lower,
                ["freigabe als laufwerk", "als laufwerk verbinden", "laufwerk zuordnen"],
            ) or _has_any(prev_lower, ["verbinde", "map", "mapp", "mount"])
            if asked_unc_for_mapping:
                return f'verbinde die freigabe als laufwerk "{explicit_path}"'
        return raw

    # NAS/Netzwerk-Follow-up ohne expliziten Pfad:
    # nutze den zuletzt gemerkten UNC-Pfad aus Session/Context.
    if (not explicit_path) and _has_any(
        lower,
        [
            "nas",
            "netzwerk nas",
            "netzwerkfreigabe",
            "netzlaufwerk",
            "network share",
            "freigabe",
        ],
    ):
        asks_fs = _has_any(
            lower,
            [
                "suche",
                "such",
                "finde",
                "find ",
                "zeige",
                "liste",
                "datei",
                "dateien",
                "files",
                "ordner",
                "verzeichnis",
                "mp3",
                "lied",
                "lieder",
                "song",
                "songs",
            ],
        )
        if asks_fs:
            net_ctx = _get_session_network_ctx(dialog_key)
            unc_ctx = str(net_ctx.get("unc", "") or "").strip()
            unc_hint = ""
            for cand in [unc_ctx, sem_last_path, prev_user_path, prev_assistant_path]:
                s = str(cand or "").strip()
                if s.startswith("\\\\"):
                    unc_hint = s.rstrip("\\/") + "\\"
                    break
            if unc_hint:
                return f'{raw} in "{unc_hint}"'

    # Persisted session preference for listings: "keine Ordner"/"nur Dateien".
    if sem_list_pref in {"files_only", "dirs_only"}:
        has_list_verb = bool(re.search(r"\b(zeige\w*|zeig\w*|liste\w*|list\w*|auflisten|welche)\b", lower, flags=re.IGNORECASE))
        has_path_hint = bool(_extract_any_path(raw))
        asks_files = _has_any(lower, ["datei", "dateien", "file", "files"])
        asks_dirs = _has_any(lower, ["ordner", "verzeichnis", "verzeichnisse", "folder", "folders", "dirs"])
        explicit_override = _has_any(
            lower,
            [
                "dateien und ordner",
                "ordner und dateien",
                "beides",
                "alles anzeigen",
                "mit ordnern",
                "mit ordner",
                "mit dateien",
            ],
        )
        if has_list_verb and (has_path_hint or asks_files or asks_dirs) and not explicit_override:
            if sem_list_pref == "files_only" and not _has_any(lower, ["nur dateien", "files only"]):
                return f"{raw} nur dateien"
            if sem_list_pref == "dirs_only" and not _has_any(lower, ["nur ordner", "nur verzeichnisse", "folders only", "dirs only"]):
                return f"{raw} nur ordner"

    # Resolve factual location follow-ups like "wie viele Menschen leben dort"
    # to the last discussed non-path topic instead of stale filesystem context.
    asks_location_followup = bool(
        _has_any(lower, [" dort", " dort?", " dort.", " da ", " da?", " da."])
        and _has_any(lower, ["wie viele", "einwohner", "menschen", "bevoelker", "bevölker", "leben", "liegt", "stadt", "ort"])
    )
    if asks_location_followup and prev_user:
        if sem_last_topic and not re.search(r"([a-z]:\\|\\\\|/)", sem_last_topic, flags=re.IGNORECASE):
            if re.search(r"\bdort\b", lower, flags=re.IGNORECASE):
                return re.sub(r"\bdort\b", f"in {sem_last_topic}", raw, count=1, flags=re.IGNORECASE)
            if re.search(r"\bda\b", lower, flags=re.IGNORECASE):
                return re.sub(r"\bda\b", f"in {sem_last_topic}", raw, count=1, flags=re.IGNORECASE)
            return f"{raw} in {sem_last_topic}"
        m_topic = re.search(r"\b(?:was\s+ist|wer\s+ist|wo\s+liegt|what\s+is|who\s+is|where\s+is)\s+(.+?)(?:\?|$)", prev_lower, flags=re.IGNORECASE)
        topic = str(m_topic.group(1) if m_topic else "").strip(" .,!?:;\"'")
        topic = topic.replace("?", "").strip()
        if (not topic) or len(topic) < 3:
            # Fallback: infer entity from previous assistant answer ("X ist eine Stadt ...")
            asst = str(prev_assistant or "")
            m_ass = re.search(r"\bzu\s+([A-ZÄÖÜ][A-Za-zÄÖÜäöüß-]{2,})\b", asst)
            if not m_ass:
                m_ass = re.search(r"\b([A-ZÄÖÜ][A-Za-zÄÖÜäöüß-]{2,})\s+ist\b", asst)
            if m_ass:
                cand = str(m_ass.group(1) or "").strip()
                if cand not in {"Ich", "Die", "Der", "Das", "Wenn", "Ja", "Nein", "Bitte"}:
                    topic = cand
        if topic and (not re.search(r"([a-z]:\\|\\\\|/)", topic, flags=re.IGNORECASE)) and len(topic) <= 80:
            if re.search(r"\bdort\b", lower, flags=re.IGNORECASE):
                return re.sub(r"\bdort\b", f"in {topic}", raw, count=1, flags=re.IGNORECASE)
            if re.search(r"\bda\b", lower, flags=re.IGNORECASE):
                return re.sub(r"\bda\b", f"in {topic}", raw, count=1, flags=re.IGNORECASE)
            return f"{raw} in {topic}"

    asks_single_file_followup = bool(
        re.search(r"\b(zeige|zeig|lies|lese|oeffne|öffne)\b.*\b(datei)\b", lower, flags=re.IGNORECASE)
        or re.search(r"\b(datei)\b.*\b(zeigen|anzeig|lesen|oeffnen|öffnen)\b", lower, flags=re.IGNORECASE)
        or _has_any(lower, ["zeige mir die datei", "zeig mir die datei", "lies die datei", "oeffne die datei", "öffne die datei"])
    )
    if asks_single_file_followup:
        candidate = ""
        if dialog_key:
            art = _get_session_last_artifact(dialog_key)
            if art and art.exists() and art.is_file():
                candidate = str(art)
        if (not candidate) and prev_assistant_path:
            candidate = str(prev_assistant_path).strip()
        if (not candidate) and prev_path:
            candidate = str(prev_path).strip()
            with contextlib.suppress(Exception):
                p_dir = Path(candidate).resolve()
                if p_dir.exists() and p_dir.is_dir():
                    latest_in_dir = _latest_file_in_dir(p_dir)
                    if latest_in_dir is not None:
                        candidate = str(latest_in_dir)
        if (not candidate) or (not re.search(r"\.[a-z0-9]{1,8}$", candidate.lower())):
            last_save = _latest_last_save_status(cfg)
            if isinstance(last_save, dict) and bool(last_save.get("saved", False)):
                target = str(last_save.get("target_path", "") or "").strip()
                if target:
                    candidate = target
        if candidate:
            p_low = candidate.lower()
            looks_file = bool(re.search(r"\.[a-z0-9]{1,8}$", p_low))
            if looks_file:
                return f'lies inhalt von "{candidate}"'

    if prev_path and _has_any(lower, ["datei", "dateien", "files"]) and _has_any(lower, ["da", "dort", "hier"]) and bool(
        re.search(r"\b(gibt\s+es|sind|existieren?)\b", lower, flags=re.IGNORECASE)
        or _has_any(lower, ["enthalten", "vorhanden", "drin"])
    ):
        return f'gibt es dateien in "{prev_path}"'
    if prev_path and _has_any(lower, ["ich sehe", "ich seh", "sehe da", "seh da", "aber eine datei", "aber datei"]):
        if _has_any(lower, ["datei", "dateien", "files"]):
            return f'gibt es dateien in "{prev_path}"'

    if prev_user_path and _has_any(lower, ["loesch", "lösch", "delete", "entferne", "remove"]) and _has_any(
        lower, [" es", " das", "dies", "diese", "dieses", "ihn", "sie"]
    ):
        try:
            p = Path(str(prev_user_path)).resolve()
            ws = workspace.resolve()
            root = ROOT_DIR.resolve()
            # Never expand a pronoun-delete to broad roots.
            if p == ws or p == root or str(p).lower().rstrip("\\/") == str(ws).lower().rstrip("\\/"):
                return raw
            if p.name.strip().lower() in {"workspace", "data", "ownbot"}:
                return raw
            return f'loesche "{p}"'
        except Exception:
            return raw

    if lower in {"ja", "j", "yes", "ok", "okay"}:
        asks_files = _has_any(prev_lower, ["welche dateien", "dateien", "files", "verzeichnis", "ordner", "workspace"])
        asked_for_path = _has_any(
            prev_ass_lower,
            ["welchen pfad", "welches verzeichnis", "meinst du das verzeichnis", "gib den genauen pfad", "falls ja"],
        )
        if asks_files and asked_for_path:
            return f'zeige dateien in "{workspace}"'

    # Short chained follow-ups: "und ordner?", "und dateien?" etc.
    if prev_path:
        if re.fullmatch(r"(und\s+)?(ordner|verzeichnis|verzeichnisse|folder|folders|dirs?)\??", lower, flags=re.IGNORECASE):
            return f'zeige ordner in "{prev_path}"'
        if re.fullmatch(r"(und\s+)?(datei|dateien|file|files)\??", lower, flags=re.IGNORECASE):
            return f'zeige dateien in "{prev_path}"'

    generic_followups = {
        "welche",
        "welche?",
        "welche dateien",
        "welche dateien?",
        "zeige mir die dateien",
        "zeige die dateien",
        "und welche",
        "und welche?",
    }
    if lower in generic_followups and prev_path:
        hint_text = f"{prev_lower} {ctx_lower}".strip()
        if _has_any(hint_text, ["datei", "dateien", "files", "txt", ".txt"]):
            ext_hint = ".txt" if _has_any(hint_text, ["txt", ".txt", "textdatei"]) else ""
            recursive_hint = " rekursiv" if _has_any(hint_text, ["alle", "gibt es", "existieren", "unter"]) else ""
            if ext_hint:
                return f'zeige dateien{recursive_hint} in "{prev_path}" {ext_hint}'
            return f'zeige dateien{recursive_hint} in "{prev_path}"'
        if _has_any(hint_text, ["ordner", "verzeichnis", "folder", "dir"]):
            return f'zeige ordner in "{prev_path}"'

    asks_recent_drive = _has_any(
        lower,
        [
            "gerade verbunden",
            "gerade verbundene",
            "das laufwerk",
            "dem laufwerk",
            "diesem laufwerk",
            "verbunden hast",
            "gemountet",
        ],
    )
    if asks_recent_drive and not explicit_path:
        drive = _latest_conversation_drive(cfg, dialog_key=dialog_key)
        if drive:
            if _has_any(lower, ["ordner", "verzeichnisse", "verzeichnis", "folder", "directories"]):
                return f"zeige ordner in {drive}\\"
            if _has_any(lower, ["dateien", "files", "datei"]):
                return f"zeige dateien in {drive}\\"

    def _normalize_topic_token(token: str) -> str:
        t = str(token or "").strip().lower()
        if t.endswith("backen") and len(t) > 8:
            t = t[: -len("backen")]
        t = t.replace("kcuh", "kuch").replace("kuhcen", "kuchen")
        t = re.sub(r"[^a-z0-9äöüß-]", "", t)
        return t

    def _topic_from_text(text: str) -> str:
        low = (text or "").lower()
        m = re.search(r"(?:fuer|für)\s+(?:den|die|das)?\s*(?:besprochenen|besprochene|genannten)?\s*([a-z0-9äöüß-]{4,})", low)
        if m:
            return _normalize_topic_token(m.group(1))
        candidates = [_normalize_topic_token(t) for t in _query_terms(low) if len(str(t)) >= 5]
        candidates = [t for t in candidates if t and t not in {"heute", "morgen", "bitte", "schnell", "einfach", "rezept", "kochen", "backen", "meinte"}]
        for t in candidates:
            if any(k in t for k in ["kuchen", "torte", "suppe", "pasta", "pizza", "salat", "brot"]):
                return t
        return candidates[0] if candidates else ""

    # Resolve "ich meinte fuer den besprochenen X" to a concrete recipe query.
    if _has_any(lower, ["ich meinte", "besprochen", "besproch"]) and _has_any(lower, [" fuer ", " für "]):
        topic = _topic_from_text(raw)
        if topic:
            return f"gib mir ein schnelles rezept fuer {topic}"

    # Topic carry-over for short/implicit recipe follow-ups.
    asks_recipe = _has_any(lower, ["rezept", "recipe"]) and _has_any(
        lower, ["schnell", "einfach", "kurz", "gib mir", "ich meinte", "besprochen", "dafuer", "dafür"]
    )
    has_target = _has_any(lower, [" fuer ", " für ", " mit ", " ohne "])
    if asks_recipe and not has_target:
        topic = _topic_from_text(prev_user)
        if topic:
            return f"{raw} fuer {topic}"
    return raw

