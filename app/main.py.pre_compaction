        messages.append(user)
    return messages

def _handle_sentence_recall_query(message: str, cfg: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    lower = message.strip().lower()
    if not lower:
        return None
    recall_intent = bool(
        re.search(
            r"(was\s+war\s+mein\s+\d+\.?\s*(satz|nachricht)|was\s+habe\s+ich\s+vor\s+\d+\s+(saetzen|sätzen|nachrichten)\s+gesagt|wiederhole\s+die\s+letzten\s+\d+\s+(saetze|sätze|nachrichten)|zeige\s+die\s+letzten\s+\d+\s+(saetze|sätze|nachrichten))",
            lower,
            flags=re.IGNORECASE,
        )
    )
    if not recall_intent:
        return None
    msgs = _recent_user_messages(cfg, limit=140)
    if not msgs:
        return {"ok": True, "reply": "Ich habe keine frueheren Nutzersaetze im Gedaechtnis gefunden."}

    # Exclude current recall question itself from lookup candidates.
    candidates = [m for m in msgs if m.strip().lower() != lower]
    if not candidates:
        return {"ok": True, "reply": "Ich habe dazu keine vorherigen Nutzersaetze gefunden."}

    m_prev = re.search(
        r"was\s+habe\s+ich\s+vor\s+(\d+)\s+(?:saetzen|sätzen|nachrichten)\s+gesagt",
        lower,
        flags=re.IGNORECASE,
    )
    if m_prev:
        n = int(m_prev.group(1))
        if n <= 0 or n > len(candidates):
            return {"ok": True, "reply": f"Ich habe nur {len(candidates)} fruehere Nutzersaetze im Verlauf."}
        hit = candidates[-n]
        return {"ok": True, "reply": f"Vor {n} Satz/Saetzen hattest du gesagt: {hit}"}

    m_ord = re.search(
        r"was\s+war\s+mein\s+(\d+)\.?\s*(?:satz|nachricht)",
        lower,
        flags=re.IGNORECASE,
    )
    if m_ord:
        idx = int(m_ord.group(1))
        if idx <= 0 or idx > len(candidates):
            return {"ok": True, "reply": f"Im gespeicherten Verlauf habe ich {len(candidates)} Nutzersaetze."}
        hit = candidates[idx - 1]
        return {"ok": True, "reply": f"Dein Satz {idx} war: {hit}"}

    m_last = re.search(
        r"(?:wiederhole|zeige)\s+die\s+letzten\s+(\d+)\s+(?:saetze|sätze|nachrichten)",
        lower,
        flags=re.IGNORECASE,
    )
    if m_last:
        n = int(m_last.group(1))
        n = max(1, min(20, n))
        tail = candidates[-n:]
        lines = [f"Letzte {len(tail)} Nutzersaetze:"]
        for i, t in enumerate(tail, start=1):
            lines.append(f"{i}. {t}")
        return {"ok": True, "reply": "\n".join(lines)}

    return None

def _extract_secret_alias_and_value(text: str) -> tuple[str, str]:
    raw = str(text or "").strip()
    if not raw:
        return "", ""
    alias = ""
    m_alias = re.search(r"\balias\s+([a-zA-Z0-9_.-]{2,64})\b", raw, flags=re.IGNORECASE)
    if m_alias:
        alias = str(m_alias.group(1) or "").strip().lower()
    if not alias:
        m_for = re.search(r"\b(?:fuer|für|for)\s+([a-zA-Z0-9_.-]{2,64})\b", raw, flags=re.IGNORECASE)
        if m_for:
            alias = str(m_for.group(1) or "").strip().lower()
    value = ""
    patterns = [
        r"(?:passwort|password|api[\s_-]?key|token|secret|client_secret)\s*(?:ist|=|:)\s*\"([^\"]+)\"",
        r"(?:passwort|password|api[\s_-]?key|token|secret|client_secret)\s*(?:ist|=|:)\s*'([^']+)'",
        r"(?:passwort|password|api[\s_-]?key|token|secret|client_secret)\s*(?:ist|=|:)\s*([^\s,;]+)",
    ]
    for p in patterns:
        m = re.search(p, raw, flags=re.IGNORECASE)
        if m:
            value = str(m.group(1) or "").strip()
            break
    if not value and _looks_like_secret_or_token(raw):
        # Last fallback: if it looks like a raw token, keep full trimmed input.
        value = raw
    if not alias:
        hint = "secret"
        low = raw.lower()
        if "medianas" in low:
            hint = "medianas"
        elif "telegram" in low:
            hint = "telegram"
        elif "discord" in low:
            hint = "discord"
        alias = f"{hint}_cred"
    return alias[:80], value

def _handle_secret_commands(message: str, cfg: Dict[str, Any], dialog_key: str) -> Optional[Dict[str, Any]]:
    text = str(message or "").strip()
    if not text:
        return None
    lower = text.lower()
    pending = _secret_dialog_get(dialog_key)
    if pending:
        yes = lower in {"ja", "j", "yes", "ok", "okay"}
        no = lower in {"nein", "n", "no", "abbrechen", "cancel"}
        if no:
            _secret_dialog_clear(dialog_key)
            return {"ok": True, "reply": "Speichern der Zugangsdaten abgebrochen."}
        if not yes:
            return {"ok": True, "reply": "Soll ich die Zugangsdaten im Secret-Store speichern? Antworte mit: ja | nein"}
        alias = str(pending.get("alias", "") or "").strip() or "secret_cred"
        value = str(pending.get("value", "") or "").strip()
        if not value:
            _secret_dialog_clear(dialog_key)
            return {"ok": True, "reply": "Kein gueltiger Secret-Wert vorhanden. Bitte erneut mit konkretem Wert senden."}
        store = _secret_store(cfg)
        existed = bool(store.has_alias(alias))
        stored_alias = store.upsert_secret(
            alias=alias,
            value=value,
            meta={"source": "user", "dialog_key": str(dialog_key or "")},
        )
        _secret_dialog_clear(dialog_key)
        fp = SecretStore.fingerprint(value)
        if existed:
            return {"ok": True, "reply": f"Secret unter Alias `{stored_alias}` wurde aktualisiert/ueberschrieben (fingerprint={fp})."}
        return {"ok": True, "reply": f"Secret gespeichert unter Alias `{stored_alias}` (fingerprint={fp})."}

    trigger = bool(re.search(r"\b(merke\s+dir|speicher|save|aktualisier|update|ersetz|ueberschreib|überschreib)\b", lower)) and _looks_like_secret_or_token(text)
    explicit_cred = bool(re.search(r"\b(zugangsdaten|credentials?)\b", lower)) and _looks_like_secret_or_token(text)
    if not (trigger or explicit_cred):
        return None
    alias, value = _extract_secret_alias_and_value(text)
    if not value:
        return {"ok": True, "reply": "Ich erkenne Zugangsdaten, aber keinen konkreten Wert. Bitte sende z. B. `passwort: ...` oder `token: ...`."}
    _secret_dialog_set(dialog_key, {"alias": alias, "value": value})
    return {"ok": True, "reply": f"Ich habe Zugangsdaten erkannt (Alias-Vorschlag: `{alias}`). Soll ich sie im Secret-Store speichern? Antworte mit: ja | nein"}

def _looks_like_secret_or_token(text: str) -> bool:
    t = str(text or "")
    if not t:
        return False
    low = t.lower()
    keywords = [
        "api key",
        "apikey",
        "token",
        "passwort",
        "password",
        "secret",
        "private key",
        "bearer ",
        "refresh token",
        "session token",
        "client_secret",
    ]
    if any(k in low for k in keywords):
        return True
    patterns = [
        r"\bsk-[a-z0-9]{16,}\b",
        r"\bAIza[0-9A-Za-z\-_]{20,}\b",
        r"-----BEGIN (?:RSA |EC |OPENSSH |)PRIVATE KEY-----",
        r"\bghp_[A-Za-z0-9]{20,}\b",
    ]
    return any(re.search(p, t, flags=re.IGNORECASE) for p in patterns)

def _llm_classify_memory_fact(cfg: Dict[str, Any], fact_text: str) -> Optional[Dict[str, Any]]:
    txt = str(fact_text or "").strip()
    if not txt:
        return None
    try:
        router = LLMRouter(cfg)
        schema: Dict[str, Any] = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "should_store": {"type": "boolean"},
                "kind": {"type": "string", "enum": ["profile", "preference", "project", "constraint", "fact", "unknown"]},
                "normalized_fact": {"type": "string"},
                "confidence": {"type": "number"},
                "needs_clarification": {"type": "boolean"},
                "clarification_question": {"type": "string"},
            },
            "required": [
                "should_store",
                "kind",
                "normalized_fact",
                "confidence",
                "needs_clarification",
                "clarification_question",
            ],
        }
        prompt = (
            "Klassifiziere die Memory-Notiz semantisch. Antworte nur als JSON.\n"
            'Schema: {"should_store":true|false,"kind":"profile|preference|project|constraint|fact|unknown","normalized_fact":"...","confidence":0..1,"needs_clarification":true|false,"clarification_question":"..."}\n'
            "Regeln:\n"
            "- normalized_fact kurz, praezise und neutral formulieren.\n"
            "- Bei unklaren/vagen Aussagen (z.B. 'ein paar Fakten') needs_clarification=true.\n"
            "- Keine Secrets/Tokens speichern: should_store=false.\n"
            f"Text: {txt}"
        )
        try:
            obj = router.chat_json(prompt=prompt, schema_name="memory_fact_v1", schema=schema)
        except Exception:
            raw = router.chat(prompt)
            obj = _extract_json_dict(str(raw.text or ""))
        if not isinstance(obj, dict):
            return None
        kind = str(obj.get("kind", "unknown") or "").strip().lower()
        if kind not in {"profile", "preference", "project", "constraint", "fact", "unknown"}:
            kind = "unknown"
        normalized = str(obj.get("normalized_fact", "") or "").strip()
        if normalized and _looks_like_secret_or_token(normalized):
            return {
                "should_store": False,
                "kind": "unknown",
                "normalized_fact": "",
                "confidence": 1.0,
                "needs_clarification": False,
                "clarification_question": "",
            }
        try:
            conf = float(obj.get("confidence", 0.0) or 0.0)
        except Exception:
            conf = 0.0
        return {
            "should_store": bool(obj.get("should_store", False)),
            "kind": kind,
            "normalized_fact": normalized,
            "confidence": max(0.0, min(1.0, conf)),
            "needs_clarification": bool(obj.get("needs_clarification", False)),
            "clarification_question": str(obj.get("clarification_question", "") or "").strip()[:220],
        }
    except Exception:
        return None

def _persist_semantic_memory_fact(cfg: Dict[str, Any], classification: Dict[str, Any], source_text: str) -> Optional[str]:
    kind = str(classification.get("kind", "unknown") or "").strip().lower()
    norm = str(classification.get("normalized_fact", "") or "").strip()
    if not norm:
        return None
    conf = float(classification.get("confidence", 0.75) or 0.75)
    store = _memory_store(cfg)
    payload = {"field": kind if kind != "unknown" else "fact", "value": norm, "source": "user", "raw": str(source_text or "")[:320]}
    digest = hashlib.sha1(norm.lower().encode("utf-8")).hexdigest()[:16]
    if kind in {"profile", "project"}:
        store.upsert_memory("profile", f"{kind}:{digest}", payload, confidence=max(0.7, min(0.98, conf)))
    else:
        field = kind if kind in {"preference", "constraint", "fact"} else "fact"
        payload["field"] = field
        store.upsert_memory("important", f"{field}:{digest}", payload, confidence=max(0.7, min(0.96, conf)))
    return norm

def _handle_personal_fact_commands(message: str, cfg: Dict[str, Any], dialog_key: str = "") -> Optional[Dict[str, Any]]:
    text = message.strip()
    lower = text.lower()

    sentence_recall = _handle_sentence_recall_query(text, cfg)
    if sentence_recall:
        return sentence_recall

    # Store birthday from explicit user statements.
    birthday_patterns = [
        r"(?:merke\s+dir\s+mein(?:en)?\s+geburtstag(?:\s+auf)?|mein(?:en)?\s+geburtstag\s+(?:ist|=)|birthday\s+is)\s*[:\-]?\s*(\d{1,2}[.\-/]\d{1,2}(?:[.\-/]\d{2,4})?)",
        r"\bgeburtstag\s*[:=]\s*(\d{1,2}[.\-/]\d{1,2}(?:[.\-/]\d{2,4})?)",
    ]
    birthday_value = ""
    for p in birthday_patterns:
        m = re.search(p, lower, flags=re.IGNORECASE)
        if m:
            birthday_value = m.group(1).strip()
            break
    if birthday_value:
        _memory_store(cfg).upsert_memory(
            "profile",
            "birthday",
            {"field": "birthday", "value": birthday_value, "source": "user"},
            confidence=0.95,
        )
        return {"ok": True, "reply": f"Okay, ich habe deinen Geburtstag ({birthday_value}) gespeichert."}

    remembers = bool(re.match(r"^\s*merke\s+dir\b", lower, flags=re.IGNORECASE))
    if remembers:
        project_match = re.search(
            r"(?:unser|mein)\s+projektname\s*(?:ist|:)\s*([A-Za-z0-9._-]{2,})",
            text,
            flags=re.IGNORECASE,
        )
        deadline_match = re.search(
            r"\bdeadline\s*(?:ist|:)?\s*([0-9]{4}-[0-9]{2}-[0-9]{2}|[0-9]{1,2}[.\-/][0-9]{1,2}[.\-/][0-9]{2,4})",
            text,
            flags=re.IGNORECASE,
        )
        stored_parts: List[str] = []
        if project_match:
            project_name = project_match.group(1).strip()
            _memory_store(cfg).upsert_memory(
                "profile",
                "project_name",
                {"field": "project_name", "value": project_name, "source": "user"},
                confidence=0.95,
            )
            stored_parts.append(f"Projektname={project_name}")
        if deadline_match:
            deadline = deadline_match.group(1).strip()
            _memory_store(cfg).upsert_memory(
                "profile",
                "deadline",
                {"field": "deadline", "value": deadline, "source": "user"},
                confidence=0.95,
            )
            stored_parts.append(f"Deadline={deadline}")
        if stored_parts:
            return {"ok": True, "reply": "Okay, gespeichert: " + ", ".join(stored_parts)}

    note_match = re.search(r"^\s*merke\s+dir\s*:?\s*(.+?)\s*$", text, flags=re.IGNORECASE)
    if note_match:
        fact = note_match.group(1).strip()
        if fact:
            if _looks_like_secret_or_token(fact):
                return {"ok": True, "reply": "Ich speichere keine Secrets/Tokens im normalen Gedaechtnis. Bitte nutze dafuer den Secret-Store."}
            semantic = _llm_classify_memory_fact(cfg, fact)
            if isinstance(semantic, dict):
                if bool(semantic.get("needs_clarification", False)):
                    q = str(semantic.get("clarification_question", "") or "").strip()
                    if q:
                        return {"ok": True, "reply": q}
                    return {"ok": True, "reply": "Welche konkreten Fakten soll ich mir genau merken?"}
                if bool(semantic.get("should_store", False)):
                    saved = _persist_semantic_memory_fact(cfg, semantic, fact)
                    if saved:
                        return {"ok": True, "reply": f'Okay, gespeichert ({semantic.get("kind","fact")}): "{saved}".'}
                return {"ok": True, "reply": "Das speichere ich nicht als dauerhaften Fakt. Nenne bitte einen konkreten, stabilen Fakt."}
            # Common pattern in tests/chats: "merke dir mein testname ist X"
            tn = re.search(r"\b(?:mein|unser)\s+testname\s*(?:ist|=)\s*([A-Za-z0-9._-]{2,})\b", fact, flags=re.IGNORECASE)
            if tn:
                testname = str(tn.group(1) or "").strip()
                if testname:
                    _memory_store(cfg).upsert_memory(
                        "profile",
                        "testname",
                        {"field": "testname", "value": testname, "source": "user"},
                        confidence=0.94,
                    )
            key = f"note:{fact.lower()[:120]}"
            _memory_store(cfg).upsert_memory(
                "profile",
                key,
                {"field": "note", "value": fact, "source": "user"},
                confidence=0.92,
            )
            return {"ok": True, "reply": f'Okay, ich habe mir gemerkt: "{fact}".'}

    # Retrieve birthday.
    asks_birthday = bool(
        re.search(r"\b(wann|was)\b.*\b(geburtstag|birthday)\b", lower)
        and re.search(r"\b(mein|ich)\b", lower)
    )
    if asks_birthday:
        birthday = _profile_get_field(cfg, "birthday")
        if birthday:
            return {"ok": True, "reply": f"Dein gespeicherter Geburtstag ist: {birthday}"}
        return {"ok": True, "reply": "Ich habe deinen Geburtstag noch nicht gespeichert."}

    asks_about_self = bool(
        re.search(
            r"(was\s+(wei[sß]t|weisst|merkst)\s+du\s+(ueber|über)\s+mich|was\s+mag\s+ich|was\s+ist\s+mir\s+wichtig|hast\s+du\s+dir\s+.*gemerkt)",
            lower,
        )
    )
    if asks_about_self:
        items_profile = _memory_store(cfg).search_by_kind(kind="profile", limit=40)
        items_important = _memory_store(cfg).search_by_kind(kind="important", limit=80)
        notes: list[tuple[float, str]] = []
        for item in items_profile:
            blob = _last_json_blob(str(item.get("content", "")))
            if not isinstance(blob, dict):
                continue
            field = str(blob.get("field", "")).strip().lower()
            value = str(blob.get("value", "")).strip()
            if not value:
                continue
            if field == "note":
                notes.append((0.9, value))
            elif field == "birthday":
                notes.append((0.95, f"Geburtstag: {value}"))
            elif field == "testname":
                notes.append((0.96, f"testname: {value}"))
        for item in items_important:
            blob = _last_json_blob(str(item.get("content", "")))
            if not isinstance(blob, dict):
                continue
            field = str(blob.get("field", "")).strip().lower()
            if field not in {"requirement", "goal", "priority", "deadline", "preference", "project_name", "project", "constraint", "fact", "profile"}:
                continue
            value = str(blob.get("value", "")).strip()
            if not value:
                continue
            vlow = value.lower()
            if vlow.startswith("llm:") or vlow.startswith("tool:"):
                continue
            imp = float(blob.get("importance", item.get("confidence", 0.7)) or 0.7)
            prefix = ""
            if field in {"requirement", "goal", "priority", "project_name"}:
                prefix = f"{field}: "
            notes.append((imp, f"{prefix}{value}"))
        if not notes:
            return {"ok": True, "reply": "Ich habe aktuell noch keine persoenlichen Notizen ueber dich gespeichert."}
        notes.sort(key=lambda x: x[0], reverse=True)
        uniq: list[str] = []
        seen: set[str] = set()
        for _, n in notes:
            k = n.lower()
            if k in seen:
                continue
            seen.add(k)
            uniq.append(n)
        preview = "\n".join(f"- {n}" for n in uniq[:8])
        return {"ok": True, "reply": f"Ich habe mir Folgendes ueber dich gemerkt:\n{preview}"}

    return None

def _provider_enabled(provider_cfg: Dict[str, Any]) -> bool:
    if isinstance(provider_cfg, dict) and "enabled" in provider_cfg:
        return bool(provider_cfg.get("enabled"))
    return True

def _provider_requires_api_key(provider_cfg: Dict[str, Any]) -> bool:
    if not isinstance(provider_cfg, dict):
        return True
    val = provider_cfg.get("api_key_required")
    if isinstance(val, bool):
        return bool(val)
    val = provider_cfg.get("allow_empty_api_key")
    if isinstance(val, bool):
        return not bool(val)
    return True

def _default_provider_cfg(provider_id: str) -> Optional[Dict[str, Any]]:
    pid = str(provider_id or "").strip().lower()
    if pid == "ollama":
        return {
            "type": "openai_compatible",
            "api_key": "",
            "api_key_required": False,
            "base_url": "http://127.0.0.1:11434/v1",
            "models": ["llama3.1"],
            "default_model": "llama3.1",
            "enabled": False,
        }
    return None

def _normalize_ollama_base_url(raw: str) -> str:
    url = str(raw or "").strip()
    if not url:
        return "http://127.0.0.1:11434/v1"
    if "://" not in url:
        url = "http://" + url
    url = url.rstrip("/")
    if not url.lower().endswith("/v1"):
        url = url + "/v1"
    return url

def _pick_first_enabled_provider(cfg: Dict[str, Any], exclude: Optional[set[str]] = None) -> Optional[tuple[str, str]]:
    providers = cfg.get("providers", {}) if isinstance(cfg.get("providers", {}), dict) else {}
    for pid, p in providers.items():
        pid_s = str(pid or "").strip()
        if not pid_s:
            continue
        if exclude and pid_s in exclude:
            continue
        if not isinstance(p, dict):
            continue
        if not _provider_enabled(p):
            continue
        if _provider_requires_api_key(p) and not str(p.get("api_key", "") or "").strip():
            continue
        if not str(p.get("base_url", "") or "").strip():
            continue
        model = str(p.get("default_model", "") or "").strip()
        if not model:
            models = p.get("models", []) if isinstance(p.get("models", []), list) else []
            if models:
                model = str(models[0]).strip()
        if model:
            return pid_s, model
    return None

def _masked_config(cfg: Dict[str, Any]) -> Dict[str, Any]:
    out = json.loads(json.dumps(cfg))
    providers = out.get("providers", {})
    for p in providers.values():
        if not isinstance(p, dict):
            continue
        key = str(p.get("api_key", "") or "")
        requires_key = _provider_requires_api_key(p)
        p["api_key_set"] = bool(key) if requires_key else True
        p["api_key_required"] = requires_key
        p["api_key"] = "***" if key else ""
    messenger = out.get("messenger", {})
    for m in messenger.values():
        if not isinstance(m, dict):
            continue
        token = str(m.get("token", "") or "")
        m["token_set"] = bool(token)
        m["token"] = "***" if token else ""
    ep = out.get("execution_plane", {}) if isinstance(out.get("execution_plane", {}), dict) else {}
    ep_token = str(ep.get("auth_token", "") or "")
    ep["auth_token_set"] = bool(ep_token)
    ep["auth_token"] = "***" if ep_token else ""
    out["execution_plane"] = ep
    return out

def _script_status_snapshot() -> Dict[str, Any]:
    with _script_lock:
        running = bool(_script_active.get("running", False))
        active = dict(_script_active) if running else {"running": False}
        history = list(_script_history)
    return {"running": running, "active": active, "history": history}

def _push_script_history(entry: Dict[str, Any]) -> None:
    with _script_lock:
        _script_history.appendleft(entry)

def _request_script_stop(reason: str = "manual") -> bool:
    cfg = _cfg()
    remote_stopped = False
    if _execution_plane_enabled(cfg):
        with contextlib.suppress(Exception):
            remote_stopped = bool(execution_plane_runtime.request_cancel_running(cfg, reason=reason))
    _script_stop_event.set()
    with _script_lock:
        proc = _script_proc
    if proc and proc.poll() is None:
        try:
            proc.terminate()
        except Exception:
            pass
        return True
    return bool(remote_stopped)

def _get_platform_cfg(cfg: Dict[str, Any], platform: str) -> Dict[str, Any]:
    return cfg.get("messenger", {}).get(platform, {})

def _remember_last_messenger_target(platform: str, target: str) -> None:
    p = str(platform or "").strip().lower()
    t = str(target or "").strip()
    if p not in {"telegram", "discord"} or not t:
        return
    with _last_messenger_target_lock:
        _last_messenger_targets[p] = t

def _last_messenger_target(platform: str) -> str:
    p = str(platform or "").strip().lower()
    if p not in {"telegram", "discord"}:
        return ""
    with _last_messenger_target_lock:
        return str(_last_messenger_targets.get(p, "") or "").strip()

def _sender_candidates(platform: str, meta: Dict[str, Any]) -> List[str]:
    sender_candidates: List[str] = []
    if platform == "telegram":
        sender_candidates.extend(
            [
                str(meta.get("user_id", "")).strip(),
                str(meta.get("chat_id", "")).strip(),
                str(meta.get("user", "")).strip(),
            ]
        )
    elif platform == "discord":
        sender_candidates.extend(
            [
                str(meta.get("author_id", "")).strip(),
                str(meta.get("channel_id", "")).strip(),
                str(meta.get("user", "")).strip(),
            ]
        )
    else:
        sender_candidates.append(str(meta.get("user", "")).strip())
    return [s for s in sender_candidates if s]

def _sender_allowed_by_list(platform_cfg: Dict[str, Any], sender_candidates: List[str]) -> bool:
    raw = platform_cfg.get("allow_from", platform_cfg.get("allowed_senders", []))
    allowed: set[str] = set()
    if isinstance(raw, list):
        for item in raw:
            v = str(item or "").strip()
            if v:
                allowed.add(v)
    if "*" in allowed:
        return True
    if not sender_candidates:
        return False
    return any(s in allowed for s in sender_candidates)

def _messenger_inbound_allowed(cfg: Dict[str, Any], platform: str, meta: Dict[str, Any]) -> tuple[bool, str]:
    platform_cfg = _get_platform_cfg(cfg, platform)
    sender_candidates = _sender_candidates(platform, meta)
    is_dm = bool(meta.get("is_dm", False))

    # Legacy mode for backward compatibility.
    strict = bool(platform_cfg.get("strict_allowlist", False))
    if strict and not _sender_allowed_by_list(platform_cfg, sender_candidates):
        return False, "strict_allowlist"

    dm_policy = str(platform_cfg.get("dm_policy", "open") or "open").strip().lower()
    group_policy = str(platform_cfg.get("group_policy", "open") or "open").strip().lower()

    policy = dm_policy if is_dm else group_policy
    if policy == "deny":
        return False, f"{'dm' if is_dm else 'group'}_policy_deny"
    if policy in {"allowlist", "pairing"}:
        if _sender_allowed_by_list(platform_cfg, sender_candidates):
            return True, "allowlist"
        return False, f"{'dm' if is_dm else 'group'}_policy_{policy}"
    return True, "open"

def _normalize_messenger_message(text: str, meta: Dict[str, Any]) -> NormalizedMessage:
    platform = str(meta.get("platform", "unknown"))
    sender_candidates = _sender_candidates(platform, meta)
    sender_id = sender_candidates[0] if sender_candidates else ""
    return NormalizedMessage(
        raw_text=str(text or "").strip(),
        command_text=str(text or "").strip(),
        platform=platform,
        source=f"messenger:{platform}",
        session_key=_session_key_from_meta(meta),
        sender_id=sender_id,
        sender_label=str(meta.get("user", "unknown")),
        chat_id=str(meta.get("chat_id", meta.get("channel_id", ""))),
        message_id=str(meta.get("message_id", meta.get("id", ""))),
        reply_to_id=str(meta.get("reply_to_id", "")),
        is_dm=bool(meta.get("is_dm", False)),
    )

def _map_standalone_command(text: str) -> Optional[str]:
    t = str(text or "").strip().lower()
    t = re.sub(r"\s+", " ", t)
    if t.startswith("/"):
        t_no_slash = t[1:].strip()
    else:
        t_no_slash = t
    mapping = {
        "/help": "/befehle",
        "/hilfe": "/befehle",
        "/befehle": "/befehle",
        "/commands": "/befehle",
        "/status": "__status__",
        "/cron": "cron jobs",
        "/cron jobs": "cron jobs",
        "/memory": "gedaechtnis anzeigen",
        "/memory show": "gedaechtnis anzeigen",
        "/memory clear": "gedaechtnis loeschen",
        "/context clear": "kontext loeschen",
        "/session neu": "__session_reset__",
        "/session reset": "__session_reset__",
        "/session loeschen": "__session_reset__",
        "/session löschen": "__session_reset__",
        "/session clear": "__session_reset__",
        "/gedaechtnis": "gedaechtnis anzeigen",
        "/gedaechtnis anzeigen": "gedaechtnis anzeigen",
        "/gedaechtnis loeschen": "gedaechtnis loeschen",
        "/gedaechtnis letzte eintraege": "zeige gedaechtnis letzte eintraege",
        "/kontext loeschen": "kontext loeschen",
    }
    hit = mapping.get(t)
    if hit:
        return hit
    # Support commands provided without leading slash after prefix extraction.
    if t_no_slash:
        # Dynamic memory commands with arguments.
        if t_no_slash.startswith("gedaechtnis letzte eintraege"):
            return f"zeige {t_no_slash}"
        if t_no_slash in {"cron", "cron jobs", "cron job", "cron liste"}:
            return "cron jobs"
        if t_no_slash.startswith("memory recent"):
            return t_no_slash
        alt = f"/{t_no_slash}"
        return mapping.get(alt)
    return None

def _session_reset_is_pending(session_key: str) -> bool:
    key = str(session_key or "").strip()
    if not key:
        return False
    with _session_reset_lock:
        ts = _session_reset_pending.get(key)
        if ts is None:
            return False
        # Auto-expire stale confirmations.
        if (time.time() - float(ts)) > 180:
            _session_reset_pending.pop(key, None)
            return False
        return True

def _session_reset_set_pending(session_key: str) -> None:
    key = str(session_key or "").strip()
    if not key:
        return
    with _session_reset_lock:
        _session_reset_pending[key] = time.time()

def _session_reset_clear_pending(session_key: str) -> None:
    key = str(session_key or "").strip()
    if not key:
        return
    with _session_reset_lock:
        _session_reset_pending.pop(key, None)

def _normalize_messenger_out_text(text: str) -> str:
    s = str(text or "")
    if not s:
        return s
    s = (
        s.replace("Ã¤", "ä")
        .replace("Ã¶", "ö")
        .replace("Ã¼", "ü")
        .replace("Ã„", "Ä")
        .replace("Ã–", "Ö")
        .replace("Ãœ", "Ü")
        .replace("ÃŸ", "ß")
        .replace("â€“", "-")
        .replace("â€”", "-")
